# PARSER + CODEGEN — recursive descent, direct emission
# ================================================================

# ================================================================
# STRUCT SUPPORT
# ================================================================
# Heap layout for structs — see src/main.cyr for the authoritative map.
# Quick reference of the regions this file touches:
#   0x13A000 var_types[8192]      65536 bytes — struct_id per var (0=scalar)
#   0x8E630  struct_names[32]     256 bytes — name offset per struct
#   0x8E730  struct_fcounts[32]   256 bytes — field count per struct (bit 63 = union)
#   0x8A000  struct_ftypes[1024]  8192 bytes — 32×32 field type IDs (stride 256)
#   0xD8000  struct_fnames[1024]  8192 bytes — 32×32 field name offsets (stride 256)
#   0x8F830  struct_count         8 bytes

fn GSTC(S) { return L64(S + 0x8F830); }
fn SSTC(S, v) { S64(S + 0x8F830, v); return 0; }

# Get/set struct_id for global variable at index vi
fn GVTYPE(S, vi) { return L64(S + 0x13A000 + vi * 8); }
fn SVTYPE(S, vi, v) { S64(S + 0x13A000 + vi * 8, v); return 0; }

# Register a new struct, return index (1-based, 0 = not a struct)
fn REGSTRUCT(S, noff) {
    var sc = GSTC(S);
    if (sc >= 64) {
        ERR_MSG(S, "too many struct definitions (max 64)", 36);
    }
    S64(S + 0x8E630 + sc * 8, noff);
    S64(S + 0x8E830 + sc * 8, 0);
    SSTC(S, sc + 1);
    return sc + 1;
}

# Find struct by name, return 1-based index or 0
fn FINDSTRUCT(S, noff) {
    var sc = GSTC(S);
    var i = 0;
    while (i < sc) {
        var sn = L64(S + 0x8E630 + i * 8);
        if (STREQ(S, sn, noff) == 1) { return i + 1; }
        i = i + 1;
    }
    return 0;
}

# Add field to struct (0-based struct index si), ftype = struct_id or 0 for scalar
fn ADDFIELD(S, si, fnoff) {
    var fc = L64(S + 0x8E830 + si * 8);
    if (fc >= 32) { ERR_MSG(S, "too many struct fields (max 32)", 31); }
    S64(S + 0xDCA000 + si * 256 + fc * 8, fnoff);
    S64(S + 0xD4A000 + si * 256 + fc * 8, 0);
    S64(S + 0x8E830 + si * 8, fc + 1);
    return 0;
}

fn ADDFIELDTYPED(S, si, fnoff, ftype) {
    var fc = L64(S + 0x8E830 + si * 8);
    if (fc >= 32) { ERR_MSG(S, "too many struct fields (max 32)", 31); }
    S64(S + 0xDCA000 + si * 256 + fc * 8, fnoff);
    S64(S + 0xD4A000 + si * 256 + fc * 8, ftype);
    S64(S + 0x8E830 + si * 8, fc + 1);
    return 0;
}

fn GETFTYPE(S, si, fi) {
    return L64(S + 0xD4A000 + si * 256 + fi * 8);
}

# Get field name offset (into tok_names at S+0x60000) for struct si, field fi.
# Returns the same offset that was recorded by ADDFIELD, so direct equality
# with a parsed IDENT's PEEKV works (idents are interned by the lexer).
fn GETFNAME(S, si, fi) {
    return L64(S + 0xDCA000 + si * 256 + fi * 8);
}

# Compare two null-terminated strings in tok_names. Returns 1 if equal.
# Needed because named-field init uses the identifier buffer (S+0x60000)
# where two different source occurrences of the same name share an offset
# (dedup), but defensive equality handles the rare non-interned case too.
fn STREQTOK(S, a_off, b_off) {
    if (a_off == b_off) { return 1; }
    var i = 0;
    while (1 == 1) {
        var ca = load8(S + 0x60000 + a_off + i);
        var cb = load8(S + 0x60000 + b_off + i);
        if (ca != cb) { return 0; }
        if (ca == 0) { return 1; }
        i = i + 1;
    }
    return 0;
}

# Get byte size of a single field from its type encoding
# >0 = nested struct ID, 0 = untyped (8), <0 = sized scalar (-width)
fn FIELDSZ(S, ft) {
    if (ft > 0) { return STRUCTSZ(S, ft - 1); }
    if (ft < 0) { return 0 - ft; }
    return 8;
}

# Get total size of a struct/union in bytes
fn STRUCTSZ(S, si) {
    var fc = GETFCOUNT(S, si);
    var is_u = ISUNION(S, si);
    var sz = 0;
    var i = 0;
    while (i < fc) {
        var fsz = FIELDSZ(S, GETFTYPE(S, si, i));
        if (is_u == 1) {
            if (fsz > sz) { sz = fsz; }
        } else {
            sz = sz + fsz;
        }
        i = i + 1;
    }
    return sz;
}

# Get byte offset of field fi within struct/union si
fn FIELDOFF(S, si, fi) {
    if (ISUNION(S, si) == 1) { return 0; }
    var off = 0;
    var i = 0;
    while (i < fi) {
        off = off + FIELDSZ(S, GETFTYPE(S, si, i));
        i = i + 1;
    }
    return off;
}

# Parse: enum Name { A; B; C; } — registers variants as global constants
# Called from BOTH pass 1 (register vars) and pass 2 (emit init code).
# Pass 1: just register var names + sizes (no code)
# Pass 2: emit mov rax, val; evstore for each variant
fn PARSE_ENUM_DEF(S, emit_code) {
    STI(S, GTI(S) + 1);
    if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
    var enoff = PEEKV(S);
    STI(S, GTI(S) + 1);
    if (PEEKT(S) != 13) { ERR_EXPECT(S, 13); }
    STI(S, GTI(S) + 1);
    var val = 0;
    var ego = 1;
    while (ego == 1) {
        if (PEEKT(S) == 14) { ego = 0; }
        else {
            if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
            var vnoff = PEEKV(S);
            STI(S, GTI(S) + 1);
            # Check for constructor syntax: Variant(param)
            var has_ctor = 0;
            if (PEEKT(S) == 10) {
                has_ctor = 1;
                STI(S, GTI(S) + 1);
                if (PEEKT(S) == 2) { STI(S, GTI(S) + 1); }
                if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); }
                STI(S, GTI(S) + 1);
            }
            if (PEEKT(S) == 4) {
                STI(S, GTI(S) + 1);
                if (PEEKT(S) != 1) { ERR_EXPECT(S, 1); }
                val = PEEKV(S);
                STI(S, GTI(S) + 1);
            }
            if (emit_code == 2) {
                # Pass 2 function section: emit constructor bodies only
                if (has_ctor == 1) {
                    NPOS_GUARD(S, 256);
                    var cwp2 = GNPOS(S);
                    var cnoff2 = cwp2;
                    var cri2 = 0;
                    var crc2 = load8(S + 0x60000 + vnoff + cri2);
                    while (crc2 != 0) { store8(S + 0x60000 + cwp2, crc2); cwp2 = cwp2 + 1; cri2 = cri2 + 1; crc2 = load8(S + 0x60000 + vnoff + cri2); }
                    store8(S + 0x60000 + cwp2, 0); cwp2 = cwp2 + 1;
                    SNPOS(S, cwp2);
                    var cfi = FINDFN(S, cnoff2);
                    if (cfi >= 0) {
                        S64(S + 0xE92000 + cfi * 8, GCP(S));
                        S64(S + 0xE9A000 + cfi * 8, 1);
                        EFNPRO(S);
                        var ctor_frame = ESUBRSP(S);
                        ESTOREPARM(S, 0, 0, 0);
                        EMOVI(S, 16); EPUSHR(S);
                        ECALLPOPS(S, 1);
                        NPOS_GUARD(S, 8);
                        var awnp = GNPOS(S);
                        store8(S + 0x60000 + awnp, 97); store8(S + 0x60000 + awnp + 1, 108);
                        store8(S + 0x60000 + awnp + 2, 108); store8(S + 0x60000 + awnp + 3, 111);
                        store8(S + 0x60000 + awnp + 4, 99); store8(S + 0x60000 + awnp + 5, 0);
                        SNPOS(S, awnp + 6);
                        var afi = FINDFN(S, awnp);
                        if (afi < 0) { afi = REGFN(S, awnp); }
                        var afoff = L64(S + 0xE92000 + afi * 8);
                        if (afoff >= 0) { ECALLTO(S, afoff); } else { ECALLFIX(S, afi); }
                        ECALLCLEAN(S, 1);
                        EFLSTORE(S, 1);
                        EFLLOAD(S, 1); EPUSHR(S); EMOVI(S, val); EPOPC(S); ESTORE64(S);
                        EFLLOAD(S, 1); EPUSHR(S); EMOVI(S, 8); EMOVCA(S); EPOPR(S); EADDR(S);
                        EPUSHR(S); EFLLOAD(S, 0); EPOPC(S); ESTORE64(S);
                        EPATCHFRAME(S, ctor_frame, 32);
                        EFLLOAD(S, 1);
                        EFNEPI(S);
                    }
                }
            }
            elif (emit_code == 0) {
                # Pass 1: register variant as global var
                var vcnt = GVCNT(S);
                S64(S + 0x11A000 + vcnt * 8, vnoff);
                S64(S + 0x12A000 + vcnt * 8, 8);
                SVCNT(S, vcnt + 1);
                # Register constructor function if has payload
                if (has_ctor == 1) {
                    NPOS_GUARD(S, 256);
                    var cwp = GNPOS(S);
                    var cnoff = cwp;
                    var cri = 0;
                    var crc = load8(S + 0x60000 + vnoff + cri);
                    while (crc != 0) { store8(S + 0x60000 + cwp, crc); cwp = cwp + 1; cri = cri + 1; crc = load8(S + 0x60000 + vnoff + cri); }
                    store8(S + 0x60000 + cwp, 0); cwp = cwp + 1;
                    SNPOS(S, cwp);
                    REGFN(S, cnoff);
                }
            } else {
                # Pass 2 enum init (emit_code == 1): just set constant values
                var idx = FINDVAR(S, vnoff);
                if (idx >= 0) { EMOVI(S, val); EVSTORE(S, idx); }
            }
            val = val + 1;
            if (PEEKT(S) == 5) { STI(S, GTI(S) + 1); }
        }
    }
    STI(S, GTI(S) + 1);
    return 0;
}

# Get field count for struct (0-based index). High bit = union flag.
fn GETFCOUNT(S, si) { return L64(S + 0x8E830 + si * 8) & 0x7FFFFFFFFFFFFFFF; }
fn ISUNION(S, si) { return L64(S + 0x8E830 + si * 8) >> 63; }

# Find field index in struct (0-based struct index), return field index or -1
fn FINDFIELD(S, si, fnoff) {
    var fc = GETFCOUNT(S, si);
    var i = 0;
    while (i < fc) {
        var fn_off = L64(S + 0xDCA000 + si * 256 + i * 8);
        if (STREQ(S, fn_off, fnoff) == 1) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

# Parse: struct Name<T> { field; field; ... }
fn PARSE_STRUCT_DEF(S) {
    STI(S, GTI(S) + 1);  # consume STRUCT
    if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
    var noff = PEEKV(S);
    STI(S, GTI(S) + 1);
    # Skip generic parameters if present: struct Foo<T, U>
    SKIP_GENERICS(S);
    var sid = REGSTRUCT(S, noff);
    var si = sid - 1;
    if (PEEKT(S) != 13) { ERR_EXPECT(S, 13); }
    STI(S, GTI(S) + 1);  # consume {
    var go = 1;
    while (go == 1) {
        if (PEEKT(S) == 14) { go = 0; }
        else {
            if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
            var fnoff = PEEKV(S);
            STI(S, GTI(S) + 1);
            # Check for type annotation: field: Type
            if (PEEKT(S) == 49) {
                STI(S, GTI(S) + 1);
                if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
                var tnoff = PEEKV(S);
                # Check scalar types first
                var ftname = L64(S + 0x60000 + tnoff);
                var fscalar = 0;
                if (ftname & 0xFFFF == 0x3869) { fscalar = 1; }
                elif (ftname & 0xFFFFFF == 0x363169) { fscalar = 2; }
                elif (ftname & 0xFFFFFF == 0x323369) { fscalar = 4; }
                elif (ftname & 0xFFFFFF == 0x343669) { fscalar = 8; }
                STI(S, GTI(S) + 1);
                if (fscalar > 0) {
                    # Store as negative width for sized scalars, 0 for i64 (default)
                    if (fscalar < 8) { ADDFIELDTYPED(S, si, fnoff, 0 - fscalar); }
                    else { ADDFIELD(S, si, fnoff); }
                } else {
                    var fsid = FINDSTRUCT(S, tnoff);
                    ADDFIELDTYPED(S, si, fnoff, fsid);
                }
            } else {
                ADDFIELD(S, si, fnoff);
            }
            if (PEEKT(S) == 5) { STI(S, GTI(S) + 1); }
        }
    }
    STI(S, GTI(S) + 1);  # consume }
    return 0;
}

# Parse union — same as struct but sets high bit in fcount to mark as union
fn PARSE_UNION_DEF(S) {
    STI(S, GTI(S) + 1);  # consume UNION
    if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
    var noff = PEEKV(S);
    STI(S, GTI(S) + 1);
    SKIP_GENERICS(S);
    var sid = REGSTRUCT(S, noff);
    var si = sid - 1;
    # Set union flag (high bit of fcount)
    S64(S + 0x8E830 + si * 8, 1 << 63);
    if (PEEKT(S) != 13) { ERR_EXPECT(S, 13); }
    STI(S, GTI(S) + 1);
    var go = 1;
    while (go == 1) {
        if (PEEKT(S) == 14) { go = 0; }
        else {
            if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
            var fnoff = PEEKV(S);
            STI(S, GTI(S) + 1);
            if (PEEKT(S) == 49) {
                STI(S, GTI(S) + 1);
                if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
                var tnoff = PEEKV(S);
                var ftname = L64(S + 0x60000 + tnoff);
                var fscalar = 0;
                if (ftname & 0xFFFF == 0x3869) { fscalar = 1; }
                elif (ftname & 0xFFFFFF == 0x363169) { fscalar = 2; }
                elif (ftname & 0xFFFFFF == 0x323369) { fscalar = 4; }
                elif (ftname & 0xFFFFFF == 0x343669) { fscalar = 8; }
                STI(S, GTI(S) + 1);
                if (fscalar > 0) {
                    if (fscalar < 8) { ADDFIELDTYPED(S, si, fnoff, 0 - fscalar); }
                    else { ADDFIELD(S, si, fnoff); }
                } else {
                    var fsid = FINDSTRUCT(S, tnoff);
                    ADDFIELDTYPED(S, si, fnoff, fsid);
                }
            } else {
                ADDFIELD(S, si, fnoff);
            }
            if (PEEKT(S) == 5) { STI(S, GTI(S) + 1); }
        }
    }
    STI(S, GTI(S) + 1);
    return 0;
}

fn STREQ(S, a, b) {
    var i = 0;
    var go = 1;
    while (go == 1) {
        var ca = load8(S + 0x60000 + a + i);
        var cb = load8(S + 0x60000 + b + i);
        if (ca != cb) { return 0; }
        if (ca == 0) { return 1; }
        i = i + 1;
    }
    return 1;
}

# Find variable by name offset, return LAST match index or -1.
# Last-match semantics ensure each function's `var buf[N]` shadows earlier ones.
fn FINDVAR(S, noff) {
    var vcnt = GVCNT(S);
    var vi = vcnt - 1;
    while (vi >= 0) {
        var stored = L64(S + 0x11A000 + vi * 8);
        if (STREQ(S, stored, noff) == 1) { return vi; }
        vi = vi - 1;
    }
    return 0 - 1;
}

# Syscall arity table: returns expected arg count for well-known
# Linux x86_64 syscalls, or -1 if unknown. The table is fixed — free information.
fn _SC_ARITY(n) {
    if (n == 0) { return 3; }    # read(fd, buf, count)
    if (n == 1) { return 3; }    # write(fd, buf, count)
    if (n == 2) { return 3; }    # open(path, flags, mode)
    if (n == 3) { return 1; }    # close(fd)
    if (n == 4) { return 2; }    # stat(path, buf)
    if (n == 5) { return 2; }    # fstat(fd, buf)
    if (n == 8) { return 3; }    # lseek(fd, off, whence)
    if (n == 9) { return 6; }    # mmap(addr, len, prot, flags, fd, off)
    if (n == 10) { return 3; }   # mprotect(addr, len, prot)
    if (n == 11) { return 2; }   # munmap(addr, len)
    if (n == 12) { return 1; }   # brk(addr)
    if (n == 16) { return 3; }   # ioctl(fd, req, arg)
    if (n == 21) { return 2; }   # access(path, mode)
    if (n == 22) { return 1; }   # pipe(fds)
    if (n == 32) { return 1; }   # dup(fd)
    if (n == 33) { return 2; }   # dup2(old, new)
    if (n == 39) { return 0; }   # getpid()
    if (n == 56) { return 5; }   # clone(flags, stack, ptid, ctid, tls)
    if (n == 57) { return 0; }   # fork()
    if (n == 59) { return 3; }   # execve(path, argv, envp)
    if (n == 60) { return 1; }   # exit(code)
    if (n == 61) { return 4; }   # wait4(pid, status, opts, rusage)
    if (n == 62) { return 2; }   # kill(pid, sig)
    if (n == 63) { return 1; }   # uname(buf)
    if (n == 72) { return 3; }   # fcntl(fd, cmd, arg)
    if (n == 79) { return 2; }   # getcwd(buf, size)
    if (n == 80) { return 1; }   # chdir(path)
    if (n == 83) { return 2; }   # mkdir(path, mode)
    if (n == 84) { return 1; }   # rmdir(path)
    if (n == 87) { return 1; }   # unlink(path)
    if (n == 90) { return 2; }   # chmod(path, mode)
    if (n == 102) { return 0; }  # getuid()
    if (n == 104) { return 0; }  # getgid()
    if (n == 107) { return 0; }  # geteuid()
    if (n == 108) { return 0; }  # getegid()
    if (n == 112) { return 1; }  # setsid() — actually 0 args but Cyrius wraps
    if (n == 113) { return 1; }  # setuid(uid)
    if (n == 116) { return 2; }  # setgroups(size, list)
    if (n == 165) { return 5; }  # mount(src, tgt, fs, flags, data)
    if (n == 166) { return 2; }  # umount2(target, flags)
    if (n == 169) { return 4; }  # reboot(magic1, magic2, cmd, arg)
    return 0 - 1;
}

# Cache for str_from function index (auto-coercion).
# Lazily resolved on first use — returns the tok_names offset for "str_from".
var _str_from_cache = 0 - 1;
fn _STR_FROM_NOFF(S) {
    if (_str_from_cache >= 0) { return _str_from_cache; }
    # Search tok_names for "str_from\0" = 0x006D6F72665F727473
    var npos = GNPOS(S);
    var i = 0;
    while (i < npos) {
        if (L64(S + 0x60000 + i) == 0x6D6F72665F727473) {
            if (load8(S + 0x60000 + i + 8) == 0) {
                _str_from_cache = i;
                return i;
            }
        }
        # Skip to next null terminator
        while (i < npos) { if (load8(S + 0x60000 + i) == 0) { i = i + 1; break; } i = i + 1; }
    }
    return 0 - 1;
}

fn PARSE_FACTOR(S) {
    var typ = PEEKT(S);
    SPSC(S, 0);
    SESTYPE(S, 0);
    SESVAR(S, 0 - 1);
    SEXW(S, 0);
    # Unary minus: -expr
    if (typ == 7) {
        STI(S, GTI(S) + 1);
        # Optimization: -NUM → emit negated constant
        if (PEEKT(S) == 1) {
            EMOVI(S, 0 - PEEKV(S));
            STI(S, GTI(S) + 1);
            return 0;
        }
        # General: parse factor, emit 0-rax via push/sub
        EMOVI(S, 0);
        EPUSHR(S);
        PARSE_FACTOR(S);
        EMOVCA(S);
        EPOPR(S);
        ESUBR(S);
        return 0;
    }
    # Unary bitwise NOT: ~expr
    if (typ == 37) {
        STI(S, GTI(S) + 1);
        PARSE_FACTOR(S);
        ENOTR(S);
        return 0;
    }
    if (typ == 61) { var fval = PEEKV(S); STI(S, GTI(S) + 1); EMIT_FLOAT_LIT(S, fval); return 0; }
    # sizeof(Type) — compile-time constant (detected as IDENT "sizeof")
    if (typ == 2) { if (L64(S + 0x60000 + PEEKV(S)) & 0xFFFFFFFFFFFF == 0x666F657A6973) {
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); }
        STI(S, GTI(S) + 1);
        var szval = 0;
        if (PEEKT(S) == 105) {
            # sizeof(u128) = 16
            szval = 16;
            STI(S, GTI(S) + 1);
        } else {
            if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
            var szn = PEEKV(S);
            STI(S, GTI(S) + 1);
            var szname = L64(S + 0x60000 + szn);
            if (szname & 0xFFFF == 0x3869) { szval = 1; }
            elif (szname & 0xFFFFFF == 0x363169) { szval = 2; }
            elif (szname & 0xFFFFFF == 0x323369) { szval = 4; }
            elif (szname & 0xFFFFFF == 0x343669) { szval = 8; }
            else {
                var szsid = FINDSTRUCT(S, szn);
                if (szsid > 0) { szval = STRUCTSZ(S, szsid - 1); }
                else { ERR_MSG(S, "sizeof: unknown type", 20); }
            }
        }
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); }
        STI(S, GTI(S) + 1);
        EMOVI(S, szval);
        return 0;
    } }
    if (typ == 1) {
        var val = PEEKV(S);
        STI(S, GTI(S) + 1);
        _cfp = GCP(S);
        EMOVI(S, val);
        # Mark as foldable only if small positive (5-byte EMOVI)
        if (val > 0) { if (val < 0x10000) { _cfv = val; _cfo = 1; } }
        return 0;
    }
    if (typ == 2) {
        # IDENT — variable load or function call
        var noff = PEEKV(S);
        STI(S, GTI(S) + 1);
        # Check for function call
        if (PEEKT(S) == 10) {
            PARSE_FNCALL(S, noff);
            _cfo = 0;
            return 0;
        }
        # Check for enum.variant or struct.field access
        if (PEEKT(S) == 41) {
            # Peek: is the second ident a known global var? (enum variant)
            var dot_ti = GTI(S);
            STI(S, GTI(S) + 1);
            if (PEEKT(S) == 2) {
                var vn = PEEKV(S);
                var vi = FINDVAR(S, vn);
                if (vi >= 0) {
                    # Enum.VARIANT — load the variant's global value
                    STI(S, GTI(S) + 1);
                    EVLOAD(S, vi);
                    _cfo = 0;
                    return 0;
                }
            }
            # Not an enum — rewind and do struct field load
            STI(S, dot_ti);
            PARSE_FIELD_LOAD(S, noff);
            _cfo = 0;
            return 0;
        }
        # Variable load — check local first if in function
        SPSC(S, 0);
        if (GINFN(S) == 1) {
            var li = FINDLOCAL(S, noff);
            if (li >= 0) {
                var lt = GLTYPE(S, li);
                SPSC(S, lt);
                # Width-correct load for scalar types (1=i8, 2=i16, 4=i32)
                if (lt > 0) { if (lt <= 8) { SEXW(S, lt); EFLLOAD_W(S, li, lt); return 0; } }
                EFLLOAD(S, li);
                return 0;
            }
        }
        var idx = FINDVAR(S, noff);
        if (idx < 0) {
            syscall(SYS_WRITE, 2, "error:", 6);
            FM_LOOKUP(S, GTLINE(S, GTI(S)));
            syscall(SYS_WRITE, 2, ": undefined variable '", 22);
            PRSTR(S + 0x60000 + noff);
            syscall(SYS_WRITE, 2, "' (missing include or enum?)\n", 29);
            syscall(SYS_EXIT, 1);
        }
        var vt = GVTYPE(S, idx);
        if (vt < 0) { SPSC(S, 0 - vt); }
        if (vt > 0) {
            # Disambiguate scalar types from struct IDs using var_sizes:
            # Scalar i8/i16/i32 have var_sizes 1/2/4. Structs have var_sizes >= 8.
            var gvsz = L64(S + 0x12A000 + idx * 8);
            if (gvsz < 8) {
                SEXW(S, gvsz);
                EVLOAD_W(S, idx, gvsz);
                return 0;
            }
            SESTYPE(S, vt);
            if (gvsz > 8) { SESVAR(S, idx); }
        }
        EVLOAD(S, idx);
        return 0;
    }
    if (typ == 10) {
        STI(S, GTI(S) + 1);
        PCMPE(S);
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); }
        STI(S, GTI(S) + 1);
        _cfo = 0;
        return 0;
    }
    if (typ == 27) {
        # &var or &fn — address of variable or function
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
        var anoff = PEEKV(S);
        STI(S, GTI(S) + 1);
        # Check if it's a function name first
        var fni = FINDFN(S, anoff);
        if (fni >= 0) {
            # Emit function address via fixup type 3
            var fc = GFCNT(S);
            if (fc >= 4096) {
                syscall(SYS_WRITE, 2, "error: fixup table full (16384)\n", 31);
                syscall(SYS_EXIT, 1);
            }
            if (_IS_OBJ(S) == 1) {
                # LEA rax, [rip+disp32]: 48 8D 05 <rel32> (PIC-safe)
                EB(S, 0x48); EB(S, 0x8D); EB(S, 0x05);
                var faddr = S + 0xE4A000 + fc * 16;
                S64(faddr, GCP(S));
                S64(faddr + 8, (3 << 56) | fni);
                SFCNT(S, fc + 1);
                EDISP32(S, 0);
            } else {
                E2(S, 0xB848);
                var faddr = S + 0xE4A000 + fc * 16;
                S64(faddr, GCP(S));
                S64(faddr + 8, (3 << 56) | fni);
                SFCNT(S, fc + 1);
                E8(S, 0);
            }
            return 0;
        }
        if (GINFN(S) == 1) {
            var ali = FINDLOCAL(S, anoff);
            if (ali >= 0) {
                E3(S, 0x858D48);
                var adisp = 0 - ((ali + 1) * 8);
                var aaddr = S + 0x54A000 + GCP(S);
                S64(aaddr, (L64(aaddr) >> 32 << 32) | (adisp & 0xFFFFFFFF));
                SCP(S, GCP(S) + 4);
                return 0;
            }
        }
        var aidx = FINDVAR(S, anoff);
        if (aidx < 0) {
            syscall(SYS_WRITE, 2, "error:", 6); FM_LOOKUP(S, GTLINE(S, GTI(S))); syscall(SYS_WRITE, 2, ": undefined variable '", 22);
            PRSTR(S + 0x60000 + anoff); syscall(SYS_WRITE, 2, "'\n", 2); syscall(SYS_EXIT, 1);
        }
        EVADDR(S, aidx);
        return 0;
    }
    if (typ == 30) {
        # STRING literal
        var sval = PEEKV(S);
        STI(S, GTI(S) + 1);
        var soff = sval >> 16;
        ESADDR(S, soff);
        return 0;
    }
    if (typ == 24) {
        # syscall(args...)
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); }
        STI(S, GTI(S) + 1);
        var argc = 0;
        var sc_num = 0 - 1;
        var scgo = 1;
        while (scgo == 1) {
            PCMPE(S);
            if (argc == 0) { if (_cfo == 1) { sc_num = _cfv; } }
            EPUSHR(S);
            argc = argc + 1;
            if (PEEKT(S) == 31) { STI(S, GTI(S) + 1); }
            else { scgo = 0; }
        }
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); }
        STI(S, GTI(S) + 1);
        ESCPOPS(S, argc);
        _cfo = 0;
        # Syscall arity check — warn if arg count doesn't match the
        # well-known arity for common Linux x86_64 syscalls.
        if (sc_num >= 0) {
            var expect = _SC_ARITY(sc_num);
            if (expect >= 0) {
                var got = argc - 1;
                if (got != expect) {
                    WARN(S, "syscall arity mismatch", 22);
                }
            }
        }
        return 0;
    }
    if (typ == 25) {
        # load8(addr)
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1);
        PCMPE(S);
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1);
        ELOAD8(S);
        return 0;
    }
    if (typ == 42) {
        # load16(addr)
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1);
        PCMPE(S);
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1);
        ELOAD16(S);
        return 0;
    }
    if (typ == 43) {
        # load32(addr)
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1);
        PCMPE(S);
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1);
        ELOAD32(S);
        return 0;
    }
    if (typ == 44) {
        # load64(addr)
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1);
        PCMPE(S);
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1);
        ELOAD64(S);
        return 0;
    }
    if (typ == 26) {
        # store8(addr, val)
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1);
        PCMPE(S); EPUSHR(S);
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S); EPOPC(S); ESTORE8(S); EXORAA(S);
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1);
        return 0;
    }
    if (typ == 45) {
        # store16(addr, val)
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1);
        PCMPE(S); EPUSHR(S);
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S); EPOPC(S); ESTORE16(S); EXORAA(S);
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1);
        return 0;
    }
    if (typ == 46) {
        # store32(addr, val)
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1);
        PCMPE(S); EPUSHR(S);
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S); EPOPC(S); ESTORE32(S); EXORAA(S);
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1);
        return 0;
    }
    if (typ == 47) {
        # store64(addr, val)
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1);
        PCMPE(S); EPUSHR(S);
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S); EPOPC(S); ESTORE64(S); EXORAA(S);
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1);
        return 0;
    }
    if (typ == 8) {
        # *expr — dereference (load64 through address)
        STI(S, GTI(S) + 1);
        PARSE_FACTOR(S);
        ELOAD64(S);
        SPSC(S, 0);
        return 0;
    }
    if (typ == 37) {
        # ~ bitwise NOT
        STI(S, GTI(S) + 1);
        PARSE_FACTOR(S);
        ENOTR(S);
        return 0;
    }
    # |params| expr — closure/lambda (no captures for now)
    if (typ == 35) {
        STI(S, GTI(S) + 1);  # consume |
        # Generate anonymous function name __closure_N
        NPOS_GUARD(S, 16);
        var clid = GFNC(S);
        var clnoff = GNPOS(S);
        var cwp = clnoff;
        # Write "__cl" + digit
        store8(S + 0x60000 + cwp, 95); cwp = cwp + 1;
        store8(S + 0x60000 + cwp, 95); cwp = cwp + 1;
        store8(S + 0x60000 + cwp, 99); cwp = cwp + 1;
        store8(S + 0x60000 + cwp, 108); cwp = cwp + 1;
        store8(S + 0x60000 + cwp, 48 + (clid % 10)); cwp = cwp + 1;
        store8(S + 0x60000 + cwp, 0); cwp = cwp + 1;
        SNPOS(S, cwp);
        # Register the closure function
        var clfi = REGFN(S, clnoff);
        # Save current state
        var cl_saved_lv = GLVAR(S);
        var cl_saved_infn = GINFN(S);
        var cl_saved_flc = GFLC(S);
        var cl_saved_rpc = GRPC(S);
        var cl_saved_sdep = GSDEP(S);
        # Set up closure function
        SINFN(S, 1);
        SFLC(S, 0);
        SRPC(S, 0);
        SSDEP(S, 0);
        # Emit function prologue
        var cl_jmp = EJMP0(S);
        S64(S + 0xE92000 + clfi * 8, GCP(S));
        EFNPRO(S);
        # Parse params until |
        var clpc = 0;
        if (PEEKT(S) != 35) {
            var cpgo = 1;
            while (cpgo == 1) {
                if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
                var cpnoff = PEEKV(S);
                STI(S, GTI(S) + 1);
                var cpli = GFLC(S);
                S64(S + 0x91000 + cpli * 8, cpnoff);
                SLDEP(S, cpli, 0);
                if (clpc < 6) { ESTOREPARM(S, clpc, cpli, 0); }
                SFLC(S, cpli + 1);
                clpc = clpc + 1;
                if (PEEKT(S) == 31) { STI(S, GTI(S) + 1); }
                else { cpgo = 0; }
            }
        }
        S64(S + 0xE9A000 + clfi * 8, clpc);
        if (PEEKT(S) != 35) { ERR_EXPECT(S, 35); }
        STI(S, GTI(S) + 1);  # consume closing |
        ESUBRSP(S, GFLC(S));
        # Parse body: { stmts } or single expression
        if (PEEKT(S) == 13) {
            STI(S, GTI(S) + 1);
            PARSE_PROG(S);
            if (PEEKT(S) != 14) { ERR_EXPECT(S, 14); }
            STI(S, GTI(S) + 1);
        } else {
            PCMPE(S);
        }
        # Patch any return statements + emit epilogue
        var clrpc = GRPC(S);
        for (var clri = 0; clri < clrpc; clri = clri + 1) {
            EPATCH(S, L64(S + 0x8DA20 + clri * 8));
        }
        EFNEPI(S);
        EPATCH(S, cl_jmp);
        # Restore state
        SINFN(S, cl_saved_infn);
        SFLC(S, cl_saved_flc);
        SRPC(S, cl_saved_rpc);
        SSDEP(S, cl_saved_sdep);
        SLVAR(S, cl_saved_lv);
        # Emit address of closure function (like &fn_name)
        var clfc = GFCNT(S);
        if (clfc >= 4096) {
            syscall(SYS_WRITE, 2, "error: fixup table full (16384)\n", 31);
            syscall(SYS_EXIT, 1);
        }
        if (_IS_OBJ(S) == 1) {
            EB(S, 0x48); EB(S, 0x8D); EB(S, 0x05);
            var clfaddr = S + 0xE4A000 + clfc * 16;
            S64(clfaddr, GCP(S));
            S64(clfaddr + 8, (3 << 56) | clfi);
            SFCNT(S, clfc + 1);
            EDISP32(S, 0);
        } else {
            E2(S, 0xB848);
            var clfaddr = S + 0xE4A000 + clfc * 16;
            S64(clfaddr, GCP(S));
            S64(clfaddr + 8, (3 << 56) | clfi);
            SFCNT(S, clfc + 1);
            E8(S, 0);
        }
        return 0;
    }
    ERR(S);
    return 0;
}
# f64 binary ops
fn PF64BIN(S, tok) {
    STI(S, GTI(S) + 1);
    if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1);
    PCMPE(S); EPUSHR(S);
    if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
    PCMPE(S);
    EMIT_F64_BINOP(S, tok - 62);
    if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1);
    return 0;
}
# f64 compare ops
fn PF64CMP(S, tok) {
    STI(S, GTI(S) + 1);
    if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1);
    PCMPE(S); EPUSHR(S);
    if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
    PCMPE(S);
    EPOPC(S); EPUSHR(S);
    EB(S, 0x48); EB(S, 0x89); EB(S, 0xC8);
    EMOVQ_X0_A(S); EPOPR(S);
    EB(S, 0x48); EB(S, 0x89); EB(S, 0xC1);
    EMOVQ_X1_C(S); EUCOMISD(S);
    # mov eax, 0 (B8 00000000) — clear without clobbering flags
    EB(S, 0xB8); EB(S, 0); EB(S, 0); EB(S, 0); EB(S, 0);
    if (tok == 68) { EB(S, 0x0F); EB(S, 0x94); EB(S, 0xC0); }
    if (tok == 69) { EB(S, 0x0F); EB(S, 0x92); EB(S, 0xC0); }
    if (tok == 70) { EB(S, 0x0F); EB(S, 0x97); EB(S, 0xC0); }
    EB(S, 0x0F); EB(S, 0xB6); EB(S, 0xC0);
    if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1);
    return 0;
}

# Constant folding state (codegen-level, same EMOVI size only)
# Handle extended SIMD builtins (tokens 93-96) in separate function
fn PARSE_SIMD_EXT(S, ptyp) {
    # f64v_div(dst, a, b, n)
    if (ptyp == 93) {
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1);
        var vbase = GFLC(S);
        PCMPE(S); EFLSTORE(S, vbase);
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S); EFLSTORE(S, vbase + 1);
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S); EFLSTORE(S, vbase + 2);
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S);
        SFLC(S, vbase + 3);
        EMIT_F64V_LOOP(S, 3, vbase);
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1);
        return 0;
    }
    # f64v_sqrt(dst, src, n)
    if (ptyp == 94) {
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1);
        var vbase = GFLC(S);
        PCMPE(S); EFLSTORE(S, vbase);
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S); EFLSTORE(S, vbase + 1);
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S);
        SFLC(S, vbase + 2);
        EMIT_F64V_UNARY(S, 0, vbase);
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1);
        return 0;
    }
    # f64v_abs(dst, src, n)
    if (ptyp == 95) {
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1);
        var vbase = GFLC(S);
        PCMPE(S); EFLSTORE(S, vbase);
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S); EFLSTORE(S, vbase + 1);
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S);
        SFLC(S, vbase + 2);
        EMIT_F64V_UNARY(S, 1, vbase);
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1);
        return 0;
    }
    # f64v_fmadd(dst, a, b, c, n)
    if (ptyp == 96) {
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1);
        var vbase = GFLC(S);
        PCMPE(S); EFLSTORE(S, vbase);
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S); EFLSTORE(S, vbase + 1);
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S); EFLSTORE(S, vbase + 2);
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S); EFLSTORE(S, vbase + 3);
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S);
        SFLC(S, vbase + 4);
        EMIT_F64V_FMADD(S, vbase);
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1);
        return 0;
    }
    # ret2(a, b) — return two values in rax:rdx
    if (ptyp == 97) {
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1);
        PCMPE(S);
        EPUSHR(S);
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S);
        # rax = b, stack = a → mov rdx, rax; pop rax
        EMOVRDXRAX(S);
        EPOPR(S);
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1);
        # Don't consume ; here — PARSE_STMT handles it via expression statement path
        var rp = EJMP0(S);
        var rpc = GRPC(S);
        if (rpc >= 64) { ERR_MSG(S, "too many return statements in function (max 64)", 47); }
        S64(S + 0x8DA20 + rpc * 8, rp);
        SRPC(S, rpc + 1);
        return 0;
    }
    # f64_atan(x) — x87: fld x, fld1, fpatan
    if (ptyp == 99) { STI(S, GTI(S) + 1); if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1); PCMPE(S); EX87PUSH(S); EB(S, 0xD9); EB(S, 0xE8); EB(S, 0xD9); EB(S, 0xF3); EX87POP(S); if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1); return 0; }
    # rethi() — read rdx from last function call (mov rax, rdx)
    if (ptyp == 98) {
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1);
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1);
        EMOVRA_RDX(S);
        return 0;
    }
    # bitget(val, offset, width) → (val >> offset) & ((1 << width) - 1)
    if (ptyp == 102) {
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1);
        PCMPE(S); ESPILL(S);
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S);
        # rax = offset, stack = val. Shift val >> offset
        EMOVCA(S); EUNSPILL(S); ESHRCL(S);
        # Now rax = val >> offset. Need to mask with (1 << width) - 1
        ESPILL(S);
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S);
        # rax = width. Compute mask: (1 << width) - 1
        EMOVCA(S); EMOVI(S, 1); ESHLCL(S);
        # rax = 1 << width. Subtract 1.
        ESPILL(S); EMOVI(S, 1); EMOVCA(S); EUNSPILL(S); ESUBR(S);
        # rax = mask. AND with shifted val.
        EMOVCA(S); EUNSPILL(S); EANDR(S);
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1);
        return 0;
    }
    # bitset(val, offset, width, new) → (val & ~(mask << offset)) | ((new & mask) << offset)
    if (ptyp == 103) {
        if (GINFN(S) == 0) { ERR_MSG(S, "bitset must be called inside a function", 39); }
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1);
        var bsb = GFLC(S);
        SFLC(S, bsb + 5);
        PCMPE(S); EFLSTORE(S, bsb);              # s0 = val
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S); EFLSTORE(S, bsb + 1);          # s1 = offset
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S); EFLSTORE(S, bsb + 2);          # s2 = width
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S); EFLSTORE(S, bsb + 3);          # s3 = new_val
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1);
        # mask = (1 << width) - 1
        EFLLOAD(S, bsb + 2); EMOVCA(S); EMOVI(S, 1); ESHLCL(S);
        ESPILL(S); EMOVI(S, 1); EMOVCA(S); EUNSPILL(S); ESUBR(S);
        EFLSTORE(S, bsb + 4);                    # s4 = mask
        # cleared = val & ~(mask << offset)
        EFLLOAD(S, bsb + 4); ESPILL(S);
        EFLLOAD(S, bsb + 1); EMOVCA(S); EUNSPILL(S); ESHLCL(S);
        ENOTR(S); ESPILL(S);
        EFLLOAD(S, bsb); EMOVCA(S); EUNSPILL(S); EANDR(S);
        EFLSTORE(S, bsb);                        # s0 = cleared
        # insert = (new_val & mask) << offset
        EFLLOAD(S, bsb + 3); ESPILL(S);
        EFLLOAD(S, bsb + 4); EMOVCA(S); EUNSPILL(S); EANDR(S);
        ESPILL(S);
        EFLLOAD(S, bsb + 1); EMOVCA(S); EUNSPILL(S); ESHLCL(S);
        # result = cleared | insert
        ESPILL(S); EFLLOAD(S, bsb); EMOVCA(S); EUNSPILL(S); EORR(S);
        return 0;
    }
    # bitclr(val, offset, width) → val & ~(((1 << width) - 1) << offset)
    if (ptyp == 104) {
        if (GINFN(S) == 0) { ERR_MSG(S, "bitclr must be called inside a function", 39); }
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1);
        var bcb = GFLC(S);
        SFLC(S, bcb + 3);
        PCMPE(S); EFLSTORE(S, bcb);              # s0 = val
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S); EFLSTORE(S, bcb + 1);          # s1 = offset
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S); EFLSTORE(S, bcb + 2);          # s2 = width
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1);
        # mask = (1 << width) - 1
        EFLLOAD(S, bcb + 2); EMOVCA(S); EMOVI(S, 1); ESHLCL(S);
        ESPILL(S); EMOVI(S, 1); EMOVCA(S); EUNSPILL(S); ESUBR(S);
        # mask << offset
        ESPILL(S); EFLLOAD(S, bcb + 1); EMOVCA(S); EUNSPILL(S); ESHLCL(S);
        # ~(mask << offset) & val
        ENOTR(S); ESPILL(S);
        EFLLOAD(S, bcb); EMOVCA(S); EUNSPILL(S); EANDR(S);
        return 0;
    }
    return 0;
}

var _cfv = 0;
var _cfp = 0;
var _cfo = 0;

fn PARSE_TERM(S) {
    _cfo = 0;
    # Extended builtins — checked first
    var ptyp = PEEKT(S);
    if (ptyp >= 93) { if (ptyp <= 99) { return PARSE_SIMD_EXT(S, ptyp); } }
    if (ptyp >= 100) { if (ptyp <= 104) { return PARSE_SIMD_EXT(S, ptyp); } }
    # f64 builtins — check before PARSE_FACTOR dispatches
    if (ptyp >= 62) { if (ptyp <= 65) { PF64BIN(S, ptyp); return 0; } }
    if (ptyp == 66) { STI(S, GTI(S) + 1); if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1); PCMPE(S); EI2F(S); EMOVQ_A_X0(S); if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1); return 0; }
    if (ptyp == 67) { STI(S, GTI(S) + 1); if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1); PCMPE(S); EMOVQ_X0_A(S); EF2I(S); if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1); return 0; }
    if (ptyp >= 68) { if (ptyp <= 70) { PF64CMP(S, ptyp); return 0; } }
    if (ptyp == 71) { STI(S, GTI(S) + 1); if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1); PCMPE(S); EMOVQ_X0_A(S); EXORPD_X1(S); EB(S, 0xF2); EB(S, 0x0F); EB(S, 0x5C); EB(S, 0xC8); EMOVAPD_01(S); EMOVQ_A_X0(S); if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1); return 0; }
    # f64_sqrt(x) — sqrtsd xmm0, xmm0
    if (ptyp == 79) { STI(S, GTI(S) + 1); if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1); PCMPE(S); EMOVQ_X0_A(S); EF64SQRT(S); EMOVQ_A_X0(S); if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1); return 0; }
    # f64_abs(x) — clear sign bit via integer AND
    if (ptyp == 80) { STI(S, GTI(S) + 1); if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1); PCMPE(S); EPUSHR(S); EMOVI(S, 0x7FFFFFFFFFFFFFFF); EMOVCA(S); EPOPR(S); EANDR(S); if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1); return 0; }
    # f64_floor(x) — roundsd xmm0, xmm0, 1 (SSE4.1)
    if (ptyp == 81) { STI(S, GTI(S) + 1); if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1); PCMPE(S); EMOVQ_X0_A(S); EF64FLOOR(S); EMOVQ_A_X0(S); if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1); return 0; }
    # f64_ceil(x) — roundsd xmm0, xmm0, 2 (SSE4.1)
    if (ptyp == 82) { STI(S, GTI(S) + 1); if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1); PCMPE(S); EMOVQ_X0_A(S); EF64CEIL(S); EMOVQ_A_X0(S); if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1); return 0; }
    # f64_round(x) — roundsd xmm0, xmm0, 0 (round to nearest)
    if (ptyp == 92) { STI(S, GTI(S) + 1); if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1); PCMPE(S); EMOVQ_X0_A(S); EF64ROUND(S); EMOVQ_A_X0(S); if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1); return 0; }
    # f64_sin(x) — x87 fsin (D9 FE)
    if (ptyp == 83) { STI(S, GTI(S) + 1); if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1); PCMPE(S); EX87PUSH(S); EB(S, 0xD9); EB(S, 0xFE); EX87POP(S); if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1); return 0; }
    # f64_cos(x) — x87 fcos (D9 FF)
    if (ptyp == 84) { STI(S, GTI(S) + 1); if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1); PCMPE(S); EX87PUSH(S); EB(S, 0xD9); EB(S, 0xFF); EX87POP(S); if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1); return 0; }
    # f64_exp(x) — x87: fldl2e; fmulp; fld st0; frndint; fsub st1,st0; fxch; f2xm1; fld1; faddp; fscale; fstp st1
    if (ptyp == 85) { STI(S, GTI(S) + 1); if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1); PCMPE(S); EX87PUSH(S); EB(S, 0xD9); EB(S, 0xEA); EB(S, 0xDE); EB(S, 0xC9); EB(S, 0xD9); EB(S, 0xC0); EB(S, 0xD9); EB(S, 0xFC); EB(S, 0xDC); EB(S, 0xE9); EB(S, 0xD9); EB(S, 0xC9); EB(S, 0xD9); EB(S, 0xF0); EB(S, 0xD9); EB(S, 0xE8); EB(S, 0xDE); EB(S, 0xC1); EB(S, 0xD9); EB(S, 0xFD); EB(S, 0xDD); EB(S, 0xD9); EX87POP(S); if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1); return 0; }
    # f64_ln(x) — x87: fldln2; fxch; fyl2x
    if (ptyp == 86) { STI(S, GTI(S) + 1); if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1); PCMPE(S); EX87PUSH(S); EB(S, 0xD9); EB(S, 0xED); EB(S, 0xD9); EB(S, 0xC9); EB(S, 0xD9); EB(S, 0xF1); EX87POP(S); if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1); return 0; }
    # f64_log2(x) — x87: fld1; fxch; fyl2x
    if (ptyp == 87) { STI(S, GTI(S) + 1); if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1); PCMPE(S); EX87PUSH(S); EB(S, 0xD9); EB(S, 0xE8); EB(S, 0xD9); EB(S, 0xC9); EB(S, 0xD9); EB(S, 0xF1); EX87POP(S); if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1); return 0; }
    # f64_exp2(x) — x87: fld st0; frndint; fsub st1,st0; fxch; f2xm1; fld1; faddp; fscale; fstp st1
    if (ptyp == 88) { STI(S, GTI(S) + 1); if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1); PCMPE(S); EX87PUSH(S); EB(S, 0xD9); EB(S, 0xC0); EB(S, 0xD9); EB(S, 0xFC); EB(S, 0xDC); EB(S, 0xE9); EB(S, 0xD9); EB(S, 0xC9); EB(S, 0xD9); EB(S, 0xF0); EB(S, 0xD9); EB(S, 0xE8); EB(S, 0xDE); EB(S, 0xC1); EB(S, 0xD9); EB(S, 0xFD); EB(S, 0xDD); EB(S, 0xD9); EX87POP(S); if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1); return 0; }
    # f64v_add/sub/mul(dst, a, b, n) — SSE2 packed f64 batch operations
    if (ptyp >= 89) { if (ptyp <= 91) {
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); } STI(S, GTI(S) + 1);
        var vbase = GFLC(S);
        PCMPE(S); EFLSTORE(S, vbase);
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S); EFLSTORE(S, vbase + 1);
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S); EFLSTORE(S, vbase + 2);
        if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);
        PCMPE(S);
        SFLC(S, vbase + 3);
        EMIT_F64V_LOOP(S, ptyp - 89, vbase);
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1);
        return 0;
    } }
    PARSE_FACTOR(S);
    var go = 1;
    while (go == 1) {
        var typ = PEEKT(S);
        if (typ == 8) {
            var mulst = GESTYPE(S);
            STI(S, GTI(S) + 1);
            if (mulst > 0) { EMIT_OP_DISPATCH(S, mulst, "mul", 3); }
            else {
                # Constant fold: NUM * NUM where both and result are small positive
                if (_cfo == 1) {
                    if (PEEKT(S) == 1) {
                        var crv = PEEKV(S);
                        if (crv == 0) { STI(S, GTI(S) + 1); SCP(S, _cfp); EMOVI(S, 0); _cfv = 0; }
                        elif (crv == 1) { STI(S, GTI(S) + 1); }
                        elif (crv > 0) {
                            var cfr = _cfv * crv;
                            if (cfr >= 0) {
                                STI(S, GTI(S) + 1);
                                SCP(S, _cfp);
                                EMOVI(S, cfr);
                                _cfv = cfr;
                            } else { _cfo = 0; ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); EIMUL(S); }
                        }
                        else { _cfo = 0; ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); EIMUL(S); }
                    } else { _cfo = 0; ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); EIMUL(S); }
                } else { ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); EIMUL(S); _cfo = 0; }
            }
        }
        else { if (typ == 9) {
            var divst = GESTYPE(S);
            STI(S, GTI(S) + 1);
            if (divst > 0) { EMIT_OP_DISPATCH(S, divst, "div", 3); }
            else {
                if (_cfo == 1) { if (PEEKT(S) == 1) {
                    var crv = PEEKV(S);
                    if (crv > 0) { if (crv < 0x10000) {
                        var cfr = _cfv / crv;
                        if (cfr > 0) { if (cfr < 0x10000) {
                            STI(S, GTI(S) + 1); SCP(S, _cfp); EMOVI(S, cfr); _cfv = cfr;
                        } else { _cfo = 0; ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); ECQO(S); EIDIV(S); } }
                        else { _cfo = 0; ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); ECQO(S); EIDIV(S); }
                    } else { _cfo = 0; ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); ECQO(S); EIDIV(S); } }
                    else { _cfo = 0; ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); ECQO(S); EIDIV(S); }
                } else { _cfo = 0; ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); ECQO(S); EIDIV(S); } }
                else { ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); ECQO(S); EIDIV(S); _cfo = 0; }
            }
        }
        else { if (typ == 34) {
            STI(S, GTI(S) + 1); _cfo = 0; ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); ECQO(S); EIDIV(S); EMOVDR(S); _cfo = 0;
        }
        else { if (typ == 38) {
            STI(S, GTI(S) + 1);
            if (_cfo == 1) { if (PEEKT(S) == 1) {
                var crv = PEEKV(S);
                if (crv > 0) { if (crv < 0x10000) {
                    var cfr = _cfv << crv;
                    if (cfr > 0) { if (cfr < 0x10000) {
                        STI(S, GTI(S) + 1); SCP(S, _cfp); EMOVI(S, cfr); _cfv = cfr;
                    } else { _cfo = 0; ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); ESHLCL(S); } }
                    else { _cfo = 0; ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); ESHLCL(S); }
                } else { _cfo = 0; ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); ESHLCL(S); } }
                else { _cfo = 0; ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); ESHLCL(S); }
            } else { _cfo = 0; ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); ESHLCL(S); } }
            else { ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); ESHLCL(S); _cfo = 0; }
        }
        else { if (typ == 39) {
            STI(S, GTI(S) + 1);
            if (_cfo == 1) { if (PEEKT(S) == 1) {
                var crv = PEEKV(S);
                if (crv > 0) { if (crv < 0x10000) {
                    var cfr = _cfv >> crv;
                    if (cfr > 0) { if (cfr < 0x10000) {
                        STI(S, GTI(S) + 1); SCP(S, _cfp); EMOVI(S, cfr); _cfv = cfr;
                    } else { _cfo = 0; ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); ESHRCL(S); } }
                    else { _cfo = 0; ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); ESHRCL(S); }
                } else { _cfo = 0; ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); ESHRCL(S); } }
                else { _cfo = 0; ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); ESHRCL(S); }
            } else { _cfo = 0; ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); ESHRCL(S); } }
            else { ESPILL(S); PARSE_FACTOR(S); EMOVCA(S); EUNSPILL(S); ESHRCL(S); _cfo = 0; }
        }
        else { go = 0; }
        } } } }
    }
    return 0;
}

fn EPTR_SCALE(S, ps) {
    # rax has the offset value; multiply by pointer scale
    # mov rcx, rax; mov rax, ps; imul rcx → rax = offset * scale
    if (ps > 1) { EMOVCA(S); EMOVI(S, ps); EIMUL(S); }
    return 0;
}

# Build operator function name: StructName_op in tok_names
# op_name is a short string like "add", "sub", "mul", "div"
fn BUILD_OP_NAME(S, stype, op_str, op_len) {
    NPOS_GUARD(S, 256);
    var si = stype - 1;
    var snoff = L64(S + 0x8E630 + si * 8);
    var owp = GNPOS(S);
    var onoff = owp;
    var ori = 0;
    var orc = load8(S + 0x60000 + snoff + ori);
    while (orc != 0) { store8(S + 0x60000 + owp, orc); owp = owp + 1; ori = ori + 1; orc = load8(S + 0x60000 + snoff + ori); }
    store8(S + 0x60000 + owp, 95); owp = owp + 1;
    var oci = 0;
    while (oci < op_len) { store8(S + 0x60000 + owp + oci, load8(op_str + oci)); oci = oci + 1; }
    owp = owp + op_len;
    store8(S + 0x60000 + owp, 0); owp = owp + 1;
    SNPOS(S, owp);
    return onoff;
}

# Emit operator dispatch: push lhs, parse rhs, call StructName_op(lhs, rhs)
fn EMIT_OP_DISPATCH(S, stype, op_str, op_len) {
    # For struct vars, push address instead of value
    var svar = GESVAR(S);
    if (svar >= 0) { EVADDR(S, svar); }
    EPUSHR(S);
    PARSE_TERM(S);
    # rhs: check if it also has a struct var
    var rsvar = GESVAR(S);
    if (rsvar >= 0) { EVADDR(S, rsvar); }
    EPUSHR(S);
    var opnoff = BUILD_OP_NAME(S, stype, op_str, op_len);
    ECALLPOPS(S, 2);
    var ofi = FINDFN(S, opnoff);
    if (ofi < 0) { ofi = REGFN(S, opnoff); }
    var ofoff = L64(S + 0xE92000 + ofi * 8);
    if (ofoff >= 0) { ECALLTO(S, ofoff); }
    else { ECALLFIX(S, ofi); }
    ECALLCLEAN(S, 2);
    SESTYPE(S, 0);
    return 0;
}

fn PEXPR(S) {
    PARSE_TERM(S);
    var ps = GPSC(S);
    var go = 1;
    while (go == 1) {
        var typ = PEEKT(S);
        if (typ == 6) {
            var addst = GESTYPE(S);
            STI(S, GTI(S) + 1);
            if (addst > 0) { EMIT_OP_DISPATCH(S, addst, "add", 3); _cfo = 0; }
            else {
                # Fold only if right side is a plain literal (not followed by * / % << >>)
                var add_can_fold = 0;
                if (_cfo == 1) { if (PEEKT(S) == 1) {
                    var nt = TOKTYP(S, GTI(S) + 1);
                    if (nt != 8) { if (nt != 9) { if (nt != 34) { if (nt != 38) { if (nt != 39) {
                        add_can_fold = 1;
                    } } } } }
                } }
                if (add_can_fold == 1) {
                    var crv = PEEKV(S);
                    if (crv == 0) { STI(S, GTI(S) + 1); }
                    elif (crv > 0) {
                        var cfr = _cfv + crv;
                        if (cfr >= 0) {
                            STI(S, GTI(S) + 1); SCP(S, _cfp); EMOVI(S, cfr); _cfv = cfr;
                        } else { _cfo = 0; ESPILL(S); SPSC(S, 0); PARSE_TERM(S); EPTR_SCALE(S, ps); EMOVCA(S); EUNSPILL(S); EADDR(S); SPSC(S, ps); }
                    }
                    else { _cfo = 0; ESPILL(S); SPSC(S, 0); PARSE_TERM(S); EPTR_SCALE(S, ps); EMOVCA(S); EUNSPILL(S); EADDR(S); SPSC(S, ps); }
                } else { ESPILL(S); SPSC(S, 0); PARSE_TERM(S); EPTR_SCALE(S, ps); EMOVCA(S); EUNSPILL(S); EADDR(S); SPSC(S, ps); _cfo = 0; }
            }
        }
        else { if (typ == 7) {
            var subst = GESTYPE(S);
            STI(S, GTI(S) + 1);
            if (subst > 0) { EMIT_OP_DISPATCH(S, subst, "sub", 3); _cfo = 0; }
            else {
                var sub_can_fold = 0;
                if (_cfo == 1) { if (PEEKT(S) == 1) {
                    var nt = TOKTYP(S, GTI(S) + 1);
                    if (nt != 8) { if (nt != 9) { if (nt != 34) { if (nt != 38) { if (nt != 39) {
                        sub_can_fold = 1;
                    } } } } }
                } }
                if (sub_can_fold == 1) {
                    var crv = PEEKV(S);
                    if (crv == 0) { STI(S, GTI(S) + 1); }
                    elif (crv > 0) {
                        var cfr = _cfv - crv;
                        if (cfr >= 0) {
                            STI(S, GTI(S) + 1); SCP(S, _cfp); EMOVI(S, cfr); _cfv = cfr;
                        } else { _cfo = 0; EPUSHR(S); SPSC(S, 0); PARSE_TERM(S); EPTR_SCALE(S, ps); EMOVCA(S); EPOPR(S); ESUBR(S); SPSC(S, ps); }
                    }
                    else { _cfo = 0; EPUSHR(S); SPSC(S, 0); PARSE_TERM(S); EPTR_SCALE(S, ps); EMOVCA(S); EPOPR(S); ESUBR(S); SPSC(S, ps); }
                } else { EPUSHR(S); SPSC(S, 0); PARSE_TERM(S); EPTR_SCALE(S, ps); EMOVCA(S); EPOPR(S); ESUBR(S); SPSC(S, ps); _cfo = 0; }
            }
        }
        else { if (typ == 27) {
            # AMPERSAND — binary AND
            STI(S, GTI(S) + 1);
            var and_can_fold = 0;
            if (_cfo == 1) { if (PEEKT(S) == 1) {
                var nt = TOKTYP(S, GTI(S) + 1);
                if (nt != 8) { if (nt != 9) { if (nt != 34) { if (nt != 38) { if (nt != 39) {
                    and_can_fold = 1;
                } } } } }
            } }
            if (and_can_fold == 1) {
                var crv = PEEKV(S);
                if (crv > 0) { if (crv < 0x10000) {
                    var cfr = _cfv & crv;
                    if (cfr > 0) { if (cfr < 0x10000) {
                        STI(S, GTI(S) + 1); SCP(S, _cfp); EMOVI(S, cfr); _cfv = cfr;
                    } else { _cfo = 0; EPUSHR(S); PARSE_TERM(S); EMOVCA(S); EPOPR(S); EANDR(S); } }
                    else { _cfo = 0; EPUSHR(S); PARSE_TERM(S); EMOVCA(S); EPOPR(S); EANDR(S); }
                } else { _cfo = 0; EPUSHR(S); PARSE_TERM(S); EMOVCA(S); EPOPR(S); EANDR(S); } }
                else { _cfo = 0; EPUSHR(S); PARSE_TERM(S); EMOVCA(S); EPOPR(S); EANDR(S); }
            } else { EPUSHR(S); PARSE_TERM(S); EMOVCA(S); EPOPR(S); EANDR(S); _cfo = 0; }
        }
        else { if (typ == 35) {
            # PIPE — binary OR
            STI(S, GTI(S) + 1);
            var or_can_fold = 0;
            if (_cfo == 1) { if (PEEKT(S) == 1) {
                var nt = TOKTYP(S, GTI(S) + 1);
                if (nt != 8) { if (nt != 9) { if (nt != 34) { if (nt != 38) { if (nt != 39) {
                    or_can_fold = 1;
                } } } } }
            } }
            if (or_can_fold == 1) {
                var crv = PEEKV(S);
                if (crv > 0) { if (crv < 0x10000) {
                    var cfr = _cfv | crv;
                    if (cfr > 0) { if (cfr < 0x10000) {
                        STI(S, GTI(S) + 1); SCP(S, _cfp); EMOVI(S, cfr); _cfv = cfr;
                    } else { _cfo = 0; EPUSHR(S); PARSE_TERM(S); EMOVCA(S); EPOPR(S); EORR(S); } }
                    else { _cfo = 0; EPUSHR(S); PARSE_TERM(S); EMOVCA(S); EPOPR(S); EORR(S); }
                } else { _cfo = 0; EPUSHR(S); PARSE_TERM(S); EMOVCA(S); EPOPR(S); EORR(S); } }
                else { _cfo = 0; EPUSHR(S); PARSE_TERM(S); EMOVCA(S); EPOPR(S); EORR(S); }
            } else { EPUSHR(S); PARSE_TERM(S); EMOVCA(S); EPOPR(S); EORR(S); _cfo = 0; }
        }
        else { if (typ == 36) {
            # CARET — binary XOR
            STI(S, GTI(S) + 1);
            var xor_can_fold = 0;
            if (_cfo == 1) { if (PEEKT(S) == 1) {
                var nt = TOKTYP(S, GTI(S) + 1);
                if (nt != 8) { if (nt != 9) { if (nt != 34) { if (nt != 38) { if (nt != 39) {
                    xor_can_fold = 1;
                } } } } }
            } }
            if (xor_can_fold == 1) {
                var crv = PEEKV(S);
                if (crv > 0) { if (crv < 0x10000) {
                    var cfr = _cfv ^ crv;
                    if (cfr > 0) { if (cfr < 0x10000) {
                        STI(S, GTI(S) + 1); SCP(S, _cfp); EMOVI(S, cfr); _cfv = cfr;
                    } else { _cfo = 0; EPUSHR(S); PARSE_TERM(S); EMOVCA(S); EPOPR(S); EXORR(S); } }
                    else { _cfo = 0; EPUSHR(S); PARSE_TERM(S); EMOVCA(S); EPOPR(S); EXORR(S); }
                } else { _cfo = 0; EPUSHR(S); PARSE_TERM(S); EMOVCA(S); EPOPR(S); EXORR(S); } }
                else { _cfo = 0; EPUSHR(S); PARSE_TERM(S); EMOVCA(S); EPOPR(S); EXORR(S); }
            } else { EPUSHR(S); PARSE_TERM(S); EMOVCA(S); EPOPR(S); EXORR(S); _cfo = 0; }
        }
        else { go = 0; }
        } } } }
    }
    return 0;
}

# Parse comparison expression: expr [cmp_op expr] [&& || cmp_expr]*
# Returns value in rax (0 or 1 for comparisons).
# Supports && (53) and || (54) as expression-level logical operators.
fn PCMPE(S) {
    PEXPR(S);
    var op = PEEKT(S);
    if (op >= 17) {
        if (op <= 22) {
            STI(S, GTI(S) + 1);
            _cfo = 0;
            EPUSHR(S);
            PEXPR(S);
            EMOVCA(S);
            EPOPR(S);
            ESETCC(S, op);
            _cfo = 0;
        }
    }
    # Short-circuit && and || chains (fixed in 4.4.1 — docs always claimed
    # short-circuit but the prior bitwise AND/OR impl evaluated both sides
    # unconditionally, causing silent miscompiles on guarded null checks
    # like `if (p != 0 && vec_len(p) > 0)` — bote feedback item 2).
    #
    # && codegen: eval left, cmp 0, je skip_right, eval right, cmp 0, setne al,
    #             jmp end, skip_right: xor rax, rax, end:
    # || codegen: eval left, cmp 0, jne skip_right, eval right, cmp 0, setne al,
    #             jmp end, skip_right: mov rax, 1, end:
    var lop = PEEKT(S);
    while (lop == 53 || lop == 54) {
        # Normalize left into boolean (0 or 1) already in rax. If a comparison
        # op preceded, ESETCC already did this; otherwise cmp rax,0; setne al.
        # But after the top block, rax already holds either a boolean (from
        # ESETCC) or an integer value — we short-circuit on "rax == 0" either
        # way, so we just need to cmp rax, 0 and branch.
        # cmp rax, 0
        EPUSHR(S);
        EMOVI(S, 0);
        EMOVCA(S);
        EPOPR(S);
        ECMPR(S);
        # For && : skip right side when left is 0 (false), jumping to the
        #          "write 0 to rax" tail. je rel32.
        # For || : skip right side when left is NOT 0 (true), jumping to the
        #          "write 1 to rax" tail. jne rel32.
        var is_and = 0;
        if (lop == 53) { is_and = 1; }
        var p_skip = 0;
        if (is_and == 1) { p_skip = EJCC(S, 0x84); }
        else { p_skip = EJCC(S, 0x85); }
        # Consume the operator token
        STI(S, GTI(S) + 1);
        # Evaluate the right operand (expression + optional comparison)
        PEXPR(S);
        var rop = PEEKT(S);
        if (rop >= 17) {
            if (rop <= 22) {
                STI(S, GTI(S) + 1);
                EPUSHR(S);
                PEXPR(S);
                EMOVCA(S);
                EPOPR(S);
                ESETCC(S, rop);
            }
        }
        # Normalize right side to boolean (cmp 0; setne al; movzx)
        EPUSHR(S);
        EMOVI(S, 0);
        EMOVCA(S);
        EPOPR(S);
        ECMPR(S);
        ESETCC(S, 18);  # 18 is !=, emits setne + movzx
        # jmp over the short-circuit tail
        var p_end = EJMP0(S);
        # skip_right lands here: write the short-circuit result
        EPATCH(S, p_skip);
        if (is_and == 1) {
            # && short-circuited because left was 0 → result is 0
            EMOVI(S, 0);
        } else {
            # || short-circuited because left was non-zero → result is 1
            EMOVI(S, 1);
        }
        EPATCH(S, p_end);
        lop = PEEKT(S);
    }
    return 0;
}

# Parse array: already past [, parse N]; register global var with aligned size
fn PARSE_ARRAY(S, noff) {
    STI(S, GTI(S) + 1);  # consume [
    if (PEEKT(S) != 1) { ERR_EXPECT(S, 1); }
    var asz = PEEKV(S);
    STI(S, GTI(S) + 1);
    if (PEEKT(S) != 29) { ERR_EXPECT(S, 29); }
    STI(S, GTI(S) + 1);  # consume ]
    if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); }
    STI(S, GTI(S) + 1);  # consume ;
    # Arrays inside functions are globals. To avoid name collisions between
    # functions (e.g. two functions both with `var buf[N]`), always register
    # a NEW global even if one with the same name exists. FINDVAR returns
    # the last match, so the current function's array shadows previous ones.
    var vcnt = GVCNT(S);
    S64(S + 0x11A000 + vcnt * 8, noff);
    var aligned = (asz + 7) & (0 - 8);
    S64(S + 0x12A000 + vcnt * 8, aligned);
    SVCNT(S, vcnt + 1);
    return 0;
}

# Build mangled method name: StructName_method in tok_names scratch.
# Returns noff of the combined name. Uses the region AFTER current
# npos as scratch — writing past live identifiers so FINDFN's byte
# compare sees a clean name. Does NOT advance npos (this is lookup-
# only; the method fn was registered at struct-def time).
# Pre-4.7.1 this wrote to a fixed offset 30000, which silently
# corrupted real identifiers in any program with >30 KB of names.
# Bote saw the downstream mis-parse as `lib/assert.cyr:3: expected
# '=', got string` because a post-corruption token noff now pointed
# at garbled bytes.
fn BUILD_METHOD_NAME(S, si, mnoff) {
    NPOS_GUARD(S, 256);
    var scratch = GNPOS(S);
    var wp = scratch;
    # Copy struct name
    var snoff = L64(S + 0x8E630 + si * 8);
    var ri = 0;
    var rc = load8(S + 0x60000 + snoff + ri);
    while (rc != 0) {
        store8(S + 0x60000 + wp, rc);
        wp = wp + 1;
        ri = ri + 1;
        rc = load8(S + 0x60000 + snoff + ri);
    }
    # Underscore separator
    store8(S + 0x60000 + wp, 95);
    wp = wp + 1;
    # Copy method name
    ri = 0;
    rc = load8(S + 0x60000 + mnoff + ri);
    while (rc != 0) {
        store8(S + 0x60000 + wp, rc);
        wp = wp + 1;
        ri = ri + 1;
        rc = load8(S + 0x60000 + mnoff + ri);
    }
    store8(S + 0x60000 + wp, 0);
    return scratch;
}

# Load a struct field: ident.field → emit load from var_addr + field_offset
# Or call a method: ident.method(args) → call StructName_method(&ident, args)
fn PARSE_FIELD_LOAD(S, noff) {
    STI(S, GTI(S) + 1);  # consume DOT
    if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
    var fnoff = PEEKV(S);
    STI(S, GTI(S) + 1);

    # Find the variable and its struct type (check locals first)
    var idx = 0 - 1;
    var sid = 0;
    if (GINFN(S) == 1) {
        var lli = FINDLOCAL(S, noff);
        if (lli >= 0) {
            var lt = GLTYPE(S, lli);
            if (lt < 0) { sid = 0 - lt; }
            idx = 0 - 2 - lli;
        }
    }
    if (idx == 0 - 1) {
        idx = FINDVAR(S, noff);
        if (idx < 0) {
            syscall(SYS_WRITE, 2, "error:", 6); FM_LOOKUP(S, GTLINE(S, GTI(S))); syscall(SYS_WRITE, 2, ": undefined variable '", 22);
            PRSTR(S + 0x60000 + noff); syscall(SYS_WRITE, 2, "'\n", 2); syscall(SYS_EXIT, 1);
        }
        sid = GVTYPE(S, idx);
    }
    var si = 0;
    if (sid > 0) { si = sid - 1; }

    # Method call: ident.method(args)
    if (PEEKT(S) == 10) {
        if (sid == 0) { ERR(S); }
        var mname = BUILD_METHOD_NAME(S, si, fnoff);
        # Push &var as first arg (self) — handle locals and globals
        if (idx < 0 - 1) {
            var mli = 0 - idx - 2;
            EFLLOAD(S, mli);
        } else {
            EVADDR(S, idx);
        }
        EPUSHR(S);
        # Parse remaining args
        STI(S, GTI(S) + 1);  # consume (
        var argc = 1;
        if (PEEKT(S) != 11) {
            var mgo = 1;
            while (mgo == 1) {
                PCMPE(S);
                EPUSHR(S);
                argc = argc + 1;
                if (PEEKT(S) == 31) { STI(S, GTI(S) + 1); }
                else { mgo = 0; }
            }
        }
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); }
        STI(S, GTI(S) + 1);  # consume )
        ECALLPOPS(S, argc);
        var mfi = FINDFN(S, mname);
        if (mfi < 0) { mfi = REGFN(S, mname); }
        var mfoff = L64(S + 0xE92000 + mfi * 8);
        if (mfoff >= 0) { ECALLTO(S, mfoff); }
        else { ECALLFIX(S, mfi); }
        ECALLCLEAN(S, argc);
        return 0;
    }

    if (sid == 0) { ERR(S); }
    var fi = FINDFIELD(S, si, fnoff);
    if (fi < 0) { ERR(S); }
    var off = FIELDOFF(S, si, fi);
    # Check for chained access: s.inner.field
    var ft = GETFTYPE(S, si, fi);
    if (ft > 0) { if (PEEKT(S) == 41) {
        # Nested struct — chain the dot access
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
        var ifnoff = PEEKV(S);
        STI(S, GTI(S) + 1);
        var isi = ft - 1;
        var ifi = FINDFIELD(S, isi, ifnoff);
        if (ifi < 0) { ERR(S); }
        off = off + FIELDOFF(S, isi, ifi);
    } }
    # Load variable address + field offset, then load value (width-correct)
    EVADDR_X1(S, idx);
    if (off > 0) { EADDIMM_X1(S, off); }
    var fld_sz = FIELDSZ(S, ft);
    if (fld_sz == 1) { EB(S, 0x48); EB(S, 0x0F); EB(S, 0xB6); EB(S, 0x01); }   # movzx rax, byte [rcx]
    elif (fld_sz == 2) { EB(S, 0x0F); EB(S, 0xB7); EB(S, 0x01); }               # movzx eax, word [rcx]
    elif (fld_sz == 4) { EB(S, 0x8B); EB(S, 0x01); }                              # mov eax, [rcx]
    else { ELODC(S); }
    return 0;
}

# Store to a struct field: ident.field = expr; or ident.inner.field = expr;
fn PARSE_FIELD_STORE(S, noff) {
    STI(S, GTI(S) + 1);  # consume DOT
    if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
    var fnoff = PEEKV(S);
    STI(S, GTI(S) + 1);
    # Find var + struct type + field
    var idx = FINDVAR(S, noff);
    if (idx < 0) {
        syscall(SYS_WRITE, 2, "error:", 6); FM_LOOKUP(S, GTLINE(S, GTI(S))); syscall(SYS_WRITE, 2, ": undefined variable '", 22);
        PRSTR(S + 0x60000 + noff); syscall(SYS_WRITE, 2, "'\n", 2); syscall(SYS_EXIT, 1);
    }
    var sid = GVTYPE(S, idx);
    if (sid == 0) { ERR(S); }
    var si = sid - 1;
    var fi = FINDFIELD(S, si, fnoff);
    if (fi < 0) { ERR(S); }
    var off = FIELDOFF(S, si, fi);
    # Check for chained access: s.inner.field = expr;
    var ft = GETFTYPE(S, si, fi);
    if (ft > 0) { if (PEEKT(S) == 41) {
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
        var ifnoff = PEEKV(S);
        STI(S, GTI(S) + 1);
        var isi = ft - 1;
        var ifi = FINDFIELD(S, isi, ifnoff);
        if (ifi < 0) { ERR(S); }
        off = off + FIELDOFF(S, isi, ifi);
    } }
    if (PEEKT(S) != 4) { ERR_EXPECT(S, 4); }
    STI(S, GTI(S) + 1);
    PCMPE(S);
    # Store value to struct field (width-correct)
    EPUSHR(S);
    EVADDR_X1(S, idx);
    if (off > 0) { EADDIMM_X1(S, off); }
    EPOPR(S);
    var fst_sz = FIELDSZ(S, ft);
    if (fst_sz == 1) { ESTORE8(S); }
    elif (fst_sz == 2) { ESTORE16(S); }
    elif (fst_sz == 4) { ESTORE32(S); }
    else { ESTOC(S); }
    if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); }
    STI(S, GTI(S) + 1);
    return 0;
}

# Parse struct init: var name = StructName { expr, expr, ... };
# sid is 1-based struct id, noff is var name offset
fn EMIT_STRUCT_FIELD(S, vcnt, boff) {
    PCMPE(S);
    EPUSHR(S);
    # Load variable address into x1/rcx via fixup
    EVADDR_X1(S, vcnt);
    if (boff > 0) {
        EADDIMM_X1(S, boff);
    }
    EPOPR(S);
    ESTOC(S);
    if (PEEKT(S) == 31) { STI(S, GTI(S) + 1); }
    return 0;
}

fn PARSE_STRUCT_INIT(S, noff, sid) {
    var si = sid - 1;
    STI(S, GTI(S) + 1);
    if (PEEKT(S) != 13) { ERR_EXPECT(S, 13); }
    STI(S, GTI(S) + 1);
    var sz = STRUCTSZ(S, si);
    var vcnt = GVCNT(S);
    S64(S + 0x11A000 + vcnt * 8, noff);
    S64(S + 0x12A000 + vcnt * 8, sz);
    SVTYPE(S, vcnt, sid);
    var fc = GETFCOUNT(S, si);
    # Detect named-field syntax: next token is IDENT (2) followed by ':' (49).
    # Empty struct literal `{}` falls through to positional branch as a no-op.
    var named = 0;
    if (PEEKT(S) == 2) {
        if (TOKTYP(S, GTI(S) + 1) == 49) { named = 1; }
    }
    if (named == 1) {
        # Named init: `StructName { field: expr, field: expr }`.
        # Each field must appear exactly once; any order. Nested struct
        # fields are not supported in named form — use positional for those.
        var initialized = 0;
        while (PEEKT(S) != 14) {
            if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
            var fname_off = PEEKV(S);
            STI(S, GTI(S) + 1);
            if (PEEKT(S) != 49) { ERR_EXPECT(S, 49); }
            STI(S, GTI(S) + 1);
            var found = 0 - 1;
            var fi = 0;
            while (fi < fc) {
                if (STREQTOK(S, GETFNAME(S, si, fi), fname_off) == 1) { found = fi; fi = fc; }
                else { fi = fi + 1; }
            }
            if (found < 0) { ERR_MSG(S, "unknown struct field in initializer", 35); }
            var ft = GETFTYPE(S, si, found);
            if (ft > 0) { ERR_MSG(S, "named init not supported for nested struct fields — use positional", 66); }
            var bit = 1 << found;
            if ((initialized & bit) != 0) { ERR_MSG(S, "struct field initialized twice", 30); }
            initialized = initialized | bit;
            var boff = FIELDOFF(S, si, found);
            EMIT_STRUCT_FIELD(S, vcnt, boff);
        }
        # Require every field to be set — no implicit zero defaults (yet).
        var fi2 = 0;
        while (fi2 < fc) {
            if ((initialized & (1 << fi2)) == 0) { ERR_MSG(S, "missing struct field in initializer", 35); }
            fi2 = fi2 + 1;
        }
    } else {
        # Positional init — emit each scalar field in declaration order,
        # flattening nested structs.
        var boff = 0;
        var fi = 0;
        while (fi < fc) {
            var ft = GETFTYPE(S, si, fi);
            if (ft > 0) {
                var ifc = GETFCOUNT(S, ft - 1);
                var ifi = 0;
                while (ifi < ifc) {
                    EMIT_STRUCT_FIELD(S, vcnt, boff);
                    boff = boff + 8;
                    ifi = ifi + 1;
                }
            } else {
                EMIT_STRUCT_FIELD(S, vcnt, boff);
                boff = boff + 8;
            }
            fi = fi + 1;
        }
    }
    if (PEEKT(S) != 14) { ERR_EXPECT(S, 14); }
    STI(S, GTI(S) + 1);
    SLVAR(S, vcnt);
    SVCNT(S, vcnt + 1);
    if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); }
    STI(S, GTI(S) + 1);
    return 0;
}

fn PARSE_GVAR_ARR(S, noff) {
    STI(S, GTI(S) + 1);
    if (PEEKT(S) != 1) { ERR_EXPECT(S, 1); }
    var sz = PEEKV(S) * 8;
    if (sz < 8) { sz = 8; }
    STI(S, GTI(S) + 1);
    if (PEEKT(S) != 29) { ERR_EXPECT(S, 29); }
    STI(S, GTI(S) + 1);
    if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); }
    STI(S, GTI(S) + 1);
    var vc = GVCNT(S);
    S64(S + 0x11A000 + vc * 8, noff);
    S64(S + 0x12A000 + vc * 8, sz);
    SLVAR(S, vc);
    SVCNT(S, vc + 1);
    return 0;
}

# Register a global var in declaration zone (no codegen, deferred init)
fn PARSE_GVAR_REG(S) {
    var sti = GTI(S);
    STI(S, GTI(S) + 1);  # consume VAR
    if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
    var noff = PEEKV(S);
    STI(S, GTI(S) + 1);
    # Optional type annotation — check scalar types, pointer types, or struct names
    var psc = 0;
    var ann_sid = 0;
    var ann_scalar = 0;
    if (PEEKT(S) == 49) {
        STI(S, GTI(S) + 1);
        if (PEEKT(S) == 8) { STI(S, GTI(S) + 1); psc = 8; STI(S, GTI(S) + 1); SKIP_GENERICS(S); }
        elif (PEEKT(S) == 105) { ann_scalar = 16; STI(S, GTI(S) + 1); }
        else {
            if (PEEKT(S) == 2) {
                var ann_sn = PEEKV(S);
                var ann_tn = L64(S + 0x60000 + ann_sn);
                if (ann_tn & 0xFFFF == 0x3869) { ann_scalar = 1; }
                elif (ann_tn & 0xFFFFFF == 0x363169) { ann_scalar = 2; }
                elif (ann_tn & 0xFFFFFF == 0x323369) { ann_scalar = 4; }
                elif (ann_tn & 0xFFFFFF == 0x343669) { ann_scalar = 8; }
                elif (ann_tn & 0xFFFFFFFF == 0x38323175) { ann_scalar = 16; }
                else { ann_sid = FINDSTRUCT(S, ann_sn); }
            }
            STI(S, GTI(S) + 1); SKIP_GENERICS(S);
        }
    }
    # Array: register with size, no deferred init
    if (PEEKT(S) == 28) {
        PARSE_GVAR_ARR(S, noff);
        return 0;
    }
    # Check for struct init after =: var p = StructName { ... }
    # Peek ahead: skip to = then check if next is IDENT matching a struct
    var save_peek = GTI(S);
    # We're past the type annotation, at = or the token before it
    # Find the = sign
    var pgo = 1;
    while (pgo == 1) {
        if (PEEKT(S) == 4) { pgo = 0; }
        else { if (PEEKT(S) == 5) { pgo = 0; }
        else { if (PEEKT(S) == 12) { pgo = 0; }
        else { STI(S, GTI(S) + 1); } } }
    }
    var is_struct = 0;
    var ssid = 0;
    if (PEEKT(S) == 4) {
        STI(S, GTI(S) + 1);
        if (PEEKT(S) == 2) {
            var sn = PEEKV(S);
            ssid = FINDSTRUCT(S, sn);
            if (ssid > 0) { is_struct = 1; }
        }
    }
    STI(S, save_peek);  # restore
    # Register
    var vcnt = GVCNT(S);
    S64(S + 0x11A000 + vcnt * 8, noff);
    if (is_struct == 1) {
        S64(S + 0x12A000 + vcnt * 8, STRUCTSZ(S, ssid - 1));
        SVTYPE(S, vcnt, ssid);
    } else {
        if (ann_scalar > 0) {
            if (ann_scalar < 8) {
                S64(S + 0x12A000 + vcnt * 8, ann_scalar);
                SVTYPE(S, vcnt, ann_scalar);
            } else {
                # 8 (i64) or 16 (u128) — allocate the full width.
                # No type marker for now: u128 bytes live in the slot,
                # scalar ops touch the low 64 bits until alpha3 lands
                # proper arithmetic.
                S64(S + 0x12A000 + vcnt * 8, ann_scalar);
            }
        } else {
            S64(S + 0x12A000 + vcnt * 8, 8);
            if (ann_sid > 0) { SVTYPE(S, vcnt, ann_sid); }
            elif (psc > 0) { SVTYPE(S, vcnt, 0 - psc); }
        }
    }
    SVCNT(S, vcnt + 1);
    # Save token index for deferred init
    var gc = L64(S + 0x9A000);
    if (gc >= 1024) {
        ERR_MSG(S, "too many initialized globals (max 1024)", 39);
    }
    S64(S + 0x98000 + gc * 8, sti);
    S64(S + 0x9A000, gc + 1);
    # Skip to semicolon
    var skg = 1;
    while (skg == 1) {
        if (PEEKT(S) == 5) { STI(S, GTI(S) + 1); skg = 0; }
        else { if (PEEKT(S) == 12) { skg = 0; }
        else { STI(S, GTI(S) + 1); } }
    }
    return 0;
}

# Emit deferred global var inits (replays saved token positions)
fn EMIT_GVAR_INITS(S) {
    var gc = L64(S + 0x9A000);
    var gi = 0;
    while (gi < gc) {
        var sti = L64(S + 0x98000 + gi * 8);
        STI(S, sti);
        STI(S, GTI(S) + 1);  # consume VAR
        var noff = PEEKV(S);
        STI(S, GTI(S) + 1);  # consume IDENT
        if (PEEKT(S) == 49) { STI(S, GTI(S) + 1); if (PEEKT(S) == 8) { STI(S, GTI(S) + 1); } STI(S, GTI(S) + 1); SKIP_GENERICS(S); }
        if (PEEKT(S) != 4) { ERR_EXPECT(S, 4); }
        STI(S, GTI(S) + 1);  # consume =
        # Check for struct init: StructName { ... }
        var idx = FINDVAR(S, noff);
        var did_struct = 0;
        if (PEEKT(S) == 2) {
            var sn = PEEKV(S);
            var sid = FINDSTRUCT(S, sn);
            if (sid > 0) {
                STI(S, GTI(S) + 1);
                if (PEEKT(S) != 13) { ERR_EXPECT(S, 13); }
                STI(S, GTI(S) + 1);
                var fc = GETFCOUNT(S, sid - 1);
                var boff = 0;
                var fii = 0;
                while (fii < fc) {
                    var fft = GETFTYPE(S, sid - 1, fii);
                    if (fft > 0) {
                        var ifc = GETFCOUNT(S, fft - 1);
                        var ifi = 0;
                        while (ifi < ifc) {
                            EMIT_STRUCT_FIELD(S, idx, boff);
                            boff = boff + 8;
                            ifi = ifi + 1;
                        }
                    } else {
                        EMIT_STRUCT_FIELD(S, idx, boff);
                        boff = boff + 8;
                    }
                    fii = fii + 1;
                }
                if (PEEKT(S) != 14) { ERR_EXPECT(S, 14); }
                STI(S, GTI(S) + 1);
                SLVAR(S, idx);
                if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); }
                STI(S, GTI(S) + 1);
                did_struct = 1;
            }
        }
        if (did_struct == 0) {
            PCMPE(S);
            if (idx >= 0) { EVSTORE(S, idx); SLVAR(S, idx); }
            if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); }
            STI(S, GTI(S) + 1);
        }
        gi = gi + 1;
    }
    return 0;
}

# Parse: var IDENT = expr ;
fn PARSE_VAR(S) {
    STI(S, GTI(S) + 1);  # consume VAR
    # expect IDENT
    if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
    var noff = PEEKV(S);
    STI(S, GTI(S) + 1);
    # Multi-var destructure: var x, y = fn()
    if (PEEKT(S) == 31) {
        STI(S, GTI(S) + 1);  # consume ,
        if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
        var noff2 = PEEKV(S);
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 4) { ERR_EXPECT(S, 4); }
        STI(S, GTI(S) + 1);  # consume =
        PCMPE(S);
        # rax = first value, rdx = second value (from ret2/return (a,b))
        if (GINFN(S) == 1) {
            # Register first local
            var li1 = GFLC(S);
            S64(S + 0x91000 + li1 * 8, noff);
            SLDEP(S, li1, GSDEP(S));
            SLTYPE(S, li1, 0);
            EFLSTORE(S, li1);
            SFLC(S, li1 + 1);
            # mov rax, rdx (get second return value)
            EMOVRA_RDX(S);
            # Register second local
            var li2 = GFLC(S);
            S64(S + 0x91000 + li2 * 8, noff2);
            SLDEP(S, li2, GSDEP(S));
            SLTYPE(S, li2, 0);
            EFLSTORE(S, li2);
            SFLC(S, li2 + 1);
        } else {
            ERR_MSG(S, "multi-var destructure only supported inside functions", 52);
        }
        if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); }
        STI(S, GTI(S) + 1);
        return 0;
    }
    # Optional type annotation: var x: type = ... or var x: *type = ...
    var pscale = 0;
    var scalar_type = 0;
    if (PEEKT(S) == 49) {
        STI(S, GTI(S) + 1);  # consume :
        if (PEEKT(S) == 8) {
            # Pointer type: *i64, *i32, *i16, *i8
            STI(S, GTI(S) + 1);  # consume *
            var tnoff = PEEKV(S);
            var tname = L64(S + 0x60000 + tnoff);
            if (tname & 0xFFFFFF == 0x343669) { pscale = 8; }
            if (tname & 0xFFFFFF == 0x323369) { pscale = 4; }
            if (tname & 0xFFFFFF == 0x363169) { pscale = 2; }
            if (tname & 0xFFFF == 0x3869) { pscale = 1; }
            if (pscale == 0) { pscale = 8; }
            STI(S, GTI(S) + 1);
            SKIP_GENERICS(S);
        } elif (PEEKT(S) == 105) {
            # u128 type
            scalar_type = 16;
            STI(S, GTI(S) + 1);
        } else {
            if (PEEKT(S) == 2) {
                var lann = PEEKV(S);
                # Check scalar types: i8, i16, i32, i64
                var ltname = L64(S + 0x60000 + lann);
                if (ltname & 0xFFFF == 0x3869) { scalar_type = 1; }
                elif (ltname & 0xFFFFFF == 0x363169) { scalar_type = 2; }
                elif (ltname & 0xFFFFFF == 0x323369) { scalar_type = 4; }
                elif (ltname & 0xFFFFFF == 0x343669) { scalar_type = 8; }
                else {
                    var lsid = FINDSTRUCT(S, lann);
                    if (lsid > 0) { pscale = 0 - lsid; }
                }
            }
            STI(S, GTI(S) + 1);
            SKIP_GENERICS(S);
        }
    }
    # Check for array: var buf[N];
    if (PEEKT(S) == 28) {
        PARSE_ARRAY(S, noff);
        return 0;
    }
    # expect EQ
    if (PEEKT(S) != 4) { ERR_EXPECT(S, 4); }
    STI(S, GTI(S) + 1);
    # Check for struct init: var p = StructName { expr, expr, ... };
    if (PEEKT(S) == 2) {
        var sn = PEEKV(S);
        var sid = FINDSTRUCT(S, sn);
        if (sid > 0) {
            PARSE_STRUCT_INIT(S, noff, sid);
            return 0;
        }
    }
    # parse expression (scalar) — use PCMPE for comparisons and &&/||
    PCMPE(S);
    # Type check: warn if pointer/scalar mismatch
    var expr_ps = GPSC(S);
    if (pscale > 0) {
        if (expr_ps == 0) { WARN(S, "assigning non-pointer to typed pointer", 38); }
    }
    # Check if inside function → local variable
    if (GINFN(S) == 1) {
        # Reject duplicate local var names
        # Allow same name in different scope (shadowing)
        var existing = FINDLOCAL(S, noff);
        if (existing >= 0) {
            if (GLDEP(S, existing) == GSDEP(S)) { ERRDUPVAR(S); }
        }
        var li = GFLC(S);
        S64(S + 0x91000 + li * 8, noff);
        SLDEP(S, li, GSDEP(S));
        if (scalar_type > 0) {
            if (scalar_type < 8) {
                SLTYPE(S, li, scalar_type);
                EFLSTORE_W(S, li, scalar_type);
            } else {
                SLTYPE(S, li, 0);
                EFLSTORE(S, li);
            }
        } else {
            SLTYPE(S, li, pscale);
            EFLSTORE(S, li);
        }
        SFLC(S, li + 1);
    } else {
        var vcnt = GVCNT(S);
        S64(S + 0x11A000 + vcnt * 8, noff);
        if (scalar_type > 0) {
            if (scalar_type < 8) {
                S64(S + 0x12A000 + vcnt * 8, scalar_type);
                SVTYPE(S, vcnt, scalar_type);
                EVSTORE_W(S, vcnt, scalar_type);
            } else {
                # 8 (i64 explicit) or 16 (u128) — allocate the full width.
                # Pre-4.8.0-alpha3 this hardcoded 8, truncating u128 vars
                # declared in the PARSE_PROG path (e.g. after a top-level
                # expression statement like `alloc_init();` that stops
                # pass 1 — see main.cyr's pass-1 loop termination).
                S64(S + 0x12A000 + vcnt * 8, scalar_type);
                EVSTORE(S, vcnt);
            }
        } else {
            S64(S + 0x12A000 + vcnt * 8, 8);
            if (pscale > 0) { SVTYPE(S, vcnt, 0 - pscale); }
            EVSTORE(S, vcnt);
        }
        SLVAR(S, vcnt);
        SVCNT(S, vcnt + 1);
    }
    if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); }
    STI(S, GTI(S) + 1);
    return 0;
}

# Parse: IDENT = expr ;
fn PARSE_ASSIGN(S) {
    var noff = PEEKV(S);
    STI(S, GTI(S) + 1);
    if (PEEKT(S) != 4) { ERR_EXPECT(S, 4); }
    STI(S, GTI(S) + 1);
    PCMPE(S);
    var idx = FINDVAR(S, noff);
    if (idx < 0) {
        syscall(SYS_WRITE, 2, "error:", 6); FM_LOOKUP(S, GTLINE(S, GTI(S))); syscall(SYS_WRITE, 2, ": undefined variable '", 22);
        PRSTR(S + 0x60000 + noff); syscall(SYS_WRITE, 2, "'\n", 2); syscall(SYS_EXIT, 1);
    }
    EVSTORE(S, idx);
    SLVAR(S, idx);
    if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); }
    STI(S, GTI(S) + 1);
    return 0;
}

# Emit inverted jcc for comparison op, return patch offset
fn ECONDOP(S, op) {
    if (op == 17) { return EJCC(S, 0x85); }
    if (op == 18) { return EJCC(S, 0x84); }
    if (op == 19) { return EJCC(S, 0x8D); }
    if (op == 20) { return EJCC(S, 0x8E); }
    if (op == 21) { return EJCC(S, 0x8F); }
    if (op == 22) { return EJCC(S, 0x8C); }
    ERR(S);
    return 0;
}

# Emit NON-inverted jcc (for || true-branch)
fn ECONDOPT(S, op) {
    if (op == 17) { return EJCC(S, 0x84); }
    if (op == 18) { return EJCC(S, 0x85); }
    if (op == 19) { return EJCC(S, 0x8C); }
    if (op == 20) { return EJCC(S, 0x8D); }
    if (op == 21) { return EJCC(S, 0x8E); }
    if (op == 22) { return EJCC(S, 0x8F); }
    ERR(S);
    return 0;
}

# Parse one comparison: expr OP expr — emit cmp, return op token
fn ECONDCMP(S) {
    PCMPE(S);
    var op = PEEKT(S);
    # If no comparison operator follows, treat value as boolean (cmp rax, 0)
    if (op < 17 || op > 22) {
        EPUSHR(S);
        EMOVI(S, 0);
        EMOVCA(S);
        EPOPR(S);
        ECMPR(S);
        return 18;
    }
    EPUSHR(S);
    STI(S, GTI(S) + 1);
    PCMPE(S);
    EMOVCA(S);
    EPOPR(S);
    ECMPR(S);
    return op;
}

# Parse condition: expr OP expr [&& expr OP expr]* [|| expr OP expr]*
# Returns patch offset for false branch. Extra patches stored via ADDXP.
fn ECOND(S) {
    SXPC(S, 0);
    var op = ECONDCMP(S);
    # Check for && or ||
    if (PEEKT(S) == 53) {
        return ECOND_AND(S, op);
    }
    if (PEEKT(S) == 54) {
        return ECOND_OR(S, op);
    }
    return ECONDOP(S, op);
}

fn ECOND_AND(S, op) {
    var p1 = ECONDOP(S, op);
    ADDXP(S, p1);
    STI(S, GTI(S) + 1);
    var op2 = ECONDCMP(S);
    # Chain: support a && b && c
    if (PEEKT(S) == 53) {
        return ECOND_AND(S, op2);
    }
    return ECONDOP(S, op2);
}

fn ECOND_OR(S, op) {
    var ptrue = ECONDOPT(S, op);
    STI(S, GTI(S) + 1);
    var op2 = ECONDCMP(S);
    # Chain: support a || b || c
    if (PEEKT(S) == 54) {
        EPATCH(S, ptrue);
        return ECOND_OR(S, op2);
    }
    var pfalse = ECONDOP(S, op2);
    EPATCH(S, ptrue);
    return pfalse;
}

# Patch all extra condition patches (from &&) to current position
fn PATCHXP(S) {
    var xc = GXPC(S);
    var xi = 0;
    while (xi < xc) {
        EPATCH(S, L64(S + 0x8F848 + xi * 8));
        xi = xi + 1;
    }
    SXPC(S, 0);
    return 0;
}

# Parse: if (cond) { stmts } [else { stmts }]
# Parse elif chain as recursive: each elif is essentially else { if (...) { } ... }
fn PARSE_ELIF(S, cond_patch) {
    # Emit jmp-to-end for previous branch
    var skip = EJMP0(S);
    # Patch previous condition-false to land here (+ any && extras)
    PATCHXP(S);
    EPATCH(S, cond_patch);
    # Parse new condition
    if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); }
    STI(S, GTI(S) + 1);
    var patch = ECOND(S);
    if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); }
    STI(S, GTI(S) + 1);
    if (PEEKT(S) != 13) { ERR_EXPECT(S, 13); }
    STI(S, GTI(S) + 1);
    PARSE_PROG(S);
    if (PEEKT(S) != 14) { ERR_EXPECT(S, 14); }
    STI(S, GTI(S) + 1);
    # Check for more elif/else
    if (PEEKT(S) == 50) {
        STI(S, GTI(S) + 1);
        PARSE_ELIF(S, patch);
    } else { if (PEEKT(S) == 23) {
        STI(S, GTI(S) + 1);
        var skip2 = EJMP0(S);
        PATCHXP(S);
        EPATCH(S, patch);
        if (PEEKT(S) != 13) { ERR_EXPECT(S, 13); }
        STI(S, GTI(S) + 1);
        PARSE_PROG(S);
        if (PEEKT(S) != 14) { ERR_EXPECT(S, 14); }
        STI(S, GTI(S) + 1);
        EPATCH(S, skip2);
    } else {
        PATCHXP(S);
        EPATCH(S, patch);
    } }
    # Patch our skip-to-end
    EPATCH(S, skip);
    return 0;
}

fn PARSE_IF(S) {
    STI(S, GTI(S) + 1);  # consume IF
    var saved_lv = GLVAR(S);
    if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); }
    STI(S, GTI(S) + 1);  # consume (
    var patch = ECOND(S);
    if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); }
    STI(S, GTI(S) + 1);  # consume )
    if (PEEKT(S) != 13) { ERR_EXPECT(S, 13); }
    STI(S, GTI(S) + 1);  # consume {
    SCOPE_PUSH(S);
    PARSE_PROG(S);
    SCOPE_POP(S);
    if (PEEKT(S) != 14) { ERR_EXPECT(S, 14); }
    STI(S, GTI(S) + 1);  # consume }
    if (PEEKT(S) == 50) {
        # elif
        STI(S, GTI(S) + 1);
        PARSE_ELIF(S, patch);
    } else { if (PEEKT(S) == 23) {
        # else
        STI(S, GTI(S) + 1);
        var skip = EJMP0(S);
        PATCHXP(S);
        EPATCH(S, patch);
        if (PEEKT(S) != 13) { ERR_EXPECT(S, 13); }
        STI(S, GTI(S) + 1);
        SCOPE_PUSH(S);
        PARSE_PROG(S);
        SCOPE_POP(S);
        if (PEEKT(S) != 14) { ERR_EXPECT(S, 14); }
        STI(S, GTI(S) + 1);
        EPATCH(S, skip);
    } else {
        PATCHXP(S);
        EPATCH(S, patch);
    } }
    SLVAR(S, saved_lv);
    return 0;
}

# Parse: while (cond) { stmts }
fn PARSE_WHILE(S) {
    STI(S, GTI(S) + 1);  # consume WHILE
    var saved_lv = GLVAR(S);
    # Save and set loop context for break/continue
    var saved_ltop = L64(S + 0x8F838);
    var saved_brk = L64(S + 0x8F840);
    var loop_top = GCP(S);
    S64(S + 0x8F838, loop_top);
    S64(S + 0x8F840, 0);
    if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); }
    STI(S, GTI(S) + 1);
    var patch = ECOND(S);
    if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); }
    STI(S, GTI(S) + 1);
    if (PEEKT(S) != 13) { ERR_EXPECT(S, 13); }
    STI(S, GTI(S) + 1);
    SCOPE_PUSH(S);
    PARSE_PROG(S);
    SCOPE_POP(S);
    if (PEEKT(S) != 14) { ERR_EXPECT(S, 14); }
    STI(S, GTI(S) + 1);
    EJMP(S, loop_top);
    PATCHXP(S);
    EPATCH(S, patch);
    # Patch all break jumps (linked list through codebuf rel32 fields)
    var brk_patch = L64(S + 0x8F840);
    while (brk_patch > 0) {
        var _ba = S + 0x54A000 + brk_patch;
        var _nb = L64(_ba) & 0xFFFFFFFF;
        EPATCH(S, brk_patch);
        brk_patch = _nb;
    }
    S64(S + 0x8F838, saved_ltop);
    S64(S + 0x8F840, saved_brk);
    SLVAR(S, saved_lv);
    return 0;
}

fn PARSE_FOR(S) {
    STI(S, GTI(S) + 1);
    var slv = GLVAR(S);
    SCOPE_PUSH(S);
    # Check for "for ident in start..end { }" syntax
    if (PEEKT(S) == 2) {
        var fiti = GTI(S);
        STI(S, GTI(S) + 1);
        if (PEEKT(S) == 76) {
            var finoff = TOKVAL(S, fiti);
            STI(S, GTI(S) + 1);
            PCMPE(S);
            # Check: range (..) or collection?
            var is_range = 0;
            if (PEEKT(S) == 41) {
                var dot_ti = GTI(S);
                STI(S, GTI(S) + 1);
                if (PEEKT(S) == 41) {
                    STI(S, GTI(S) + 1);
                    is_range = 1;
                } else {
                    STI(S, dot_ti);
                }
            }
            if (is_range == 0) {
                # COLLECTION for-in: for item in expr { body }
                # rax has the collection (vec pointer)
                # Store collection in hidden var
                var ficol = GVCNT(S);
                S64(S + 0x11A000 + ficol * 8, 0);
                S64(S + 0x12A000 + ficol * 8, 8);
                SVCNT(S, ficol + 1);
                EVSTORE(S, ficol);
                # Get length: call vec_len(collection)
                EVLOAD(S, ficol);
                EPUSHR(S);
                ECALLPOPS(S, 1);
                var vlfi = FINDFN(S, 0);
                # Find vec_len — search by building name
                NPOS_GUARD(S, 16);
                var vlnp = GNPOS(S);
                store8(S + 0x60000 + vlnp, 118); store8(S + 0x60000 + vlnp + 1, 101);
                store8(S + 0x60000 + vlnp + 2, 99); store8(S + 0x60000 + vlnp + 3, 95);
                store8(S + 0x60000 + vlnp + 4, 108); store8(S + 0x60000 + vlnp + 5, 101);
                store8(S + 0x60000 + vlnp + 6, 110); store8(S + 0x60000 + vlnp + 7, 0);
                SNPOS(S, vlnp + 8);
                vlfi = FINDFN(S, vlnp);
                if (vlfi < 0) { vlfi = REGFN(S, vlnp); }
                var vloff = L64(S + 0xE92000 + vlfi * 8);
                if (vloff >= 0) { ECALLTO(S, vloff); } else { ECALLFIX(S, vlfi); }
                ECALLCLEAN(S, 1);
                # Store length in hidden var
                var filen = GVCNT(S);
                S64(S + 0x11A000 + filen * 8, 0);
                S64(S + 0x12A000 + filen * 8, 8);
                SVCNT(S, filen + 1);
                EVSTORE(S, filen);
                # Index var (starts at 0)
                var fili = GFLC(S);
                NPOS_GUARD(S, 8);
                var fiidx_noff = GNPOS(S);
                store8(S + 0x60000 + fiidx_noff, 95); store8(S + 0x60000 + fiidx_noff + 1, 105);
                store8(S + 0x60000 + fiidx_noff + 2, 0);
                SNPOS(S, fiidx_noff + 3);
                S64(S + 0x91000 + fili * 8, fiidx_noff);
                SLDEP(S, fili, GSDEP(S));
                SLTYPE(S, fili, 0);
                EMOVI(S, 0);
                EFLSTORE(S, fili);
                SFLC(S, fili + 1);
                # Item var
                var fiitem = GFLC(S);
                S64(S + 0x91000 + fiitem * 8, finoff);
                SLDEP(S, fiitem, GSDEP(S));
                SLTYPE(S, fiitem, 0);
                EMOVI(S, 0);
                EFLSTORE(S, fiitem);
                SFLC(S, fiitem + 1);
                # Loop: while (idx < len)
                var fislt = L64(S + 0x8F838);
                var fisbk = L64(S + 0x8F840);
                var fiscfw = L64(S + 0x8F898);
                var fitop = GCP(S);
                S64(S + 0x8F838, fitop);
                S64(S + 0x8F840, 0);
                S64(S + 0x8F898, 1);
                EFLLOAD(S, fili);
                EPUSHR(S);
                EVLOAD(S, filen);
                EMOVCA(S);
                EPOPR(S);
                ECMPR(S);
                var ficond = EJCC(S, 0x8D);
                # item = vec_get(collection, idx)
                EVLOAD(S, ficol);
                EPUSHR(S);
                EFLLOAD(S, fili);
                EPUSHR(S);
                ECALLPOPS(S, 2);
                var vgfi = FINDFN(S, 0);
                NPOS_GUARD(S, 16);
                var vgnp = GNPOS(S);
                store8(S + 0x60000 + vgnp, 118); store8(S + 0x60000 + vgnp + 1, 101);
                store8(S + 0x60000 + vgnp + 2, 99); store8(S + 0x60000 + vgnp + 3, 95);
                store8(S + 0x60000 + vgnp + 4, 103); store8(S + 0x60000 + vgnp + 5, 101);
                store8(S + 0x60000 + vgnp + 6, 116); store8(S + 0x60000 + vgnp + 7, 0);
                SNPOS(S, vgnp + 8);
                vgfi = FINDFN(S, vgnp);
                if (vgfi < 0) { vgfi = REGFN(S, vgnp); }
                var vgoff = L64(S + 0xE92000 + vgfi * 8);
                if (vgoff >= 0) { ECALLTO(S, vgoff); } else { ECALLFIX(S, vgfi); }
                ECALLCLEAN(S, 2);
                EFLSTORE(S, fiitem);
                # Body
                if (PEEKT(S) != 13) { ERR_EXPECT(S, 13); } STI(S, GTI(S) + 1);
                SCOPE_PUSH(S);
                PARSE_PROG(S);
                SCOPE_POP(S);
                if (PEEKT(S) != 14) { ERR_EXPECT(S, 14); } STI(S, GTI(S) + 1);
                # Patch continue to here (before step)
                var ficfwn = L64(S + 0x8F898) - 1;
                var ficfwi = 0;
                while (ficfwi < ficfwn) { EPATCH(S, L64(S + 0x8F8A0 + ficfwi * 8)); ficfwi = ficfwi + 1; }
                S64(S + 0x8F898, 0);
                # Step: idx = idx + 1
                EFLLOAD(S, fili);
                EPUSHR(S);
                EMOVI(S, 1);
                EMOVCA(S);
                EPOPR(S);
                EADDR(S);
                EFLSTORE(S, fili);
                EJMP(S, fitop);
                PATCHXP(S);
                EPATCH(S, ficond);
                var fibrk = L64(S + 0x8F840);
                while (fibrk > 0) { var _fba = S + 0x54A000 + fibrk; var _fnb = L64(_fba) & 0xFFFFFFFF; EPATCH(S, fibrk); fibrk = _fnb; }
                S64(S + 0x8F838, fislt);
                S64(S + 0x8F840, fisbk);
                S64(S + 0x8F898, fiscfw);
                SCOPE_POP(S);
                SLVAR(S, slv);
                return 0;
            }
            # RANGE for-in (.. already consumed, is_range==1)
            # rax has start value from PEXPR above
            var fili = GFLC(S);
            S64(S + 0x91000 + fili * 8, finoff);
            SLDEP(S, fili, GSDEP(S));
            SLTYPE(S, fili, 0);
            EFLSTORE(S, fili);
            SFLC(S, fili + 1);
            # End value into hidden global
            PCMPE(S);
            var fiend = GVCNT(S);
            S64(S + 0x11A000 + fiend * 8, 0);
            S64(S + 0x12A000 + fiend * 8, 8);
            SVCNT(S, fiend + 1);
            EVSTORE(S, fiend);
            # Loop setup
            var fislt = L64(S + 0x8F838);
            var fisbk = L64(S + 0x8F840);
            var fiscfw = L64(S + 0x8F898);
            var fitop = GCP(S);
            S64(S + 0x8F838, fitop);
            S64(S + 0x8F840, 0);
            S64(S + 0x8F898, 1);
            # Condition: var < end
            EFLLOAD(S, fili);
            EPUSHR(S);
            EVLOAD(S, fiend);
            EMOVCA(S);
            EPOPR(S);
            ECMPR(S);
            var ficond = EJCC(S, 0x8D);
            # Body
            if (PEEKT(S) != 13) { ERR_EXPECT(S, 13); } STI(S, GTI(S) + 1);
            SCOPE_PUSH(S);
            PARSE_PROG(S);
            SCOPE_POP(S);
            if (PEEKT(S) != 14) { ERR_EXPECT(S, 14); } STI(S, GTI(S) + 1);
            # Patch all continues to here (before step)
            var ficfwn = L64(S + 0x8F898) - 1;
            var ficfwi = 0;
            while (ficfwi < ficfwn) { EPATCH(S, L64(S + 0x8F8A0 + ficfwi * 8)); ficfwi = ficfwi + 1; }
            S64(S + 0x8F898, 0);
            # Step: var = var + 1
            EFLLOAD(S, fili);
            EPUSHR(S);
            EMOVI(S, 1);
            EMOVCA(S);
            EPOPR(S);
            EADDR(S);
            EFLSTORE(S, fili);
            EJMP(S, fitop);
            PATCHXP(S);
            EPATCH(S, ficond);
            var fibrk = L64(S + 0x8F840);
            while (fibrk > 0) { var _fba = S + 0x54A000 + fibrk; var _fnb = L64(_fba) & 0xFFFFFFFF; EPATCH(S, fibrk); fibrk = _fnb; }
            S64(S + 0x8F838, fislt);
            S64(S + 0x8F840, fisbk);
            S64(S + 0x8F898, fiscfw);
            SCOPE_POP(S);
            SLVAR(S, slv);
            return 0;
        }
        STI(S, fiti);
    }
    if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); }
    STI(S, GTI(S) + 1);
    PARSE_STMT(S);
    var slt = L64(S + 0x8F838);
    var sbk = L64(S + 0x8F840);
    var scfw = L64(S + 0x8F898);
    var ltop = GCP(S);
    S64(S + 0x8F838, ltop);
    S64(S + 0x8F840, 0);
    S64(S + 0x8F898, 1);
    var cpat = ECOND(S);
    if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); }
    STI(S, GTI(S) + 1);
    var sst = GTI(S);
    var dep = 0;
    var skg = 1;
    while (skg == 1) {
        var tok = PEEKT(S);
        if (tok == 10) { dep = dep + 1; STI(S, GTI(S) + 1); }
        else { if (tok == 11) {
            if (dep == 0) { skg = 0; }
            else { dep = dep - 1; STI(S, GTI(S) + 1); }
        }
        else { STI(S, GTI(S) + 1); } }
    }
    STI(S, GTI(S) + 1);
    if (PEEKT(S) != 13) { ERR_EXPECT(S, 13); }
    STI(S, GTI(S) + 1);
    PARSE_PROG(S);
    if (PEEKT(S) != 14) { ERR_EXPECT(S, 14); }
    STI(S, GTI(S) + 1);
    # Patch continue forward jump to here (step expression)
    var cfwn = L64(S + 0x8F898) - 1;
    var cfwi = 0;
    while (cfwi < cfwn) { EPATCH(S, L64(S + 0x8F8A0 + cfwi * 8)); cfwi = cfwi + 1; }
    S64(S + 0x8F898, 0);
    # Emit step: replay as assignment or compound assignment
    var sti = GTI(S);
    STI(S, sst);
    var noff = PEEKV(S);
    STI(S, GTI(S) + 1);
    # Check for compound assignment in step (+=, -=, etc.)
    var step_cop = 0;
    var step_ct = PEEKT(S);
    if (step_ct == 6 || step_ct == 7 || step_ct == 8 || step_ct == 9 || step_ct == 34) {
        var step_next = GTI(S) + 1;
        if (step_next < GTCNT(S)) {
            if (TOKTYP(S, step_next) == 4) {
                step_cop = step_ct;
                STI(S, GTI(S) + 2);
            }
        }
    }
    if (step_cop == 0) {
        if (PEEKT(S) != 4) { ERR_EXPECT(S, 4); }
        STI(S, GTI(S) + 1);
    }
    if (step_cop != 0) {
        var step_idx = FINDLOCAL(S, noff);
        if (step_idx >= 0) { EFLLOAD(S, step_idx); }
        else { var step_gi = FINDVAR(S, noff); if (step_gi >= 0) { EVLOAD(S, step_gi); } }
        EPUSHR(S);
        PCMPE(S);
        EMOVCA(S); EPOPR(S);
        if (step_cop == 6) { EADDR(S); }
        elif (step_cop == 7) { ESUBR(S); }
        elif (step_cop == 8) { EIMUL(S); }
        elif (step_cop == 9) { ECQO(S); EIDIV(S); }
        elif (step_cop == 34) { ECQO(S); EIDIV(S); EMOVRA_RDX(S); }
    } else {
        PCMPE(S);
    }
    var idx = 0 - 1;
    if (GINFN(S) == 1) { idx = FINDLOCAL(S, noff); }
    if (idx >= 0) { EFLSTORE(S, idx); }
    else {
        idx = FINDVAR(S, noff);
        if (idx >= 0) { EVSTORE(S, idx); SLVAR(S, idx); }
    }
    STI(S, sti);
    EJMP(S, ltop);
    PATCHXP(S);
    EPATCH(S, cpat);
    var bpat = L64(S + 0x8F840);
    while (bpat > 0) { var _bpa = S + 0x54A000 + bpat; var _bnb = L64(_bpa) & 0xFFFFFFFF; EPATCH(S, bpat); bpat = _bnb; }
    SCOPE_POP(S);
    S64(S + 0x8F838, slt);
    S64(S + 0x8F840, sbk);
    S64(S + 0x8F898, scfw);
    SLVAR(S, slv);
    return 0;
}

# ================================================================
# FUNCTION TABLE + CODEGEN
# ================================================================

# Register new function, return index
fn REGFN(S, noff) {
    var fc = GFNC(S);
    if (fc >= 4096) {
        syscall(SYS_WRITE, 2, "error: function table full (", 28);
        PRNUM(fc);
        syscall(SYS_WRITE, 2, "/4096) — split into separate compilation units\n", 48);
        syscall(SYS_EXIT, 1);
    }
    S64(S + 0xE8A000 + fc * 8, noff);
    S64(S + 0xE92000 + fc * 8, 0 - 1);
    S64(S + 0xE9A000 + fc * 8, 0);
    SFNC(S, fc + 1);
    return fc;
}

# Find function by name, return index or -1
fn FINDFN(S, noff) {
    var fc = GFNC(S);
    var i = 0;
    while (i < fc) {
        var sn = L64(S + 0xE8A000 + i * 8);
        if (STREQ(S, sn, noff) == 1) { return i; }
        i = i + 1;
    }
    # Check use aliases: if noff matches a use_from, look up use_to
    var uc = GUSEC(S);
    i = 0;
    while (i < uc) {
        var ufrom = L64(S + 0x8FFD0 + i * 8);
        if (STREQ(S, ufrom, noff) == 1) {
            var uto = L64(S + 0x901D0 + i * 8);
            return FINDFN(S, uto);
        }
        i = i + 1;
    }
    return 0 - 1;
}

# NOTE: Arch-specific function emit functions (EFNPRO, ESUBRSP, EFNEPI,
# ECALLTO, ECALLFIX, EPOPARG, ECALLPOPS, ECALLCLEAN, EDISP32,
# ESTOREREGPARM, ESTORESTACKPARM, ESTOREPARM, EFLLOAD, EFLSTORE)
# are now in the arch-specific emit files:
#   x86_64:  src/cc/emit.cyr
#   aarch64: src/backend/aarch64/emit.cyr

# Find fn local variable by name
fn FINDLOCAL(S, noff) {
    var lc = GFLC(S);
    var i = lc - 1;
    # Search backward so inner scope shadows outer
    while (i >= 0) {
        var sn = L64(S + 0x91000 + i * 8);
        if (sn >= 0) { if (STREQ(S, sn, noff) == 1) { return i; } }
        i = i - 1;
    }
    return 0 - 1;
}

# ================================================================
# PARSER — STATEMENT DISPATCH + FUNCTION SUPPORT
# ================================================================

# Parse return expr ;  (uses PCMPE so return a == b; works)
# Tail call optimization: return fn(args); → epilogue + jmp fn
fn PARSE_RETURN(S) {
    STI(S, GTI(S) + 1);
    # Check for tail call: return IDENT(args);
    # Pattern: next token is IDENT, followed by LPAREN
    # Disabled inside inline replay (would emit caller's epilogue)
    if (GINFN(S) == 1) { if (GIDEP(S) == 0) {
        if (PEEKT(S) == 2) {
            var ti_after = GTI(S) + 1;
            if (ti_after < GTCNT(S)) {
                if (TOKTYP(S, ti_after) == 10) {
                    # Verify it's actually a tail call: find matching ) and check for ;
                    var tc_scan = ti_after + 1;
                    var tc_depth = 1;
                    var tc_is_tail = 0;
                    while (tc_scan < GTCNT(S)) {
                        if (TOKTYP(S, tc_scan) == 10) { tc_depth = tc_depth + 1; }
                        if (TOKTYP(S, tc_scan) == 11) { tc_depth = tc_depth - 1; if (tc_depth == 0) { break; } }
                        tc_scan = tc_scan + 1;
                    }
                    if (tc_scan + 1 < GTCNT(S)) {
                        if (TOKTYP(S, tc_scan + 1) == 5) { tc_is_tail = 1; }
                    }
                if (tc_is_tail == 1) {
                    # Tail call: return fn(args); → evaluate args, epilogue, jmp fn
                    var tcnoff = PEEKV(S);
                    STI(S, GTI(S) + 1);
                    # Parse args (same as PARSE_FNCALL arg handling)
                    STI(S, GTI(S) + 1);  # consume (
                    var tcargc = 0;
                    if (PEEKT(S) != 11) {
                        var tcgo = 1;
                        while (tcgo == 1) {
                            PCMPE(S);
                            EPUSHR(S);
                            tcargc = tcargc + 1;
                            if (PEEKT(S) == 31) { STI(S, GTI(S) + 1); }
                            else { tcgo = 0; }
                        }
                    }
                    if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); }
                    STI(S, GTI(S) + 1);  # consume )
                    # Pop args into registers
                    ECALLPOPS(S, tcargc);
                    if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); }
                    STI(S, GTI(S) + 1);
                    # Look up function
                    var tcfi = FINDFN(S, tcnoff);
                    if (tcfi < 0) { tcfi = REGFN(S, tcnoff); }
                    if (tcargc > 6) {
                        # >6 args: normal call (stack args clobbered by tail call epilogue)
                        var foff2 = L64(S + 0xE92000 + tcfi * 8);
                        if (foff2 >= 0) { ECALLTO(S, foff2); }
                        else { ECALLFIX(S, tcfi); }
                        ECALLCLEAN(S, tcargc);
                        # Jump to function epilogue (same as normal return)
                        var rp2 = EJMP0(S);
                        var rpc2 = GRPC(S);
                        if (rpc2 >= 64) { ERR_MSG(S, "too many return statements in function (max 64)", 47); }
                        S64(S + 0x8DA20 + rpc2 * 8, rp2);
                        SRPC(S, rpc2 + 1);
                    } else {
                        # Emit epilogue + jmp (tail call, ≤6 args only)
                        ETAILJMP(S, tcfi);
                    }
                    return 0;
                } }
            }
        }
    } }
    # Check for multi-return: return (a, b) → ret2(a, b)
    if (PEEKT(S) == 10) {
        # Scan ahead for comma at depth 1 to distinguish (a, b) from (a + b)
        var mr_scan = GTI(S) + 1;
        var mr_depth = 1;
        var mr_is_tuple = 0;
        while (mr_scan < GTCNT(S) && mr_depth > 0) {
            var mr_tok = TOKTYP(S, mr_scan);
            if (mr_tok == 10) { mr_depth = mr_depth + 1; }
            if (mr_tok == 11) { mr_depth = mr_depth - 1; }
            if (mr_tok == 31 && mr_depth == 1) { mr_is_tuple = 1; break; }
            mr_scan = mr_scan + 1;
        }
        if (mr_is_tuple == 1) {
            # Multi-return: return (a, b) → same codegen as ret2(a, b)
            STI(S, GTI(S) + 1);  # consume (
            PCMPE(S);
            EPUSHR(S);
            if (PEEKT(S) != 31) { ERR_EXPECT(S, 31); } STI(S, GTI(S) + 1);  # consume ,
            PCMPE(S);
            # rax = b, stack = a → mov rdx, rax; pop rax
            EMOVRDXRAX(S);
            EPOPR(S);
            if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); } STI(S, GTI(S) + 1);  # consume )
            if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); } STI(S, GTI(S) + 1);  # consume ;
            var rp = EJMP0(S);
            var rpc = GRPC(S);
            if (rpc >= 64) { ERR_MSG(S, "too many return statements in function (max 64)", 47); }
            S64(S + 0x8DA20 + rpc * 8, rp);
            SRPC(S, rpc + 1);
            return 0;
        }
    }
    PCMPE(S);
    if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); }
    STI(S, GTI(S) + 1);
    # Emit jmp to epilogue (record as return patch)
    var rp = EJMP0(S);
    var rpc = GRPC(S);
    if (rpc >= 64) { ERR_MSG(S, "too many return statements in function (max 64)", 47); }
    S64(S + 0x8DA20 + rpc * 8, rp);
    SRPC(S, rpc + 1);
    return 0;
}

# Parse fn call args and emit call (as expression)
fn PARSE_FNCALL(S, noff) {
    STI(S, GTI(S) + 1);  # consume (
    # Check for inline candidate
    var fi = FINDFN(S, noff);
    if (fi < 0) { fi = REGFN(S, noff); }
    if (GFINL(S, fi) != 0) { if (GIDEP(S) < 3) { if (GINFN(S) == 1) {
        # INLINE PATH: replay function body tokens at call site
        var pc = L64(S + 0xE9A000 + fi * 8);
        var saved_flc = GFLC(S);
        # Allocate fresh frame slots for callee params
        var p0_slot = saved_flc;
        var p1_slot = saved_flc + 1;
        # Evaluate args and store to param slots
        var iargc = 0;
        if (PEEKT(S) != 11) {
            var iago = 1;
            while (iago == 1) {
                PCMPE(S);
                if (iargc == 0) { EFLSTORE(S, p0_slot); }
                if (iargc == 1) { EFLSTORE(S, p1_slot); }
                iargc = iargc + 1;
                if (PEEKT(S) == 31) { STI(S, GTI(S) + 1); }
                else { iago = 0; }
            }
        }
        if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); }
        STI(S, GTI(S) + 1);
        # Set local count past the param slots
        SFLC(S, saved_flc + pc);
        # Register callee param names as temporary locals (packed in fn_inline)
        var inl_packed = GFINL(S, fi);
        var pn0 = inl_packed & 0xFFFFFFFF;
        var pn1 = (inl_packed >> 32) & 0xFFFFFFFF;
        if (pc >= 1) { S64(S + 0x91000 + p0_slot * 8, pn0); SLDEP(S, p0_slot, GSDEP(S)); }
        if (pc >= 2) { S64(S + 0x91000 + p1_slot * 8, pn1); SLDEP(S, p1_slot, GSDEP(S)); }
        # Save state and replay body tokens
        var saved_ti = GTI(S);
        var saved_rpc = GRPC(S);
        SIDEP(S, GIDEP(S) + 1);
        STI(S, GFBS(S, fi));
        PARSE_PROG(S);
        # Patch return jumps from inlined body to here
        var new_rpc = GRPC(S);
        var ri = saved_rpc;
        while (ri < new_rpc) {
            EPATCH(S, L64(S + 0x8DA20 + ri * 8));
            ri = ri + 1;
        }
        SRPC(S, saved_rpc);
        SIDEP(S, GIDEP(S) - 1);
        # Restore token index
        STI(S, saved_ti);
        # Invalidate temporary param locals
        if (pc >= 1) { S64(S + 0x91000 + p0_slot * 8, 0 - 1); }
        if (pc >= 2) { S64(S + 0x91000 + p1_slot * 8, 0 - 1); }
        return 0;
    } } }
    # NORMAL CALL PATH
    # Args pushed left-to-right: arg1 first (bottom), argN last (top).
    # ECALLPOPS pops top 6 into registers: rdi=argN-5, ..., r9=argN.
    # For >6 args, the first (argc-6) remain on stack in forward order.
    # ESTORESTACKPARM compensates for the reversed register assignment.
    # Auto-coerce string literals to Str for params annotated : Str.
    var argc = 0;
    var smask = L64(S + 0xEBA000 + fi * 8);
    if (PEEKT(S) != 11) {
        var argo = 1;
        while (argo == 1) {
            # Auto-coercion: if this param is : Str and the arg is a string literal,
            # emit str_from(literal) instead of the raw cstr pointer.
            if (smask & (1 << argc)) {
                if (PEEKT(S) == 30) {
                    # String literal in a Str-typed param slot — auto-wrap with str_from
                    var sf_fi = FINDFN(S, _STR_FROM_NOFF(S));
                    PCMPE(S);
                    EPUSHR(S);
                    ECALLPOPS(S, 1);
                    if (sf_fi >= 0) {
                        var sfoff = L64(S + 0xE92000 + sf_fi * 8);
                        if (sfoff >= 0) { ECALLTO(S, sfoff); }
                        else { ECALLFIX(S, sf_fi); }
                    }
                    ECALLCLEAN(S, 1);
                    EPUSHR(S);
                    argc = argc + 1;
                    if (PEEKT(S) == 31) { STI(S, GTI(S) + 1); }
                    else { argo = 0; }
                    continue;
                }
            }
            PCMPE(S);
            EPUSHR(S);
            argc = argc + 1;
            if (PEEKT(S) == 31) { STI(S, GTI(S) + 1); }
            else { argo = 0; }
        }
    }
    if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); }
    STI(S, GTI(S) + 1);
    ECALLPOPS(S, argc);
    var foff = L64(S + 0xE92000 + fi * 8);
    if (foff >= 0) {
        ECALLTO(S, foff);
    } else {
        ECALLFIX(S, fi);
    }
    ECALLCLEAN(S, argc);
    return 0;
}

# Parse: impl TraitName for TypeName { fn method(self) { } ... }
# Methods get mangled to TypeName_method (trait name is documentation only for now)
fn PARSE_IMPL(S) {
    STI(S, GTI(S) + 1);  # consume IMPL
    # Parse trait name (skip for now — just used for documentation)
    if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
    STI(S, GTI(S) + 1);  # consume trait name
    # Expect "for"
    if (PEEKT(S) != 55) { ERR_EXPECT(S, 55); }
    STI(S, GTI(S) + 1);  # consume FOR
    # Parse type name
    if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
    var type_noff = PEEKV(S);
    STI(S, GTI(S) + 1);  # consume type name
    if (PEEKT(S) != 13) { ERR_EXPECT(S, 13); }
    STI(S, GTI(S) + 1);  # consume {
    # Parse methods inside the impl block
    # Temporarily set module to the type name so methods get mangled
    var saved_mod = GMOD(S);
    SMOD(S, type_noff);
    var igo = 1;
    while (igo == 1) {
        if (PEEKT(S) == 14) { igo = 0; }
        else {
            if (PEEKT(S) == 73) { STI(S, GTI(S) + 1); }
            if (PEEKT(S) == 32) { PARSE_FN_DEF(S); }
            else { igo = 0; }
        }
    }
    if (PEEKT(S) != 14) { ERR_EXPECT(S, 14); }
    STI(S, GTI(S) + 1);  # consume }
    SMOD(S, saved_mod);
    return 0;
}

# Skip generic parameters <T, U, ...> if present
fn SKIP_GENERICS(S) {
    if (PEEKT(S) == 19) {
        STI(S, GTI(S) + 1);  # consume <
        var ggo = 1;
        while (ggo == 1) {
            if (PEEKT(S) == 20) { ggo = 0; }
            else { STI(S, GTI(S) + 1); }
        }
        STI(S, GTI(S) + 1);  # consume >
    }
    return 0;
}

# Parse fn name<T>(params) { body }
# Dead store elimination: scan codebuf for consecutive stores to the same
# [rbp-N] offset, NOP out the first store when redundant.
# Pattern: store [rbp-N] (7) + load_imm (2/5/10) + store [rbp-N] (7) → NOP first store.
fn DSE_PASS(S, fn_start) {
    var dse_cp = GCP(S);
    var dse_i = fn_start;
    while (dse_i + 14 < dse_cp) {
        if (load8(S + 0x54A000 + dse_i) == 0x48) {
            if (load8(S + 0x54A000 + dse_i + 1) == 0x89) {
                if (load8(S + 0x54A000 + dse_i + 2) == 0x85) {
                    var dse_off = load32(S + 0x54A000 + dse_i + 3);
                    var dse_j = dse_i + 7;
                    var dse_skip = 0;
                    if (load8(S + 0x54A000 + dse_j) == 0x31) { dse_skip = 2; }
                    elif (load8(S + 0x54A000 + dse_j) == 0xB8) { dse_skip = 5; }
                    elif (load8(S + 0x54A000 + dse_j) == 0x48) {
                        if (load8(S + 0x54A000 + dse_j + 1) == 0xB8) { dse_skip = 10; }
                    }
                    if (dse_skip > 0) {
                        var dse_next = dse_j + dse_skip;
                        if (dse_next + 7 <= dse_cp) {
                            if (load8(S + 0x54A000 + dse_next) == 0x48) {
                                if (load8(S + 0x54A000 + dse_next + 1) == 0x89) {
                                    if (load8(S + 0x54A000 + dse_next + 2) == 0x85) {
                                        if (load32(S + 0x54A000 + dse_next + 3) == dse_off) {
                                            var dse_ni = dse_i;
                                            while (dse_ni < dse_j) {
                                                store8(S + 0x54A000 + dse_ni, 0x90);
                                                dse_ni = dse_ni + 1;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        dse_i = dse_i + 1;
    }
    return 0;
}

# Check if a codebuf offset is a jump target (recorded by EPATCH)
fn IS_JUMP_TARGET(S, off) {
    var jtc = L64(S + 0x9E000);
    var i = 0;
    while (i < jtc) {
        if (L64(S + 0x9E008 + i * 8) == off) { return 1; }
        i += 1;
    }
    return 0;
}

fn PARSE_FN_DEF(S) {
    STI(S, GTI(S) + 1);  # consume FN
    if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
    var noff = PEEKV(S);
    STI(S, GTI(S) + 1);
    # Skip generic parameters if present: fn foo<T, U>(...)
    SKIP_GENERICS(S);
    # Mangle name if inside a module: mod_fn
    var mmod = GMOD(S);
    if (mmod != 0) {
        NPOS_GUARD(S, 256);
        var mwp = GNPOS(S);
        var mnoff = mwp;
        var mri = 0;
        var mrc = load8(S + 0x60000 + mmod + mri);
        while (mrc != 0) { store8(S + 0x60000 + mwp, mrc); mwp = mwp + 1; mri = mri + 1; mrc = load8(S + 0x60000 + mmod + mri); }
        store8(S + 0x60000 + mwp, 95); mwp = mwp + 1;
        mri = 0; mrc = load8(S + 0x60000 + noff + mri);
        while (mrc != 0) { store8(S + 0x60000 + mwp, mrc); mwp = mwp + 1; mri = mri + 1; mrc = load8(S + 0x60000 + noff + mri); }
        store8(S + 0x60000 + mwp, 0); mwp = mwp + 1;
        SNPOS(S, mwp);
        noff = mnoff;
    }
    # Register or find fn
    var fi = FINDFN(S, noff);
    if (fi < 0) { fi = REGFN(S, noff); }
    # Set fn offset to current CP
    S64(S + 0xE92000 + fi * 8, GCP(S));
    # Save compiler state
    var saved_lv = GLVAR(S);
    SINFN(S, 1);
    SFLC(S, 0);
    SRPC(S, 0);
    S64(S + 0x8F900, 0);  # defer_count = 0
    S64(S + 0x9E000, 0);  # jump_target_count = 0
    # Emit prologue
    EFNPRO(S);
    var frame_patch = ESUBRSP(S);
    var fn_start = GCP(S);
    # Parse params
    if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); }
    STI(S, GTI(S) + 1);
    var pc = 0;
    var str_mask = 0;
    if (PEEKT(S) != 11) {
        var pgo = 1;
        while (pgo == 1) {
            if (PEEKT(S) != 2) { ERR_EXPECT(S, 2); }
            var pnoff = PEEKV(S);
            STI(S, GTI(S) + 1);
            # Optional type annotation: fn f(x: Str, y: Vec<i64>, ...)
            # If the type is Str, set bit pc in str_mask for auto-coercion.
            if (PEEKT(S) == 49) {
                STI(S, GTI(S) + 1);  # consume :
                if (PEEKT(S) == 8) { STI(S, GTI(S) + 1); }  # skip * for pointer types
                if (PEEKT(S) == 2) {
                    var tnoff = PEEKV(S);
                    # Check if type name is "Str" (0x00727453 = "Str\0")
                    if (L64(S + 0x60000 + tnoff) & 0xFFFFFFFF == 0x00727453) {
                        str_mask = str_mask | (1 << pc);
                    }
                }
                STI(S, GTI(S) + 1);  # consume type
                SKIP_GENERICS(S);    # skip <T> if present
            }
            var li = GFLC(S);
            S64(S + 0x91000 + li * 8, pnoff);
            SLDEP(S, li, 0);
            # Only emit register params now (0-5)
            if (pc < 6) {
                ESTOREPARM(S, pc, li, 0);
            }
            SFLC(S, li + 1);
            pc = pc + 1;
            if (PEEKT(S) == 31) { STI(S, GTI(S) + 1); }
            else { pgo = 0; }
        }
    }
    if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); }
    STI(S, GTI(S) + 1);
    S64(S + 0xE9A000 + fi * 8, pc);
    # Store Str param mask — bit N set = param N is : Str
    S64(S + 0xEBA000 + fi * 8, str_mask);
    # Record first param name offset for inlining (stored in fn_inline later)
    # Emit stack param stores (7+) now that we know total pc
    if (pc > 6) {
        var spi = 6;
        while (spi < pc) {
            ESTOREPARM(S, spi, spi, pc);
            spi = spi + 1;
        }
    }
    # Parse body
    if (PEEKT(S) != 13) { ERR_EXPECT(S, 13); }
    STI(S, GTI(S) + 1);
    # Emit jmp placeholder for defer flag init (backpatched after body)
    var defer_init_jmp = EJMP0(S);
    var body_cp = GCP(S);
    # Record body start for inline replay (x86 only)
    if (_INLINE_OK == 1) { SFBS(S, fi, GTI(S)); }
    PARSE_PROG(S);
    if (PEEKT(S) != 14) { ERR_EXPECT(S, 14); }
    # Record body end and classify inline candidate (x86 only)
    if (_INLINE_OK == 1) {
        SFBE(S, fi, GTI(S));
        var btokens = GTI(S) - GFBS(S, fi);
        var can_inline = 1;
        if (pc > 2) { can_inline = 0; }
        if (btokens > 16) { can_inline = 0; }
        if (can_inline == 1) {
            var sci = GFBS(S, fi);
            while (sci < GTI(S)) {
                var st = TOKTYP(S, sci);
                if (st == 15) { can_inline = 0; }
                if (st == 16) { can_inline = 0; }
                if (st == 55) { can_inline = 0; }
                if (st == 3) { can_inline = 0; }
                sci = sci + 1;
            }
        }
        if (can_inline == 1) {
            if (pc == 2) { SFINL(S, fi, (L64(S + 0x91008) << 32) | (L64(S + 0x91000) & 0xFFFFFFFF)); }
            elif (pc == 1) { SFINL(S, fi, L64(S + 0x91000)); }
            elif (pc == 0) { SFINL(S, fi, 1); }
        } else { SFINL(S, fi, 0); }
    }
    STI(S, GTI(S) + 1);
    var dc = L64(S + 0x8F900);
    # Backpatch defer flag init: emit zeroing code, then jmp to body
    if (dc > 0) {
        # Emit zeroing trampoline at current CP (after body, before epilogue)
        EPATCH(S, defer_init_jmp);  # patch initial jmp → here (zeroing code)
        var dzi = 0;
        while (dzi < dc) {
            var dzflag = L64(S + 0x8F908 + dzi * 24 + 16);
            EMOVI(S, 0);
            EFLSTORE(S, dzflag);
            dzi = dzi + 1;
        }
        EJMP(S, body_cp);  # jmp back to body start
    } else {
        # No defers — patch jmp to land at body_cp
        # Temporarily set CP to body_cp so EPATCH computes the right offset
        var saved_cp = GCP(S);
        SCP(S, body_cp);
        EPATCH(S, defer_init_jmp);
        SCP(S, saved_cp);
    }
    var rpc = GRPC(S);
    # Patch return jumps to land here
    var ri = 0;
    while (ri < rpc) {
        EPATCH(S, L64(S + 0x8DA20 + ri * 8));
        ri = ri + 1;
    }
    # Execute deferred blocks LIFO: save rax, check flag, jmp→block, restore rax
    if (dc > 0) {
        EPUSHR(S);  # save return value
        var di = dc - 1;
        while (di >= 0) {
            var bstart = L64(S + 0x8F908 + di * 24);
            var bend = L64(S + 0x8F908 + di * 24 + 8);
            var dflag = L64(S + 0x8F908 + di * 24 + 16);
            # Check flag: load flag, test rax==0, je skip
            EFLLOAD(S, dflag);
            ETESTAZ(S);
            # je skip (0F 84 rel32) — skip this defer if flag==0
            var dskip = EJCC(S, 0x84);
            # Jump to the deferred block
            EJMP(S, bstart);
            # Patch the block's end-jmp to return here (current CP)
            EPATCH(S, bend);
            # Patch skip to land here
            EPATCH(S, dskip);
            di = di - 1;
        }
        EPOPR(S);  # restore return value
    }
    # Emit epilogue
    EFNEPI(S);
    DSE_PASS(S, fn_start);
    # LASE: eliminate store+load pairs where the load is NOT a jump target
    var lase_cp = GCP(S);
    var lase_i = fn_start;
    var lase_count = 0;
    while (lase_i + 14 <= lase_cp) {
        # Detect store (7 bytes): 48 89 85 XX XX XX XX
        if (load8(S + 0x54A000 + lase_i) == 0x48) {
        if (load8(S + 0x54A000 + lase_i + 1) == 0x89) {
        if (load8(S + 0x54A000 + lase_i + 2) == 0x85) {
            # Check for load at exactly store+7: 48 8B 85 XX XX XX XX (same offset)
            var lj = lase_i + 7;
            if (load8(S + 0x54A000 + lj) == 0x48) {
            if (load8(S + 0x54A000 + lj + 1) == 0x8B) {
            if (load8(S + 0x54A000 + lj + 2) == 0x85) {
                if (load32(S + 0x54A000 + lase_i + 3) == load32(S + 0x54A000 + lj + 3)) {
                    # Same offset — check if load is a jump target
                    if (IS_JUMP_TARGET(S, lj) == 0) {
                        # Safe to eliminate — NOP the 7-byte load
                        var ln = lj;
                        while (ln < lj + 7) {
                            store8(S + 0x54A000 + ln, 0x90);
                            ln += 1;
                        }
                        lase_count += 1;
                    }
                }
            } } }
        } } }
        lase_i += 1;
    }
    # Patch frame size
    var flc = GFLC(S);
    var fsz = (flc * 8 + 15) & (0 - 16);
    EPATCHFRAME(S, frame_patch, fsz);
    # Record fn code end (v4.4.0 DCE) — this is GCP after epilogue + LASE + frame patch.
    # Paired with fn_start at 0xC4000[fi], the [start, end) range bounds the emitted
    # body bytes for this fn, usable by the FIXUP pass to NOP dead functions safely.
    SFNE(S, fi, GCP(S));
    # Restore state (DON'T restore VCNT — arrays inside functions are globals that persist)
    SLVAR(S, saved_lv);
    SINFN(S, 0);
    return 0;
}

# ASM_MNEMONIC and helpers are in arch-specific emit files:
# src/backend/x86/emit.cyr and src/backend/aarch64/emit.cyr

fn PARSE_SWITCH(S) {
    STI(S, GTI(S) + 1);
    if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); }
    STI(S, GTI(S) + 1);
    PCMPE(S);
    if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); }
    STI(S, GTI(S) + 1);
    if (PEEKT(S) != 13) { ERR_EXPECT(S, 13); }
    STI(S, GTI(S) + 1);
    # Pre-scan: collect case values to decide chain vs jump table
    var save_ti = GTI(S);
    var case_count = 0;
    var case_min = 0x7FFFFFFFFFFFFFFF;
    var case_max = 0;
    var has_default = 0;
    var pgo = 1;
    while (pgo == 1) {
        if (PEEKT(S) == 58) {
            STI(S, GTI(S) + 1);
            if (PEEKT(S) == 1) {
                var cv = PEEKV(S);
                if (case_count == 0) { case_min = cv; case_max = cv; }
                else {
                    if (cv < case_min) { case_min = cv; }
                    if (cv > case_max) { case_max = cv; }
                }
                case_count = case_count + 1;
            }
            # Skip to next case/default/} (track brace depth for block bodies)
            var _psd = 0;
            while (1) {
                if (PEEKT(S) == 13) { _psd = _psd + 1; }
                if (PEEKT(S) == 14) { if (_psd > 0) { _psd = _psd - 1; } else { break; } }
                if (_psd == 0 && PEEKT(S) == 58) { break; }
                if (_psd == 0 && PEEKT(S) == 59) { break; }
                if (PEEKT(S) == 12) { break; }
                STI(S, GTI(S) + 1);
            }
        }
        else { if (PEEKT(S) == 59) { has_default = 1;
            var _psd2 = 0;
            while (1) {
                if (PEEKT(S) == 13) { _psd2 = _psd2 + 1; }
                if (PEEKT(S) == 14) { if (_psd2 > 0) { _psd2 = _psd2 - 1; } else { break; } }
                if (PEEKT(S) == 12) { break; }
                STI(S, GTI(S) + 1);
            }
        }
        else { pgo = 0; } }
    }
    STI(S, save_ti);
    # Decide: jump table if >= 4 cases, density >= 1/3, and range < 256.
    # v4.8.2 lowered threshold from 50% (*2) to 33% (*3) — more real-world
    # enum-like switches with a few gaps now hit the O(1) dispatch path.
    # The 256-byte range cap keeps the jump table itself small.
    var range = case_max - case_min;
    var use_table = 0;
    if (case_count >= 4) {
        if (range + 1 <= case_count * 3) {
            if (range < 256) { use_table = 1; }
        }
    }
    # Allocate hidden global to hold switch value
    var swidx = GVCNT(S);
    S64(S + 0x11A000 + swidx * 8, 0);
    S64(S + 0x12A000 + swidx * 8, 8);
    SVCNT(S, swidx + 1);
    EVSTORE(S, swidx);
    if (use_table == 1) {
        # === JUMP TABLE PATH ===
        # Emit: sub rax, min
        EPUSHR(S); EMOVI(S, case_min); EMOVCA(S); EPOPR(S);
        E3(S, 0xC82948);
        # Emit: cmp rax, range (unsigned)
        EPUSHR(S); EMOVI(S, range); EMOVCA(S); EPOPR(S);
        E3(S, 0xC83948);
        # Emit: ja default (0F 87 rel32)
        var default_patch = EJCC(S, 0x87);
        # Emit: lea rcx, [rip+0] (48 8D 0D 00000000) — patched to table
        E3(S, 0x0D8D48); var lea_patch = GCP(S); EB(S, 0); EB(S, 0); EB(S, 0); EB(S, 0);
        # Emit: movsxd rax, [rcx+rax*4] (48 63 04 81)
        EB(S, 0x48); EB(S, 0x63); EB(S, 0x04); EB(S, 0x81);
        # Emit: add rax, rcx (48 01 C8)
        E3(S, 0xC80148);
        # Emit: jmp rax (FF E0)
        E2(S, 0xE0FF);
        # Patch lea disp32: table starts right here
        var table_cp = GCP(S);
        var lea_disp = table_cp - lea_patch - 4;
        var la = S + 0x54A000 + lea_patch;
        S64(la, (L64(la) >> 32 << 32) | (lea_disp & 0xFFFFFFFF));
        # Emit table: (range+1) entries * 4 bytes, all zeros initially
        var ti = 0;
        while (ti <= range) { EB(S, 0); EB(S, 0); EB(S, 0); EB(S, 0); ti = ti + 1; }
        # Parse case bodies, patching table entries
        var ends[256];
        var ec = 0;
        var default_cp = 0 - 1;   # filled in when `default:` is parsed
        var sgo = 1;
        while (sgo == 1) {
            if (PEEKT(S) == 58) {
                STI(S, GTI(S) + 1);
                if (PEEKT(S) != 1) { ERR_EXPECT(S, 1); }
                var val = PEEKV(S);
                STI(S, GTI(S) + 1);
                if (PEEKT(S) != 49) { ERR_EXPECT(S, 49); }
                STI(S, GTI(S) + 1);
                # Patch table entry: table[val - min] = body_cp - table_cp
                var body_cp = GCP(S);
                var toff = (val - case_min) * 4 + table_cp;
                var ta = S + 0x54A000 + toff;
                var trel = body_cp - table_cp;
                S64(ta, (L64(ta) >> 32 << 32) | (trel & 0xFFFFFFFF));
                # Parse case body
                var cgo = 1;
                while (cgo == 1) {
                    if (PEEKT(S) == 58) { cgo = 0; }
                    else { if (PEEKT(S) == 59) { cgo = 0; }
                    else { if (PEEKT(S) == 14) { cgo = 0; }
                    else { if (PEEKT(S) == 12) { cgo = 0; }
                    else { PARSE_STMT(S); } } } }
                }
                store64(&ends + ec * 8, EJMP0(S));
                ec = ec + 1;
            }
            else { if (PEEKT(S) == 59) {
                STI(S, GTI(S) + 1);
                if (PEEKT(S) != 49) { ERR_EXPECT(S, 49); }
                STI(S, GTI(S) + 1);
                # Default body — patch default_patch to here
                EPATCH(S, default_patch);
                default_patch = 0;
                default_cp = GCP(S);
                while (PEEKT(S) != 14) {
                    if (PEEKT(S) == 12) { break; }
                    PARSE_STMT(S);
                }
                store64(&ends + ec * 8, EJMP0(S));
                ec = ec + 1;
            }
            else { sgo = 0; } }
        }
        # Patch default jump if no default case was found
        if (default_patch > 0) { EPATCH(S, default_patch); }
        # Fill unpatched table entries. If a `default:` was present
        # (v4.8.2), gaps within [case_min, case_max] now jump to the
        # default body — before this fix they fell through to the
        # end of the switch, which silently hid sparse-case bugs at
        # the previous 50% density threshold (no gaps). When no
        # default exists, gaps still fall through.
        var end_cp = GCP(S);
        var gap_rel = end_cp - table_cp;
        if (default_cp >= 0) { gap_rel = default_cp - table_cp; }
        ti = 0;
        while (ti <= range) {
            var te = S + 0x54A000 + table_cp + ti * 4;
            if (load32(te) == 0) {
                S64(te, (L64(te) >> 32 << 32) | (gap_rel & 0xFFFFFFFF));
            }
            ti = ti + 1;
        }
        if (PEEKT(S) != 14) { ERR_EXPECT(S, 14); }
        STI(S, GTI(S) + 1);
        for (var ei = 0; ei < ec; ei = ei + 1) { EPATCH(S, load64(&ends + ei * 8)); }
    } else {
        # === CHAIN PATH (original) ===
        var ends[256];
        var ec = 0;
        var sgo = 1;
        while (sgo == 1) {
            if (PEEKT(S) == 58) {
                STI(S, GTI(S) + 1);
                if (PEEKT(S) != 1) { ERR_EXPECT(S, 1); }
                var val = PEEKV(S);
                STI(S, GTI(S) + 1);
                if (PEEKT(S) != 49) { ERR_EXPECT(S, 49); }
                STI(S, GTI(S) + 1);
                EVLOAD(S, swidx);
                EPUSHR(S);
                EMOVI(S, val);
                EMOVCA(S);
                EPOPR(S);
                ECMPR(S);
                var skip = EJCC(S, 0x85);
                var cgo = 1;
                while (cgo == 1) {
                    if (PEEKT(S) == 58) { cgo = 0; }
                    else { if (PEEKT(S) == 59) { cgo = 0; }
                    else { if (PEEKT(S) == 14) { cgo = 0; }
                    else { if (PEEKT(S) == 12) { cgo = 0; }
                    else { PARSE_STMT(S); } } } }
                }
                store64(&ends + ec * 8, EJMP0(S));
                ec = ec + 1;
                EPATCH(S, skip);
            }
            else { if (PEEKT(S) == 59) {
                STI(S, GTI(S) + 1);
                if (PEEKT(S) != 49) { ERR_EXPECT(S, 49); }
                STI(S, GTI(S) + 1);
                while (PEEKT(S) != 14) {
                    if (PEEKT(S) == 12) { break; }
                    PARSE_STMT(S);
                }
            }
            else { sgo = 0; } }
        }
        if (PEEKT(S) != 14) { ERR_EXPECT(S, 14); }
        STI(S, GTI(S) + 1);
        for (var ei = 0; ei < ec; ei = ei + 1) { EPATCH(S, load64(&ends + ei * 8)); }
    }
    return 0;
}

# Parse: match expr { val => { stmts } val => { stmts } _ => { stmts } }
fn PARSE_MATCH(S) {
    STI(S, GTI(S) + 1);
    PCMPE(S);
    if (PEEKT(S) != 13) { ERR_EXPECT(S, 13); }
    STI(S, GTI(S) + 1);
    # Store match value in hidden temp var
    var midx = GVCNT(S);
    S64(S + 0x11A000 + midx * 8, 0);
    S64(S + 0x12A000 + midx * 8, 8);
    SVCNT(S, midx + 1);
    EVSTORE(S, midx);
    var ends[256];
    var ec = 0;
    var mgo = 1;
    while (mgo == 1) {
        if (PEEKT(S) == 14) { mgo = 0; }
        else {
            # Check for _ (wildcard/default)
            var is_default = 0;
            if (PEEKT(S) == 2) {
                # Check if identifier is "_"
                var mnoff = PEEKV(S);
                if (load8(S + 0x60000 + mnoff) == 95) {
                    if (load8(S + 0x60000 + mnoff + 1) == 0) {
                        is_default = 1;
                    }
                }
            }
            if (is_default == 1) {
                # _ => { stmts }
                STI(S, GTI(S) + 1);
                # Expect =>
                if (PEEKT(S) != 4) { ERR_EXPECT(S, 4); }
                STI(S, GTI(S) + 1);
                if (PEEKT(S) != 20) { ERR_EXPECT(S, 20); }
                STI(S, GTI(S) + 1);
                if (PEEKT(S) != 13) { ERR_EXPECT(S, 13); }
                STI(S, GTI(S) + 1);
                SCOPE_PUSH(S);
                PARSE_PROG(S);
                SCOPE_POP(S);
                if (PEEKT(S) != 14) { ERR_EXPECT(S, 14); }
                STI(S, GTI(S) + 1);
            } else {
                # val => { stmts }
                EVLOAD(S, midx);
                EPUSHR(S);
                PCMPE(S);
                EMOVCA(S);
                EPOPR(S);
                ECMPR(S);
                var skip = EJCC(S, 0x85);
                # Expect =>
                if (PEEKT(S) != 4) { ERR_EXPECT(S, 4); }
                STI(S, GTI(S) + 1);
                if (PEEKT(S) != 20) { ERR_EXPECT(S, 20); }
                STI(S, GTI(S) + 1);
                if (PEEKT(S) != 13) { ERR_EXPECT(S, 13); }
                STI(S, GTI(S) + 1);
                SCOPE_PUSH(S);
                PARSE_PROG(S);
                SCOPE_POP(S);
                if (PEEKT(S) != 14) { ERR_EXPECT(S, 14); }
                STI(S, GTI(S) + 1);
                store64(&ends + ec * 8, EJMP0(S));
                ec = ec + 1;
                EPATCH(S, skip);
            }
        }
    }
    STI(S, GTI(S) + 1);
    for (var ei = 0; ei < ec; ei = ei + 1) { EPATCH(S, load64(&ends + ei * 8)); }
    return 0;
}

# Evaluate a single constant atom for #assert: number literal or sizeof(T).
# Returns the constant value. Advances TI past the consumed tokens.
fn _EVAL_CONST_ATOM(S) {
    var t = PEEKT(S);
    if (t == 1) {
        var v = PEEKV(S);
        STI(S, GTI(S) + 1);
        return v;
    }
    if (t == 2) {
        var noff = PEEKV(S);
        # sizeof(Type)
        if (L64(S + 0x60000 + noff) & 0xFFFFFFFFFFFF == 0x666F657A6973) {
            STI(S, GTI(S) + 1);
            if (PEEKT(S) != 10) { ERR_EXPECT(S, 10); }
            STI(S, GTI(S) + 1);
            var szval = 0;
            if (PEEKT(S) == 2) {
                var szn = PEEKV(S);
                STI(S, GTI(S) + 1);
                var szname = L64(S + 0x60000 + szn);
                if (szname & 0xFFFF == 0x3869) { szval = 1; }
                elif (szname & 0xFFFFFF == 0x363169) { szval = 2; }
                elif (szname & 0xFFFFFF == 0x323369) { szval = 4; }
                elif (szname & 0xFFFFFF == 0x343669) { szval = 8; }
                else {
                    var szsid = FINDSTRUCT(S, szn);
                    if (szsid > 0) { szval = STRUCTSZ(S, szsid - 1); }
                    else { ERR_MSG(S, "#assert: unknown type in sizeof", 31); }
                }
            }
            if (PEEKT(S) != 11) { ERR_EXPECT(S, 11); }
            STI(S, GTI(S) + 1);
            return szval;
        }
        ERR_MSG(S, "#assert: expected number or sizeof()", 36);
    }
    ERR_MSG(S, "#assert: expected constant expression", 37);
    return 0;
}

fn PARSE_STMT(S) {
    var typ = PEEKT(S);
    # #assert EXPR OP EXPR, "msg" — compile-time check
    if (typ == 107) {
        STI(S, GTI(S) + 1);
        var lhs = _EVAL_CONST_ATOM(S);
        # Check for comparison operator
        var op = PEEKT(S);
        if (op >= 17 && op <= 22) {
            STI(S, GTI(S) + 1);
            var rhs = _EVAL_CONST_ATOM(S);
            var result = 0;
            if (op == 17) { if (lhs == rhs) { result = 1; } }
            if (op == 18) { if (lhs != rhs) { result = 1; } }
            if (op == 19) { if (lhs < rhs) { result = 1; } }
            if (op == 20) { if (lhs > rhs) { result = 1; } }
            if (op == 21) { if (lhs <= rhs) { result = 1; } }
            if (op == 22) { if (lhs >= rhs) { result = 1; } }
            lhs = result;
        }
        # lhs is now the assertion value (0 = fail, non-zero = pass)
        if (PEEKT(S) == 31) { STI(S, GTI(S) + 1); }
        if (lhs == 0) {
            syscall(SYS_WRITE, 2, "error:", 6);
            FM_LOOKUP(S, GTLINE(S, GTI(S)));
            syscall(SYS_WRITE, 2, ": #assert failed", 16);
            if (PEEKT(S) == 30) {
                # String token value is (offset << 16) | length
                var sv = PEEKV(S);
                var soff = sv >> 16;
                var slen = sv & 0xFFFF;
                syscall(SYS_WRITE, 2, ": ", 2);
                syscall(SYS_WRITE, 2, S + 0x14A000 + soff, slen);
            }
            syscall(SYS_WRITE, 2, "\n", 1);
            syscall(SYS_EXIT, 1);
        }
        # Skip to end of line (consume remaining tokens until ; or newline change)
        while (PEEKT(S) != 5 && PEEKT(S) != 12) { STI(S, GTI(S) + 1); }
        if (PEEKT(S) == 5) { STI(S, GTI(S) + 1); }
        return 0;
    }
    if (typ == 3) { PARSE_VAR(S); return 0; }
    # Block statement: { ... }
    if (typ == 13) {
        STI(S, GTI(S) + 1);
        SCOPE_PUSH(S);
        PARSE_PROG(S);
        SCOPE_POP(S);
        if (PEEKT(S) != 14) { ERR_EXPECT(S, 14); }
        STI(S, GTI(S) + 1);
        return 0;
    }
    if (typ == 15) { PARSE_IF(S); return 0; }
    if (typ == 16) { PARSE_WHILE(S); return 0; }
    if (typ == 55) { PARSE_FOR(S); return 0; }
    if (typ == 57) { PARSE_SWITCH(S); return 0; }
    if (typ == 75) { PARSE_MATCH(S); return 0; }
    if (typ == 33) { PARSE_RETURN(S); return 0; }
    # break; — forward jump to after loop (linked list through codebuf)
    if (typ == 51) {
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); }
        STI(S, GTI(S) + 1);
        var prev_brk = L64(S + 0x8F840);
        var brk_off = EJMP0(S);
        # Store prev break offset in this jmp's rel32 field (chain link)
        var brk_addr = S + 0x54A000 + brk_off;
        S64(brk_addr, (L64(brk_addr) >> 32 << 32) | (prev_brk & 0xFFFFFFFF));
        S64(S + 0x8F840, brk_off);
        return 0;
    }
    # defer { body } — execute body at function return (LIFO)
    # Each defer gets a runtime flag (hidden local) set to 1 when reached.
    # At epilogue, flag is checked before running the block — unreached defers are skipped.
    if (typ == 106) {
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 13) { ERR_EXPECT(S, 13); }
        # Allocate hidden local for defer flag (initialized to 0 in prologue)
        var dflag = GFLC(S);
        S64(S + 0x91000 + dflag * 8, 0);
        SLDEP(S, dflag, GSDEP(S));
        SLTYPE(S, dflag, 0);
        SFLC(S, dflag + 1);
        # Emit: flag = 1 (set when defer statement is reached)
        EMOVI(S, 1);
        EFLSTORE(S, dflag);
        # Emit jmp-over (skip deferred block during normal execution)
        var djmp = EJMP0(S);
        # Record block start (current CP after jmp-over)
        var dstart = GCP(S);
        # Parse deferred block body
        STI(S, GTI(S) + 1);
        PARSE_PROG(S);
        if (PEEKT(S) != 14) { ERR_EXPECT(S, 14); }
        STI(S, GTI(S) + 1);
        # Emit jmp placeholder (patched to next defer block or epilogue)
        var dend = EJMP0(S);
        # Store {block_start, end_jmp, flag_local} triple (24 bytes per entry)
        var dci = L64(S + 0x8F900);
        if (dci >= 8) {
            syscall(SYS_WRITE, 2, "error: too many defer blocks (max 8)\n", 36);
            syscall(SYS_EXIT, 1);
        }
        S64(S + 0x8F908 + dci * 24, dstart);
        S64(S + 0x8F908 + dci * 24 + 8, dend);
        S64(S + 0x8F908 + dci * 24 + 16, dflag);
        S64(S + 0x8F900, dci + 1);
        # Patch jmp-over to land here (after the deferred block)
        EPATCH(S, djmp);
        return 0;
    }
    # continue; — jump to loop top (or step for C-style for)
    if (typ == 52) {
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); }
        STI(S, GTI(S) + 1);
        var cfw = L64(S + 0x8F898);
        if (cfw > 0) {
            # For-loop: forward patch to step (array of patches)
            var ci = cfw - 1;
            if (ci >= 8) {
                ERR_MSG(S, "too many continue statements in loop (max 8)", 44);
            }
            S64(S + 0x8F8A0 + ci * 8, EJMP0(S));
            S64(S + 0x8F898, cfw + 1);
        } else {
            # While/for-in: direct jump to loop top
            EJMP(S, L64(S + 0x8F838));
        }
        return 0;
    }
    # asm { ... } — raw bytes or mnemonic instructions
    if (typ == 48) {
        STI(S, GTI(S) + 1);
        if (PEEKT(S) != 13) { ERR_EXPECT(S, 13); }
        STI(S, GTI(S) + 1);
        var ago = 1;
        while (ago == 1) {
            if (PEEKT(S) == 14) { ago = 0; }
            else {
                if (PEEKT(S) == 1) {
                    # Raw byte
                    EB(S, PEEKV(S) & 0xFF);
                    STI(S, GTI(S) + 1);
                    if (PEEKT(S) == 5) { STI(S, GTI(S) + 1); }
                }
                elif (PEEKT(S) == 2) {
                    # Mnemonic — dispatch to ASM_MNEMONIC
                    ASM_MNEMONIC(S);
                }
                else { ERR(S); }
            }
        }
        STI(S, GTI(S) + 1);
        return 0;
    }
    # *expr = val; (pointer store)
    if (typ == 8) {
        STI(S, GTI(S) + 1);
        PARSE_FACTOR(S);
        # rax now holds the address
        EPUSHR(S);
        if (PEEKT(S) != 4) { ERR_EXPECT(S, 4); }
        STI(S, GTI(S) + 1);
        PCMPE(S);
        # rax = value, stack = address
        EPOPC(S);
        ESTORE64(S);
        if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); }
        STI(S, GTI(S) + 1);
        return 0;
    }
    # Expression statements: syscall(...); store8(...); load8(...);
    if (typ == 24) { PCMPE(S); if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); } STI(S, GTI(S) + 1); return 0; }
    if (typ == 26) { PCMPE(S); if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); } STI(S, GTI(S) + 1); return 0; }
    if (typ == 25) { PCMPE(S); if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); } STI(S, GTI(S) + 1); return 0; }
    if (typ == 45) { PCMPE(S); if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); } STI(S, GTI(S) + 1); return 0; }
    if (typ == 46) { PCMPE(S); if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); } STI(S, GTI(S) + 1); return 0; }
    if (typ == 47) { PCMPE(S); if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); } STI(S, GTI(S) + 1); return 0; }
    # f64/SIMD builtins as statements
    if (typ >= 62) { if (typ <= 105) { PCMPE(S); if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); } STI(S, GTI(S) + 1); return 0; } }
    if (typ == 2) {
        # Could be assignment or fn call as statement
        var noff = PEEKV(S);
        STI(S, GTI(S) + 1);
        if (PEEKT(S) == 10) {
            # fn call statement
            PARSE_FNCALL(S, noff);
            if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); }
            STI(S, GTI(S) + 1);
            return 0;
        }
        # struct field access: ident.field = expr; or ident.method(args);
        if (PEEKT(S) == 41) {
            # Peek ahead: is this a method call or field store?
            # Save position, consume DOT, check if ident followed by (
            var save_ti = GTI(S);
            STI(S, GTI(S) + 1);  # consume DOT
            if (PEEKT(S) == 2) {
                var peek_noff = PEEKV(S);
                STI(S, GTI(S) + 1);  # consume method name
                if (PEEKT(S) == 10) {
                    # Method call: rewind and use PARSE_FIELD_LOAD (which handles methods)
                    STI(S, save_ti);
                    PARSE_FIELD_LOAD(S, noff);
                    if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); }
                    STI(S, GTI(S) + 1);
                    return 0;
                }
            }
            # Not a method call — rewind and do field store
            STI(S, save_ti);
            PARSE_FIELD_STORE(S, noff);
            return 0;
        }
        # assignment or compound assignment: already consumed IDENT
        # Check for +=, -=, *=, /=, %=, &=, |=, ^=, <<=, >>=
        var compound_op = 0;
        var ct = PEEKT(S);
        if (ct == 6 || ct == 7 || ct == 8 || ct == 9 || ct == 34 || ct == 27 || ct == 35 || ct == 36 || ct == 38 || ct == 39) {
            var ti_next = GTI(S) + 1;
            if (ti_next < GTCNT(S)) {
                if (TOKTYP(S, ti_next) == 4) {
                    compound_op = ct;
                    STI(S, GTI(S) + 2);
                }
            }
        }
        if (compound_op == 0) {
            if (PEEKT(S) != 4) { ERR_EXPECT(S, 4); }
            STI(S, GTI(S) + 1);
        }
        if (compound_op != 0) {
            # Compound: x += expr → load x, push, eval expr, then x OP expr
            var cidx = FINDLOCAL(S, noff);
            if (cidx >= 0) { EFLLOAD(S, cidx); }
            else {
                var gidx = FINDVAR(S, noff);
                if (gidx >= 0) { EVLOAD(S, gidx); }
            }
            EPUSHR(S);
            PCMPE(S);
            # Stack = x, rax = expr. For x OP expr: mov rcx,rax; pop rax; OP
            EMOVCA(S);
            EPOPR(S);
            if (compound_op == 6) { EADDR(S); }
            elif (compound_op == 7) { ESUBR(S); }
            elif (compound_op == 8) { EIMUL(S); }
            elif (compound_op == 9) { ECQO(S); EIDIV(S); }
            elif (compound_op == 34) { ECQO(S); EIDIV(S); EMOVRA_RDX(S); }
            elif (compound_op == 27) { EANDR(S); }
            elif (compound_op == 35) { EORR(S); }
            elif (compound_op == 36) { EXORR(S); }
            elif (compound_op == 38) { ESHLCL(S); }
            elif (compound_op == 39) { ESHRCL(S); }
        } else {
            PCMPE(S);
        }
        # Type check at assignment
        var aps = GPSC(S);
        var idx = 0 - 1;
        if (GINFN(S) == 1) {
            idx = FINDLOCAL(S, noff);
            if (idx >= 0) {
                var lt = GLTYPE(S, idx);
                if (lt > 0) {
                    if (aps == 0) { WARN(S, "assigning non-pointer to typed pointer", 38); }
                }
            }
        }
        if (idx >= 0) {
            var lt = GLTYPE(S, idx);
            var ew = GEXW(S);
            if (lt > 0) {
                if (lt <= 8) {
                    if (ew > lt) { WARN(S, "narrowing assignment (value may truncate)", 45); }
                    EFLSTORE_W(S, idx, lt);
                } else { EFLSTORE(S, idx); }
            }
            else { EFLSTORE(S, idx); }
        }
        else {
            idx = FINDVAR(S, noff);
            if (idx < 0) {
                syscall(SYS_WRITE, 2, "error:", 6);
                FM_LOOKUP(S, GTLINE(S, GTI(S)));
                syscall(SYS_WRITE, 2, ": undefined variable '", 22);
                PRSTR(S + 0x60000 + noff);
                syscall(SYS_WRITE, 2, "'\n", 2);
                syscall(SYS_EXIT, 1);
            }
            var vt = GVTYPE(S, idx);
            if (vt < 0) {
                if (aps == 0) { WARN(S, "assigning non-pointer to typed pointer", 38); }
            }
            var avsz = L64(S + 0x12A000 + idx * 8);
            var ew = GEXW(S);
            if (avsz < 8) {
                if (ew > avsz) { WARN(S, "narrowing assignment (value may truncate)", 45); }
                EVSTORE_W(S, idx, avsz);
            }
            else { EVSTORE(S, idx); }
            SLVAR(S, idx);
        }
        if (PEEKT(S) != 5) { ERR_EXPECT(S, 5); }
        STI(S, GTI(S) + 1);
        return 0;
    }
    ERR(S);
    return 0;
}

fn PARSE_PROG(S) {
    var go = 1;
    while (go == 1) {
        var typ = PEEKT(S);
        if (typ == 12) { go = 0; }
        else { if (typ == 14) { go = 0; }
        else { if (typ == 32) {
            # fn definition inside top-level code (relaxed ordering)
            # Emit jmp over fn body, compile fn, patch jmp
            var fn_skip = EJMP0(S);
            PARSE_FN_DEF(S);
            EPATCH(S, fn_skip);
        }
        else { PARSE_STMT(S); } } }
    }
    return 0;
}

