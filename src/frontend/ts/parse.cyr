# ================================================================
# src/frontend/ts/parse.cyr — TypeScript parser (cyrius-ts P2)
# ================================================================
#
# v5.7.2 P2.1 SCAFFOLD — AST format + heap regions + helpers + entry stub.
# Subsequent phases (P2.2-P2.6) populate TS_PARSE with actual parsing.
#
# Architecture (see also docs/development/roadmap.md § v5.7.2):
#
# Unlike cyrius's existing parse.cyr (single-pass, parse-to-IR), the TS
# frontend builds an explicit AST. TypeScript needs multiple passes over
# the same source: parse → typecheck → monomorphize generics → lower.
# Single-pass parse-to-IR doesn't compose with that pipeline.
#
# AST node format — uniform 48 bytes per node:
#
#   offset  size  field         purpose
#   0       8 B   kind          TS_AST_KIND_* (see enum below)
#   8       8 B   span          (start_offset << 24) | length — same
#                               packing as TS_TOK value field
#   16      8 B   payload[0]    interpretation depends on kind:
#                                 - for binary ops:  lhs node index
#                                 - for member:     receiver index
#                                 - for ident:      name span (offset|len)
#                                 - for var-decl:   binding kind (var/let/const)
#                                 - etc.
#   24      8 B   payload[1]    second operand / type-args index / etc.
#   32      8 B   payload[2]    third — generally child-list pointer or
#                               flags bitmask
#   40      8 B   payload[3]    fourth — reserved / next-sibling for lists
#
# Wasteful for tiny nodes (literals don't need 4 payloads) but uniform
# size = trivial indexing (`node_addr = ts_ast_off + idx * 48`) and
# matches cyrius's "wide, simple, uniform" style.
#
# Children of variable arity (long arg lists, statement bodies, big
# object types) reference an external children array via a payload
# index into TS_AST_CHILDREN_OFF. Each entry there is an i64 child-node
# index, terminated by sentinel -1.

# ================================================================
# Heap region map — parser additions
# ================================================================
#
# Extends ts/lex.cyr's heap map. All offsets relative to ts_base.
#
# Offset       Region              Size       Purpose
# ----------------------------------------------------------------
# 0x880000     ts_ast_nodes        [0x400000] 4 MB — uniform 48 B
#                                             nodes (~83K cap)
# 0xC80000     ts_ast_children     [0x100000] 1 MB — variable-length
#                                             children arrays
# 0xD80000     ts_parse_state      [0x001000] 4 KB — parser scratch
# 0xD81000     —                              reserved for growth
#
# New TS_HEAP_SIZE: 0xD81000 (~13.5 MB; was 0x880000 = 8.5 MB at P1).
# main.cyr brk extends by an additional 5.01 MB to cover.

var TS_AST_NODES_OFF      = 0x880000;
var TS_AST_CHILDREN_OFF   = 0xC80000;
var TS_PARSE_STATE_OFF    = 0xD80000;

var TS_AST_NODE_SIZE      = 48;
var TS_AST_NODE_CAP       = 87381;          # 0x400000 / 48 — ~83K nodes
var TS_AST_CHILDREN_CAP   = 131072;         # 0x100000 / 8 — ~131K i64 entries

# Parser state slots within ts_parse_state region
var TS_PS_NODE_COUNT      = 0;              # nodes allocated so far
var TS_PS_TOK_IDX         = 8;              # current token index (into TS_TOK_TYPES)
var TS_PS_CHILDREN_USED   = 16;             # i64 entries used in children region
var TS_PS_ERR_CODE        = 24;             # 0 = ok, non-zero = parse error code
var TS_PS_ERR_TOK_IDX     = 32;             # token index where error occurred
var TS_PS_ROOT_NODE       = 40;             # index of ROOT node (always 0 by convention)

# ================================================================
# AST kind enum
# ================================================================
#
# Numbered in 100-blocks per category to leave room for additions.
# Many kinds are placeholders for P2.2-P2.6 — declared here so
# helpers + the kind-string table can reference them.

# Structural (0-9)
var TS_AST_NONE                 = 0;
var TS_AST_ROOT                 = 1;        # source-file root; payload[0] = first-child idx in ts_ast_children
var TS_AST_ERROR                = 2;        # placeholder when parse fails recoverably

# Expression literals (10-19)
var TS_AST_EXPR_INT             = 10;
var TS_AST_EXPR_FLOAT           = 11;
var TS_AST_EXPR_STRING          = 12;
var TS_AST_EXPR_TEMPLATE        = 13;       # payload[0] = quasi count, [1] = quasi list, [2] = expr list
var TS_AST_EXPR_REGEX           = 14;
var TS_AST_EXPR_TRUE            = 15;
var TS_AST_EXPR_FALSE           = 16;
var TS_AST_EXPR_NULL            = 17;
var TS_AST_EXPR_UNDEFINED       = 18;
var TS_AST_EXPR_THIS            = 19;

# Expression composites (20-49)
var TS_AST_EXPR_SUPER           = 20;
var TS_AST_EXPR_IDENT           = 21;       # payload[0] = name span
var TS_AST_EXPR_MEMBER          = 22;       # payload[0] = receiver, [1] = name span
var TS_AST_EXPR_OPTIONAL_MEMBER = 23;       # a?.b
var TS_AST_EXPR_INDEX           = 24;       # payload[0] = receiver, [1] = index expr
var TS_AST_EXPR_CALL            = 25;       # payload[0] = callee, [1] = args list
var TS_AST_EXPR_OPTIONAL_CALL   = 26;       # a?.()
var TS_AST_EXPR_NEW             = 27;       # payload[0] = constructor, [1] = args list
var TS_AST_EXPR_UNARY           = 28;       # payload[0] = op (token type), [1] = operand
var TS_AST_EXPR_BINARY          = 29;       # payload[0] = op, [1] = lhs, [2] = rhs
var TS_AST_EXPR_TERNARY         = 30;       # payload[0] = cond, [1] = then, [2] = else
var TS_AST_EXPR_ASSIGN          = 31;       # payload[0] = op, [1] = lhs, [2] = rhs
var TS_AST_EXPR_ARROW           = 32;       # payload[0] = params list, [1] = body, [2] = return type
var TS_AST_EXPR_ARRAY           = 33;       # payload[0] = elements list
var TS_AST_EXPR_OBJECT          = 34;       # payload[0] = properties list
var TS_AST_EXPR_SPREAD          = 35;       # payload[0] = operand
var TS_AST_EXPR_TYPE_ASSERT     = 36;       # x as T  ; payload[0] = expr, [1] = type
var TS_AST_EXPR_NON_NULL        = 37;       # x!      ; payload[0] = operand
var TS_AST_EXPR_POSTFIX         = 38;       # x++ x-- ; payload[0] = op, [1] = operand
var TS_AST_EXPR_PAREN           = 39;       # (x)     ; payload[0] = inner

# Statements (100-199)
var TS_AST_STMT_BLOCK           = 100;      # payload[0] = stmt list
var TS_AST_STMT_EXPR            = 101;      # payload[0] = expr
var TS_AST_STMT_IF              = 102;      # payload[0] = cond, [1] = then, [2] = else (optional)
var TS_AST_STMT_FOR             = 103;      # payload[0] = init, [1] = cond, [2] = update, [3] = body
var TS_AST_STMT_FOR_OF          = 104;      # payload[0] = decl/lhs, [1] = expr, [2] = body
var TS_AST_STMT_FOR_IN          = 105;      # same shape as FOR_OF
var TS_AST_STMT_WHILE           = 106;      # payload[0] = cond, [1] = body
var TS_AST_STMT_DO_WHILE        = 107;      # payload[0] = body, [1] = cond
var TS_AST_STMT_RETURN          = 108;      # payload[0] = expr (optional)
var TS_AST_STMT_THROW           = 109;      # payload[0] = expr
var TS_AST_STMT_BREAK           = 110;      # payload[0] = label (optional name span)
var TS_AST_STMT_CONTINUE        = 111;
var TS_AST_STMT_TRY             = 112;      # payload[0] = try, [1] = catch, [2] = finally
var TS_AST_STMT_CATCH_CLAUSE    = 113;      # payload[0] = param name, [1] = body
var TS_AST_STMT_SWITCH          = 114;      # payload[0] = expr, [1] = case list
var TS_AST_STMT_SWITCH_CASE     = 115;      # payload[0] = expr (null = default), [1] = stmt list
var TS_AST_STMT_LABELED         = 116;      # payload[0] = label name, [1] = stmt
var TS_AST_STMT_VAR_DECL        = 117;      # payload[0] = kind (var/let/const), [1] = bindings list

# Declarations (200-299)
var TS_AST_DECL_FUNCTION        = 200;      # payload: name, type-params, params, return-type, body
var TS_AST_DECL_CLASS           = 201;      # payload: name, type-params, extends, implements, members
var TS_AST_DECL_INTERFACE       = 202;
var TS_AST_DECL_TYPE_ALIAS      = 203;      # payload: name, type-params, type
var TS_AST_DECL_VAR_BINDING     = 204;      # payload[0] = pattern, [1] = type, [2] = init
var TS_AST_DECL_PARAM           = 205;      # payload: name, type, default, modifiers
var TS_AST_DECL_PROPERTY        = 206;      # class field; payload: name, type, init, modifiers
var TS_AST_DECL_METHOD          = 207;      # payload: kind (method/get/set), name, params, return-type, body, modifiers
var TS_AST_DECL_CONSTRUCTOR     = 208;
var TS_AST_DECL_TYPE_PARAM      = 209;      # generic type param; payload: name, constraint, default

# Type expressions (300-399)
var TS_AST_TYPE_PRIMITIVE       = 300;      # payload[0] = primitive kind (string/number/etc.)
var TS_AST_TYPE_REF             = 301;      # payload[0] = name span, [1] = type-args list
var TS_AST_TYPE_ARRAY           = 302;      # payload[0] = element type
var TS_AST_TYPE_TUPLE           = 303;      # payload[0] = elements list
var TS_AST_TYPE_UNION           = 304;      # payload[0] = members list
var TS_AST_TYPE_INTERSECTION    = 305;      # payload[0] = members list
var TS_AST_TYPE_FN              = 306;      # payload: type-params, params, return
var TS_AST_TYPE_OBJECT          = 307;      # payload[0] = members list
var TS_AST_TYPE_INDEX_SIG       = 308;      # [k: K]: V
var TS_AST_TYPE_KEYOF           = 309;      # keyof T
var TS_AST_TYPE_TYPEOF          = 310;      # typeof x (in type pos)
var TS_AST_TYPE_LITERAL         = 311;      # 'foo' as a type
var TS_AST_TYPE_PAREN           = 312;
var TS_AST_TYPE_OPTIONAL        = 313;      # T? (type with ? marker; rare in TS, mainly tuple elements)

# Module statements (400-499)
var TS_AST_IMPORT               = 400;      # payload[0] = specifiers list, [1] = source string span
var TS_AST_IMPORT_DEFAULT       = 401;      # default import specifier
var TS_AST_IMPORT_NAMED         = 402;      # { x } / { x as y } specifier
var TS_AST_IMPORT_NAMESPACE     = 403;      # * as ns
var TS_AST_EXPORT               = 404;      # payload[0] = decl
var TS_AST_EXPORT_DEFAULT       = 405;
var TS_AST_EXPORT_NAMED         = 406;      # named re-export specifier
var TS_AST_EXPORT_ALL           = 407;      # export * from "..."

# Patterns (destructuring) (500-599)
var TS_AST_PATTERN_IDENT        = 500;      # payload[0] = name span
var TS_AST_PATTERN_OBJECT       = 501;      # payload[0] = properties list
var TS_AST_PATTERN_ARRAY        = 502;      # payload[0] = elements list
var TS_AST_PATTERN_REST         = 503;      # ...rest
var TS_AST_PATTERN_DEFAULT      = 504;      # x = default

# Misc (600-699) — template parts, arg-list wrappers, etc.
var TS_AST_TEMPLATE_QUASI       = 600;      # the literal-text chunks of a template
var TS_AST_PROPERTY_ASSIGN      = 601;      # k: v in object literals
var TS_AST_SHORTHAND_PROP       = 602;      # { x } shorthand

# ================================================================
# AST node helpers
# ================================================================

# Push a new AST node. Returns the node's index, or -1 on cap exceeded.
# The caller fills payloads via TS_AST_SET_PAYLOAD afterward.
fn TS_AST_PUSH(ts_base, kind, span) {
    var n = load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_NODE_COUNT);
    if (n >= TS_AST_NODE_CAP) {
        store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_CODE, 1);
        return 0 - 1;
    }
    var addr = ts_base + TS_AST_NODES_OFF + n * TS_AST_NODE_SIZE;
    store64(addr,      kind);
    store64(addr + 8,  span);
    store64(addr + 16, 0);
    store64(addr + 24, 0);
    store64(addr + 32, 0);
    store64(addr + 40, 0);
    store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_NODE_COUNT, n + 1);
    return n;
}

fn TS_AST_KIND(ts_base, idx) {
    return load64(ts_base + TS_AST_NODES_OFF + idx * TS_AST_NODE_SIZE);
}

fn TS_AST_SPAN(ts_base, idx) {
    return load64(ts_base + TS_AST_NODES_OFF + idx * TS_AST_NODE_SIZE + 8);
}

# Read payload[slot] (slot in 0..3).
fn TS_AST_PAYLOAD(ts_base, idx, slot) {
    return load64(ts_base + TS_AST_NODES_OFF + idx * TS_AST_NODE_SIZE + 16 + slot * 8);
}

# Write payload[slot]. Returns 0.
fn TS_AST_SET_PAYLOAD(ts_base, idx, slot, val) {
    store64(ts_base + TS_AST_NODES_OFF + idx * TS_AST_NODE_SIZE + 16 + slot * 8, val);
    return 0;
}

fn TS_AST_NODE_COUNT(ts_base) {
    return load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_NODE_COUNT);
}

# Allocate a children-list. Returns the offset (i64 entries) into
# TS_AST_CHILDREN_OFF where the caller writes child indices, terminated
# by -1. Caller is responsible for advancing TS_PS_CHILDREN_USED via
# TS_AST_CHILDREN_APPEND or directly.
#
# Returns the start offset (i64-index, not bytes), or -1 on cap.
fn TS_AST_CHILDREN_RESERVE(ts_base, count) {
    var used = load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_CHILDREN_USED);
    # +1 for the -1 terminator
    if (used + count + 1 > TS_AST_CHILDREN_CAP) {
        store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_CODE, 2);
        return 0 - 1;
    }
    return used;
}

# Write child index `child_idx` at children[at]. Returns 0.
fn TS_AST_CHILDREN_SET(ts_base, at, child_idx) {
    store64(ts_base + TS_AST_CHILDREN_OFF + at * 8, child_idx);
    return 0;
}

fn TS_AST_CHILDREN_GET(ts_base, at) {
    return load64(ts_base + TS_AST_CHILDREN_OFF + at * 8);
}

# Bump children-used to account for `count` newly-written entries.
fn TS_AST_CHILDREN_COMMIT(ts_base, count) {
    var used = load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_CHILDREN_USED);
    store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_CHILDREN_USED, used + count);
    return 0;
}

# ================================================================
# Token-stream helpers (parser walks tokens emitted by TS_LEX)
# ================================================================

fn TS_PARSE_PEEK(ts_base) {
    var i = load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_TOK_IDX);
    return TS_PEEKT(ts_base, i);
}

fn TS_PARSE_PEEK_AHEAD(ts_base, n) {
    var i = load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_TOK_IDX);
    return TS_PEEKT(ts_base, i + n);
}

fn TS_PARSE_TOK_VAL(ts_base) {
    var i = load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_TOK_IDX);
    return load64(ts_base + TS_TOK_VALUES_OFF + i * 8);
}

fn TS_PARSE_TOK_LINE(ts_base) {
    var i = load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_TOK_IDX);
    return load64(ts_base + TS_TOK_LINES_OFF + i * 8);
}

fn TS_PARSE_CONSUME(ts_base) {
    var i = load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_TOK_IDX);
    store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_TOK_IDX, i + 1);
    return 0;
}

# Expect a specific token kind at current position. Consumes it on
# match, sets ERR_CODE 3 + ERR_TOK_IDX on miss. Returns 0 / -1.
fn TS_PARSE_EXPECT(ts_base, kind) {
    if (TS_PARSE_PEEK(ts_base) != kind) {
        store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_CODE, 3);
        store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_TOK_IDX,
                load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_TOK_IDX));
        return 0 - 1;
    }
    TS_PARSE_CONSUME(ts_base);
    return 0;
}

# Optionally consume a token if it matches. Returns 1 if consumed, 0 if not.
fn TS_PARSE_MATCH(ts_base, kind) {
    if (TS_PARSE_PEEK(ts_base) == kind) {
        TS_PARSE_CONSUME(ts_base);
        return 1;
    }
    return 0;
}

fn TS_PARSE_GETERR(ts_base) {
    return load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_CODE);
}

fn TS_PARSE_GETERR_TOK(ts_base) {
    return load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_TOK_IDX);
}

# ================================================================
# Parser state init
# ================================================================

fn TS_PARSE_INIT(ts_base) {
    store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_NODE_COUNT, 0);
    store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_TOK_IDX, 0);
    store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_CHILDREN_USED, 0);
    store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_CODE, 0);
    store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_TOK_IDX, 0);
    store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ROOT_NODE, 0);
    return 0;
}

# ================================================================
# Expression parser (P2.2)
# ================================================================
#
# Pratt-style precedence climbing. Levels (low -> high):
#
#   level   ops                                          assoc
#   1       , (sequence)                                 left  — TS's comma; not parsed here
#   2       =, +=, -=, *=, /=, %=, **=, <<=, >>=, >>>=, right
#           &=, |=, ^=, &&=, ||=, ??=                    right
#   3       ? :                                          right
#   4       || ??                                        left
#   5       &&                                           left
#   6       |                                            left
#   7       ^                                            left
#   8       &                                            left
#   9       == != === !==                                left
#   10      < > <= >= in instanceof                      left
#   11      << >> >>>                                    left
#   12      + -                                          left
#   13      * / %                                        left
#   14      ** (right-assoc, handled via min_prec=14)    right
#   15      unary prefix (!, ~, +, -, ++, --, typeof,    right (RTL)
#           void, delete, await)
#   16      postfix (++, --, !)                          left (chain)
#   17      member/index/call/new (LTR chain)            left
#   18      primary (literal, ident, paren, array,
#           object, template)
#
# Each TS_PARSE_* fn returns AST node index on success, -1 on error.

# Returns 1 if op is an assignment (any of =, +=, -=, ...).
fn TS_IS_ASSIGN_OP(op) {
    if (op == TS_TOK_EQ)            { return 1; }
    if (op == TS_TOK_PLUS_EQ)       { return 1; }
    if (op == TS_TOK_MINUS_EQ)      { return 1; }
    if (op == TS_TOK_STAR_EQ)       { return 1; }
    if (op == TS_TOK_SLASH_EQ)      { return 1; }
    if (op == TS_TOK_PERCENT_EQ)    { return 1; }
    if (op == TS_TOK_STAR_STAR_EQ)  { return 1; }
    if (op == TS_TOK_LT_LT_EQ)      { return 1; }
    if (op == TS_TOK_GT_GT_EQ)      { return 1; }
    if (op == TS_TOK_GT_GT_GT_EQ)   { return 1; }
    if (op == TS_TOK_AMP_EQ)        { return 1; }
    if (op == TS_TOK_PIPE_EQ)       { return 1; }
    if (op == TS_TOK_CARET_EQ)      { return 1; }
    if (op == TS_TOK_AMP_AMP_EQ)    { return 1; }
    if (op == TS_TOK_PIPE_PIPE_EQ)  { return 1; }
    if (op == TS_TOK_QQ_EQ)         { return 1; }
    return 0;
}

# Returns binary precedence (1-14) or 0 if op is not binary.
# Used by TS_PARSE_BINARY for precedence climbing.
fn TS_BINARY_PREC(op) {
    if (op == TS_TOK_PIPE_PIPE)     { return 4; }
    if (op == TS_TOK_QQ)            { return 4; }
    if (op == TS_TOK_AMP_AMP)       { return 5; }
    if (op == TS_TOK_PIPE)          { return 6; }
    if (op == TS_TOK_CARET)         { return 7; }
    if (op == TS_TOK_AMP)           { return 8; }
    if (op == TS_TOK_EQ_EQ)         { return 9; }
    if (op == TS_TOK_BANG_EQ)       { return 9; }
    if (op == TS_TOK_EQ_EQ_EQ)      { return 9; }
    if (op == TS_TOK_BANG_EQ_EQ)    { return 9; }
    if (op == TS_TOK_LT)            { return 10; }
    if (op == TS_TOK_GT)            { return 10; }
    if (op == TS_TOK_LT_EQ)         { return 10; }
    if (op == TS_TOK_GT_EQ)         { return 10; }
    if (op == TS_TOK_KW_IN)         { return 10; }
    if (op == TS_TOK_KW_INSTANCEOF) { return 10; }
    if (op == TS_TOK_LT_LT)         { return 11; }
    if (op == TS_TOK_GT_GT)         { return 11; }
    if (op == TS_TOK_GT_GT_GT)      { return 11; }
    if (op == TS_TOK_PLUS)          { return 12; }
    if (op == TS_TOK_MINUS)         { return 12; }
    if (op == TS_TOK_STAR)          { return 13; }
    if (op == TS_TOK_SLASH)         { return 13; }
    if (op == TS_TOK_PERCENT)       { return 13; }
    if (op == TS_TOK_STAR_STAR)     { return 14; }
    return 0;
}

# Mutual recursion: TS_PARSE_PRIMARY <-> TS_PARSE_EXPR (parens) and
# TS_PARSE_ARGS -> TS_PARSE_EXPR. cyrius's 2-pass parser handles
# forward references automatically (PASS_1 registers all fn names),
# so we don't need C-style prototypes.

# Parse comma-separated argument list inside `(...)`. Caller has
# already consumed the opening `(`. Stores child indices into
# ts_ast_children, terminated by -1; returns the children-offset
# (i64-index, not bytes). Caller sets that as a payload of the call/new node.
# Returns -1 on error.
fn TS_PARSE_ARGS(ts_base) {
    var off = TS_AST_CHILDREN_RESERVE(ts_base, 16);  # initial guess; can grow
    if (off < 0) { return 0 - 1; }
    var i = 0;
    if (TS_PARSE_PEEK(ts_base) != TS_TOK_RPAREN) {
        var done = 0;
        while (done == 0) {
            # Spread arg ...x
            if (TS_PARSE_PEEK(ts_base) == TS_TOK_ELLIPSIS) {
                TS_PARSE_CONSUME(ts_base);
                var inner = TS_PARSE_EXPR(ts_base);
                if (inner < 0) { return 0 - 1; }
                var sp = TS_AST_PUSH(ts_base, TS_AST_EXPR_SPREAD, 0);
                if (sp < 0) { return 0 - 1; }
                TS_AST_SET_PAYLOAD(ts_base, sp, 0, inner);
                TS_AST_CHILDREN_SET(ts_base, off + i, sp);
            } else {
                var e = TS_PARSE_EXPR(ts_base);
                if (e < 0) { return 0 - 1; }
                TS_AST_CHILDREN_SET(ts_base, off + i, e);
            }
            i = i + 1;
            if (TS_PARSE_MATCH(ts_base, TS_TOK_COMMA) == 0) { done = 1; }
        }
    }
    TS_AST_CHILDREN_SET(ts_base, off + i, 0 - 1);   # sentinel
    TS_AST_CHILDREN_COMMIT(ts_base, i + 1);
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_RPAREN) < 0) { return 0 - 1; }
    return off;
}

# Parse array literal: [e1, e2, ...e3]. Caller has consumed [.
# Returns the array node index.
fn TS_PARSE_ARRAY_LITERAL(ts_base) {
    var span = TS_PARSE_TOK_VAL(ts_base);
    var node = TS_AST_PUSH(ts_base, TS_AST_EXPR_ARRAY, span);
    if (node < 0) { return 0 - 1; }
    var off = TS_AST_CHILDREN_RESERVE(ts_base, 16);
    if (off < 0) { return 0 - 1; }
    var i = 0;
    if (TS_PARSE_PEEK(ts_base) != TS_TOK_RBRACKET) {
        var done = 0;
        while (done == 0) {
            if (TS_PARSE_PEEK(ts_base) == TS_TOK_ELLIPSIS) {
                TS_PARSE_CONSUME(ts_base);
                var inner = TS_PARSE_EXPR(ts_base);
                if (inner < 0) { return 0 - 1; }
                var sp = TS_AST_PUSH(ts_base, TS_AST_EXPR_SPREAD, 0);
                if (sp < 0) { return 0 - 1; }
                TS_AST_SET_PAYLOAD(ts_base, sp, 0, inner);
                TS_AST_CHILDREN_SET(ts_base, off + i, sp);
            } else {
                var e = TS_PARSE_EXPR(ts_base);
                if (e < 0) { return 0 - 1; }
                TS_AST_CHILDREN_SET(ts_base, off + i, e);
            }
            i = i + 1;
            if (TS_PARSE_MATCH(ts_base, TS_TOK_COMMA) == 0) { done = 1; }
        }
    }
    TS_AST_CHILDREN_SET(ts_base, off + i, 0 - 1);
    TS_AST_CHILDREN_COMMIT(ts_base, i + 1);
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_RBRACKET) < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, node, 0, off);
    return node;
}

# Parse object literal: {k: v, k2: v2, k3, ...spread}. Caller has consumed {.
# Each property is a PROPERTY_ASSIGN node (k:v) or SHORTHAND_PROP (k) or SPREAD.
fn TS_PARSE_OBJECT_LITERAL(ts_base) {
    var span = TS_PARSE_TOK_VAL(ts_base);
    var node = TS_AST_PUSH(ts_base, TS_AST_EXPR_OBJECT, span);
    if (node < 0) { return 0 - 1; }
    var off = TS_AST_CHILDREN_RESERVE(ts_base, 16);
    if (off < 0) { return 0 - 1; }
    var i = 0;
    if (TS_PARSE_PEEK(ts_base) != TS_TOK_RBRACE) {
        var done = 0;
        while (done == 0) {
            var t = TS_PARSE_PEEK(ts_base);
            if (t == TS_TOK_ELLIPSIS) {
                TS_PARSE_CONSUME(ts_base);
                var inner = TS_PARSE_EXPR(ts_base);
                if (inner < 0) { return 0 - 1; }
                var sp = TS_AST_PUSH(ts_base, TS_AST_EXPR_SPREAD, 0);
                if (sp < 0) { return 0 - 1; }
                TS_AST_SET_PAYLOAD(ts_base, sp, 0, inner);
                TS_AST_CHILDREN_SET(ts_base, off + i, sp);
            } else {
                # Property: key [: value]
                var key_span = TS_PARSE_TOK_VAL(ts_base);
                # Accept IDENT, STRING, INT as property names.
                # (Computed [expr]: deferred for v5.7.x.)
                if (t != TS_TOK_IDENT && t != TS_TOK_STRING && t != TS_TOK_INT) {
                    store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_CODE, 4);
                    return 0 - 1;
                }
                TS_PARSE_CONSUME(ts_base);
                if (TS_PARSE_PEEK(ts_base) == TS_TOK_COLON) {
                    TS_PARSE_CONSUME(ts_base);
                    var v = TS_PARSE_EXPR(ts_base);
                    if (v < 0) { return 0 - 1; }
                    var pa = TS_AST_PUSH(ts_base, TS_AST_PROPERTY_ASSIGN, key_span);
                    if (pa < 0) { return 0 - 1; }
                    TS_AST_SET_PAYLOAD(ts_base, pa, 0, key_span);
                    TS_AST_SET_PAYLOAD(ts_base, pa, 1, v);
                    TS_AST_CHILDREN_SET(ts_base, off + i, pa);
                } else {
                    # Shorthand: { x } sugar for { x: x }
                    var sh = TS_AST_PUSH(ts_base, TS_AST_SHORTHAND_PROP, key_span);
                    if (sh < 0) { return 0 - 1; }
                    TS_AST_SET_PAYLOAD(ts_base, sh, 0, key_span);
                    TS_AST_CHILDREN_SET(ts_base, off + i, sh);
                }
            }
            i = i + 1;
            if (TS_PARSE_MATCH(ts_base, TS_TOK_COMMA) == 0) { done = 1; }
        }
    }
    TS_AST_CHILDREN_SET(ts_base, off + i, 0 - 1);
    TS_AST_CHILDREN_COMMIT(ts_base, i + 1);
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_RBRACE) < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, node, 0, off);
    return node;
}

# Parse a template literal. Caller has just observed TEMPLATE_NOSUB
# (single chunk) or TEMPLATE_HEAD (start of an interpolated chain).
# For NOSUB: consume + emit single TEMPLATE node.
# For HEAD: emit TEMPLATE node with quasi list + expr list interleaved.
fn TS_PARSE_TEMPLATE(ts_base) {
    var span = TS_PARSE_TOK_VAL(ts_base);
    var node = TS_AST_PUSH(ts_base, TS_AST_EXPR_TEMPLATE, span);
    if (node < 0) { return 0 - 1; }

    if (TS_PARSE_PEEK(ts_base) == TS_TOK_TEMPLATE_NOSUB) {
        # Single chunk; just attach the quasi span.
        var q_off = TS_AST_CHILDREN_RESERVE(ts_base, 2);
        if (q_off < 0) { return 0 - 1; }
        var q = TS_AST_PUSH(ts_base, TS_AST_TEMPLATE_QUASI, span);
        TS_AST_CHILDREN_SET(ts_base, q_off, q);
        TS_AST_CHILDREN_SET(ts_base, q_off + 1, 0 - 1);
        TS_AST_CHILDREN_COMMIT(ts_base, 2);
        TS_AST_SET_PAYLOAD(ts_base, node, 0, q_off);
        TS_PARSE_CONSUME(ts_base);
        return node;
    }

    # Interpolated path: HEAD expr (MID expr)* TAIL
    var q_off = TS_AST_CHILDREN_RESERVE(ts_base, 32);
    if (q_off < 0) { return 0 - 1; }
    var e_off = TS_AST_CHILDREN_RESERVE(ts_base, 32);
    if (e_off < 0) { return 0 - 1; }
    var qi = 0;
    var ei = 0;

    # HEAD
    var head_span = TS_PARSE_TOK_VAL(ts_base);
    var head_q = TS_AST_PUSH(ts_base, TS_AST_TEMPLATE_QUASI, head_span);
    TS_AST_CHILDREN_SET(ts_base, q_off + qi, head_q);
    qi = qi + 1;
    TS_PARSE_CONSUME(ts_base);

    var done = 0;
    while (done == 0) {
        # Expression inside ${}
        var e = TS_PARSE_EXPR(ts_base);
        if (e < 0) { return 0 - 1; }
        TS_AST_CHILDREN_SET(ts_base, e_off + ei, e);
        ei = ei + 1;
        # Followed by MID (more interps) or TAIL (end)
        var t = TS_PARSE_PEEK(ts_base);
        var part_span = TS_PARSE_TOK_VAL(ts_base);
        var part_q = TS_AST_PUSH(ts_base, TS_AST_TEMPLATE_QUASI, part_span);
        TS_AST_CHILDREN_SET(ts_base, q_off + qi, part_q);
        qi = qi + 1;
        TS_PARSE_CONSUME(ts_base);
        if (t == TS_TOK_TEMPLATE_TAIL) { done = 1; }
        elif (t != TS_TOK_TEMPLATE_MID) {
            store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_CODE, 5);
            return 0 - 1;
        }
    }
    TS_AST_CHILDREN_SET(ts_base, q_off + qi, 0 - 1);
    TS_AST_CHILDREN_SET(ts_base, e_off + ei, 0 - 1);
    TS_AST_CHILDREN_COMMIT(ts_base, qi + 1 + ei + 1);
    TS_AST_SET_PAYLOAD(ts_base, node, 0, q_off);
    TS_AST_SET_PAYLOAD(ts_base, node, 1, e_off);
    return node;
}

# Primary: literal, identifier, paren, array, object, template, regex,
# this/super, true/false/null/undefined.
# (Arrow functions deferred — need lookahead to disambiguate from
#  parenthesized expressions; punted to P2.3 with the rest of the
#  statements/decls work.)
fn TS_PARSE_PRIMARY(ts_base) {
    var t = TS_PARSE_PEEK(ts_base);
    var v = TS_PARSE_TOK_VAL(ts_base);

    if (t == TS_TOK_INT) {
        var n = TS_AST_PUSH(ts_base, TS_AST_EXPR_INT, v);
        TS_PARSE_CONSUME(ts_base);
        return n;
    }
    if (t == TS_TOK_FLOAT) {
        var n = TS_AST_PUSH(ts_base, TS_AST_EXPR_FLOAT, v);
        TS_PARSE_CONSUME(ts_base);
        return n;
    }
    if (t == TS_TOK_STRING) {
        var n = TS_AST_PUSH(ts_base, TS_AST_EXPR_STRING, v);
        TS_PARSE_CONSUME(ts_base);
        return n;
    }
    if (t == TS_TOK_REGEX) {
        var n = TS_AST_PUSH(ts_base, TS_AST_EXPR_REGEX, v);
        TS_PARSE_CONSUME(ts_base);
        return n;
    }
    if (t == TS_TOK_KW_TRUE) {
        var n = TS_AST_PUSH(ts_base, TS_AST_EXPR_TRUE, 0);
        TS_PARSE_CONSUME(ts_base);
        return n;
    }
    if (t == TS_TOK_KW_FALSE) {
        var n = TS_AST_PUSH(ts_base, TS_AST_EXPR_FALSE, 0);
        TS_PARSE_CONSUME(ts_base);
        return n;
    }
    if (t == TS_TOK_KW_NULL) {
        var n = TS_AST_PUSH(ts_base, TS_AST_EXPR_NULL, 0);
        TS_PARSE_CONSUME(ts_base);
        return n;
    }
    if (t == TS_TOK_KW_UNDEFINED) {
        var n = TS_AST_PUSH(ts_base, TS_AST_EXPR_UNDEFINED, 0);
        TS_PARSE_CONSUME(ts_base);
        return n;
    }
    if (t == TS_TOK_KW_THIS) {
        var n = TS_AST_PUSH(ts_base, TS_AST_EXPR_THIS, 0);
        TS_PARSE_CONSUME(ts_base);
        return n;
    }
    if (t == TS_TOK_KW_SUPER) {
        var n = TS_AST_PUSH(ts_base, TS_AST_EXPR_SUPER, 0);
        TS_PARSE_CONSUME(ts_base);
        return n;
    }
    # Identifier (real ident OR contextual keyword used as ident).
    # We accept the same set that TS_IS_PRIMARY_CONTEXT accepts as
    # property-name-eligible.
    if (t == TS_TOK_IDENT
        || t == TS_TOK_KW_FROM || t == TS_TOK_KW_AS
        || t == TS_TOK_KW_OF   || t == TS_TOK_KW_GET
        || t == TS_TOK_KW_SET  || t == TS_TOK_KW_TYPE) {
        # Bare-ident arrow:  x => body
        if (TS_PARSE_PEEK_AHEAD(ts_base, 1) == TS_TOK_ARROW) {
            return TS_PARSE_ARROW_SINGLE_IDENT(ts_base);
        }
        var n = TS_AST_PUSH(ts_base, TS_AST_EXPR_IDENT, v);
        TS_AST_SET_PAYLOAD(ts_base, n, 0, v);
        TS_PARSE_CONSUME(ts_base);
        return n;
    }
    # Function expression: `function [name] (params) [: ret] { body }`
    if (t == TS_TOK_KW_FUNCTION) {
        TS_PARSE_CONSUME(ts_base);
        return TS_PARSE_DECL_FUNCTION(ts_base, 0);   # name optional
    }
    # Class expression: `class [name] [...] { ... }` — rare but legal.
    if (t == TS_TOK_KW_CLASS) {
        TS_PARSE_CONSUME(ts_base);
        return TS_PARSE_DECL_CLASS(ts_base);
    }
    # Parenthesized expression OR paren-arrow function.
    # Disambiguate by scanning past the matching RPAREN.
    if (t == TS_TOK_LPAREN) {
        if (TS_LOOKAHEAD_IS_ARROW(ts_base) == 1) {
            return TS_PARSE_ARROW_PAREN(ts_base);
        }
        TS_PARSE_CONSUME(ts_base);
        var inner = TS_PARSE_EXPR(ts_base);
        if (inner < 0) { return 0 - 1; }
        if (TS_PARSE_EXPECT(ts_base, TS_TOK_RPAREN) < 0) { return 0 - 1; }
        var n = TS_AST_PUSH(ts_base, TS_AST_EXPR_PAREN, 0);
        TS_AST_SET_PAYLOAD(ts_base, n, 0, inner);
        return n;
    }
    # Array literal
    if (t == TS_TOK_LBRACKET) {
        TS_PARSE_CONSUME(ts_base);
        return TS_PARSE_ARRAY_LITERAL(ts_base);
    }
    # Object literal
    if (t == TS_TOK_LBRACE) {
        TS_PARSE_CONSUME(ts_base);
        return TS_PARSE_OBJECT_LITERAL(ts_base);
    }
    # Template literal
    if (t == TS_TOK_TEMPLATE_NOSUB || t == TS_TOK_TEMPLATE_HEAD) {
        return TS_PARSE_TEMPLATE(ts_base);
    }
    # Unexpected
    store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_CODE, 6);
    store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_TOK_IDX,
            load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_TOK_IDX));
    return 0 - 1;
}

# new Target(args) — supports `new new Foo()` chain via recursion.
# Per spec, `new X` (no args) is also valid.
fn TS_PARSE_NEW(ts_base) {
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_KW_NEW) {
        TS_PARSE_CONSUME(ts_base);
        var ctor = TS_PARSE_NEW(ts_base);
        if (ctor < 0) { return 0 - 1; }
        var n = TS_AST_PUSH(ts_base, TS_AST_EXPR_NEW, 0);
        if (n < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, n, 0, ctor);
        if (TS_PARSE_PEEK(ts_base) == TS_TOK_LPAREN) {
            TS_PARSE_CONSUME(ts_base);
            var args = TS_PARSE_ARGS(ts_base);
            if (args < 0) { return 0 - 1; }
            TS_AST_SET_PAYLOAD(ts_base, n, 1, args);
        } else {
            TS_AST_SET_PAYLOAD(ts_base, n, 1, 0 - 1);   # no args
        }
        return n;
    }
    return TS_PARSE_PRIMARY(ts_base);
}

# Member / index / call chain (left-associative). After parsing the
# leftmost primary/new, repeatedly extend with .foo, ?.foo, [idx],
# (args), ?.( args ), ?.[ idx ].
fn TS_PARSE_CALL_MEMBER(ts_base) {
    var expr = TS_PARSE_NEW(ts_base);
    if (expr < 0) { return 0 - 1; }
    var go = 1;
    while (go == 1) {
        var t = TS_PARSE_PEEK(ts_base);
        if (t == TS_TOK_DOT) {
            TS_PARSE_CONSUME(ts_base);
            var name_t = TS_PARSE_PEEK(ts_base);
            # Member name accepts ident + most keywords (TS allows
            # `obj.return`, etc. as property access).
            var name_v = TS_PARSE_TOK_VAL(ts_base);
            TS_PARSE_CONSUME(ts_base);
            var dn = TS_AST_PUSH(ts_base, TS_AST_EXPR_MEMBER, 0);
            if (dn < 0) { return 0 - 1; }
            TS_AST_SET_PAYLOAD(ts_base, dn, 0, expr);
            TS_AST_SET_PAYLOAD(ts_base, dn, 1, name_v);
            expr = dn;
        } elif (t == TS_TOK_Q_DOT) {
            TS_PARSE_CONSUME(ts_base);
            var nt = TS_PARSE_PEEK(ts_base);
            if (nt == TS_TOK_LPAREN) {
                # Optional call: a?.()
                TS_PARSE_CONSUME(ts_base);
                var args = TS_PARSE_ARGS(ts_base);
                if (args < 0) { return 0 - 1; }
                var oc = TS_AST_PUSH(ts_base, TS_AST_EXPR_OPTIONAL_CALL, 0);
                if (oc < 0) { return 0 - 1; }
                TS_AST_SET_PAYLOAD(ts_base, oc, 0, expr);
                TS_AST_SET_PAYLOAD(ts_base, oc, 1, args);
                expr = oc;
            } elif (nt == TS_TOK_LBRACKET) {
                # Optional index: a?.[idx]
                TS_PARSE_CONSUME(ts_base);
                var idx = TS_PARSE_EXPR(ts_base);
                if (idx < 0) { return 0 - 1; }
                if (TS_PARSE_EXPECT(ts_base, TS_TOK_RBRACKET) < 0) { return 0 - 1; }
                var oi = TS_AST_PUSH(ts_base, TS_AST_EXPR_OPTIONAL_MEMBER, 0);
                if (oi < 0) { return 0 - 1; }
                TS_AST_SET_PAYLOAD(ts_base, oi, 0, expr);
                TS_AST_SET_PAYLOAD(ts_base, oi, 1, idx);
                TS_AST_SET_PAYLOAD(ts_base, oi, 2, 1);   # marker: index-shape
                expr = oi;
            } else {
                # Optional member: a?.b
                var name_v2 = TS_PARSE_TOK_VAL(ts_base);
                TS_PARSE_CONSUME(ts_base);
                var om = TS_AST_PUSH(ts_base, TS_AST_EXPR_OPTIONAL_MEMBER, 0);
                if (om < 0) { return 0 - 1; }
                TS_AST_SET_PAYLOAD(ts_base, om, 0, expr);
                TS_AST_SET_PAYLOAD(ts_base, om, 1, name_v2);
                expr = om;
            }
        } elif (t == TS_TOK_LBRACKET) {
            TS_PARSE_CONSUME(ts_base);
            var idx2 = TS_PARSE_EXPR(ts_base);
            if (idx2 < 0) { return 0 - 1; }
            if (TS_PARSE_EXPECT(ts_base, TS_TOK_RBRACKET) < 0) { return 0 - 1; }
            var ix = TS_AST_PUSH(ts_base, TS_AST_EXPR_INDEX, 0);
            if (ix < 0) { return 0 - 1; }
            TS_AST_SET_PAYLOAD(ts_base, ix, 0, expr);
            TS_AST_SET_PAYLOAD(ts_base, ix, 1, idx2);
            expr = ix;
        } elif (t == TS_TOK_LPAREN) {
            TS_PARSE_CONSUME(ts_base);
            var args2 = TS_PARSE_ARGS(ts_base);
            if (args2 < 0) { return 0 - 1; }
            var c = TS_AST_PUSH(ts_base, TS_AST_EXPR_CALL, 0);
            if (c < 0) { return 0 - 1; }
            TS_AST_SET_PAYLOAD(ts_base, c, 0, expr);
            TS_AST_SET_PAYLOAD(ts_base, c, 1, args2);
            expr = c;
        } elif (t == TS_TOK_BANG) {
            # TS postfix non-null assertion (`x!`). Belongs in the
            # call/member chain because subsequent `.foo` / `[idx]` /
            # `(args)` can follow: `arr[0]!.foo!.bar()` is legal TS.
            TS_PARSE_CONSUME(ts_base);
            var nn = TS_AST_PUSH(ts_base, TS_AST_EXPR_NON_NULL, 0);
            if (nn < 0) { return 0 - 1; }
            TS_AST_SET_PAYLOAD(ts_base, nn, 0, expr);
            expr = nn;
        } else {
            go = 0;
        }
    }
    return expr;
}

# Postfix update: ++, --. Non-null `!` is handled inside CALL_MEMBER
# above so it can interleave with .foo / [idx] / (args). ++/-- are
# pure postfix and don't chain with member access.
fn TS_PARSE_POSTFIX(ts_base) {
    var expr = TS_PARSE_CALL_MEMBER(ts_base);
    if (expr < 0) { return 0 - 1; }
    var t = TS_PARSE_PEEK(ts_base);
    if (t == TS_TOK_PLUS_PLUS || t == TS_TOK_MINUS_MINUS) {
        TS_PARSE_CONSUME(ts_base);
        var n = TS_AST_PUSH(ts_base, TS_AST_EXPR_POSTFIX, 0);
        if (n < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, n, 0, t);
        TS_AST_SET_PAYLOAD(ts_base, n, 1, expr);
        return n;
    }
    return expr;
}

# Unary prefix: !, ~, +, -, ++, --, typeof, void, delete, await.
# Right-assoc (recurses into TS_PARSE_UNARY).
fn TS_PARSE_UNARY(ts_base) {
    var t = TS_PARSE_PEEK(ts_base);
    var is_unary = 0;
    if (t == TS_TOK_BANG)        { is_unary = 1; }
    if (t == TS_TOK_TILDE)       { is_unary = 1; }
    if (t == TS_TOK_PLUS)        { is_unary = 1; }
    if (t == TS_TOK_MINUS)       { is_unary = 1; }
    if (t == TS_TOK_PLUS_PLUS)   { is_unary = 1; }
    if (t == TS_TOK_MINUS_MINUS) { is_unary = 1; }
    if (t == TS_TOK_KW_TYPEOF)   { is_unary = 1; }
    if (t == TS_TOK_KW_VOID)     { is_unary = 1; }
    if (t == TS_TOK_KW_DELETE)   { is_unary = 1; }
    if (t == TS_TOK_KW_AWAIT)    { is_unary = 1; }
    if (is_unary == 1) {
        TS_PARSE_CONSUME(ts_base);
        var operand = TS_PARSE_UNARY(ts_base);
        if (operand < 0) { return 0 - 1; }
        var n = TS_AST_PUSH(ts_base, TS_AST_EXPR_UNARY, 0);
        if (n < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, n, 0, t);
        TS_AST_SET_PAYLOAD(ts_base, n, 1, operand);
        return n;
    }
    return TS_PARSE_POSTFIX(ts_base);
}

# Binary precedence climbing. min_prec gates which binary ops we
# consume at this level. Left-assoc default; ** is right-assoc and
# uses min_prec=14 to recurse at the same level.
fn TS_PARSE_BINARY(ts_base, min_prec) {
    var lhs = TS_PARSE_UNARY(ts_base);
    if (lhs < 0) { return 0 - 1; }
    var go = 1;
    while (go == 1) {
        var op = TS_PARSE_PEEK(ts_base);
        var prec = TS_BINARY_PREC(op);
        if (prec < min_prec || prec == 0) {
            go = 0;
        } else {
            TS_PARSE_CONSUME(ts_base);
            var next_min = prec + 1;
            if (op == TS_TOK_STAR_STAR) { next_min = prec; }   # right-assoc
            var rhs = TS_PARSE_BINARY(ts_base, next_min);
            if (rhs < 0) { return 0 - 1; }
            var n = TS_AST_PUSH(ts_base, TS_AST_EXPR_BINARY, 0);
            if (n < 0) { return 0 - 1; }
            TS_AST_SET_PAYLOAD(ts_base, n, 0, op);
            TS_AST_SET_PAYLOAD(ts_base, n, 1, lhs);
            TS_AST_SET_PAYLOAD(ts_base, n, 2, rhs);
            lhs = n;
        }
    }
    return lhs;
}

# Ternary: cond ? then : else (right-assoc).
fn TS_PARSE_TERNARY(ts_base) {
    var cond = TS_PARSE_BINARY(ts_base, 4);
    if (cond < 0) { return 0 - 1; }
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_QUESTION) {
        TS_PARSE_CONSUME(ts_base);
        var then_e = TS_PARSE_ASSIGN(ts_base);
        if (then_e < 0) { return 0 - 1; }
        if (TS_PARSE_EXPECT(ts_base, TS_TOK_COLON) < 0) { return 0 - 1; }
        var else_e = TS_PARSE_ASSIGN(ts_base);
        if (else_e < 0) { return 0 - 1; }
        var n = TS_AST_PUSH(ts_base, TS_AST_EXPR_TERNARY, 0);
        if (n < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, n, 0, cond);
        TS_AST_SET_PAYLOAD(ts_base, n, 1, then_e);
        TS_AST_SET_PAYLOAD(ts_base, n, 2, else_e);
        return n;
    }
    return cond;
}

# Assignment: =, +=, etc. Right-associative.
fn TS_PARSE_ASSIGN(ts_base) {
    var lhs = TS_PARSE_TERNARY(ts_base);
    if (lhs < 0) { return 0 - 1; }
    var op = TS_PARSE_PEEK(ts_base);
    if (TS_IS_ASSIGN_OP(op) == 1) {
        TS_PARSE_CONSUME(ts_base);
        var rhs = TS_PARSE_ASSIGN(ts_base);
        if (rhs < 0) { return 0 - 1; }
        var n = TS_AST_PUSH(ts_base, TS_AST_EXPR_ASSIGN, 0);
        if (n < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, n, 0, op);
        TS_AST_SET_PAYLOAD(ts_base, n, 1, lhs);
        TS_AST_SET_PAYLOAD(ts_base, n, 2, rhs);
        return n;
    }
    return lhs;
}

# Top-level expression entry. P2.2 = assignment expr; comma operator
# (sequence) is deferred since SY rarely uses it and it complicates
# argument-list parsing.
fn TS_PARSE_EXPR(ts_base) {
    return TS_PARSE_ASSIGN(ts_base);
}

# ================================================================
# Arrow function lookahead + parsing (P2.3)
# ================================================================
#
# Disambiguation: at LPAREN, walk forward through balanced parens to
# the matching RPAREN. If next token is `=>`, or `:` followed
# eventually by `=>` (return type annotation), it's an arrow function.
# Otherwise it's a parenthesized expression. Doesn't advance the
# real tok_idx — peeks via TS_PEEKT(ts_base, i).
#
# For the `:` case, scan for `=>` while remaining at top-level (don't
# get fooled by `?:` ternary inside type expressions). Stop at `;`,
# `{`, EOF — those mean we're past the arrow boundary already.

fn TS_LOOKAHEAD_IS_ARROW(ts_base) {
    var start = load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_TOK_IDX);
    var i = start + 1;                       # past the LPAREN
    var depth = 1;
    var done = 0;
    var max_scan = start + 4096;             # bound the scan
    while (done == 0) {
        if (i >= max_scan) { return 0; }
        var t = TS_PEEKT(ts_base, i);
        if (t == TS_TOK_EOF)         { return 0; }
        if (t == TS_TOK_LPAREN)      { depth = depth + 1; }
        elif (t == TS_TOK_RPAREN) {
            depth = depth - 1;
            if (depth == 0) { done = 1; }
        }
        i = i + 1;
    }
    # i is now past the matching RPAREN
    var after = TS_PEEKT(ts_base, i);
    if (after == TS_TOK_ARROW) { return 1; }
    if (after == TS_TOK_COLON) {
        # Return-type annotation: scan for =>
        var j = i + 1;
        var depth2 = 0;
        while (j < max_scan) {
            var jt = TS_PEEKT(ts_base, j);
            if (jt == TS_TOK_EOF)     { return 0; }
            if (jt == TS_TOK_LPAREN || jt == TS_TOK_LBRACKET || jt == TS_TOK_LT) {
                depth2 = depth2 + 1;
            } elif (jt == TS_TOK_RPAREN || jt == TS_TOK_RBRACKET || jt == TS_TOK_GT) {
                depth2 = depth2 - 1;
                if (depth2 < 0) { return 0; }
            } elif (depth2 == 0) {
                if (jt == TS_TOK_ARROW)        { return 1; }
                if (jt == TS_TOK_LBRACE)       { return 0; }
                if (jt == TS_TOK_SEMI)         { return 0; }
                if (jt == TS_TOK_COMMA)        { return 0; }
            }
            j = j + 1;
        }
    }
    return 0;
}

# Bare-ident arrow: `x => body`. Caller has confirmed PEEK is IDENT
# and PEEK_AHEAD(1) is ARROW.
fn TS_PARSE_ARROW_SINGLE_IDENT(ts_base) {
    var name_v = TS_PARSE_TOK_VAL(ts_base);
    TS_PARSE_CONSUME(ts_base);              # ident
    TS_PARSE_CONSUME(ts_base);              # =>

    var arrow = TS_AST_PUSH(ts_base, TS_AST_EXPR_ARROW, 0);
    if (arrow < 0) { return 0 - 1; }

    # Single param: build a one-element children list
    var p = TS_AST_PUSH(ts_base, TS_AST_DECL_PARAM, name_v);
    if (p < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, p, 0, name_v);

    var off = TS_AST_CHILDREN_RESERVE(ts_base, 2);
    if (off < 0) { return 0 - 1; }
    TS_AST_CHILDREN_SET(ts_base, off, p);
    TS_AST_CHILDREN_SET(ts_base, off + 1, 0 - 1);
    TS_AST_CHILDREN_COMMIT(ts_base, 2);

    var body = TS_PARSE_ARROW_BODY(ts_base);
    if (body < 0) { return 0 - 1; }

    TS_AST_SET_PAYLOAD(ts_base, arrow, 0, off);
    TS_AST_SET_PAYLOAD(ts_base, arrow, 1, body);
    return arrow;
}

# Parse arrow params: `(x, y: T, z = init, ...rest)`. Caller has
# already consumed the LPAREN. Type annotations and defaults are
# parsed loosely — captured in the param node's payloads but not
# semantically validated. Returns children-array offset, or -1.
fn TS_PARSE_ARROW_PARAMS(ts_base) {
    var off = TS_AST_CHILDREN_RESERVE(ts_base, 16);
    if (off < 0) { return 0 - 1; }
    var i = 0;
    if (TS_PARSE_PEEK(ts_base) != TS_TOK_RPAREN) {
        var done = 0;
        while (done == 0) {
            # Class constructor parameter properties allow modifier
            # keywords here (`public x: T`, `readonly y: U`). Eat
            # them for syntax acceptance — they're harmless in other
            # contexts since modifier keywords aren't valid param
            # names.
            TS_PARSE_SKIP_MODIFIERS(ts_base);
            var t = TS_PARSE_PEEK(ts_base);
            var is_rest = 0;
            if (t == TS_TOK_ELLIPSIS) {
                is_rest = 1;
                TS_PARSE_CONSUME(ts_base);
            }
            var name_v = TS_PARSE_TOK_VAL(ts_base);
            if (TS_PARSE_EXPECT(ts_base, TS_TOK_IDENT) < 0) { return 0 - 1; }
            var p = TS_AST_PUSH(ts_base, TS_AST_DECL_PARAM, name_v);
            if (p < 0) { return 0 - 1; }
            TS_AST_SET_PAYLOAD(ts_base, p, 0, name_v);
            TS_AST_SET_PAYLOAD(ts_base, p, 3, is_rest);   # marker
            # Optional `?:`
            if (TS_PARSE_PEEK(ts_base) == TS_TOK_QUESTION) {
                TS_PARSE_CONSUME(ts_base);
            }
            # Optional `: T` — record full type AST in payload[1].
            if (TS_PARSE_PEEK(ts_base) == TS_TOK_COLON) {
                TS_PARSE_CONSUME(ts_base);
                var pt_node = TS_PARSE_TYPE(ts_base);
                if (pt_node < 0) { return 0 - 1; }
                TS_AST_SET_PAYLOAD(ts_base, p, 1, pt_node);
            }
            # Optional `= default`
            if (TS_PARSE_PEEK(ts_base) == TS_TOK_EQ) {
                TS_PARSE_CONSUME(ts_base);
                var defv = TS_PARSE_ASSIGN(ts_base);
                if (defv < 0) { return 0 - 1; }
                TS_AST_SET_PAYLOAD(ts_base, p, 2, defv);
            }
            TS_AST_CHILDREN_SET(ts_base, off + i, p);
            i = i + 1;
            if (TS_PARSE_MATCH(ts_base, TS_TOK_COMMA) == 0) { done = 1; }
        }
    }
    TS_AST_CHILDREN_SET(ts_base, off + i, 0 - 1);
    TS_AST_CHILDREN_COMMIT(ts_base, i + 1);
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_RPAREN) < 0) { return 0 - 1; }
    return off;
}

# ================================================================
# Type expression parser (P2.4)
# ================================================================
# Replaces v5.7.2 P2.3's loose type-skipper. Builds a real AST for
# type expressions covering:
#   - primitives (void) + literal types ('foo', 42, true, null, ...)
#   - type refs with type-args (Foo, Foo<T>, A.B.C)
#   - object types ({ x: T; y?: U }), index signatures ([k: K]: V)
#   - tuple types ([T, U?, ...V])
#   - array postfix (T[], T[][])
#   - function types ((a: T, b: T) => U) — paren-vs-fn lookahead
#   - union (|) and intersection (&) operators
#   - keyof T, typeof x.y
#   - parenthesized types
#
# Mapped types ({ [K in keyof T]: U }) and conditional types
# (T extends U ? V : W) are deferred to v5.7.3 — they're not blocking
# SY parse acceptance.

# Lookahead: in TYPE context, scan past LPAREN to its matching RPAREN
# and check whether the following token is `=>`. If so, this LPAREN
# starts a function-type parameter list.
fn TS_TYPE_LOOKAHEAD_IS_FN(ts_base) {
    var start = load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_TOK_IDX);
    var i = start + 1;
    var depth = 1;
    var max_scan = start + 4096;
    var done = 0;
    while (done == 0) {
        if (i >= max_scan) { return 0; }
        var t = TS_PEEKT(ts_base, i);
        if (t == TS_TOK_EOF) { return 0; }
        if (t == TS_TOK_LPAREN) { depth = depth + 1; }
        elif (t == TS_TOK_RPAREN) {
            depth = depth - 1;
            if (depth == 0) { done = 1; }
        }
        i = i + 1;
    }
    if (TS_PEEKT(ts_base, i) == TS_TOK_ARROW) { return 1; }
    return 0;
}

# In type-argument context, the lexer cannot tell apart `>>` (right
# shift) from two adjacent `>` characters closing nested generics like
# `Promise<Array<T>>`. This helper unifies the close: it accepts GT
# directly, but for GT_GT / GT_GT_GT / GT_EQ / GT_GT_EQ / GT_GT_GT_EQ
# it rewrites the current token entry in place to "consume" one `>`
# worth and leave the remainder for the next call.
fn TS_PARSE_EXPECT_TYPE_GT(ts_base) {
    var idx = load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_TOK_IDX);
    var t = TS_PEEKT(ts_base, idx);
    if (t == TS_TOK_GT) {
        TS_PARSE_CONSUME(ts_base);
        return 0;
    }
    var off = ts_base + TS_TOK_TYPES_OFF + idx * 8;
    if (t == TS_TOK_GT_GT) {
        store64(off, TS_TOK_GT);
        return 0;
    }
    if (t == TS_TOK_GT_GT_GT) {
        store64(off, TS_TOK_GT_GT);
        return 0;
    }
    if (t == TS_TOK_GT_EQ) {
        store64(off, TS_TOK_EQ);
        return 0;
    }
    if (t == TS_TOK_GT_GT_EQ) {
        store64(off, TS_TOK_GT_EQ);
        return 0;
    }
    if (t == TS_TOK_GT_GT_GT_EQ) {
        store64(off, TS_TOK_GT_GT_EQ);
        return 0;
    }
    store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_CODE, 3);
    store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_TOK_IDX, idx);
    return 0 - 1;
}

# Reference: A | A.B | A.B.C  with optional <T, U> type args.
fn TS_PARSE_TYPE_REF(ts_base) {
    var name_v = TS_PARSE_TOK_VAL(ts_base);
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_IDENT) < 0) { return 0 - 1; }
    while (TS_PARSE_PEEK(ts_base) == TS_TOK_DOT) {
        TS_PARSE_CONSUME(ts_base);
        if (TS_PARSE_EXPECT(ts_base, TS_TOK_IDENT) < 0) { return 0 - 1; }
    }
    var ref = TS_AST_PUSH(ts_base, TS_AST_TYPE_REF, name_v);
    if (ref < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, ref, 0, name_v);
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_LT) {
        TS_PARSE_CONSUME(ts_base);
        var args_off = TS_AST_CHILDREN_RESERVE(ts_base, 16);
        if (args_off < 0) { return 0 - 1; }
        var ai = 0;
        var first = 1;
        var done_args = 0;
        while (done_args == 0) {
            var pt = TS_PARSE_PEEK(ts_base);
            if (pt == TS_TOK_GT || pt == TS_TOK_GT_GT || pt == TS_TOK_GT_GT_GT
                || pt == TS_TOK_GT_EQ || pt == TS_TOK_GT_GT_EQ
                || pt == TS_TOK_GT_GT_GT_EQ) {
                done_args = 1;
            } else {
                if (first == 0) {
                    if (TS_PARSE_EXPECT(ts_base, TS_TOK_COMMA) < 0) { return 0 - 1; }
                }
                first = 0;
                var arg = TS_PARSE_TYPE(ts_base);
                if (arg < 0) { return 0 - 1; }
                TS_AST_CHILDREN_SET(ts_base, args_off + ai, arg);
                ai = ai + 1;
            }
        }
        TS_AST_CHILDREN_SET(ts_base, args_off + ai, 0 - 1);
        TS_AST_CHILDREN_COMMIT(ts_base, ai + 1);
        TS_AST_SET_PAYLOAD(ts_base, ref, 1, args_off);
        if (TS_PARSE_EXPECT_TYPE_GT(ts_base) < 0) { return 0 - 1; }
    }
    return ref;
}

# Object type: { name: T; [k: K]: V; readonly q: W }
fn TS_PARSE_TYPE_OBJECT(ts_base) {
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_LBRACE) < 0) { return 0 - 1; }
    var n = TS_AST_PUSH(ts_base, TS_AST_TYPE_OBJECT, 0);
    if (n < 0) { return 0 - 1; }
    var members_off = TS_AST_CHILDREN_RESERVE(ts_base, 16);
    if (members_off < 0) { return 0 - 1; }
    var mi = 0;
    while (TS_PARSE_PEEK(ts_base) != TS_TOK_RBRACE) {
        if (TS_PARSE_PEEK(ts_base) == TS_TOK_KW_READONLY) {
            TS_PARSE_CONSUME(ts_base);
        }
        var member = 0 - 1;
        if (TS_PARSE_PEEK(ts_base) == TS_TOK_LBRACKET) {
            # Index signature: [name: K]: V
            TS_PARSE_CONSUME(ts_base);
            if (TS_PARSE_EXPECT(ts_base, TS_TOK_IDENT) < 0) { return 0 - 1; }
            if (TS_PARSE_EXPECT(ts_base, TS_TOK_COLON) < 0) { return 0 - 1; }
            var k_t = TS_PARSE_TYPE(ts_base);
            if (k_t < 0) { return 0 - 1; }
            if (TS_PARSE_EXPECT(ts_base, TS_TOK_RBRACKET) < 0) { return 0 - 1; }
            if (TS_PARSE_EXPECT(ts_base, TS_TOK_COLON) < 0) { return 0 - 1; }
            var v_t = TS_PARSE_TYPE(ts_base);
            if (v_t < 0) { return 0 - 1; }
            member = TS_AST_PUSH(ts_base, TS_AST_TYPE_INDEX_SIG, 0);
            if (member < 0) { return 0 - 1; }
            TS_AST_SET_PAYLOAD(ts_base, member, 0, k_t);
            TS_AST_SET_PAYLOAD(ts_base, member, 1, v_t);
        } else {
            # Property: name [?] : T
            var name_v = TS_PARSE_TOK_VAL(ts_base);
            var pt = TS_PARSE_PEEK(ts_base);
            var ok = 0;
            if (pt == TS_TOK_IDENT) { ok = 1; }
            elif (pt == TS_TOK_STRING) { ok = 1; }
            elif (pt == TS_TOK_INT) { ok = 1; }
            elif (pt == TS_TOK_KW_FROM) { ok = 1; }
            elif (pt == TS_TOK_KW_AS) { ok = 1; }
            elif (pt == TS_TOK_KW_OF) { ok = 1; }
            elif (pt == TS_TOK_KW_GET) { ok = 1; }
            elif (pt == TS_TOK_KW_SET) { ok = 1; }
            elif (pt == TS_TOK_KW_TYPE) { ok = 1; }
            if (ok == 0) {
                store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_CODE, 7);
                store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_TOK_IDX,
                        load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_TOK_IDX));
                return 0 - 1;
            }
            TS_PARSE_CONSUME(ts_base);
            if (TS_PARSE_PEEK(ts_base) == TS_TOK_QUESTION) {
                TS_PARSE_CONSUME(ts_base);
            }
            if (TS_PARSE_EXPECT(ts_base, TS_TOK_COLON) < 0) { return 0 - 1; }
            var pv_t = TS_PARSE_TYPE(ts_base);
            if (pv_t < 0) { return 0 - 1; }
            member = TS_AST_PUSH(ts_base, TS_AST_PROPERTY_ASSIGN, name_v);
            if (member < 0) { return 0 - 1; }
            TS_AST_SET_PAYLOAD(ts_base, member, 0, name_v);
            TS_AST_SET_PAYLOAD(ts_base, member, 1, pv_t);
        }
        TS_AST_CHILDREN_SET(ts_base, members_off + mi, member);
        mi = mi + 1;
        var sep = TS_PARSE_PEEK(ts_base);
        if (sep == TS_TOK_COMMA) { TS_PARSE_CONSUME(ts_base); }
        elif (sep == TS_TOK_SEMI) { TS_PARSE_CONSUME(ts_base); }
    }
    TS_AST_CHILDREN_SET(ts_base, members_off + mi, 0 - 1);
    TS_AST_CHILDREN_COMMIT(ts_base, mi + 1);
    TS_AST_SET_PAYLOAD(ts_base, n, 0, members_off);
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_RBRACE) < 0) { return 0 - 1; }
    return n;
}

# Tuple type: [T, U, V?, ...W[]]
fn TS_PARSE_TYPE_TUPLE(ts_base) {
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_LBRACKET) < 0) { return 0 - 1; }
    var n = TS_AST_PUSH(ts_base, TS_AST_TYPE_TUPLE, 0);
    if (n < 0) { return 0 - 1; }
    var elems_off = TS_AST_CHILDREN_RESERVE(ts_base, 16);
    if (elems_off < 0) { return 0 - 1; }
    var ei = 0;
    var first = 1;
    while (TS_PARSE_PEEK(ts_base) != TS_TOK_RBRACKET) {
        if (first == 0) {
            if (TS_PARSE_EXPECT(ts_base, TS_TOK_COMMA) < 0) { return 0 - 1; }
            if (TS_PARSE_PEEK(ts_base) == TS_TOK_RBRACKET) { ei = ei; }
        }
        first = 0;
        if (TS_PARSE_PEEK(ts_base) == TS_TOK_RBRACKET) {
            # trailing comma
            ei = ei;
        } else {
            if (TS_PARSE_PEEK(ts_base) == TS_TOK_ELLIPSIS) {
                TS_PARSE_CONSUME(ts_base);
            }
            var el = TS_PARSE_TYPE(ts_base);
            if (el < 0) { return 0 - 1; }
            if (TS_PARSE_PEEK(ts_base) == TS_TOK_QUESTION) {
                TS_PARSE_CONSUME(ts_base);
                var opt = TS_AST_PUSH(ts_base, TS_AST_TYPE_OPTIONAL, 0);
                if (opt < 0) { return 0 - 1; }
                TS_AST_SET_PAYLOAD(ts_base, opt, 0, el);
                el = opt;
            }
            TS_AST_CHILDREN_SET(ts_base, elems_off + ei, el);
            ei = ei + 1;
        }
    }
    TS_AST_CHILDREN_SET(ts_base, elems_off + ei, 0 - 1);
    TS_AST_CHILDREN_COMMIT(ts_base, ei + 1);
    TS_AST_SET_PAYLOAD(ts_base, n, 0, elems_off);
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_RBRACKET) < 0) { return 0 - 1; }
    return n;
}

# Function type: (a: T, b: T) => U  or  () => U
# Caller has confirmed peek == LPAREN and TS_TYPE_LOOKAHEAD_IS_FN == 1.
fn TS_PARSE_TYPE_FN(ts_base) {
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_LPAREN) < 0) { return 0 - 1; }
    var params_off = TS_AST_CHILDREN_RESERVE(ts_base, 16);
    if (params_off < 0) { return 0 - 1; }
    var pi = 0;
    var first = 1;
    while (TS_PARSE_PEEK(ts_base) != TS_TOK_RPAREN) {
        if (first == 0) {
            if (TS_PARSE_EXPECT(ts_base, TS_TOK_COMMA) < 0) { return 0 - 1; }
        }
        first = 0;
        var is_rest = 0;
        if (TS_PARSE_PEEK(ts_base) == TS_TOK_ELLIPSIS) {
            TS_PARSE_CONSUME(ts_base);
            is_rest = 1;
        }
        var name_v = TS_PARSE_TOK_VAL(ts_base);
        if (TS_PARSE_EXPECT(ts_base, TS_TOK_IDENT) < 0) { return 0 - 1; }
        if (TS_PARSE_PEEK(ts_base) == TS_TOK_QUESTION) {
            TS_PARSE_CONSUME(ts_base);
        }
        if (TS_PARSE_EXPECT(ts_base, TS_TOK_COLON) < 0) { return 0 - 1; }
        var t_node = TS_PARSE_TYPE(ts_base);
        if (t_node < 0) { return 0 - 1; }
        var p = TS_AST_PUSH(ts_base, TS_AST_DECL_PARAM, name_v);
        if (p < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, p, 0, name_v);
        TS_AST_SET_PAYLOAD(ts_base, p, 1, t_node);
        TS_AST_SET_PAYLOAD(ts_base, p, 3, is_rest);
        TS_AST_CHILDREN_SET(ts_base, params_off + pi, p);
        pi = pi + 1;
    }
    TS_AST_CHILDREN_SET(ts_base, params_off + pi, 0 - 1);
    TS_AST_CHILDREN_COMMIT(ts_base, pi + 1);
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_RPAREN) < 0) { return 0 - 1; }
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_ARROW) < 0) { return 0 - 1; }
    var ret_t = TS_PARSE_TYPE(ts_base);
    if (ret_t < 0) { return 0 - 1; }
    var n = TS_AST_PUSH(ts_base, TS_AST_TYPE_FN, 0);
    if (n < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, n, 0, params_off);
    TS_AST_SET_PAYLOAD(ts_base, n, 1, ret_t);
    return n;
}

fn TS_PARSE_TYPE_PRIMARY(ts_base) {
    var t = TS_PARSE_PEEK(ts_base);
    var v = TS_PARSE_TOK_VAL(ts_base);
    if (t == TS_TOK_KW_VOID) {
        TS_PARSE_CONSUME(ts_base);
        var nv = TS_AST_PUSH(ts_base, TS_AST_TYPE_PRIMITIVE, v);
        if (nv < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, nv, 0, v);
        return nv;
    }
    if (t == TS_TOK_STRING || t == TS_TOK_INT || t == TS_TOK_FLOAT
        || t == TS_TOK_KW_TRUE || t == TS_TOK_KW_FALSE
        || t == TS_TOK_KW_NULL || t == TS_TOK_KW_UNDEFINED) {
        TS_PARSE_CONSUME(ts_base);
        var nl = TS_AST_PUSH(ts_base, TS_AST_TYPE_LITERAL, v);
        if (nl < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, nl, 0, v);
        return nl;
    }
    if (t == TS_TOK_KW_KEYOF) {
        TS_PARSE_CONSUME(ts_base);
        var inner_k = TS_PARSE_TYPE_PRIMARY(ts_base);
        if (inner_k < 0) { return 0 - 1; }
        var nk = TS_AST_PUSH(ts_base, TS_AST_TYPE_KEYOF, 0);
        if (nk < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, nk, 0, inner_k);
        return nk;
    }
    if (t == TS_TOK_KW_TYPEOF) {
        TS_PARSE_CONSUME(ts_base);
        var name_v = TS_PARSE_TOK_VAL(ts_base);
        if (TS_PARSE_EXPECT(ts_base, TS_TOK_IDENT) < 0) { return 0 - 1; }
        while (TS_PARSE_PEEK(ts_base) == TS_TOK_DOT) {
            TS_PARSE_CONSUME(ts_base);
            if (TS_PARSE_EXPECT(ts_base, TS_TOK_IDENT) < 0) { return 0 - 1; }
        }
        var nt = TS_AST_PUSH(ts_base, TS_AST_TYPE_TYPEOF, name_v);
        if (nt < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, nt, 0, name_v);
        return nt;
    }
    if (t == TS_TOK_KW_READONLY) {
        TS_PARSE_CONSUME(ts_base);
        return TS_PARSE_TYPE_PRIMARY(ts_base);
    }
    if (t == TS_TOK_LBRACE) {
        return TS_PARSE_TYPE_OBJECT(ts_base);
    }
    if (t == TS_TOK_LBRACKET) {
        return TS_PARSE_TYPE_TUPLE(ts_base);
    }
    if (t == TS_TOK_LPAREN) {
        if (TS_TYPE_LOOKAHEAD_IS_FN(ts_base) == 1) {
            return TS_PARSE_TYPE_FN(ts_base);
        }
        TS_PARSE_CONSUME(ts_base);
        var inner_p = TS_PARSE_TYPE(ts_base);
        if (inner_p < 0) { return 0 - 1; }
        if (TS_PARSE_EXPECT(ts_base, TS_TOK_RPAREN) < 0) { return 0 - 1; }
        var np = TS_AST_PUSH(ts_base, TS_AST_TYPE_PAREN, 0);
        if (np < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, np, 0, inner_p);
        return np;
    }
    if (t == TS_TOK_IDENT
        || t == TS_TOK_KW_FROM || t == TS_TOK_KW_AS
        || t == TS_TOK_KW_OF   || t == TS_TOK_KW_GET
        || t == TS_TOK_KW_SET  || t == TS_TOK_KW_TYPE) {
        return TS_PARSE_TYPE_REF(ts_base);
    }
    store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_CODE, 9);
    store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_TOK_IDX,
            load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_TOK_IDX));
    return 0 - 1;
}

# Postfix: T[]  (array)  or  T[K]  (indexed access — folded into ARRAY
# with payload[1] = K for now; full mapped/conditional types are P2.x+).
fn TS_PARSE_TYPE_POSTFIX(ts_base) {
    var inner = TS_PARSE_TYPE_PRIMARY(ts_base);
    if (inner < 0) { return 0 - 1; }
    while (TS_PARSE_PEEK(ts_base) == TS_TOK_LBRACKET) {
        TS_PARSE_CONSUME(ts_base);
        if (TS_PARSE_PEEK(ts_base) == TS_TOK_RBRACKET) {
            TS_PARSE_CONSUME(ts_base);
            var arr = TS_AST_PUSH(ts_base, TS_AST_TYPE_ARRAY, 0);
            if (arr < 0) { return 0 - 1; }
            TS_AST_SET_PAYLOAD(ts_base, arr, 0, inner);
            inner = arr;
        } else {
            var k = TS_PARSE_TYPE(ts_base);
            if (k < 0) { return 0 - 1; }
            if (TS_PARSE_EXPECT(ts_base, TS_TOK_RBRACKET) < 0) { return 0 - 1; }
            var ix = TS_AST_PUSH(ts_base, TS_AST_TYPE_ARRAY, 0);
            if (ix < 0) { return 0 - 1; }
            TS_AST_SET_PAYLOAD(ts_base, ix, 0, inner);
            TS_AST_SET_PAYLOAD(ts_base, ix, 1, k);
            inner = ix;
        }
    }
    return inner;
}

fn TS_PARSE_TYPE_INTERSECTION(ts_base) {
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_AMP) { TS_PARSE_CONSUME(ts_base); }
    var lhs = TS_PARSE_TYPE_POSTFIX(ts_base);
    if (lhs < 0) { return 0 - 1; }
    if (TS_PARSE_PEEK(ts_base) != TS_TOK_AMP) { return lhs; }
    var off = TS_AST_CHILDREN_RESERVE(ts_base, 16);
    if (off < 0) { return 0 - 1; }
    var i = 0;
    TS_AST_CHILDREN_SET(ts_base, off + i, lhs);
    i = i + 1;
    while (TS_PARSE_PEEK(ts_base) == TS_TOK_AMP) {
        TS_PARSE_CONSUME(ts_base);
        var rhs = TS_PARSE_TYPE_POSTFIX(ts_base);
        if (rhs < 0) { return 0 - 1; }
        TS_AST_CHILDREN_SET(ts_base, off + i, rhs);
        i = i + 1;
    }
    TS_AST_CHILDREN_SET(ts_base, off + i, 0 - 1);
    TS_AST_CHILDREN_COMMIT(ts_base, i + 1);
    var n = TS_AST_PUSH(ts_base, TS_AST_TYPE_INTERSECTION, 0);
    if (n < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, n, 0, off);
    return n;
}

fn TS_PARSE_TYPE_UNION(ts_base) {
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_PIPE) { TS_PARSE_CONSUME(ts_base); }
    var lhs = TS_PARSE_TYPE_INTERSECTION(ts_base);
    if (lhs < 0) { return 0 - 1; }
    if (TS_PARSE_PEEK(ts_base) != TS_TOK_PIPE) { return lhs; }
    var off = TS_AST_CHILDREN_RESERVE(ts_base, 16);
    if (off < 0) { return 0 - 1; }
    var i = 0;
    TS_AST_CHILDREN_SET(ts_base, off + i, lhs);
    i = i + 1;
    while (TS_PARSE_PEEK(ts_base) == TS_TOK_PIPE) {
        TS_PARSE_CONSUME(ts_base);
        var rhs = TS_PARSE_TYPE_INTERSECTION(ts_base);
        if (rhs < 0) { return 0 - 1; }
        TS_AST_CHILDREN_SET(ts_base, off + i, rhs);
        i = i + 1;
    }
    TS_AST_CHILDREN_SET(ts_base, off + i, 0 - 1);
    TS_AST_CHILDREN_COMMIT(ts_base, i + 1);
    var n = TS_AST_PUSH(ts_base, TS_AST_TYPE_UNION, 0);
    if (n < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, n, 0, off);
    return n;
}

# Top-level type entry — accepts unions/intersections/postfix/primary.
fn TS_PARSE_TYPE(ts_base) {
    return TS_PARSE_TYPE_UNION(ts_base);
}

# Parse arrow body: expression OR block.
fn TS_PARSE_ARROW_BODY(ts_base) {
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_LBRACE) {
        return TS_PARSE_BLOCK(ts_base);
    }
    return TS_PARSE_ASSIGN(ts_base);
}

# Paren arrow: `(params) => body` or `(params): T => body`. Caller
# has confirmed via lookahead. Consumes the LPAREN here.
fn TS_PARSE_ARROW_PAREN(ts_base) {
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_LPAREN) < 0) { return 0 - 1; }
    var params_off = TS_PARSE_ARROW_PARAMS(ts_base);
    if (params_off < 0) { return 0 - 1; }
    # Optional return type — payload[2] holds the AST node index of
    # the parsed type, or 0 when absent. (TS_PARSE always allocates
    # ROOT at index 0, so a real type node always has index >= 1
    # in production parses.)
    var ret_type_node = 0;
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_COLON) {
        TS_PARSE_CONSUME(ts_base);
        ret_type_node = TS_PARSE_TYPE(ts_base);
        if (ret_type_node < 0) { return 0 - 1; }
    }
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_ARROW) < 0) { return 0 - 1; }
    var body = TS_PARSE_ARROW_BODY(ts_base);
    if (body < 0) { return 0 - 1; }
    var arrow = TS_AST_PUSH(ts_base, TS_AST_EXPR_ARROW, 0);
    if (arrow < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, arrow, 0, params_off);
    TS_AST_SET_PAYLOAD(ts_base, arrow, 1, body);
    TS_AST_SET_PAYLOAD(ts_base, arrow, 2, ret_type_node);
    return arrow;
}

# ================================================================
# Statement parser (P2.3)
# ================================================================

# Block: `{ stmt; stmt; }`. Caller has NOT yet consumed the LBRACE.
fn TS_PARSE_BLOCK(ts_base) {
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_LBRACE) < 0) { return 0 - 1; }
    var span = 0;
    var node = TS_AST_PUSH(ts_base, TS_AST_STMT_BLOCK, span);
    if (node < 0) { return 0 - 1; }
    var off = TS_AST_CHILDREN_RESERVE(ts_base, 32);
    if (off < 0) { return 0 - 1; }
    var i = 0;
    var go = 1;
    while (go == 1) {
        var t = TS_PARSE_PEEK(ts_base);
        if (t == TS_TOK_RBRACE || t == TS_TOK_EOF) { go = 0; }
        else {
            var s = TS_PARSE_STMT(ts_base);
            if (s < 0) { return 0 - 1; }
            TS_AST_CHILDREN_SET(ts_base, off + i, s);
            i = i + 1;
        }
    }
    TS_AST_CHILDREN_SET(ts_base, off + i, 0 - 1);
    TS_AST_CHILDREN_COMMIT(ts_base, i + 1);
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_RBRACE) < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, node, 0, off);
    return node;
}

# Optional `;` consumer with loose ASI (allow `}` or EOF as terminator).
fn TS_PARSE_OPT_SEMI(ts_base) {
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_SEMI) {
        TS_PARSE_CONSUME(ts_base);
    }
    return 0;
}

# Single binding pattern: ident, {a, b}, [x, y], or with ...rest.
# Returns a PATTERN_* AST node index.
fn TS_PARSE_BINDING_PATTERN(ts_base) {
    var t = TS_PARSE_PEEK(ts_base);
    if (t == TS_TOK_LBRACE) {
        TS_PARSE_CONSUME(ts_base);
        var n = TS_AST_PUSH(ts_base, TS_AST_PATTERN_OBJECT, 0);
        if (n < 0) { return 0 - 1; }
        var off = TS_AST_CHILDREN_RESERVE(ts_base, 16);
        if (off < 0) { return 0 - 1; }
        var i = 0;
        if (TS_PARSE_PEEK(ts_base) != TS_TOK_RBRACE) {
            var done = 0;
            while (done == 0) {
                var pt = TS_PARSE_PEEK(ts_base);
                if (pt == TS_TOK_ELLIPSIS) {
                    TS_PARSE_CONSUME(ts_base);
                    var rname = TS_PARSE_TOK_VAL(ts_base);
                    if (TS_PARSE_EXPECT(ts_base, TS_TOK_IDENT) < 0) { return 0 - 1; }
                    var rest = TS_AST_PUSH(ts_base, TS_AST_PATTERN_REST, rname);
                    if (rest < 0) { return 0 - 1; }
                    TS_AST_SET_PAYLOAD(ts_base, rest, 0, rname);
                    TS_AST_CHILDREN_SET(ts_base, off + i, rest);
                } else {
                    var name_v = TS_PARSE_TOK_VAL(ts_base);
                    if (TS_PARSE_EXPECT(ts_base, TS_TOK_IDENT) < 0) { return 0 - 1; }
                    var pn = TS_AST_PUSH(ts_base, TS_AST_PATTERN_IDENT, name_v);
                    if (pn < 0) { return 0 - 1; }
                    TS_AST_SET_PAYLOAD(ts_base, pn, 0, name_v);
                    TS_AST_CHILDREN_SET(ts_base, off + i, pn);
                }
                i = i + 1;
                if (TS_PARSE_MATCH(ts_base, TS_TOK_COMMA) == 0) { done = 1; }
            }
        }
        TS_AST_CHILDREN_SET(ts_base, off + i, 0 - 1);
        TS_AST_CHILDREN_COMMIT(ts_base, i + 1);
        if (TS_PARSE_EXPECT(ts_base, TS_TOK_RBRACE) < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, n, 0, off);
        return n;
    }
    if (t == TS_TOK_LBRACKET) {
        TS_PARSE_CONSUME(ts_base);
        var n2 = TS_AST_PUSH(ts_base, TS_AST_PATTERN_ARRAY, 0);
        if (n2 < 0) { return 0 - 1; }
        var off2 = TS_AST_CHILDREN_RESERVE(ts_base, 16);
        if (off2 < 0) { return 0 - 1; }
        var i2 = 0;
        if (TS_PARSE_PEEK(ts_base) != TS_TOK_RBRACKET) {
            var done2 = 0;
            while (done2 == 0) {
                var pt2 = TS_PARSE_PEEK(ts_base);
                if (pt2 == TS_TOK_ELLIPSIS) {
                    TS_PARSE_CONSUME(ts_base);
                    var rname2 = TS_PARSE_TOK_VAL(ts_base);
                    if (TS_PARSE_EXPECT(ts_base, TS_TOK_IDENT) < 0) { return 0 - 1; }
                    var rest2 = TS_AST_PUSH(ts_base, TS_AST_PATTERN_REST, rname2);
                    if (rest2 < 0) { return 0 - 1; }
                    TS_AST_SET_PAYLOAD(ts_base, rest2, 0, rname2);
                    TS_AST_CHILDREN_SET(ts_base, off2 + i2, rest2);
                } else {
                    # Allow nested patterns
                    var inner = TS_PARSE_BINDING_PATTERN(ts_base);
                    if (inner < 0) { return 0 - 1; }
                    TS_AST_CHILDREN_SET(ts_base, off2 + i2, inner);
                }
                i2 = i2 + 1;
                if (TS_PARSE_MATCH(ts_base, TS_TOK_COMMA) == 0) { done2 = 1; }
            }
        }
        TS_AST_CHILDREN_SET(ts_base, off2 + i2, 0 - 1);
        TS_AST_CHILDREN_COMMIT(ts_base, i2 + 1);
        if (TS_PARSE_EXPECT(ts_base, TS_TOK_RBRACKET) < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, n2, 0, off2);
        return n2;
    }
    # Plain ident
    var iv = TS_PARSE_TOK_VAL(ts_base);
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_IDENT) < 0) { return 0 - 1; }
    var pi = TS_AST_PUSH(ts_base, TS_AST_PATTERN_IDENT, iv);
    if (pi < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, pi, 0, iv);
    return pi;
}

# Single binding: pattern [: type] [= init]
fn TS_PARSE_VAR_BINDING(ts_base) {
    var pat = TS_PARSE_BINDING_PATTERN(ts_base);
    if (pat < 0) { return 0 - 1; }
    var n = TS_AST_PUSH(ts_base, TS_AST_DECL_VAR_BINDING, 0);
    if (n < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, n, 0, pat);
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_COLON) {
        TS_PARSE_CONSUME(ts_base);
        var vb_t = TS_PARSE_TYPE(ts_base);
        if (vb_t < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, n, 1, vb_t);
    }
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_EQ) {
        TS_PARSE_CONSUME(ts_base);
        var init = TS_PARSE_ASSIGN(ts_base);
        if (init < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, n, 2, init);
    }
    return n;
}

# var/let/const x = init, y = init, z;
fn TS_PARSE_VAR_DECL(ts_base) {
    var kind_tok = TS_PARSE_PEEK(ts_base);
    TS_PARSE_CONSUME(ts_base);                  # consume var/let/const
    var node = TS_AST_PUSH(ts_base, TS_AST_STMT_VAR_DECL, 0);
    if (node < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, node, 0, kind_tok);
    var off = TS_AST_CHILDREN_RESERVE(ts_base, 8);
    if (off < 0) { return 0 - 1; }
    var i = 0;
    var done = 0;
    while (done == 0) {
        var b = TS_PARSE_VAR_BINDING(ts_base);
        if (b < 0) { return 0 - 1; }
        TS_AST_CHILDREN_SET(ts_base, off + i, b);
        i = i + 1;
        if (TS_PARSE_MATCH(ts_base, TS_TOK_COMMA) == 0) { done = 1; }
    }
    TS_AST_CHILDREN_SET(ts_base, off + i, 0 - 1);
    TS_AST_CHILDREN_COMMIT(ts_base, i + 1);
    TS_AST_SET_PAYLOAD(ts_base, node, 1, off);
    TS_PARSE_OPT_SEMI(ts_base);
    return node;
}

# if (cond) stmt [else stmt]
fn TS_PARSE_IF(ts_base) {
    TS_PARSE_CONSUME(ts_base);                  # if
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_LPAREN) < 0) { return 0 - 1; }
    var cond = TS_PARSE_EXPR(ts_base);
    if (cond < 0) { return 0 - 1; }
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_RPAREN) < 0) { return 0 - 1; }
    var then_s = TS_PARSE_STMT(ts_base);
    if (then_s < 0) { return 0 - 1; }
    var else_s = 0 - 1;
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_KW_ELSE) {
        TS_PARSE_CONSUME(ts_base);
        else_s = TS_PARSE_STMT(ts_base);
        if (else_s < 0) { return 0 - 1; }
    }
    var n = TS_AST_PUSH(ts_base, TS_AST_STMT_IF, 0);
    if (n < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, n, 0, cond);
    TS_AST_SET_PAYLOAD(ts_base, n, 1, then_s);
    TS_AST_SET_PAYLOAD(ts_base, n, 2, else_s);
    return n;
}

# for (init; cond; update) body
# for (decl of expr) body
# for (decl in expr) body
fn TS_PARSE_FOR(ts_base) {
    TS_PARSE_CONSUME(ts_base);                  # for
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_LPAREN) < 0) { return 0 - 1; }

    # Detect for-of / for-in vs C-style. The init slot can be a
    # decl OR an expression. Detect by peek + first-token-after-decl.
    # Strategy: parse the init clause; then peek for `of` / `in` /
    # `;` to disambiguate.
    var init = 0 - 1;
    var t0 = TS_PARSE_PEEK(ts_base);
    if (t0 == TS_TOK_KW_VAR || t0 == TS_TOK_KW_LET || t0 == TS_TOK_KW_CONST) {
        # Parse a single binding (no comma chain in for-init)
        var kind = t0;
        TS_PARSE_CONSUME(ts_base);
        var b = TS_PARSE_VAR_BINDING(ts_base);
        if (b < 0) { return 0 - 1; }
        # Wrap in a VAR_DECL with single binding for AST consistency
        var vd = TS_AST_PUSH(ts_base, TS_AST_STMT_VAR_DECL, 0);
        if (vd < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, vd, 0, kind);
        var off = TS_AST_CHILDREN_RESERVE(ts_base, 2);
        TS_AST_CHILDREN_SET(ts_base, off, b);
        TS_AST_CHILDREN_SET(ts_base, off + 1, 0 - 1);
        TS_AST_CHILDREN_COMMIT(ts_base, 2);
        TS_AST_SET_PAYLOAD(ts_base, vd, 1, off);
        init = vd;
    } elif (t0 != TS_TOK_SEMI) {
        init = TS_PARSE_EXPR(ts_base);
        if (init < 0) { return 0 - 1; }
    }

    # Now peek: of / in / ;
    var pk = TS_PARSE_PEEK(ts_base);
    if (pk == TS_TOK_KW_OF) {
        TS_PARSE_CONSUME(ts_base);
        var iter = TS_PARSE_EXPR(ts_base);
        if (iter < 0) { return 0 - 1; }
        if (TS_PARSE_EXPECT(ts_base, TS_TOK_RPAREN) < 0) { return 0 - 1; }
        var body = TS_PARSE_STMT(ts_base);
        if (body < 0) { return 0 - 1; }
        var n = TS_AST_PUSH(ts_base, TS_AST_STMT_FOR_OF, 0);
        if (n < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, n, 0, init);
        TS_AST_SET_PAYLOAD(ts_base, n, 1, iter);
        TS_AST_SET_PAYLOAD(ts_base, n, 2, body);
        return n;
    }
    if (pk == TS_TOK_KW_IN) {
        TS_PARSE_CONSUME(ts_base);
        var iter2 = TS_PARSE_EXPR(ts_base);
        if (iter2 < 0) { return 0 - 1; }
        if (TS_PARSE_EXPECT(ts_base, TS_TOK_RPAREN) < 0) { return 0 - 1; }
        var body2 = TS_PARSE_STMT(ts_base);
        if (body2 < 0) { return 0 - 1; }
        var n2 = TS_AST_PUSH(ts_base, TS_AST_STMT_FOR_IN, 0);
        if (n2 < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, n2, 0, init);
        TS_AST_SET_PAYLOAD(ts_base, n2, 1, iter2);
        TS_AST_SET_PAYLOAD(ts_base, n2, 2, body2);
        return n2;
    }
    # C-style for
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_SEMI) < 0) { return 0 - 1; }
    var cond = 0 - 1;
    if (TS_PARSE_PEEK(ts_base) != TS_TOK_SEMI) {
        cond = TS_PARSE_EXPR(ts_base);
        if (cond < 0) { return 0 - 1; }
    }
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_SEMI) < 0) { return 0 - 1; }
    var update = 0 - 1;
    if (TS_PARSE_PEEK(ts_base) != TS_TOK_RPAREN) {
        update = TS_PARSE_EXPR(ts_base);
        if (update < 0) { return 0 - 1; }
    }
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_RPAREN) < 0) { return 0 - 1; }
    var body3 = TS_PARSE_STMT(ts_base);
    if (body3 < 0) { return 0 - 1; }
    var n3 = TS_AST_PUSH(ts_base, TS_AST_STMT_FOR, 0);
    if (n3 < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, n3, 0, init);
    TS_AST_SET_PAYLOAD(ts_base, n3, 1, cond);
    TS_AST_SET_PAYLOAD(ts_base, n3, 2, update);
    TS_AST_SET_PAYLOAD(ts_base, n3, 3, body3);
    return n3;
}

# while (cond) body
fn TS_PARSE_WHILE(ts_base) {
    TS_PARSE_CONSUME(ts_base);
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_LPAREN) < 0) { return 0 - 1; }
    var cond = TS_PARSE_EXPR(ts_base);
    if (cond < 0) { return 0 - 1; }
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_RPAREN) < 0) { return 0 - 1; }
    var body = TS_PARSE_STMT(ts_base);
    if (body < 0) { return 0 - 1; }
    var n = TS_AST_PUSH(ts_base, TS_AST_STMT_WHILE, 0);
    if (n < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, n, 0, cond);
    TS_AST_SET_PAYLOAD(ts_base, n, 1, body);
    return n;
}

# do body while (cond);
fn TS_PARSE_DO_WHILE(ts_base) {
    TS_PARSE_CONSUME(ts_base);                  # do
    var body = TS_PARSE_STMT(ts_base);
    if (body < 0) { return 0 - 1; }
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_KW_WHILE) < 0) { return 0 - 1; }
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_LPAREN) < 0) { return 0 - 1; }
    var cond = TS_PARSE_EXPR(ts_base);
    if (cond < 0) { return 0 - 1; }
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_RPAREN) < 0) { return 0 - 1; }
    TS_PARSE_OPT_SEMI(ts_base);
    var n = TS_AST_PUSH(ts_base, TS_AST_STMT_DO_WHILE, 0);
    if (n < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, n, 0, body);
    TS_AST_SET_PAYLOAD(ts_base, n, 1, cond);
    return n;
}

fn TS_PARSE_RETURN(ts_base) {
    TS_PARSE_CONSUME(ts_base);
    var n = TS_AST_PUSH(ts_base, TS_AST_STMT_RETURN, 0);
    if (n < 0) { return 0 - 1; }
    var t = TS_PARSE_PEEK(ts_base);
    if (t != TS_TOK_SEMI && t != TS_TOK_RBRACE && t != TS_TOK_EOF) {
        var e = TS_PARSE_EXPR(ts_base);
        if (e < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, n, 0, e);
    } else {
        TS_AST_SET_PAYLOAD(ts_base, n, 0, 0 - 1);
    }
    TS_PARSE_OPT_SEMI(ts_base);
    return n;
}

fn TS_PARSE_THROW(ts_base) {
    TS_PARSE_CONSUME(ts_base);
    var e = TS_PARSE_EXPR(ts_base);
    if (e < 0) { return 0 - 1; }
    var n = TS_AST_PUSH(ts_base, TS_AST_STMT_THROW, 0);
    if (n < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, n, 0, e);
    TS_PARSE_OPT_SEMI(ts_base);
    return n;
}

fn TS_PARSE_BREAK(ts_base) {
    TS_PARSE_CONSUME(ts_base);
    var n = TS_AST_PUSH(ts_base, TS_AST_STMT_BREAK, 0);
    if (n < 0) { return 0 - 1; }
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_IDENT) {
        TS_AST_SET_PAYLOAD(ts_base, n, 0, TS_PARSE_TOK_VAL(ts_base));
        TS_PARSE_CONSUME(ts_base);
    }
    TS_PARSE_OPT_SEMI(ts_base);
    return n;
}

fn TS_PARSE_CONTINUE(ts_base) {
    TS_PARSE_CONSUME(ts_base);
    var n = TS_AST_PUSH(ts_base, TS_AST_STMT_CONTINUE, 0);
    if (n < 0) { return 0 - 1; }
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_IDENT) {
        TS_AST_SET_PAYLOAD(ts_base, n, 0, TS_PARSE_TOK_VAL(ts_base));
        TS_PARSE_CONSUME(ts_base);
    }
    TS_PARSE_OPT_SEMI(ts_base);
    return n;
}

fn TS_PARSE_TRY(ts_base) {
    TS_PARSE_CONSUME(ts_base);                  # try
    var try_body = TS_PARSE_BLOCK(ts_base);
    if (try_body < 0) { return 0 - 1; }
    var catch_clause = 0 - 1;
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_KW_CATCH) {
        TS_PARSE_CONSUME(ts_base);
        catch_clause = TS_AST_PUSH(ts_base, TS_AST_STMT_CATCH_CLAUSE, 0);
        if (catch_clause < 0) { return 0 - 1; }
        # Optional `(name)` or `(name: T)`
        if (TS_PARSE_PEEK(ts_base) == TS_TOK_LPAREN) {
            TS_PARSE_CONSUME(ts_base);
            var pname = TS_PARSE_TOK_VAL(ts_base);
            if (TS_PARSE_EXPECT(ts_base, TS_TOK_IDENT) < 0) { return 0 - 1; }
            TS_AST_SET_PAYLOAD(ts_base, catch_clause, 0, pname);
            if (TS_PARSE_PEEK(ts_base) == TS_TOK_COLON) {
                TS_PARSE_CONSUME(ts_base);
                var ct_t = TS_PARSE_TYPE(ts_base);
                if (ct_t < 0) { return 0 - 1; }
                TS_AST_SET_PAYLOAD(ts_base, catch_clause, 2, ct_t);
            }
            if (TS_PARSE_EXPECT(ts_base, TS_TOK_RPAREN) < 0) { return 0 - 1; }
        }
        var cbody = TS_PARSE_BLOCK(ts_base);
        if (cbody < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, catch_clause, 1, cbody);
    }
    var finally_body = 0 - 1;
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_KW_FINALLY) {
        TS_PARSE_CONSUME(ts_base);
        finally_body = TS_PARSE_BLOCK(ts_base);
        if (finally_body < 0) { return 0 - 1; }
    }
    var n = TS_AST_PUSH(ts_base, TS_AST_STMT_TRY, 0);
    if (n < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, n, 0, try_body);
    TS_AST_SET_PAYLOAD(ts_base, n, 1, catch_clause);
    TS_AST_SET_PAYLOAD(ts_base, n, 2, finally_body);
    return n;
}

fn TS_PARSE_SWITCH(ts_base) {
    TS_PARSE_CONSUME(ts_base);                  # switch
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_LPAREN) < 0) { return 0 - 1; }
    var disc = TS_PARSE_EXPR(ts_base);
    if (disc < 0) { return 0 - 1; }
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_RPAREN) < 0) { return 0 - 1; }
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_LBRACE) < 0) { return 0 - 1; }
    var n = TS_AST_PUSH(ts_base, TS_AST_STMT_SWITCH, 0);
    if (n < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, n, 0, disc);
    var coff = TS_AST_CHILDREN_RESERVE(ts_base, 32);
    if (coff < 0) { return 0 - 1; }
    var ci = 0;
    var go = 1;
    while (go == 1) {
        var t = TS_PARSE_PEEK(ts_base);
        if (t == TS_TOK_RBRACE || t == TS_TOK_EOF) { go = 0; }
        elif (t == TS_TOK_KW_CASE || t == TS_TOK_KW_DEFAULT) {
            var case_node = TS_AST_PUSH(ts_base, TS_AST_STMT_SWITCH_CASE, 0);
            if (case_node < 0) { return 0 - 1; }
            if (t == TS_TOK_KW_CASE) {
                TS_PARSE_CONSUME(ts_base);
                var ce = TS_PARSE_EXPR(ts_base);
                if (ce < 0) { return 0 - 1; }
                TS_AST_SET_PAYLOAD(ts_base, case_node, 0, ce);
            } else {
                TS_PARSE_CONSUME(ts_base);
                TS_AST_SET_PAYLOAD(ts_base, case_node, 0, 0 - 1);
            }
            if (TS_PARSE_EXPECT(ts_base, TS_TOK_COLON) < 0) { return 0 - 1; }
            # Body: stmts until next case/default/}
            var soff = TS_AST_CHILDREN_RESERVE(ts_base, 16);
            if (soff < 0) { return 0 - 1; }
            var si = 0;
            var sgo = 1;
            while (sgo == 1) {
                var st = TS_PARSE_PEEK(ts_base);
                if (st == TS_TOK_KW_CASE || st == TS_TOK_KW_DEFAULT
                    || st == TS_TOK_RBRACE || st == TS_TOK_EOF) {
                    sgo = 0;
                } else {
                    var s = TS_PARSE_STMT(ts_base);
                    if (s < 0) { return 0 - 1; }
                    TS_AST_CHILDREN_SET(ts_base, soff + si, s);
                    si = si + 1;
                }
            }
            TS_AST_CHILDREN_SET(ts_base, soff + si, 0 - 1);
            TS_AST_CHILDREN_COMMIT(ts_base, si + 1);
            TS_AST_SET_PAYLOAD(ts_base, case_node, 1, soff);
            TS_AST_CHILDREN_SET(ts_base, coff + ci, case_node);
            ci = ci + 1;
        } else {
            store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_CODE, 7);
            return 0 - 1;
        }
    }
    TS_AST_CHILDREN_SET(ts_base, coff + ci, 0 - 1);
    TS_AST_CHILDREN_COMMIT(ts_base, ci + 1);
    TS_AST_SET_PAYLOAD(ts_base, n, 1, coff);
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_RBRACE) < 0) { return 0 - 1; }
    return n;
}

# ================================================================
# Declaration parsers (P2.5)
# ================================================================
# function / class / interface / type-alias declarations + supporting
# helpers. Class/interface members included. Function expression
# variant (`function (args) { body }` in expression position) lives
# in TS_PARSE_PRIMARY for proximity to other primary forms.
#
# Modifiers (public/private/protected/static/readonly/abstract/async)
# are consumed for syntax acceptance but not recorded in the AST.
# Type-params (`<T extends C = D>`) are consumed similarly. The
# typechecker that follows will re-parse these from the source spans.

# Generic type-param list `<T, U extends C = D>`. Returns the count
# parsed (0 if no `<` follows). On error returns -1.
fn TS_PARSE_TYPE_PARAMS(ts_base) {
    if (TS_PARSE_PEEK(ts_base) != TS_TOK_LT) { return 0; }
    TS_PARSE_CONSUME(ts_base);
    var n = 0;
    var done = 0;
    while (done == 0) {
        var pt = TS_PARSE_PEEK(ts_base);
        if (pt == TS_TOK_GT || pt == TS_TOK_GT_GT || pt == TS_TOK_GT_GT_GT
            || pt == TS_TOK_GT_EQ || pt == TS_TOK_GT_GT_EQ
            || pt == TS_TOK_GT_GT_GT_EQ) {
            done = 1;
        } else {
            if (n > 0) {
                if (TS_PARSE_EXPECT(ts_base, TS_TOK_COMMA) < 0) { return 0 - 1; }
            }
            # Param name
            if (TS_PARSE_EXPECT(ts_base, TS_TOK_IDENT) < 0) { return 0 - 1; }
            # Optional `extends ConstraintType`
            if (TS_PARSE_PEEK(ts_base) == TS_TOK_KW_EXTENDS) {
                TS_PARSE_CONSUME(ts_base);
                var c = TS_PARSE_TYPE(ts_base);
                if (c < 0) { return 0 - 1; }
            }
            # Optional `= DefaultType`
            if (TS_PARSE_PEEK(ts_base) == TS_TOK_EQ) {
                TS_PARSE_CONSUME(ts_base);
                var d = TS_PARSE_TYPE(ts_base);
                if (d < 0) { return 0 - 1; }
            }
            n = n + 1;
        }
    }
    if (TS_PARSE_EXPECT_TYPE_GT(ts_base) < 0) { return 0 - 1; }
    return n;
}

# Comma-separated type-ref list for extends/implements clauses.
# Returns children-array offset of the list (terminated by -1).
fn TS_PARSE_HERITAGE_LIST(ts_base) {
    var off = TS_AST_CHILDREN_RESERVE(ts_base, 16);
    if (off < 0) { return 0 - 1; }
    var i = 0;
    var done = 0;
    while (done == 0) {
        var ref = TS_PARSE_TYPE_REF(ts_base);
        if (ref < 0) { return 0 - 1; }
        TS_AST_CHILDREN_SET(ts_base, off + i, ref);
        i = i + 1;
        if (TS_PARSE_MATCH(ts_base, TS_TOK_COMMA) == 0) { done = 1; }
    }
    TS_AST_CHILDREN_SET(ts_base, off + i, 0 - 1);
    TS_AST_CHILDREN_COMMIT(ts_base, i + 1);
    return off;
}

# `function [name] [<T>] (params) [: ret] { body }`.
# Caller has just consumed the `function` keyword (or, for async fn,
# `async` then `function`). For function expression caller passes
# stmt_required=0 (name optional); for declaration stmt_required=1.
fn TS_PARSE_DECL_FUNCTION(ts_base, name_required) {
    var name_v = 0;
    var pk = TS_PARSE_PEEK(ts_base);
    if (pk == TS_TOK_IDENT) {
        name_v = TS_PARSE_TOK_VAL(ts_base);
        TS_PARSE_CONSUME(ts_base);
    } elif (name_required == 1) {
        store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_CODE, 4);
        store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_TOK_IDX,
                load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_TOK_IDX));
        return 0 - 1;
    }
    var tp = TS_PARSE_TYPE_PARAMS(ts_base);
    if (tp < 0) { return 0 - 1; }
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_LPAREN) < 0) { return 0 - 1; }
    var params_off = TS_PARSE_ARROW_PARAMS(ts_base);
    if (params_off < 0) { return 0 - 1; }
    var ret_t = 0;
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_COLON) {
        TS_PARSE_CONSUME(ts_base);
        ret_t = TS_PARSE_TYPE(ts_base);
        if (ret_t < 0) { return 0 - 1; }
    }
    var body = TS_PARSE_BLOCK(ts_base);
    if (body < 0) { return 0 - 1; }
    var n = TS_AST_PUSH(ts_base, TS_AST_DECL_FUNCTION, name_v);
    if (n < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, n, 0, name_v);
    TS_AST_SET_PAYLOAD(ts_base, n, 1, params_off);
    TS_AST_SET_PAYLOAD(ts_base, n, 2, ret_t);
    TS_AST_SET_PAYLOAD(ts_base, n, 3, body);
    return n;
}

# `type Name [<T>] = type;`. Caller has consumed `type`.
fn TS_PARSE_DECL_TYPE_ALIAS(ts_base) {
    var name_v = TS_PARSE_TOK_VAL(ts_base);
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_IDENT) < 0) { return 0 - 1; }
    var tp = TS_PARSE_TYPE_PARAMS(ts_base);
    if (tp < 0) { return 0 - 1; }
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_EQ) < 0) { return 0 - 1; }
    var t = TS_PARSE_TYPE(ts_base);
    if (t < 0) { return 0 - 1; }
    TS_PARSE_OPT_SEMI(ts_base);
    var n = TS_AST_PUSH(ts_base, TS_AST_DECL_TYPE_ALIAS, name_v);
    if (n < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, n, 0, name_v);
    TS_AST_SET_PAYLOAD(ts_base, n, 1, t);
    TS_AST_SET_PAYLOAD(ts_base, n, 2, tp);
    return n;
}

# Single interface member.
# Shapes:
#   readonly? name [?] : type ;             -> property
#   name [<T>] (params) [: ret] ;           -> method
#   new (params) : ret ;                    -> construct sig
#   (params) : ret ;                        -> call sig
#   [k: K]: V ;                             -> index sig
fn TS_PARSE_INTERFACE_MEMBER(ts_base) {
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_KW_READONLY) {
        TS_PARSE_CONSUME(ts_base);
    }
    var t = TS_PARSE_PEEK(ts_base);
    # Index signature: [k: K]: V
    if (t == TS_TOK_LBRACKET) {
        TS_PARSE_CONSUME(ts_base);
        if (TS_PARSE_EXPECT(ts_base, TS_TOK_IDENT) < 0) { return 0 - 1; }
        if (TS_PARSE_EXPECT(ts_base, TS_TOK_COLON) < 0) { return 0 - 1; }
        var k_t = TS_PARSE_TYPE(ts_base);
        if (k_t < 0) { return 0 - 1; }
        if (TS_PARSE_EXPECT(ts_base, TS_TOK_RBRACKET) < 0) { return 0 - 1; }
        if (TS_PARSE_EXPECT(ts_base, TS_TOK_COLON) < 0) { return 0 - 1; }
        var v_t = TS_PARSE_TYPE(ts_base);
        if (v_t < 0) { return 0 - 1; }
        TS_PARSE_OPT_SEMI(ts_base);
        var ix = TS_AST_PUSH(ts_base, TS_AST_TYPE_INDEX_SIG, 0);
        if (ix < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, ix, 0, k_t);
        TS_AST_SET_PAYLOAD(ts_base, ix, 1, v_t);
        return ix;
    }
    # Construct signature: new (params) : ret
    if (t == TS_TOK_KW_NEW) {
        TS_PARSE_CONSUME(ts_base);
        if (TS_PARSE_EXPECT(ts_base, TS_TOK_LPAREN) < 0) { return 0 - 1; }
        var ctor_params = TS_PARSE_ARROW_PARAMS(ts_base);
        if (ctor_params < 0) { return 0 - 1; }
        var ctor_ret = 0;
        if (TS_PARSE_PEEK(ts_base) == TS_TOK_COLON) {
            TS_PARSE_CONSUME(ts_base);
            ctor_ret = TS_PARSE_TYPE(ts_base);
            if (ctor_ret < 0) { return 0 - 1; }
        }
        TS_PARSE_OPT_SEMI(ts_base);
        var cn = TS_AST_PUSH(ts_base, TS_AST_DECL_CONSTRUCTOR, 0);
        if (cn < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, cn, 1, ctor_params);
        TS_AST_SET_PAYLOAD(ts_base, cn, 2, ctor_ret);
        return cn;
    }
    # Call signature: (params) : ret  — bare LPAREN as first token
    if (t == TS_TOK_LPAREN) {
        TS_PARSE_CONSUME(ts_base);
        var call_params = TS_PARSE_ARROW_PARAMS(ts_base);
        if (call_params < 0) { return 0 - 1; }
        var call_ret = 0;
        if (TS_PARSE_PEEK(ts_base) == TS_TOK_COLON) {
            TS_PARSE_CONSUME(ts_base);
            call_ret = TS_PARSE_TYPE(ts_base);
            if (call_ret < 0) { return 0 - 1; }
        }
        TS_PARSE_OPT_SEMI(ts_base);
        var fnsig = TS_AST_PUSH(ts_base, TS_AST_TYPE_FN, 0);
        if (fnsig < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, fnsig, 0, call_params);
        TS_AST_SET_PAYLOAD(ts_base, fnsig, 1, call_ret);
        return fnsig;
    }
    # Otherwise: name-based property / method
    var name_v = TS_PARSE_TOK_VAL(ts_base);
    var pt = TS_PARSE_PEEK(ts_base);
    var ok = 0;
    if (pt == TS_TOK_IDENT) { ok = 1; }
    elif (pt == TS_TOK_STRING) { ok = 1; }
    elif (pt == TS_TOK_INT) { ok = 1; }
    elif (pt == TS_TOK_KW_FROM) { ok = 1; }
    elif (pt == TS_TOK_KW_AS) { ok = 1; }
    elif (pt == TS_TOK_KW_OF) { ok = 1; }
    elif (pt == TS_TOK_KW_GET) { ok = 1; }
    elif (pt == TS_TOK_KW_SET) { ok = 1; }
    elif (pt == TS_TOK_KW_TYPE) { ok = 1; }
    if (ok == 0) {
        store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_CODE, 5);
        store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_TOK_IDX,
                load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_TOK_IDX));
        return 0 - 1;
    }
    TS_PARSE_CONSUME(ts_base);
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_QUESTION) {
        TS_PARSE_CONSUME(ts_base);
    }
    var nxt = TS_PARSE_PEEK(ts_base);
    # Method: optional <T> then (params) : ret
    if (nxt == TS_TOK_LT || nxt == TS_TOK_LPAREN) {
        var mtp = TS_PARSE_TYPE_PARAMS(ts_base);
        if (mtp < 0) { return 0 - 1; }
        if (TS_PARSE_EXPECT(ts_base, TS_TOK_LPAREN) < 0) { return 0 - 1; }
        var mp = TS_PARSE_ARROW_PARAMS(ts_base);
        if (mp < 0) { return 0 - 1; }
        var mr = 0;
        if (TS_PARSE_PEEK(ts_base) == TS_TOK_COLON) {
            TS_PARSE_CONSUME(ts_base);
            mr = TS_PARSE_TYPE(ts_base);
            if (mr < 0) { return 0 - 1; }
        }
        TS_PARSE_OPT_SEMI(ts_base);
        var mn = TS_AST_PUSH(ts_base, TS_AST_DECL_METHOD, name_v);
        if (mn < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, mn, 0, name_v);
        TS_AST_SET_PAYLOAD(ts_base, mn, 1, mp);
        TS_AST_SET_PAYLOAD(ts_base, mn, 2, mr);
        return mn;
    }
    # Property: : type
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_COLON) < 0) { return 0 - 1; }
    var pty = TS_PARSE_TYPE(ts_base);
    if (pty < 0) { return 0 - 1; }
    TS_PARSE_OPT_SEMI(ts_base);
    var pn = TS_AST_PUSH(ts_base, TS_AST_DECL_PROPERTY, name_v);
    if (pn < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, pn, 0, name_v);
    TS_AST_SET_PAYLOAD(ts_base, pn, 1, pty);
    return pn;
}

# `interface Name [<T>] [extends X, Y] { members }`.
# Caller has consumed `interface`.
fn TS_PARSE_DECL_INTERFACE(ts_base) {
    var name_v = TS_PARSE_TOK_VAL(ts_base);
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_IDENT) < 0) { return 0 - 1; }
    var tp = TS_PARSE_TYPE_PARAMS(ts_base);
    if (tp < 0) { return 0 - 1; }
    var ext_off = 0;
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_KW_EXTENDS) {
        TS_PARSE_CONSUME(ts_base);
        ext_off = TS_PARSE_HERITAGE_LIST(ts_base);
        if (ext_off < 0) { return 0 - 1; }
    }
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_LBRACE) < 0) { return 0 - 1; }
    var members_off = TS_AST_CHILDREN_RESERVE(ts_base, 32);
    if (members_off < 0) { return 0 - 1; }
    var mi = 0;
    while (TS_PARSE_PEEK(ts_base) != TS_TOK_RBRACE) {
        if (TS_PARSE_PEEK(ts_base) == TS_TOK_SEMI) {
            TS_PARSE_CONSUME(ts_base);
        } else {
            var m = TS_PARSE_INTERFACE_MEMBER(ts_base);
            if (m < 0) { return 0 - 1; }
            TS_AST_CHILDREN_SET(ts_base, members_off + mi, m);
            mi = mi + 1;
        }
    }
    TS_AST_CHILDREN_SET(ts_base, members_off + mi, 0 - 1);
    TS_AST_CHILDREN_COMMIT(ts_base, mi + 1);
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_RBRACE) < 0) { return 0 - 1; }
    var n = TS_AST_PUSH(ts_base, TS_AST_DECL_INTERFACE, name_v);
    if (n < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, n, 0, name_v);
    TS_AST_SET_PAYLOAD(ts_base, n, 1, members_off);
    TS_AST_SET_PAYLOAD(ts_base, n, 2, ext_off);
    TS_AST_SET_PAYLOAD(ts_base, n, 3, tp);
    return n;
}

# Skip class/interface modifier prefixes: public/private/protected/
# static/readonly/abstract/async/declare/override. Returns 0.
# (We consume them for syntax acceptance; the typechecker re-parses.)
fn TS_PARSE_SKIP_MODIFIERS(ts_base) {
    var done = 0;
    while (done == 0) {
        var t = TS_PARSE_PEEK(ts_base);
        if (t == TS_TOK_KW_PUBLIC) { TS_PARSE_CONSUME(ts_base); }
        elif (t == TS_TOK_KW_PRIVATE) { TS_PARSE_CONSUME(ts_base); }
        elif (t == TS_TOK_KW_PROTECTED) { TS_PARSE_CONSUME(ts_base); }
        elif (t == TS_TOK_KW_STATIC) { TS_PARSE_CONSUME(ts_base); }
        elif (t == TS_TOK_KW_READONLY) { TS_PARSE_CONSUME(ts_base); }
        elif (t == TS_TOK_KW_ABSTRACT) { TS_PARSE_CONSUME(ts_base); }
        elif (t == TS_TOK_KW_ASYNC) { TS_PARSE_CONSUME(ts_base); }
        else { done = 1; }
    }
    return 0;
}

# Single class member.
fn TS_PARSE_CLASS_MEMBER(ts_base) {
    TS_PARSE_SKIP_MODIFIERS(ts_base);
    var t = TS_PARSE_PEEK(ts_base);
    # Constructor: `constructor(params) { body }`
    if (t == TS_TOK_KW_CONSTRUCTOR) {
        TS_PARSE_CONSUME(ts_base);
        if (TS_PARSE_EXPECT(ts_base, TS_TOK_LPAREN) < 0) { return 0 - 1; }
        var cp = TS_PARSE_ARROW_PARAMS(ts_base);
        if (cp < 0) { return 0 - 1; }
        var cb = TS_PARSE_BLOCK(ts_base);
        if (cb < 0) { return 0 - 1; }
        var cn = TS_AST_PUSH(ts_base, TS_AST_DECL_CONSTRUCTOR, 0);
        if (cn < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, cn, 1, cp);
        TS_AST_SET_PAYLOAD(ts_base, cn, 3, cb);
        return cn;
    }
    # Get/set accessor: `get|set name(...) { }`. Both KW_GET/KW_SET
    # are contextual — followed by an IDENT-eligible name token.
    if (t == TS_TOK_KW_GET || t == TS_TOK_KW_SET) {
        var ahead = TS_PARSE_PEEK_AHEAD(ts_base, 1);
        var ahead_ok = 0;
        if (ahead == TS_TOK_IDENT) { ahead_ok = 1; }
        elif (ahead == TS_TOK_STRING) { ahead_ok = 1; }
        elif (ahead == TS_TOK_INT) { ahead_ok = 1; }
        if (ahead_ok == 1) {
            TS_PARSE_CONSUME(ts_base);                 # get / set
            var aname = TS_PARSE_TOK_VAL(ts_base);
            TS_PARSE_CONSUME(ts_base);                 # name
            if (TS_PARSE_EXPECT(ts_base, TS_TOK_LPAREN) < 0) { return 0 - 1; }
            var ap = TS_PARSE_ARROW_PARAMS(ts_base);
            if (ap < 0) { return 0 - 1; }
            var ar = 0;
            if (TS_PARSE_PEEK(ts_base) == TS_TOK_COLON) {
                TS_PARSE_CONSUME(ts_base);
                ar = TS_PARSE_TYPE(ts_base);
                if (ar < 0) { return 0 - 1; }
            }
            var ab = TS_PARSE_BLOCK(ts_base);
            if (ab < 0) { return 0 - 1; }
            var an = TS_AST_PUSH(ts_base, TS_AST_DECL_METHOD, aname);
            if (an < 0) { return 0 - 1; }
            TS_AST_SET_PAYLOAD(ts_base, an, 0, aname);
            TS_AST_SET_PAYLOAD(ts_base, an, 1, ap);
            TS_AST_SET_PAYLOAD(ts_base, an, 2, ar);
            TS_AST_SET_PAYLOAD(ts_base, an, 3, ab);
            return an;
        }
    }
    # Otherwise: name-based property or method
    var name_v = TS_PARSE_TOK_VAL(ts_base);
    var pt = TS_PARSE_PEEK(ts_base);
    var ok = 0;
    if (pt == TS_TOK_IDENT) { ok = 1; }
    elif (pt == TS_TOK_STRING) { ok = 1; }
    elif (pt == TS_TOK_INT) { ok = 1; }
    elif (pt == TS_TOK_KW_FROM) { ok = 1; }
    elif (pt == TS_TOK_KW_AS) { ok = 1; }
    elif (pt == TS_TOK_KW_OF) { ok = 1; }
    elif (pt == TS_TOK_KW_GET) { ok = 1; }
    elif (pt == TS_TOK_KW_SET) { ok = 1; }
    elif (pt == TS_TOK_KW_TYPE) { ok = 1; }
    if (ok == 0) {
        store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_CODE, 6);
        store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ERR_TOK_IDX,
                load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_TOK_IDX));
        return 0 - 1;
    }
    TS_PARSE_CONSUME(ts_base);
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_QUESTION) {
        TS_PARSE_CONSUME(ts_base);
    }
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_BANG) {
        TS_PARSE_CONSUME(ts_base);   # definite-assignment marker
    }
    var nxt = TS_PARSE_PEEK(ts_base);
    # Method
    if (nxt == TS_TOK_LT || nxt == TS_TOK_LPAREN) {
        var mtp = TS_PARSE_TYPE_PARAMS(ts_base);
        if (mtp < 0) { return 0 - 1; }
        if (TS_PARSE_EXPECT(ts_base, TS_TOK_LPAREN) < 0) { return 0 - 1; }
        var mp = TS_PARSE_ARROW_PARAMS(ts_base);
        if (mp < 0) { return 0 - 1; }
        var mr = 0;
        if (TS_PARSE_PEEK(ts_base) == TS_TOK_COLON) {
            TS_PARSE_CONSUME(ts_base);
            mr = TS_PARSE_TYPE(ts_base);
            if (mr < 0) { return 0 - 1; }
        }
        # Abstract methods (and ambient declarations) have no body —
        # they end with `;` (or via ASI). Otherwise expect a block.
        var mb = 0;
        if (TS_PARSE_PEEK(ts_base) == TS_TOK_SEMI) {
            TS_PARSE_CONSUME(ts_base);
        } else {
            mb = TS_PARSE_BLOCK(ts_base);
            if (mb < 0) { return 0 - 1; }
        }
        var mn = TS_AST_PUSH(ts_base, TS_AST_DECL_METHOD, name_v);
        if (mn < 0) { return 0 - 1; }
        TS_AST_SET_PAYLOAD(ts_base, mn, 0, name_v);
        TS_AST_SET_PAYLOAD(ts_base, mn, 1, mp);
        TS_AST_SET_PAYLOAD(ts_base, mn, 2, mr);
        TS_AST_SET_PAYLOAD(ts_base, mn, 3, mb);
        return mn;
    }
    # Property: optional `: type`, optional `= init`, then `;`
    var prop_ty = 0;
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_COLON) {
        TS_PARSE_CONSUME(ts_base);
        prop_ty = TS_PARSE_TYPE(ts_base);
        if (prop_ty < 0) { return 0 - 1; }
    }
    var prop_init = 0;
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_EQ) {
        TS_PARSE_CONSUME(ts_base);
        prop_init = TS_PARSE_ASSIGN(ts_base);
        if (prop_init < 0) { return 0 - 1; }
    }
    TS_PARSE_OPT_SEMI(ts_base);
    var pn = TS_AST_PUSH(ts_base, TS_AST_DECL_PROPERTY, name_v);
    if (pn < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, pn, 0, name_v);
    TS_AST_SET_PAYLOAD(ts_base, pn, 1, prop_ty);
    TS_AST_SET_PAYLOAD(ts_base, pn, 2, prop_init);
    return pn;
}

# `class Name [<T>] [extends X] [implements Y, Z] { members }`.
# Caller has consumed `class` (and any leading `abstract` modifier).
fn TS_PARSE_DECL_CLASS(ts_base) {
    var name_v = 0;
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_IDENT) {
        name_v = TS_PARSE_TOK_VAL(ts_base);
        TS_PARSE_CONSUME(ts_base);
    }
    var tp = TS_PARSE_TYPE_PARAMS(ts_base);
    if (tp < 0) { return 0 - 1; }
    var extends_t = 0;
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_KW_EXTENDS) {
        TS_PARSE_CONSUME(ts_base);
        extends_t = TS_PARSE_TYPE_REF(ts_base);
        if (extends_t < 0) { return 0 - 1; }
    }
    var impl_off = 0;
    if (TS_PARSE_PEEK(ts_base) == TS_TOK_KW_IMPLEMENTS) {
        TS_PARSE_CONSUME(ts_base);
        impl_off = TS_PARSE_HERITAGE_LIST(ts_base);
        if (impl_off < 0) { return 0 - 1; }
    }
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_LBRACE) < 0) { return 0 - 1; }
    var members_off = TS_AST_CHILDREN_RESERVE(ts_base, 64);
    if (members_off < 0) { return 0 - 1; }
    var mi = 0;
    while (TS_PARSE_PEEK(ts_base) != TS_TOK_RBRACE) {
        if (TS_PARSE_PEEK(ts_base) == TS_TOK_SEMI) {
            TS_PARSE_CONSUME(ts_base);
        } else {
            var m = TS_PARSE_CLASS_MEMBER(ts_base);
            if (m < 0) { return 0 - 1; }
            TS_AST_CHILDREN_SET(ts_base, members_off + mi, m);
            mi = mi + 1;
        }
    }
    TS_AST_CHILDREN_SET(ts_base, members_off + mi, 0 - 1);
    TS_AST_CHILDREN_COMMIT(ts_base, mi + 1);
    if (TS_PARSE_EXPECT(ts_base, TS_TOK_RBRACE) < 0) { return 0 - 1; }
    var n = TS_AST_PUSH(ts_base, TS_AST_DECL_CLASS, name_v);
    if (n < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, n, 0, name_v);
    TS_AST_SET_PAYLOAD(ts_base, n, 1, members_off);
    TS_AST_SET_PAYLOAD(ts_base, n, 2, extends_t);
    TS_AST_SET_PAYLOAD(ts_base, n, 3, impl_off);
    return n;
}

# expression statement: `expr;`
fn TS_PARSE_EXPR_STMT(ts_base) {
    var e = TS_PARSE_EXPR(ts_base);
    if (e < 0) { return 0 - 1; }
    var n = TS_AST_PUSH(ts_base, TS_AST_STMT_EXPR, 0);
    if (n < 0) { return 0 - 1; }
    TS_AST_SET_PAYLOAD(ts_base, n, 0, e);
    TS_PARSE_OPT_SEMI(ts_base);
    return n;
}

# Statement dispatcher.
fn TS_PARSE_STMT(ts_base) {
    var t = TS_PARSE_PEEK(ts_base);
    if (t == TS_TOK_LBRACE)        { return TS_PARSE_BLOCK(ts_base); }
    if (t == TS_TOK_KW_VAR)        { return TS_PARSE_VAR_DECL(ts_base); }
    if (t == TS_TOK_KW_LET)        { return TS_PARSE_VAR_DECL(ts_base); }
    if (t == TS_TOK_KW_CONST)      { return TS_PARSE_VAR_DECL(ts_base); }
    if (t == TS_TOK_KW_IF)         { return TS_PARSE_IF(ts_base); }
    if (t == TS_TOK_KW_FOR)        { return TS_PARSE_FOR(ts_base); }
    if (t == TS_TOK_KW_WHILE)      { return TS_PARSE_WHILE(ts_base); }
    if (t == TS_TOK_KW_DO)         { return TS_PARSE_DO_WHILE(ts_base); }
    if (t == TS_TOK_KW_RETURN)     { return TS_PARSE_RETURN(ts_base); }
    if (t == TS_TOK_KW_THROW)      { return TS_PARSE_THROW(ts_base); }
    if (t == TS_TOK_KW_BREAK)      { return TS_PARSE_BREAK(ts_base); }
    if (t == TS_TOK_KW_CONTINUE)   { return TS_PARSE_CONTINUE(ts_base); }
    if (t == TS_TOK_KW_TRY)        { return TS_PARSE_TRY(ts_base); }
    if (t == TS_TOK_KW_SWITCH)     { return TS_PARSE_SWITCH(ts_base); }
    if (t == TS_TOK_KW_FUNCTION) {
        TS_PARSE_CONSUME(ts_base);
        return TS_PARSE_DECL_FUNCTION(ts_base, 1);
    }
    if (t == TS_TOK_KW_INTERFACE) {
        TS_PARSE_CONSUME(ts_base);
        return TS_PARSE_DECL_INTERFACE(ts_base);
    }
    if (t == TS_TOK_KW_CLASS) {
        TS_PARSE_CONSUME(ts_base);
        return TS_PARSE_DECL_CLASS(ts_base);
    }
    if (t == TS_TOK_KW_ABSTRACT) {
        # Only accept `abstract class` here; bare `abstract` falls
        # through to expression statement.
        if (TS_PARSE_PEEK_AHEAD(ts_base, 1) == TS_TOK_KW_CLASS) {
            TS_PARSE_CONSUME(ts_base);   # abstract
            TS_PARSE_CONSUME(ts_base);   # class
            return TS_PARSE_DECL_CLASS(ts_base);
        }
    }
    if (t == TS_TOK_KW_ASYNC) {
        # `async function` -> async function decl. Bare `async` falls
        # through; `async (` may be an arrow expression but that's
        # handled at expression level.
        if (TS_PARSE_PEEK_AHEAD(ts_base, 1) == TS_TOK_KW_FUNCTION) {
            TS_PARSE_CONSUME(ts_base);   # async
            TS_PARSE_CONSUME(ts_base);   # function
            return TS_PARSE_DECL_FUNCTION(ts_base, 1);
        }
    }
    if (t == TS_TOK_KW_TYPE) {
        # `type Name = ...` is contextual: only treat as type-alias
        # when next is IDENT and the one after is `<` or `=`.
        if (TS_PARSE_PEEK_AHEAD(ts_base, 1) == TS_TOK_IDENT) {
            var ahead2 = TS_PARSE_PEEK_AHEAD(ts_base, 2);
            if (ahead2 == TS_TOK_EQ || ahead2 == TS_TOK_LT) {
                TS_PARSE_CONSUME(ts_base);   # type
                return TS_PARSE_DECL_TYPE_ALIAS(ts_base);
            }
        }
    }
    if (t == TS_TOK_SEMI) {
        # Empty statement
        TS_PARSE_CONSUME(ts_base);
        return TS_PARSE_STMT(ts_base);
    }
    return TS_PARSE_EXPR_STMT(ts_base);
}

# ================================================================
# TS_PARSE — main parser entry (P2.1 STUB)
# ================================================================
# Caller has already invoked TS_LEX to populate the token tables.
# This entry walks those tokens and builds the AST in TS_AST_NODES.
#
# Returns: total node count on success, or -1 on parse error.
# Call TS_PARSE_GETERR(ts_base) for the err code:
#   1 = AST node cap exceeded
#   2 = children buffer cap exceeded
#   3 = unexpected token (call TS_PARSE_GETERR_TOK for the index)
#
# P2.1 STUB: just allocates a ROOT node and returns. P2.2-P2.6 fill
# in real parsing. P2.7 acceptance gate runs against SY's TS surface.

fn TS_PARSE(ts_base) {
    TS_PARSE_INIT(ts_base);
    var root = TS_AST_PUSH(ts_base, TS_AST_ROOT, 0);
    if (root < 0) { return 0 - 1; }
    store64(ts_base + TS_PARSE_STATE_OFF + TS_PS_ROOT_NODE, root);

    # Reserve children[0] as a sentinel so subsequent RESERVE() always
    # returns offset >= 1. This lets payload-stored "0" mean "no list"
    # without colliding with a real list at offset 0. (Same idea as
    # the node-0 placeholder used by parse_expr/parse_type test
    # helpers — see P2.4 sentinel discussion.)
    var sentinel0 = TS_AST_CHILDREN_RESERVE(ts_base, 1);
    if (sentinel0 < 0) { return 0 - 1; }
    TS_AST_CHILDREN_SET(ts_base, sentinel0, 0 - 1);
    TS_AST_CHILDREN_COMMIT(ts_base, 1);

    # P2.3: parse a sequence of top-level statements.
    # ROOT.payload[0] = children-array offset (head)
    # ROOT.payload[1] = statement count
    # Sentinel -1 closes the children list.
    var head = 0 - 1;
    var count = 0;
    var first = 1;
    while (TS_PARSE_PEEK(ts_base) != TS_TOK_EOF) {
        var s = TS_PARSE_STMT(ts_base);
        if (s < 0) { return 0 - 1; }
        var slot = TS_AST_CHILDREN_RESERVE(ts_base, 1);
        if (slot < 0) { return 0 - 1; }
        TS_AST_CHILDREN_SET(ts_base, slot, s);
        TS_AST_CHILDREN_COMMIT(ts_base, 1);
        if (first == 1) { head = slot; first = 0; }
        count = count + 1;
    }
    # Append sentinel
    var sent = TS_AST_CHILDREN_RESERVE(ts_base, 1);
    if (sent >= 0) {
        TS_AST_CHILDREN_SET(ts_base, sent, 0 - 1);
        TS_AST_CHILDREN_COMMIT(ts_base, 1);
    }
    if (count > 0) {
        TS_AST_SET_PAYLOAD(ts_base, root, 0, head);
    }
    TS_AST_SET_PAYLOAD(ts_base, root, 1, count);
    return TS_AST_NODE_COUNT(ts_base);
}
