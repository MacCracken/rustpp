    while (bpat > 0) { var _bpa = S + 0x64A000 + bpat; var _bnb = L64(_bpa) & 0xFFFFFFFF; EPATCH(S, bpat); bpat = _bnb; }
    SCOPE_POP(S);
    S64(S + 0x18F838, slt);
    S64(S + 0x18F840, sbk);
    S64(S + 0x18F898, scfw);
    SLVAR(S, slv);
    return 0;
}

