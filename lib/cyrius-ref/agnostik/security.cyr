# agnostik/security.cyr — security types and access control
# Usage: include "lib/agnostik/security.cyr"
#
# Cyrius re-implementation of agnostik security.rs
# Covers: permissions, roles, filesystem access, network access, sandbox config.

# Filesystem access levels
enum FsAccess {
    FS_NO_ACCESS = 0;
    FS_READ_ONLY = 1;
    FS_READ_WRITE = 2;
}

# Network access levels
enum NetworkAccess {
    NET_NONE = 0;
    NET_LOCALHOST_ONLY = 1;
    NET_RESTRICTED = 2;
    NET_FULL = 3;
}

# Permission types (bit flags — can be OR'd together)
enum Permission {
    PERM_FILE_READ = 1;
    PERM_FILE_WRITE = 2;
    PERM_NETWORK = 4;
    PERM_PROCESS_SPAWN = 8;
    PERM_LLM_INFERENCE = 16;
    PERM_AUDIT_READ = 32;
}

# Roles
enum Role {
    ROLE_ADMIN = 0;
    ROLE_OPERATOR = 1;
    ROLE_AUDITOR = 2;
    ROLE_VIEWER = 3;
    ROLE_SERVICE = 4;
}

# Policy effects
enum PolicyEffect {
    POLICY_ALLOW = 0;
    POLICY_DENY = 1;
    POLICY_AUDIT = 2;
}

# Seccomp actions
enum SeccompAction {
    SECCOMP_ALLOW = 0;
    SECCOMP_KILL = 1;
    SECCOMP_KILL_PROCESS = 2;
    SECCOMP_TRAP = 3;
    SECCOMP_LOG = 4;
}

# Seccomp modes
enum SeccompMode {
    SECCOMP_DISABLED = 0;
    SECCOMP_STRICT = 1;
    SECCOMP_FILTER = 2;
}

# Security context: agent_id, permissions (bitmask), role, sandbox flags
struct SecurityContext {
    agent_id;
    permissions;
    role;
    fs_access;
    net_access;
    seccomp_mode;
    no_new_privs;
}

# Resource limits for sandboxing
struct ResourceLimits {
    max_memory;
    max_cpu_time;
    max_file_descriptors;
    max_processes;
    max_disk_bytes;
}

# Create a default security context (viewer, no permissions)
fn sec_ctx_new(agent_id) {
    var ctx = alloc(56);
    store64(ctx, agent_id);
    store64(ctx + 8, 0);
    store64(ctx + 16, ROLE_VIEWER);
    store64(ctx + 24, FS_NO_ACCESS);
    store64(ctx + 32, NET_NONE);
    store64(ctx + 40, SECCOMP_DISABLED);
    store64(ctx + 48, 1);
    return ctx;
}

# Check if security context has a specific permission
fn sec_has_perm(ctx, perm) {
    var perms = load64(ctx + 8);
    if ((perms & perm) != 0) { return 1; }
    return 0;
}

# Grant a permission
fn sec_grant_perm(ctx, perm) {
    var perms = load64(ctx + 8);
    store64(ctx + 8, perms | perm);
    return 0;
}

# Revoke a permission
fn sec_revoke_perm(ctx, perm) {
    var perms = load64(ctx + 8);
    store64(ctx + 8, perms & (0 - 1 - perm));
    return 0;
}

# Set role
fn sec_set_role(ctx, role) {
    store64(ctx + 16, role);
    return 0;
}

# Get role
fn sec_get_role(ctx) {
    return load64(ctx + 16);
}

# Set filesystem access level
fn sec_set_fs(ctx, level) {
    store64(ctx + 24, level);
    return 0;
}

# Set network access level
fn sec_set_net(ctx, level) {
    store64(ctx + 32, level);
    return 0;
}

# Check if role can perform admin operations
fn role_is_admin(role) {
    if (role == ROLE_ADMIN) { return 1; }
    return 0;
}

# Print role name
fn role_print(role) {
    if (role == ROLE_ADMIN) { syscall(1, 1, "Admin", 5); return 0; }
    if (role == ROLE_OPERATOR) { syscall(1, 1, "Operator", 8); return 0; }
    if (role == ROLE_AUDITOR) { syscall(1, 1, "Auditor", 7); return 0; }
    if (role == ROLE_VIEWER) { syscall(1, 1, "Viewer", 6); return 0; }
    if (role == ROLE_SERVICE) { syscall(1, 1, "Service", 7); return 0; }
    syscall(1, 1, "Unknown", 7);
    return 0;
}

# Create default resource limits
fn rlimits_new() {
    var lim = alloc(40);
    store64(lim, 256 * 1024 * 1024);
    store64(lim + 8, 60);
    store64(lim + 16, 256);
    store64(lim + 24, 32);
    store64(lim + 32, 1024 * 1024 * 1024);
    return lim;
}
