# agnostik/agent.cyr — agent configuration and lifecycle
# Usage: include "lib/agnostik/agent.cyr"
# Requires: alloc.cyr, agnostik/types.cyr, agnostik/security.cyr
#
# Cyrius re-implementation of agnostik agent.rs
# Agent config, resource tracking, health check, rate limiting.

# Agent configuration (heap-allocated)
# Layout: name_ptr(0), agent_type(8), restart_policy(16), max_memory(24),
#         max_cpu_time(32), max_fds(40), max_procs(48), health_interval(56),
#         health_timeout(64), health_retries(72)
var AGENT_CONFIG_SIZE = 80;

fn agent_config_new(name) {
    var cfg = alloc(AGENT_CONFIG_SIZE);
    store64(cfg, name);
    store64(cfg + 8, AGENT_USER);
    store64(cfg + 16, RESTART_NEVER);
    store64(cfg + 24, 256 * 1024 * 1024);
    store64(cfg + 32, 60);
    store64(cfg + 40, 256);
    store64(cfg + 48, 32);
    store64(cfg + 56, 30);
    store64(cfg + 64, 5);
    store64(cfg + 72, 3);
    return cfg;
}

fn agent_config_name(cfg) { return load64(cfg); }
fn agent_config_type(cfg) { return load64(cfg + 8); }
fn agent_config_set_type(cfg, t) { store64(cfg + 8, t); return 0; }
fn agent_config_restart(cfg) { return load64(cfg + 16); }
fn agent_config_set_restart(cfg, p) { store64(cfg + 16, p); return 0; }
fn agent_config_max_mem(cfg) { return load64(cfg + 24); }
fn agent_config_set_max_mem(cfg, m) { store64(cfg + 24, m); return 0; }

# Agent info: id, name, type, status (runtime state)
# Layout: id(0), name_ptr(8), agent_type(16), status(24)
var AGENT_INFO_SIZE = 32;

fn agent_info_new(id, name, atype) {
    var info = alloc(AGENT_INFO_SIZE);
    store64(info, id);
    store64(info + 8, name);
    store64(info + 16, atype);
    store64(info + 24, STATUS_PENDING);
    return info;
}

fn agent_info_id(info) { return load64(info); }
fn agent_info_name(info) { return load64(info + 8); }
fn agent_info_type(info) { return load64(info + 16); }
fn agent_info_status(info) { return load64(info + 24); }
fn agent_info_set_status(info, s) { store64(info + 24, s); return 0; }

# Agent stats: total_requests, total_tokens, uptime_seconds
# Layout: requests(0), tokens(8), uptime(16)
var AGENT_STATS_SIZE = 24;

fn agent_stats_new() {
    var st = alloc(AGENT_STATS_SIZE);
    store64(st, 0);
    store64(st + 8, 0);
    store64(st + 16, 0);
    return st;
}

fn agent_stats_requests(st) { return load64(st); }
fn agent_stats_tokens(st) { return load64(st + 8); }
fn agent_stats_uptime(st) { return load64(st + 16); }
fn agent_stats_inc_req(st) { store64(st, load64(st) + 1); return 0; }
fn agent_stats_add_tokens(st, n) { store64(st + 8, load64(st + 8) + n); return 0; }
fn agent_stats_set_uptime(st, t) { store64(st + 16, t); return 0; }

# Rate limit: max_tokens_per_hour, max_req_per_min, max_concurrent
# Layout: tokens_hr(0), req_min(8), concurrent(16)
var RATE_LIMIT_SIZE = 24;

fn rate_limit_new(tokens_hr, req_min, concurrent) {
    var rl = alloc(RATE_LIMIT_SIZE);
    store64(rl, tokens_hr);
    store64(rl + 8, req_min);
    store64(rl + 16, concurrent);
    return rl;
}

# Resource usage tracking
# Layout: mem_used(0), cpu_used(8), fds_used(16), procs_used(24)
var RESOURCE_USAGE_SIZE = 32;

fn resource_usage_new() {
    var ru = alloc(RESOURCE_USAGE_SIZE);
    store64(ru, 0);
    store64(ru + 8, 0);
    store64(ru + 16, 0);
    store64(ru + 24, 0);
    return ru;
}

fn resource_mem(ru) { return load64(ru); }
fn resource_cpu(ru) { return load64(ru + 8); }
fn resource_fds(ru) { return load64(ru + 16); }
fn resource_procs(ru) { return load64(ru + 24); }

# Check if resource usage exceeds config limits
fn resource_exceeds(ru, cfg) {
    if (load64(ru) > load64(cfg + 24)) { return 1; }
    if (load64(ru + 8) > load64(cfg + 32)) { return 1; }
    if (load64(ru + 16) > load64(cfg + 40)) { return 1; }
    if (load64(ru + 24) > load64(cfg + 48)) { return 1; }
    return 0;
}

# Print agent type name
fn agent_type_print(t) {
    if (t == AGENT_SYSTEM) { syscall(1, 1, "System", 6); return 0; }
    if (t == AGENT_USER) { syscall(1, 1, "User", 4); return 0; }
    if (t == AGENT_SERVICE) { syscall(1, 1, "Service", 7); return 0; }
    syscall(1, 1, "Unknown", 7);
    return 0;
}
