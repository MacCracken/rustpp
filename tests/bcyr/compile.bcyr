# Bench: Compiler performance
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/bench.cyr"
include "lib/io.cyr"
include "lib/process.cyr"

# Benchmark: self-compile time
fn bench_self_compile() {
    run_capture("cat src/main.cyr | ./build/cc2 > /dev/null 2>&1");
    return 0;
}

var b1 = bench_new("self-compile", &bench_self_compile, 0);
bench_run(b1, 10);
bench_report(b1);

# Benchmark: hello world compile
fn bench_hello() {
    run_capture("echo 'var x = 42;' | ./build/cc2 > /dev/null 2>&1");
    return 0;
}

var b2 = bench_new("hello-compile", &bench_hello, 0);
bench_run(b2, 100);
bench_report(b2);

var x = 0;
