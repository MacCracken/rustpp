# v5.7.x P4.9 — generic function/method types in type position:
# `<T>(params) => Ret`. Used as a top-level type and as an
# object-type member (`{ post: <T>(...): T }`). Pre-fix
# TS_PARSE_TYPE_PRIMARY had no LT branch; the `<T>` prefix was
# unrecognized in type position.
#
# Slot lifted +3 SY corpus files: 2 .ts + 1 .tsx.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/syscalls.cyr"
include "lib/assert.cyr"

include "src/frontend/ts/lex.cyr"
include "src/frontend/ts/parse.cyr"

alloc_init();
var ts_base = alloc(TS_HEAP_SIZE + 4096);

fn parse_first_stmt(src) {
    var nt = TS_LEX(ts_base, src, strlen(src));
    if (nt < 0) { return 0 - 1; }
    var nn = TS_PARSE(ts_base);
    if (nn < 0) { return 0 - 1; }
    var head = TS_AST_PAYLOAD(ts_base, 0, 0);
    return TS_AST_CHILDREN_GET(ts_base, head);
}

# ─── top-level generic fn type ──────────────────────────────────
test_group("top-level generic fn type");

var s = parse_first_stmt("let f: <T>(x: T) => T;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "<T>(x: T) => T");

s = parse_first_stmt("let g: <T, U>(t: T, u: U) => [T, U];");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "<T, U>(t, u) => [T, U]");

s = parse_first_stmt("let h: <T extends Base = Default>(x: T) => T;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "<T extends Base = Default>");

# ─── generic method type inside object type (the SY repro) ──────
test_group("generic method type in object type");

s = parse_first_stmt("let c: { post: <T>(path: string, body?: unknown) => Promise<T> };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "{ post: <T>(...) => Promise<T> }");

s = parse_first_stmt("let v: { fetch: <K>(k: K) => K; ping: () => void };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "two members, one generic, one not");

# ─── regression: plain fn types still work ──────────────────────
test_group("regression: plain fn types");

s = parse_first_stmt("let f: (x: number) => string;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "(x: number) => string");

s = parse_first_stmt("let m: { run: (x: number) => string };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "{ run: (x) => string }");

# ─── regression: type-ref with type-args still works ────────────
test_group("regression: type-ref type-args");

s = parse_first_stmt("let p: Promise<string>;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "Promise<string>");

var exit_code = assert_summary();
syscall(60, exit_code);
