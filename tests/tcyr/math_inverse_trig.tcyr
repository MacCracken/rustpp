# math_inverse_trig.tcyr — `f64_asin` / `f64_acos` / `f64_atan2`
# (v4.8.5-alpha5)
#
# Headline fix for abaco: atan2 quadrant correctness. abaco 1.1.0
# was carrying an inline identity-based stopgap that was wrong in
# Q2 / Q3 (no quadrant correction). These tests pin every quadrant
# plus the four axis cases (±x, ±y = 0) so regressions show up
# loudly.

include "lib/syscalls.cyr"
include "lib/alloc.cyr"
include "lib/math.cyr"
include "lib/assert.cyr"

alloc_init();

# eps ≈ 1e-10 as an f64 bit pattern.
var EPS = 0x3DDB_7CDF_D9D7_BDBB;

# Return 1 if |a − b| < EPS.
fn near(a, b) {
    return f64_lt(f64_abs(f64_sub(a, b)), EPS);
}

# Pre-computed reference bit patterns for values not built from
# primitives already in F64_* — π/6, 3π/4, π/3, etc.
var F64_PI_6 = 0x3FE0_C152_382D_7365;   # π/6
var F64_PI_3 = 0x3FF0_C152_382D_7365;   # π/3

test_group("asin");
assert_eq(near(f64_asin(0),        0),        1, "asin(0) = 0");
assert_eq(near(f64_asin(F64_ONE),  F64_PI_2), 1, "asin(1) = π/2");
assert_eq(near(f64_asin(F64_HALF), F64_PI_6), 1, "asin(½) = π/6");
assert_eq(near(f64_asin(f64_neg(F64_ONE)), f64_neg(F64_PI_2)), 1,
          "asin(−1) = −π/2");

test_group("acos");
assert_eq(near(f64_acos(F64_ONE), 0),        1, "acos(1) = 0");
assert_eq(near(f64_acos(0),       F64_PI_2), 1, "acos(0) = π/2");
assert_eq(near(f64_acos(F64_HALF), F64_PI_3), 1, "acos(½) = π/3");
assert_eq(near(f64_acos(f64_neg(F64_ONE)), F64_PI), 1,
          "acos(−1) = π");

test_group("atan2 quadrants");
# Q1: (+, +) → atan(y/x), range (0, π/2)
assert_eq(near(f64_atan2(F64_ONE, F64_ONE), F64_PI_4), 1,
          "atan2(1, 1) = π/4");
# Q2: (+, −) → atan(y/x) + π, range (π/2, π)
var three_pi_4 = f64_sub(F64_PI, F64_PI_4);
assert_eq(near(f64_atan2(F64_ONE, f64_neg(F64_ONE)), three_pi_4), 1,
          "atan2(1, −1) = 3π/4");
# Q3: (−, −) → atan(y/x) − π, range (−π, −π/2)
assert_eq(near(f64_atan2(f64_neg(F64_ONE), f64_neg(F64_ONE)),
               f64_neg(three_pi_4)), 1,
          "atan2(−1, −1) = −3π/4");
# Q4: (−, +) → atan(y/x), range (−π/2, 0)
assert_eq(near(f64_atan2(f64_neg(F64_ONE), F64_ONE),
               f64_neg(F64_PI_4)), 1,
          "atan2(−1, 1) = −π/4");

test_group("atan2 axes + origin");
assert_eq(f64_atan2(0, 0), 0, "atan2(0, 0) = 0 (convention)");
assert_eq(near(f64_atan2(F64_ONE, 0),          F64_PI_2), 1,
          "atan2(1, 0) = π/2");
assert_eq(near(f64_atan2(f64_neg(F64_ONE), 0), f64_neg(F64_PI_2)), 1,
          "atan2(−1, 0) = −π/2");
# y = 0 axis: x > 0 → 0; x < 0 → π.
assert_eq(near(f64_atan2(0, F64_ONE),          0),      1,
          "atan2(0, +x) = 0");
assert_eq(near(f64_atan2(0, f64_neg(F64_ONE)), F64_PI), 1,
          "atan2(0, −x) = π");

var _exit_code = assert_summary();
syscall(60, _exit_code);
