# result.tcyr — v5.8.28 — Result<T, E> typed sum type + helpers
# (carved out of lib/tagged.cyr into lib/result.cyr).
#
# Locks the regression floor for:
#   (1) `enum Result<T, E> { Ok(v); Err(e); }` — typed/generic
#       shape using v5.8.21 generic-parameter syntax. Type params
#       are syntactically accepted, not yet bound semantically
#       (mono-only erasure — same status as `enum TwoParams<T, E>`
#       in tests/tcyr/enum_generics.tcyr).
#   (2) Constructor layout: `Ok(v)` / `Err(e)` produce the same
#       tag-at-+0 / payload-at-+8 / 16-byte heap form as the
#       v5.8.23 compiler-generated tagged unions. Tag values
#       match the prior OK = 0 / ERR = 1 convention.
#   (3) Helpers: `is_ok`, `is_err_result`, `result_unwrap`,
#       `result_unwrap_or`, `err_code_of`, `result_print`.
#   (4) Pattern-match consumer over a Result via `match load64(res)`
#       (current v5.8.x match dispatches on the tag discriminator).
#   (5) Backward compat: lib/tagged.cyr still re-exports Result
#       transitively, so existing consumers (lib/net.cyr,
#       lib/ws_server.cyr, lib/sandhi.cyr, tests/tcyr/tagged.tcyr)
#       keep working — the tagged.tcyr test continues to pass.
#
# Sets up v5.8.29's `?` propagation (which desugars to early-
# return on `Err`) and v5.8.30/.31 stdlib migrations.

include "lib/syscalls.cyr"
include "lib/alloc.cyr"
include "lib/fmt.cyr"
include "lib/result.cyr"
include "lib/assert.cyr"

alloc_init();

test_group("typed Result<T, E> — Ok constructor");
var ok = Ok(42);
assert_eq(load64(ok), 0, "Ok tag = 0");
assert_eq(load64(ok + 8), 42, "Ok payload = 42");

test_group("typed Result<T, E> — Err constructor");
var err = Err(7);
assert_eq(load64(err), 1, "Err tag = 1");
assert_eq(load64(err + 8), 7, "Err payload = 7");

test_group("is_ok / is_err_result");
assert_eq(is_ok(ok), 1, "is_ok(Ok) = 1");
assert_eq(is_ok(err), 0, "is_ok(Err) = 0");
assert_eq(is_err_result(ok), 0, "is_err_result(Ok) = 0");
assert_eq(is_err_result(err), 1, "is_err_result(Err) = 1");

test_group("result_unwrap_or");
assert_eq(result_unwrap_or(ok, 0 - 1), 42, "Ok(42) -> 42");
assert_eq(result_unwrap_or(err, 99), 99, "Err(7) -> fallback 99");

test_group("err_code_of");
assert_eq(err_code_of(ok), 0, "Ok -> code 0");
assert_eq(err_code_of(err), 7, "Err(7) -> code 7");

test_group("payload roundtrip — negatives and zero");
var ok_zero = Ok(0);
assert_eq(load64(ok_zero + 8), 0, "Ok(0) payload = 0");
var ok_neg = Ok(0 - 1);
assert_eq(load64(ok_neg + 8), 0 - 1, "Ok(-1) payload = -1");
var err_neg = Err(0 - 42);
assert_eq(load64(err_neg + 8), 0 - 42, "Err(-42) payload = -42");

# ---- Pattern-match consumer ----
# v5.8.x match dispatches on the tag discriminator; for payload-
# carrying variants the canonical shape is `match load64(res)`.
# v5.8.29 `?` and any future variant-binding sugar layer on top.
fn _classify(res) {
    var r = 0;
    match load64(res) {
        Ok  => { r = 100; }
        Err => { r = 200; }
    }
    return r;
}

test_group("pattern-match consumer over Result");
assert_eq(_classify(Ok(1)),  100, "match Ok arm");
assert_eq(_classify(Err(2)), 200, "match Err arm");
assert_eq(_classify(Ok(0 - 99)),  100, "match Ok arm (negative payload)");
assert_eq(_classify(Err(0)),      200, "match Err arm (zero payload)");

# ---- Realistic shape: a fn returning Result ----
fn _safe_div(n, d) {
    if (d == 0) { return Err(1); }
    return Ok(n / d);
}

test_group("Result-returning fn — happy path");
var r1 = _safe_div(20, 4);
assert_eq(is_ok(r1), 1, "20/4 is Ok");
assert_eq(result_unwrap_or(r1, 0), 5, "20/4 = 5");

test_group("Result-returning fn — error path");
var r2 = _safe_div(20, 0);
assert_eq(is_err_result(r2), 1, "20/0 is Err");
assert_eq(err_code_of(r2), 1, "div-by-zero code = 1");
assert_eq(result_unwrap_or(r2, 0 - 1), 0 - 1, "fallback used on Err");

var r = assert_summary();
