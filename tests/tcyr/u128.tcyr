# Regression: u128 type slot (4.8.0-alpha1 + alpha3) + stdlib helpers.
#
# The alpha3 fix (PARSE_VAR's global fallback setting var_size to the
# full ann_scalar, not hardcoded 8) is what makes this test meaningful:
# with `alloc_init();` as the first top-level statement, pass 1 stops
# and the subsequent `var a: u128 = 0;` runs through PARSE_VAR — which
# pre-alpha3 truncated u128 slots to 8 bytes, silently overlapping hi
# with the next var's lo.

include "lib/syscalls.cyr"
include "lib/alloc.cyr"
include "lib/assert.cyr"
include "lib/u128.cyr"

alloc_init();

test_group("u128 var slot zero-init");
var z: u128 = 0;
assert_eq(load64(&z), 0, "lo zero");
assert_eq(load64(&z + 8), 0, "hi zero");

test_group("u128_set / u128_lo / u128_hi");
var a: u128 = 0;
u128_set(&a, 0xDEAD_BEEF_CAFE_BABE, 0x1234_5678_9ABC_DEF0);
assert_eq(u128_lo(&a), 0xDEADBEEFCAFEBABE, "lo readback");
assert_eq(u128_hi(&a), 0x123456789ABCDEF0, "hi readback");

test_group("u128_from_u64 zero-extends");
var b: u128 = 0;
u128_from_u64(&b, 42);
assert_eq(u128_lo(&b), 42, "lo = 42");
assert_eq(u128_hi(&b), 0, "hi = 0");

test_group("u128_copy preserves both limbs");
var c: u128 = 0;
u128_copy(&c, &a);
assert_eq(u128_lo(&c), u128_lo(&a), "lo copied");
assert_eq(u128_hi(&c), u128_hi(&a), "hi copied");

test_group("u128_eq");
var d: u128 = 0;
u128_set(&d, 0xDEADBEEFCAFEBABE, 0x123456789ABCDEF0);
assert_eq(u128_eq(&a, &d), 1, "a == d");
assert_eq(u128_eq(&a, &b), 0, "a != b");

test_group("u128_is_zero");
assert_eq(u128_is_zero(&z), 1, "z is zero");
assert_eq(u128_is_zero(&a), 0, "a not zero");
var hi_only: u128 = 0;
u128_set(&hi_only, 0, 1);
assert_eq(u128_is_zero(&hi_only), 0, "hi-only not zero");

test_group("16-byte slot layout (alpha3 regression guard)");
var g1: u128 = 0;
var g2: u128 = 0;
assert_eq(&g2 - &g1, 16, "consecutive u128 vars are 16 bytes apart");

test_group("u128_add (alpha4)");
var add_a: u128 = 0;
var add_b: u128 = 0;
var add_r: u128 = 0;
# 0 + 0 = 0
u128_add(&add_r, &add_a, &add_b);
assert_eq(u128_is_zero(&add_r), 1, "0 + 0 = 0");
# 1 + 1 = 2
u128_set(&add_a, 1, 0);
u128_set(&add_b, 1, 0);
u128_add(&add_r, &add_a, &add_b);
assert_eq(u128_lo(&add_r), 2, "1 + 1 lo = 2");
assert_eq(u128_hi(&add_r), 0, "1 + 1 hi = 0");
# 0xFFFF_FFFF_FFFF_FFFF + 1 = 2^64 (crosses limb boundary)
u128_set(&add_a, 0xFFFF_FFFF_FFFF_FFFF, 0);
u128_set(&add_b, 1, 0);
u128_add(&add_r, &add_a, &add_b);
assert_eq(u128_lo(&add_r), 0, "max_u64 + 1 lo = 0 (carry)");
assert_eq(u128_hi(&add_r), 1, "max_u64 + 1 hi = 1");
# (2^64 - 1, 2^64 - 1) + (0, 1) = (2^64 - 1, 0) (hi wraps)
u128_set(&add_a, 0xFFFF_FFFF_FFFF_FFFF, 0xFFFF_FFFF_FFFF_FFFF);
u128_set(&add_b, 0, 1);
u128_add(&add_r, &add_a, &add_b);
assert_eq(u128_lo(&add_r), 0xFFFF_FFFF_FFFF_FFFF, "wrap lo unchanged");
assert_eq(u128_hi(&add_r), 0, "wrap hi = 0 (no carry out)");
# max_u128 + 1 = 0 (full wrap)
u128_set(&add_a, 0xFFFF_FFFF_FFFF_FFFF, 0xFFFF_FFFF_FFFF_FFFF);
u128_set(&add_b, 1, 0);
u128_add(&add_r, &add_a, &add_b);
assert_eq(u128_is_zero(&add_r), 1, "max_u128 + 1 = 0");

test_group("u128_sub");
var sub_a: u128 = 0;
var sub_b: u128 = 0;
var sub_r: u128 = 0;
# 2 - 1 = 1
u128_set(&sub_a, 2, 0);
u128_set(&sub_b, 1, 0);
u128_sub(&sub_r, &sub_a, &sub_b);
assert_eq(u128_lo(&sub_r), 1, "2 - 1 lo = 1");
assert_eq(u128_hi(&sub_r), 0, "2 - 1 hi = 0");
# (0, 1) - (1, 0) = max_u64 (borrow across limb)
u128_set(&sub_a, 0, 1);
u128_set(&sub_b, 1, 0);
u128_sub(&sub_r, &sub_a, &sub_b);
assert_eq(u128_lo(&sub_r), 0xFFFF_FFFF_FFFF_FFFF, "borrow lo = max_u64");
assert_eq(u128_hi(&sub_r), 0, "borrow hi = 0");
# 0 - 1 = max_u128 (full wrap)
u128_set(&sub_a, 0, 0);
u128_set(&sub_b, 1, 0);
u128_sub(&sub_r, &sub_a, &sub_b);
assert_eq(u128_lo(&sub_r), 0xFFFF_FFFF_FFFF_FFFF, "0 - 1 lo = max_u64");
assert_eq(u128_hi(&sub_r), 0xFFFF_FFFF_FFFF_FFFF, "0 - 1 hi = max_u64");
# a + b - b == a (round-trip)
u128_set(&sub_a, 0xDEAD_BEEF_CAFE_BABE, 0x1234_5678_9ABC_DEF0);
u128_set(&sub_b, 0x1111_2222_3333_4444, 0x5555_6666_7777_8888);
var tmp: u128 = 0;
u128_add(&tmp, &sub_a, &sub_b);
u128_sub(&sub_r, &tmp, &sub_b);
assert_eq(u128_eq(&sub_r, &sub_a), 1, "(a+b)-b == a");

test_group("u128_addeq / u128_subeq");
var acc: u128 = 0;
var one: u128 = 0;
u128_set(&one, 1, 0);
u128_set(&acc, 10, 0);
u128_addeq(&acc, &one);
assert_eq(u128_lo(&acc), 11, "10 += 1 = 11");
u128_subeq(&acc, &one);
u128_subeq(&acc, &one);
assert_eq(u128_lo(&acc), 9, "11 -= 1 -= 1 = 9");

test_group("u128_mul (alpha5)");
var m_a: u128 = 0;
var m_b: u128 = 0;
var m_r: u128 = 0;
# 0 * anything = 0
u128_set(&m_a, 0xDEAD_BEEF_CAFE_BABE, 0x1234_5678_9ABC_DEF0);
u128_set(&m_b, 0, 0);
u128_mul(&m_r, &m_a, &m_b);
assert_eq(u128_is_zero(&m_r), 1, "x * 0 = 0");
# 1 * x = x
u128_set(&m_b, 1, 0);
u128_mul(&m_r, &m_a, &m_b);
assert_eq(u128_eq(&m_r, &m_a), 1, "1 * x = x");
# 2 * 2 = 4
u128_set(&m_a, 2, 0);
u128_set(&m_b, 2, 0);
u128_mul(&m_r, &m_a, &m_b);
assert_eq(u128_lo(&m_r), 4, "2 * 2 lo = 4");
assert_eq(u128_hi(&m_r), 0, "2 * 2 hi = 0");
# 2^32 * 2^32 = 2^64 (crosses limb boundary, pure chunk carry)
u128_set(&m_a, 0x1_0000_0000, 0);
u128_set(&m_b, 0x1_0000_0000, 0);
u128_mul(&m_r, &m_a, &m_b);
assert_eq(u128_lo(&m_r), 0, "2^32 * 2^32 lo = 0");
assert_eq(u128_hi(&m_r), 1, "2^32 * 2^32 hi = 1");
# max_u64 * max_u64 = 2^128 - 2^65 + 1 = (1, max_u64 - 1)
u128_set(&m_a, 0xFFFF_FFFF_FFFF_FFFF, 0);
u128_set(&m_b, 0xFFFF_FFFF_FFFF_FFFF, 0);
u128_mul(&m_r, &m_a, &m_b);
assert_eq(u128_lo(&m_r), 1, "max_u64^2 lo = 1");
assert_eq(u128_hi(&m_r), 0xFFFF_FFFF_FFFF_FFFE, "max_u64^2 hi = max_u64 - 1");
# (0, 1) * (0, 1) = (0, 0) — 2^64 * 2^64 = 2^128 wraps
u128_set(&m_a, 0, 1);
u128_set(&m_b, 0, 1);
u128_mul(&m_r, &m_a, &m_b);
assert_eq(u128_is_zero(&m_r), 1, "2^64 * 2^64 wraps to 0");
# Cross terms: (1, 1) * (2, 3) = (2, 5)
# = (1 + 2^64) * (2 + 3*2^64) = 2 + 3*2^64 + 2*2^64 + 3*2^128
# mod 2^128 = 2 + 5*2^64
u128_set(&m_a, 1, 1);
u128_set(&m_b, 2, 3);
u128_mul(&m_r, &m_a, &m_b);
assert_eq(u128_lo(&m_r), 2, "(1,1)*(2,3) lo = 2");
assert_eq(u128_hi(&m_r), 5, "(1,1)*(2,3) hi = 5");
# u128_muleq in-place
var sq: u128 = 0;
u128_set(&sq, 7, 0);
var seven: u128 = 0;
u128_set(&seven, 7, 0);
u128_muleq(&sq, &seven);
assert_eq(u128_lo(&sq), 49, "7 *= 7 = 49");

assert_summary();
