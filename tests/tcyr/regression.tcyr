# regression.tcyr — regression tests for fixed compiler bugs
# Every bug fix should have a test here to prevent recurrence.

include "lib/assert.cyr"
include "lib/alloc.cyr"
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/syscalls.cyr"
include "lib/io.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/freelist.cyr"
include "lib/hashmap.cyr"
include "lib/json.cyr"
include "lib/fnptr.cyr"

# ================================================================
# Bug #32 regression: 7+ function arguments (3.3.11)
# push r12 shifted stack, args 7+ read wrong values
# ================================================================

fn add7(a, b, c, d, e, f, g) { return a + b + c + d + e + f + g; }
fn add8(a, b, c, d, e, f, g, h) { return a + b + c + d + e + f + g + h; }

fn test_stack_args() {
    test_group("7+ stack args");
    assert_eq(add7(1, 2, 3, 4, 5, 6, 7), 28, "7 args sum=28");
    assert_eq(add8(1, 2, 3, 4, 5, 6, 7, 8), 36, "8 args sum=36");
    assert_eq(add7(10, 20, 30, 40, 50, 60, 70), 280, "7 args large");
    assert_eq(add8(100, 200, 300, 400, 500, 600, 700, 800), 3600, "8 args large");
}

# ================================================================
# Break linked-list regression (3.3.15)
# Single break slot only patched last break; earlier breaks jumped to garbage
# ================================================================

fn test_multi_break() {
    test_group("multi break");
    var i = 0;
    var found = 0;
    while (i < 100) {
        if (i == 5) { found = 1; break; }
        if (i == 10) { found = 2; break; }
        if (i == 15) { found = 3; break; }
        i = i + 1;
    }
    assert_eq(found, 1, "first break at 5");
    assert_eq(i, 5, "stopped at 5");
}

fn test_nested_break() {
    test_group("nested break");
    var outer = 0;
    var inner_sum = 0;
    while (outer < 3) {
        var inner = 0;
        while (inner < 100) {
            if (inner == 5) { break; }
            inner = inner + 1;
        }
        inner_sum = inner_sum + inner;
        outer = outer + 1;
    }
    assert_eq(outer, 3, "outer completed");
    assert_eq(inner_sum, 15, "inner broke at 5 each time");
}

fn test_break_in_for() {
    test_group("break in for");
    var found = 0;
    for (var i = 0; i < 100; i = i + 1) {
        if (i == 42) { found = i; break; }
    }
    assert_eq(found, 42, "for break at 42");
}

# ================================================================
# Hex literal parsing regression (3.3.17)
# LEXHEX read from S+p instead of S+0x44A000+p
# ================================================================

fn test_hex_parsing() {
    test_group("hex literals");
    assert_eq(0xFF, 255, "0xFF");
    assert_eq(0xAB, 171, "0xAB");
    assert_eq(0x1A, 26, "0x1A");
    assert_eq(0x1A2, 418, "0x1A2");
    assert_eq(0x44A, 1098, "0x44A");
    # Large hex with mixed digits and letters
    var big = 0x44A000;
    assert_eq(big, 4497408, "0x44A000");
    assert_eq(big >> 20, 4, "0x44A000 >> 20");
}

# ================================================================
# Derive Serialize/Deserialize regression (3.4.4)
# _from_json_str declared var _neg/_iv/_vs per field, duplicate on 2nd field
# ================================================================

#derive(Serialize)
struct RegrPoint { x; y; }

#derive(Serialize)
struct RegrConfig { name: Str; value; count; }

fn test_derive_regression() {
    test_group("derive serialize");
    var p = RegrPoint { 42, 99 };
    var p2 = RegrPoint_from_json_str("{\"x\":42,\"y\":99}");
    assert_eq(load64(p2), 42, "from_json_str x");
    assert_eq(load64(p2 + 8), 99, "from_json_str y");

    test_group("derive multi-field");
    # Config has Str + 2 ints — tests duplicate var fix
    var c = RegrConfig_from_json_str("{\"name\":\"test\",\"value\":10,\"count\":3}");
    assert_eq(load64(c + 8), 10, "config value");
    assert_eq(load64(c + 16), 3, "config count");
}

# ================================================================
# fncall3-6 regression (3.4.3)
# Indirect calls with 3-6 args via System V ABI
# ================================================================

fn mul3(a, b, c) { return a * b * c; }
fn sum4(a, b, c, d) { return a + b + c + d; }
fn sum6(a, b, c, d, e, f) { return a + b + c + d + e + f; }

fn test_fncall() {
    test_group("fncall indirect");
    assert_eq(fncall3(&mul3, 2, 3, 7), 42, "fncall3");
    assert_eq(fncall4(&sum4, 10, 20, 30, 40), 100, "fncall4");
    assert_eq(fncall6(&sum6, 1, 2, 3, 4, 5, 6), 21, "fncall6");
}

# ================================================================
# Small function inlining regression (3.3.5)
# 2-param functions should inline correctly
# ================================================================

fn add_inline(a, b) { return a + b; }
fn mul_inline(a, b) { return a * b; }

fn test_inlining() {
    test_group("2-param inline");
    assert_eq(add_inline(20, 22), 42, "add inline");
    assert_eq(mul_inline(6, 7), 42, "mul inline");
    # Nested inline calls
    assert_eq(add_inline(mul_inline(3, 4), mul_inline(5, 6)), 42, "nested inline");
}

# ================================================================
# Gotcha #6 regression: nested while + load8 + break (3.4.6)
# CSV-style parsing with shared pos var across nested while loops
# ================================================================

fn test_nested_while_load8() {
    test_group("nested while load8");
    var buf = "3,7,2,5";
    var len = 7;
    var sum = 0;
    var pos = 0;
    while (pos < len) {
        var val = 0;
        while (pos < len) {
            var c = load8(buf + pos);
            if (c == 44) { pos = pos + 1; break; }
            if (c == 0) { break; }
            val = val * 10 + (c - 48);
            pos = pos + 1;
        }
        sum = sum + val;
    }
    assert_eq(sum, 17, "CSV 3+7+2+5=17");
}

# ================================================================
# Dead store elimination regression (3.3.2)
# ================================================================

fn test_dse() {
    test_group("dead store elimination");
    var x = 0;
    x = 42;
    assert_eq(x, 42, "DSE var init then assign");
    var y = 99;
    y = y + 1;
    assert_eq(y, 100, "DSE increment");
}

# ================================================================
# Constant folding regression (3.3.1)
# ================================================================

fn test_const_fold() {
    test_group("constant folding");
    assert_eq(320 * 200, 64000, "large multiply");
    assert_eq(50 * 1000, 50000, "50*1000 folds");
    var x = 42;
    assert_eq(x + 0, 42, "x+0 identity");
    assert_eq(x - 0, 42, "x-0 identity");
    assert_eq(x * 1, 42, "x*1 identity");
    assert_eq(x * 0, 0, "x*0 zero");
}

# ================================================================
# Defer statement regression (3.2.0)
# ================================================================

var _defer_order = 0;

fn defer_test_fn() {
    _defer_order = 0;
    defer { _defer_order = _defer_order * 10 + 1; }
    defer { _defer_order = _defer_order * 10 + 2; }
    _defer_order = 3;
    return 0;
}

fn defer_conditional_fn(x) {
    _defer_order = 0;
    defer { _defer_order = _defer_order * 10 + 1; }
    if (x == 0) { return 0; }
    defer { _defer_order = _defer_order * 10 + 2; }
    return 1;
}

fn test_defer() {
    test_group("defer LIFO");
    defer_test_fn();
    # Execution: _defer_order=3, then defer2 (3*10+2=32), then defer1 (32*10+1=321)
    assert_eq(_defer_order, 321, "defer LIFO order");
    # Conditional defer: early return before second defer (v3.8.0)
    test_group("defer on exit paths (v3.8.0)");
    defer_conditional_fn(0);
    assert_eq(_defer_order, 1, "early return: only first defer");
    defer_conditional_fn(1);
    assert_eq(_defer_order, 21, "normal return: both defers LIFO");
}

# ================================================================
# Expression-position comparisons (v3.5.0)
# ================================================================
# Before v3.5.0, == != < > only worked inside if()/while() conditions.
# Now they return 0/1 as values anywhere: var init, fn args, store, return.

fn test_expr_cmp() {
    test_group("expr comparisons (v3.5.0)");
    var a = 42;
    var b = 42;
    var c = 99;
    # var init
    assert_eq(a == b, 1, "== as value (equal)");
    assert_eq(a == c, 0, "== as value (not equal)");
    assert_eq(a != c, 1, "!= as value");
    assert_eq(a < c, 1, "< as value");
    assert_eq(c > a, 1, "> as value");
    assert_eq(a <= b, 1, "<= as value");
    assert_eq(a >= b, 1, ">= as value");
    # store + load roundtrip
    var buf[8];
    store64(&buf, a == b);
    assert_eq(load64(&buf), 1, "cmp in store64 value");
    # return value
    assert_eq(a == b, 1, "cmp as return value");
    # chained &&
    assert_eq(a == b && c > a, 1, "&& chain as value");
    assert_eq(a == c && c > a, 0, "&& short-circuit as value");
}

# ================================================================
# String interning (v3.6.1)
# ================================================================
# Identical string literals share the same address — pointer comparison works.

fn test_string_interning() {
    test_group("string interning (v3.6.1)");
    var a = "hello";
    var b = "hello";
    assert_eq(a == b, 1, "same literal same addr");
    var c = "world";
    assert_eq(a == c, 0, "different literal different addr");
    # Multiple occurrences across function boundaries
    assert_eq("test" == "test", 1, "inline interning");
    assert_eq("abc" == "abd", 0, "differ by last char");
    # Empty strings
    assert_eq("" == "", 1, "empty string interned");
}

# ================================================================
# Str/cstr auto-coercion (v3.6.0)
# ================================================================
# Functions with : Str parameters auto-wrap string literal args in str_from.

fn _coerce_test_eq(a: Str, b: Str) { return str_eq(a, b); }
fn _coerce_test_contains(s: Str, needle: Str) { return str_contains(s, needle); }

fn test_auto_coercion() {
    test_group("auto-coercion (v3.6.0)");
    # Both args auto-coerced
    assert_eq(_coerce_test_eq("hello", "hello"), 1, "both coerced eq");
    assert_eq(_coerce_test_eq("hello", "world"), 0, "both coerced neq");
    # Mixed: Str + literal
    var s = str_from("test");
    assert_eq(_coerce_test_eq(s, "test"), 1, "mixed Str + literal");
    # stdlib str_contains with annotation
    var h = str_from("hello world");
    assert_eq(str_contains(h, "world"), 1, "stdlib contains coerce");
    assert_eq(str_contains(h, "xyz"), 0, "stdlib contains miss");
    # str_starts_with / str_ends_with
    assert_eq(str_starts_with(h, "hello"), 1, "starts_with coerce");
    assert_eq(str_ends_with(h, "world"), 1, "ends_with coerce");
    # str_cat with auto-coercion
    var cat = str_cat("a", "b");
    assert_eq(str_len(cat), 2, "cat coerced len");
}

# ================================================================
# Syscall arity warning (v3.5.0) — compile-time only, verify no crash
# ================================================================
# These just confirm the compiler doesn't crash on well-formed syscalls.
# The actual WARNING check is a compile-time diagnostic, not a runtime test.

fn test_syscall_arity() {
    test_group("syscall arity (v3.5.0)");
    # Correct arities — should compile without warnings
    var pid = syscall(39);         # getpid: 0 args
    assert(pid > 0, "getpid");
    syscall(1, 2, "ok\n", 3);     # write: 3 args (fd=2, buf, len)
    assert(1, "write 3-arg ok");
}

# ================================================================
# Float literal in expressions (v3.7.0)
# ================================================================
# Float lexer had a bug: read next-char from S+np (stale input buffer)
# instead of S+0x44A000+np (preprocess buffer). Large programs read garbage
# and float detection failed — "expected ')', got '.'".

fn test_float_literal() {
    test_group("float literal (v3.7.0)");
    var f1 = 0.5;
    assert(f1 != 0, "0.5 not zero");
    var f2 = 0.25;
    assert(f2 != 0, "0.25 not zero");
    # Float in store64 (the avatara pattern)
    var buf[8];
    store64(&buf, 0.6);
    var loaded = load64(&buf);
    assert(loaded != 0, "store64 float roundtrip");
    # Float after arithmetic
    var p = alloc(16);
    store64(p + 8, 0.85);
    assert(load64(p + 8) != 0, "float after ptr arithmetic");
}

# ================================================================
# #derive(accessors) (v3.7.1)
# ================================================================
# Auto-generate field getters and setters for heap-allocated structs.
# #derive(accessors) struct Point { x; y; }
# Generates: Point_x(p), Point_set_x(p, v), Point_y(p), Point_set_y(p, v)

#derive(accessors)
struct AccPoint { x; y; }

#derive(accessors)
struct AccConfig { name: Str; value; count; }

fn test_derive_accessors() {
    test_group("derive accessors (v3.7.1)");
    # Basic 2-field struct
    var p = alloc(16);
    store64(p, 42);
    store64(p + 8, 99);
    assert_eq(AccPoint_x(p), 42, "getter x");
    assert_eq(AccPoint_y(p), 99, "getter y");
    AccPoint_set_x(p, 100);
    AccPoint_set_y(p, 200);
    assert_eq(AccPoint_x(p), 100, "setter x");
    assert_eq(AccPoint_y(p), 200, "setter y");
    # Mixed types (Str + scalars)
    var c = alloc(24);
    var s = str_from("hello");
    store64(c, s);
    store64(c + 8, 10);
    store64(c + 16, 3);
    assert_eq(AccConfig_value(c), 10, "config getter value");
    assert_eq(AccConfig_count(c), 3, "config getter count");
    AccConfig_set_value(c, 20);
    assert_eq(AccConfig_value(c), 20, "config setter value");
    # Str field accessor
    var ns = AccConfig_name(c);
    assert_eq(str_eq(ns, s), 1, "config getter Str");
}

# ================================================================
# Native multi-return (v3.7.2)
# ================================================================
# return (a, b) → rax:rdx register pair
# var x, y = fn() → destructure from rax:rdx

fn divmod(a, b) { return (a / b, a % b); }
fn swap(a, b) { return (b, a); }
fn minmax(a, b) { if (a < b) { return (a, b); } return (b, a); }

fn test_multi_return() {
    test_group("multi-return (v3.7.2)");
    # Basic return (a, b)
    var q, r = divmod(17, 5);
    assert_eq(q, 3, "divmod quotient");
    assert_eq(r, 2, "divmod remainder");
    # Swap
    var x, y = swap(10, 20);
    assert_eq(x, 20, "swap first");
    assert_eq(y, 10, "swap second");
    # Conditional multi-return
    var lo, hi = minmax(99, 7);
    assert_eq(lo, 7, "minmax lo");
    assert_eq(hi, 99, "minmax hi");
    # Using rethi() still works (backward compat)
    divmod(17, 5);
    var rhi = rethi();
    assert_eq(rhi, 2, "rethi compat");
}

# ================================================================
# Switch case blocks (v3.7.4)
# ================================================================
# case N: { ... } — block bodies in switch cases

fn test_switch_blocks() {
    test_group("switch case blocks (v3.7.4)");
    # Block body in case
    var result = 0;
    var x = 2;
    switch (x) {
        case 1: {
            var a = 10;
            result = a;
        }
        case 2: {
            var a = 20;
            var b = 22;
            result = a + b;
        }
        case 3: {
            result = 99;
        }
    }
    assert_eq(result, 42, "case 2 block body");
    # Mixed: some cases with blocks, some without
    var r2 = 0;
    switch (x) {
        case 1: r2 = 10;
        case 2: {
            r2 = 42;
        }
        case 3: r2 = 30;
    }
    assert_eq(r2, 42, "mixed block/inline");
    # Default with block
    var r3 = 0;
    switch (99) {
        case 1: r3 = 1;
        default: {
            r3 = 42;
        }
    }
    assert_eq(r3, 42, "default block body");
    # Nested control flow inside block
    var r4 = 0;
    switch (3) {
        case 3: {
            var sum = 0;
            for (var i = 0; i < 5; i = i + 1) {
                sum = sum + i;
            }
            r4 = sum;
        }
    }
    assert_eq(r4, 10, "for loop in case block");
}

# ================================================================
# Compound assignment (v3.10.1)
# ================================================================

fn test_compound_assign() {
    test_group("compound assign (v3.10.1)");
    var x = 10;
    x += 5;
    assert_eq(x, 15, "+=");
    x -= 3;
    assert_eq(x, 12, "-=");
    x *= 2;
    assert_eq(x, 24, "*=");
    x /= 4;
    assert_eq(x, 6, "/=");
    x %= 4;
    assert_eq(x, 2, "%=");
    # Bitwise
    var b = 0xFF;
    b &= 0x0F;
    assert_eq(b, 0x0F, "&=");
    b |= 0xF0;
    assert_eq(b, 0xFF, "|=");
    b ^= 0x0F;
    assert_eq(b, 0xF0, "^=");
    # In a for loop
    var sum = 0;
    for (var i = 0; i < 5; i += 1) {
        sum += i;
    }
    assert_eq(sum, 10, "for loop +=");
}

# ================================================================
# Entry point
# ================================================================

fn main() {
    alloc_init();

    test_stack_args();
    test_multi_break();
    test_nested_break();
    test_break_in_for();
    test_hex_parsing();
    test_derive_regression();
    test_fncall();
    test_inlining();
    test_nested_while_load8();
    test_dse();
    test_const_fold();
    test_defer();
    test_expr_cmp();
    test_string_interning();
    test_auto_coercion();
    test_syscall_arity();
    test_float_literal();
    test_derive_accessors();
    test_multi_return();
    test_switch_blocks();
    test_compound_assign();

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
