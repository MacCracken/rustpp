# Test: bitget, bitset, bitclr builtins
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/assert.cyr"

test_group("bitget");
var pte = 0x1007;
assert_eq(bitget(pte, 0, 1), 1, "PTE present bit");
assert_eq(bitget(pte, 1, 1), 1, "PTE writable bit");
assert_eq(bitget(pte, 2, 1), 1, "PTE user bit");
assert_eq(bitget(pte, 12, 4), 1, "PTE page frame");
assert_eq(bitget(0xAB, 0, 4), 0xB, "low nibble");
assert_eq(bitget(0xAB, 4, 4), 0xA, "high nibble");

test_group("bitset");
fn test_bitset() {
    var val = 0;
    val = bitset(val, 0, 8, 0x42);
    assert_eq(bitget(val, 0, 8), 0x42, "set low byte");
    val = bitset(val, 8, 8, 0xFF);
    assert_eq(bitget(val, 8, 8), 0xFF, "set high byte");
    assert_eq(bitget(val, 0, 8), 0x42, "low byte preserved");
    return 0;
}
test_bitset();

test_group("bitclr");
fn test_bitclr() {
    var mask = 0xFF;
    mask = bitclr(mask, 4, 4);
    assert_eq(mask, 0x0F, "clear high nibble");
    mask = bitclr(mask, 0, 2);
    assert_eq(mask, 0x0C, "clear low 2 bits");
    return 0;
}
test_bitclr();

test_group("hardware patterns");
fn test_pte_build() {
    var pte2 = 0;
    pte2 = bitset(pte2, 0, 1, 1);
    pte2 = bitset(pte2, 1, 1, 1);
    pte2 = bitset(pte2, 12, 40, 1);
    assert_eq(bitget(pte2, 0, 1), 1, "built PTE present");
    assert_eq(bitget(pte2, 1, 1), 1, "built PTE writable");
    assert_eq(bitget(pte2, 2, 1), 0, "built PTE not user");
    assert_eq(bitget(pte2, 12, 40), 1, "built PTE page");
    return 0;
}
test_pte_build();

var r = assert_summary();
