# v5.7.2 P2.5 — TS parser declarations.
#
# Verifies the four major declaration forms shipped in P2.5:
#   - function declarations + function expressions
#   - type aliases (with type-params, with complex bodies)
#   - interfaces (members, extends list)
#   - classes (extends, implements, constructors, properties, methods,
#              get/set accessors, modifiers)
#
# Modifiers (public/private/protected/static/readonly/abstract/async)
# are accepted and consumed for syntax acceptance but not recorded
# in the AST. Generic type-params are skip-counted.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/syscalls.cyr"
include "lib/assert.cyr"

include "src/frontend/ts/lex.cyr"
include "src/frontend/ts/parse.cyr"

alloc_init();
var ts_base = alloc(TS_HEAP_SIZE + 4096);

# Parse `src` as top-level program; return first stmt index.
fn parse_first_stmt(src) {
    var nt = TS_LEX(ts_base, src, strlen(src));
    if (nt < 0) { return 0 - 1; }
    var nn = TS_PARSE(ts_base);
    if (nn < 0) { return 0 - 1; }
    var head = TS_AST_PAYLOAD(ts_base, 0, 0);
    return TS_AST_CHILDREN_GET(ts_base, head);
}

# Parse `src` as expression (placeholder reserves node 0).
fn parse_expr(src) {
    var nt = TS_LEX(ts_base, src, strlen(src));
    if (nt < 0) { return 0 - 1; }
    TS_PARSE_INIT(ts_base);
    TS_AST_PUSH(ts_base, TS_AST_NONE, 0);
    return TS_PARSE_EXPR(ts_base);
}

fn top_count() {
    return TS_AST_PAYLOAD(ts_base, 0, 1);
}

# ─── function declarations ───────────────────────────────────────
test_group("function declarations");

var s = parse_first_stmt("function foo() { return 1; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "function foo() {} -> DECL_FUNCTION");
assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on plain function");

s = parse_first_stmt("function add(a: number, b: number): number { return a + b; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "typed fn -> DECL_FUNCTION");
var ret_t = TS_AST_PAYLOAD(ts_base, s, 2);
assert(ret_t > 0, "return type stored");
assert_eq(TS_AST_KIND(ts_base, ret_t), TS_AST_TYPE_REF, "return type -> TYPE_REF");

# Generic fn
s = parse_first_stmt("function id<T>(x: T): T { return x; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "generic fn");
assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on generic fn");

# Async fn
s = parse_first_stmt("async function fetchIt(): Promise<string> { return \"x\"; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "async fn -> DECL_FUNCTION");

# Rest params
s = parse_first_stmt("function tag(...args: string[]) { return args; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "rest params");

# ─── function expressions ────────────────────────────────────────
test_group("function expressions");

var n = parse_expr("function() { return 1; }");
assert_eq(TS_AST_KIND(ts_base, n), TS_AST_DECL_FUNCTION, "anon fn expr");

n = parse_expr("function named(x: number) { return x; }");
assert_eq(TS_AST_KIND(ts_base, n), TS_AST_DECL_FUNCTION, "named fn expr");

# Function expr in const init
s = parse_first_stmt("const f = function(x: number) { return x; };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "const f = function...");
assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on const fn-expr init");

# ─── type aliases ────────────────────────────────────────────────
test_group("type aliases");

s = parse_first_stmt("type ID = string;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "type ID = string");
var alias_t = TS_AST_PAYLOAD(ts_base, s, 1);
assert(alias_t > 0, "alias body stored");
assert_eq(TS_AST_KIND(ts_base, alias_t), TS_AST_TYPE_REF, "body = TYPE_REF");

# Generic alias
s = parse_first_stmt("type Pair<A, B> = { first: A; second: B };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "generic alias");
var tp_count = TS_AST_PAYLOAD(ts_base, s, 2);
assert_eq(tp_count, 2, "two type params");
alias_t = TS_AST_PAYLOAD(ts_base, s, 1);
assert_eq(TS_AST_KIND(ts_base, alias_t), TS_AST_TYPE_OBJECT, "body = TYPE_OBJECT");

# Union alias
s = parse_first_stmt("type Result = string | number | null;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "union alias");
alias_t = TS_AST_PAYLOAD(ts_base, s, 1);
assert_eq(TS_AST_KIND(ts_base, alias_t), TS_AST_TYPE_UNION, "body = TYPE_UNION");

# `type` used as variable name (NOT a type-alias) — falls through to expr
s = parse_first_stmt("type;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_EXPR, "bare `type;` -> expr stmt");

# ─── interfaces ──────────────────────────────────────────────────
test_group("interfaces");

s = parse_first_stmt("interface Empty {}");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_INTERFACE, "empty interface");
assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on empty interface");

s = parse_first_stmt("interface Point { x: number; y: number; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_INTERFACE, "interface with props");
var members = TS_AST_PAYLOAD(ts_base, s, 1);
var first_m = TS_AST_CHILDREN_GET(ts_base, members);
assert_eq(TS_AST_KIND(ts_base, first_m), TS_AST_DECL_PROPERTY, "first member = PROPERTY");

# Interface with methods + optional + readonly
s = parse_first_stmt("interface User { readonly id: string; name?: string; greet(): void; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_INTERFACE, "user interface");
assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on user interface");

# Interface with extends
s = parse_first_stmt("interface Cat extends Animal, Pet { meow(): void; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_INTERFACE, "interface extends list");
var ext = TS_AST_PAYLOAD(ts_base, s, 2);
assert(ext > 0, "extends offset stored");
var first_ext = TS_AST_CHILDREN_GET(ts_base, ext);
assert_eq(TS_AST_KIND(ts_base, first_ext), TS_AST_TYPE_REF, "first extends -> TYPE_REF");

# Interface with generic + extends + index sig
s = parse_first_stmt("interface Map<K, V> extends Iterable<V> { [k: K]: V; size: number; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_INTERFACE, "complex interface");
var tpc = TS_AST_PAYLOAD(ts_base, s, 3);
assert_eq(tpc, 2, "two type params on Map");

# Interface with construct sig + call sig
s = parse_first_stmt("interface Factory { new (x: number): Foo; (s: string): Bar; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_INTERFACE, "interface ctor + call sigs");
assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on sigs");

# ─── classes ─────────────────────────────────────────────────────
test_group("classes");

s = parse_first_stmt("class Empty {}");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "empty class");

s = parse_first_stmt("class Point { x: number = 0; y: number = 0; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class with fields");
var class_members = TS_AST_PAYLOAD(ts_base, s, 1);
var fm = TS_AST_CHILDREN_GET(ts_base, class_members);
assert_eq(TS_AST_KIND(ts_base, fm), TS_AST_DECL_PROPERTY, "first field = PROPERTY");

# Class with constructor
s = parse_first_stmt("class P { constructor(public x: number, private y: string) {} }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "ctor with parameter properties");
var pmembers = TS_AST_PAYLOAD(ts_base, s, 1);
var ctor = TS_AST_CHILDREN_GET(ts_base, pmembers);
assert_eq(TS_AST_KIND(ts_base, ctor), TS_AST_DECL_CONSTRUCTOR, "first member = CONSTRUCTOR");

# Class with extends + implements
s = parse_first_stmt("class Cat extends Animal implements Pet, Cuddly { meow(): void { } }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "extends + implements");
var ext_t = TS_AST_PAYLOAD(ts_base, s, 2);
assert(ext_t > 0, "extends type stored");
assert_eq(TS_AST_KIND(ts_base, ext_t), TS_AST_TYPE_REF, "extends -> TYPE_REF");
var impl_off = TS_AST_PAYLOAD(ts_base, s, 3);
assert(impl_off > 0, "implements offset stored");

# Class with get/set
s = parse_first_stmt("class P { _x: number = 0; get x(): number { return this._x; } set x(v: number) { this._x = v; } }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class with accessors");
assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on accessors");

# Class with all the modifiers
s = parse_first_stmt("class All { public a: number = 1; private b: string = \"\"; protected c: boolean = false; static d: number = 0; readonly e: string = \"\"; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "all modifiers");
assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on modifiers");

# Abstract class + abstract method
s = parse_first_stmt("abstract class Shape { abstract area(): number; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "abstract class");
assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on abstract");

# Generic class with method
s = parse_first_stmt("class Box<T> { value: T; constructor(v: T) { this.value = v; } get(): T { return this.value; } }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "generic class");

# ─── multi-decl programs ─────────────────────────────────────────
test_group("multi-decl programs");

s = parse_first_stmt("interface I { x: number; } class C implements I { x: number = 0; } function use(c: C): number { return c.x; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_INTERFACE, "first = interface");
assert_eq(top_count(), 3, "three top-level decls");

# Nested function inside function body
s = parse_first_stmt("function outer() { function inner() { return 1; } return inner(); }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "outer fn parses");
assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on nested fn");

# ─── error paths ─────────────────────────────────────────────────
test_group("decl parse errors");

# Unnamed function decl is invalid
var nt = TS_LEX(ts_base, "function () { }", 15);
assert(nt > 0, "lex unnamed fn decl OK");
TS_PARSE_INIT(ts_base);
TS_AST_PUSH(ts_base, TS_AST_ROOT, 0);
TS_PARSE_CONSUME(ts_base);  # function
var bad = TS_PARSE_DECL_FUNCTION(ts_base, 1);
assert(bad < 0, "unnamed function decl rejected");

var exit_code = assert_summary();
syscall(60, exit_code);
