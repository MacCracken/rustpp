# v5.7.2 P1.4 — TS lexer regression for template literals.
#
# Includes the orphan src/frontend/ts/lex.cyr (not yet wired into
# main.cyr; that's P1.6) and exercises the multi-state template
# scanner via TS_LEX_TEMPLATE_BODY + the template state stack.
#
# Coverage:
#   - empty + plain templates -> NOSUB
#   - single interp -> HEAD, expr-toks, TAIL
#   - multiple interp -> HEAD, expr, MID, expr, TAIL
#   - nested templates -> stack handles depth correctly
#   - escapes inside template (backslash + next byte skipped)
#   - newlines inside template (line counter ticks)
#   - error: unterminated template
#   - error: truncated escape

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/syscalls.cyr"
include "lib/assert.cyr"

include "src/frontend/ts/lex.cyr"

alloc_init();
var ts_base = alloc(TS_HEAP_SIZE + 4096);

fn test_lex(src) {
    return TS_LEX(ts_base, src, strlen(src));
}

fn assert_tok(idx, expected_typ, name) {
    assert_eq(TS_PEEKT(ts_base, idx), expected_typ, name);
    return 0;
}

# ─── plain templates (no interpolation) ──────────────────────────
test_group("plain templates");

var n = test_lex("``");
assert_eq(n, 2, "empty template -> 1 tok + EOF");
assert_tok(0, TS_TOK_TEMPLATE_NOSUB, "`` -> NOSUB");

n = test_lex("`hello`");
assert_eq(n, 2, "`hello` -> NOSUB + EOF");
assert_tok(0, TS_TOK_TEMPLATE_NOSUB, "`hello` -> NOSUB");

n = test_lex("`with spaces and 123`");
assert_eq(n, 2, "`with spaces and 123` -> NOSUB");
assert_tok(0, TS_TOK_TEMPLATE_NOSUB, "spaces+digits inside backticks");

# ─── single interpolation ────────────────────────────────────────
test_group("single interpolation");

n = test_lex("`hi ${name}`");
# Tokens: TEMPLATE_HEAD("hi "), IDENT(name), TEMPLATE_TAIL(""), EOF
assert_eq(n, 4, "`hi ${name}` -> HEAD, IDENT, TAIL, EOF");
assert_tok(0, TS_TOK_TEMPLATE_HEAD,  "TEMPLATE_HEAD `hi ${`");
assert_tok(1, TS_TOK_IDENT,          "IDENT name");
assert_tok(2, TS_TOK_TEMPLATE_TAIL,  "TEMPLATE_TAIL `}`");

n = test_lex("`${x}`");
# Tokens: HEAD(""), IDENT(x), TAIL(""), EOF
assert_eq(n, 4, "`${x}` -> 4 toks");
assert_tok(0, TS_TOK_TEMPLATE_HEAD, "HEAD with empty content");
assert_tok(1, TS_TOK_IDENT,         "x");
assert_tok(2, TS_TOK_TEMPLATE_TAIL, "TAIL with empty content");

# Interp expression with multiple tokens
n = test_lex("`sum: ${a + b}`");
# HEAD("sum: "), IDENT(a), PLUS, IDENT(b), TAIL(""), EOF
assert_eq(n, 6, "interp with binary op -> 5 toks + EOF");
assert_tok(0, TS_TOK_TEMPLATE_HEAD, "HEAD");
assert_tok(1, TS_TOK_IDENT,         "a");
assert_tok(2, TS_TOK_PLUS,          "+");
assert_tok(3, TS_TOK_IDENT,         "b");
assert_tok(4, TS_TOK_TEMPLATE_TAIL, "TAIL");

# ─── multiple interpolations ─────────────────────────────────────
test_group("multiple interpolations");

n = test_lex("`${a} mid ${b}`");
# HEAD(""), IDENT(a), MID(" mid "), IDENT(b), TAIL(""), EOF
assert_eq(n, 6, "two interps -> HEAD, ident, MID, ident, TAIL, EOF");
assert_tok(0, TS_TOK_TEMPLATE_HEAD, "HEAD ");
assert_tok(1, TS_TOK_IDENT,         "a");
assert_tok(2, TS_TOK_TEMPLATE_MID,  "MID");
assert_tok(3, TS_TOK_IDENT,         "b");
assert_tok(4, TS_TOK_TEMPLATE_TAIL, "TAIL");

# Three interps
n = test_lex("`${a}-${b}-${c}`");
# HEAD, a, MID, b, MID, c, TAIL, EOF = 8
assert_eq(n, 8, "three interps");
assert_tok(0, TS_TOK_TEMPLATE_HEAD, "HEAD");
assert_tok(1, TS_TOK_IDENT,         "a");
assert_tok(2, TS_TOK_TEMPLATE_MID,  "MID 1");
assert_tok(3, TS_TOK_IDENT,         "b");
assert_tok(4, TS_TOK_TEMPLATE_MID,  "MID 2");
assert_tok(5, TS_TOK_IDENT,         "c");
assert_tok(6, TS_TOK_TEMPLATE_TAIL, "TAIL");

# ─── nested templates ────────────────────────────────────────────
test_group("nested templates");

# `outer ${`inner`}`
# TOKENS: HEAD("outer "), TEMPLATE_NOSUB("inner"), TAIL(""), EOF
# (the inner `inner` is a complete template inside the interp)
n = test_lex("`outer ${`inner`}`");
assert_eq(n, 4, "nested template inside interp");
assert_tok(0, TS_TOK_TEMPLATE_HEAD,  "outer HEAD");
assert_tok(1, TS_TOK_TEMPLATE_NOSUB, "inner NOSUB");
assert_tok(2, TS_TOK_TEMPLATE_TAIL,  "outer TAIL");

# `${`${x}`}`
# HEAD(""), HEAD(""), IDENT(x), TAIL(""), TAIL(""), EOF = 6
n = test_lex("`${`${x}`}`");
assert_eq(n, 6, "nested interp inside interp");
assert_tok(0, TS_TOK_TEMPLATE_HEAD,  "outer HEAD");
assert_tok(1, TS_TOK_TEMPLATE_HEAD,  "inner HEAD");
assert_tok(2, TS_TOK_IDENT,          "x");
assert_tok(3, TS_TOK_TEMPLATE_TAIL,  "inner TAIL");
assert_tok(4, TS_TOK_TEMPLATE_TAIL,  "outer TAIL");

# ─── escapes inside template ─────────────────────────────────────
test_group("escapes");

n = test_lex("`\\``");
# Single template containing an escaped backtick. Becomes NOSUB.
# Content span includes the escape but doesn't decode it (P3+ work).
assert_eq(n, 2, "`\\`` -> NOSUB containing escaped backtick");
assert_tok(0, TS_TOK_TEMPLATE_NOSUB, "escaped backtick inside template");

n = test_lex("`escaped \\${not_interp}`");
# Escape on the $ should suppress interpolation. Treat as plain NOSUB.
assert_eq(n, 2, "escaped $ suppresses interp");
assert_tok(0, TS_TOK_TEMPLATE_NOSUB, "\\${...} stays in template body");

# ─── newlines inside template (allowed in TS, unlike strings) ────
test_group("newlines");

n = test_lex("`line1\nline2`");
assert_eq(n, 2, "multi-line template -> NOSUB");
assert_tok(0, TS_TOK_TEMPLATE_NOSUB, "newline in template OK");
# Verify line counter ticked
assert_eq(TS_PEEKLINE(ts_base, 1), 2, "EOF on line 2 after embedded \\n");

n = test_lex("`a\nb\nc`");
assert_eq(n, 2, "two newlines in template");
assert_eq(TS_PEEKLINE(ts_base, 1), 3, "EOF on line 3");

# ─── interp with ${} containing braces ───────────────────────────
test_group("interp with brace expression");

# `${{key: val}}` — object literal inside interp. The first { is the
# object-literal open, matched by the LAST } before backtick. Lexer
# must NOT treat the first } as closing the interp.
# Wait — actually it would. Let me think:
# - `: HEAD start
# - HEAD content "" -> emit TEMPLATE_HEAD, push interp
# - { -> RBRACE? no wait, LBRACE (123)
# - Inside interp: {key: val}
#   - LBRACE, IDENT key, COLON, IDENT val, RBRACE
#   - But the RBRACE here pops the interp (top of stack is 2)
#   - So we get: HEAD, LBRACE, IDENT, COLON, IDENT, then RBRACE pops
#     → resume template scanning which sees the OUTER } as start of
#     more template... wait no, the outer } is the } AFTER the inner
#     } in the source. Let me re-read.
#
# Actually `${{key:val}}` expanded: ` $ { { key : val } } `
# Walking:
#  - ` -> push template (slot=0), enter template body
#  - body sees ${ -> emit HEAD, push interp (slot=2), advance past ${
#  - inside interp: { -> LBRACE
#  - inside interp: key -> IDENT
#  - inside interp: : -> COLON
#  - inside interp: val -> IDENT
#  - inside interp: } -> top==2, pop interp; resume template body
#  - template body sees }... but } is not in the template body's
#    handle list (it just passes through as content!)
#  - template body keeps scanning, sees ` -> emit TAIL, pop template
#
# So the result: HEAD, LBRACE, IDENT, COLON, IDENT, TAIL, EOF = 7 toks.
# The OUTER `}` becomes part of the TAIL's content span. Correct
# per JS semantics.

n = test_lex("`${{key:val}}`");
assert_eq(n, 7, "object literal in interp (outer } is template content)");
assert_tok(0, TS_TOK_TEMPLATE_HEAD, "HEAD");
assert_tok(1, TS_TOK_LBRACE,        "{");
assert_tok(2, TS_TOK_IDENT,         "key");
assert_tok(3, TS_TOK_COLON,         ":");
assert_tok(4, TS_TOK_IDENT,         "val");
assert_tok(5, TS_TOK_TEMPLATE_TAIL, "TAIL — the outer } is in TAIL content");

# ─── error paths ─────────────────────────────────────────────────
test_group("error paths");

# Unterminated template
n = test_lex("`hello world");
assert_eq(n, 0 - 1, "unterminated template returns -1");
assert_eq(TS_GETERR(ts_base), 8, "err code 8 = unterminated template");

# Truncated escape (backslash at end of source)
n = test_lex("`oops \\");
assert_eq(n, 0 - 1, "truncated escape returns -1");
assert_eq(TS_GETERR(ts_base), 7, "err code 7 = truncated escape");

# Unterminated after seeing ${
n = test_lex("`a ${b");
assert_eq(n, 0 - 1, "unterminated after interp");
# Either err 8 (still inside template) or another code — just check non-zero
assert(TS_GETERR(ts_base) != 0, "some err code on unterminated post-interp");

var exit_code = assert_summary();
syscall(60, exit_code);
