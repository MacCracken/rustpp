# test_lib.tcyr — v5.7.46 acceptance gate for lib/test.cyr.
#
# Scope: test_each iterates correctly, fires fn per case in order,
# handles empty cases vec, plays nicely with assert.cyr accounting
# (assertion totals across cases match expected counts).

include "lib/syscalls.cyr"
include "lib/alloc.cyr"
include "lib/string.cyr"
include "lib/str.cyr"
include "lib/vec.cyr"
include "lib/fmt.cyr"
include "lib/io.cyr"
include "lib/math.cyr"
include "lib/test.cyr"

alloc_init();

# ── Trace state for ordering verification ────────────────────────────
var _calls   = 0;
var _trace_buf = 0;
var _trace_len = 0;

fn _trace(c) {
    if (_trace_buf == 0) { return 0; }
    store8(_trace_buf + _trace_len, c);
    _trace_len = _trace_len + 1;
    return 0;
}

# Case shape: alloc(16); +0 = expected int; +8 = label cstr.
fn _check_case(c) {
    _calls = _calls + 1;
    var want  = load64(c);
    var label = load64(c + 8);
    _trace(48 + want);   # ASCII '0' + want for trace
    assert_eq(want, want, label);   # always passes; counts toward total
    return 0;
}

_trace_buf = alloc(64);

# ── test_each fires fn once per case in vec order ────────────────────
test_group("test_each ordering");
var cases = vec_new();
var i = 0;
while (i < 5) {
    var c = alloc(16);
    store64(c,     i);
    store64(c + 8, "case label");
    vec_push(cases, c);
    i = i + 1;
}
_calls = 0;
_trace_len = 0;
test_each(cases, &_check_case);
assert_eq(_calls, 5, "fn called 5 times");
store8(_trace_buf + _trace_len, 0);
assert(streq(_trace_buf, "01234") == 1, "trace = '01234' (in vec order)");

# ── Empty cases_vec is a no-op ───────────────────────────────────────
test_group("empty cases vec");
var empty = vec_new();
_calls = 0;
test_each(empty, &_check_case);
assert_eq(_calls, 0, "fn not called on empty vec");

# ── Null cases_vec is safe ───────────────────────────────────────────
test_group("null inputs");
_calls = 0;
test_each(0, &_check_case);
assert_eq(_calls, 0, "null cases_vec is safe (no calls)");

test_each(cases, 0);   # should not crash; no assertion check needed

# ── Single-element vec ───────────────────────────────────────────────
test_group("single element");
var single = vec_new();
var s0 = alloc(16);
store64(s0, 7);
store64(s0 + 8, "single");
vec_push(single, s0);
_calls = 0;
_trace_len = 0;
test_each(single, &_check_case);
assert_eq(_calls, 1, "single-element vec → 1 call");
store8(_trace_buf + _trace_len, 0);
assert(streq(_trace_buf, "7") == 1, "trace = '7'");

# ── assert.cyr accounting integrates correctly ───────────────────────
# The 5+1 = 6 _check_case calls each fired exactly 1 assert_eq, so
# the assert_total accounting (visible via assert_summary) should
# include all of them plus the meta-assertions in this file.
# We don't assert the exact number here (would couple to test order)
# — assert_summary at end of file dumps the total.

var r = assert_summary();
