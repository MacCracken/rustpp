# tests/tcyr/ts_parse_decls.tcyr — TS parser declarations + modifiers.
#
# v5.7.37: groups the 5 declaration-shape tests — declaration
# forms (P2.5), ES module surface (P2.6), async/await mechanism
# (P4.4), definite-assignment `!:` in declarators (P4.5),
# TS_PARSE_SKIP_MODIFIERS for contextual modifier keywords
# (P4.7). Includes lex.cyr + parse.cyr once; bodies share
# `ts_base`.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/syscalls.cyr"
include "lib/assert.cyr"

include "src/frontend/ts/lex.cyr"
include "src/frontend/ts/parse.cyr"

alloc_init();
var ts_base = alloc(TS_HEAP_SIZE + 4096);

# ── helpers from ts_parse_p25 ──
fn _ts_parse_p25_parse_first_stmt(src) {
    var nt = TS_LEX(ts_base, src, strlen(src));
    if (nt < 0) { return 0 - 1; }
    var nn = TS_PARSE(ts_base);
    if (nn < 0) { return 0 - 1; }
    var head = TS_AST_PAYLOAD(ts_base, 0, 0);
    return TS_AST_CHILDREN_GET(ts_base, head);
}
fn _ts_parse_p25_parse_expr(src) {
    var nt = TS_LEX(ts_base, src, strlen(src));
    if (nt < 0) { return 0 - 1; }
    TS_PARSE_INIT(ts_base);
    TS_AST_PUSH(ts_base, TS_AST_NONE, 0);
    return TS_PARSE_EXPR(ts_base);
}
fn _ts_parse_p25_top_count() {
    return TS_AST_PAYLOAD(ts_base, 0, 1);
}

# ── helpers from ts_parse_p26 ──
fn _ts_parse_p26_parse_first_stmt(src) {
    var nt = TS_LEX(ts_base, src, strlen(src));
    if (nt < 0) { return 0 - 1; }
    var nn = TS_PARSE(ts_base);
    if (nn < 0) { return 0 - 1; }
    var head = TS_AST_PAYLOAD(ts_base, 0, 0);
    return TS_AST_CHILDREN_GET(ts_base, head);
}
fn _ts_parse_p26_top_count() {
    return TS_AST_PAYLOAD(ts_base, 0, 1);
}

# ── helpers from ts_parse_p44 ──
fn _ts_parse_p44_parse_first_stmt(src) {
    var nt = TS_LEX(ts_base, src, strlen(src));
    if (nt < 0) { return 0 - 1; }
    var nn = TS_PARSE(ts_base);
    if (nn < 0) { return 0 - 1; }
    var head = TS_AST_PAYLOAD(ts_base, 0, 0);
    return TS_AST_CHILDREN_GET(ts_base, head);
}
fn _ts_parse_p44_parse_expr(src) {
    var nt = TS_LEX(ts_base, src, strlen(src));
    if (nt < 0) { return 0 - 1; }
    TS_PARSE_INIT(ts_base);
    TS_AST_PUSH(ts_base, TS_AST_NONE, 0);
    return TS_PARSE_EXPR(ts_base);
}

# ── helpers from ts_parse_p45 ──
fn _ts_parse_p45_parse_first_stmt(src) {
    var nt = TS_LEX(ts_base, src, strlen(src));
    if (nt < 0) { return 0 - 1; }
    var nn = TS_PARSE(ts_base);
    if (nn < 0) { return 0 - 1; }
    var head = TS_AST_PAYLOAD(ts_base, 0, 0);
    return TS_AST_CHILDREN_GET(ts_base, head);
}

# ── helpers from ts_parse_p47 ──
fn _ts_parse_p47_parse_first_stmt(src) {
    var nt = TS_LEX(ts_base, src, strlen(src));
    if (nt < 0) { return 0 - 1; }
    var nn = TS_PARSE(ts_base);
    if (nn < 0) { return 0 - 1; }
    var head = TS_AST_PAYLOAD(ts_base, 0, 0);
    return TS_AST_CHILDREN_GET(ts_base, head);
}

# ── ts_parse_p25 ───────────────────────────────────────────
fn ts_parse_test_ts_parse_p25() {
    
    
    
    # Parse `src` as top-level program; return first stmt index.
    
    # Parse `src` as expression (placeholder reserves node 0).
    
    
    # ─── function declarations ───────────────────────────────────────
    test_group("function declarations");
    
    var s = _ts_parse_p25_parse_first_stmt("function foo() { return 1; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "function foo() {} -> DECL_FUNCTION");
    assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on plain function");
    
    s = _ts_parse_p25_parse_first_stmt("function add(a: number, b: number): number { return a + b; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "typed fn -> DECL_FUNCTION");
    var ret_t = TS_AST_PAYLOAD(ts_base, s, 2);
    assert(ret_t > 0, "return type stored");
    assert_eq(TS_AST_KIND(ts_base, ret_t), TS_AST_TYPE_REF, "return type -> TYPE_REF");
    
    # Generic fn
    s = _ts_parse_p25_parse_first_stmt("function id<T>(x: T): T { return x; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "generic fn");
    assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on generic fn");
    
    # Async fn
    s = _ts_parse_p25_parse_first_stmt("async function fetchIt(): Promise<string> { return \"x\"; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "async fn -> DECL_FUNCTION");
    
    # Rest params
    s = _ts_parse_p25_parse_first_stmt("function tag(...args: string[]) { return args; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "rest params");
    
    # ─── function expressions ────────────────────────────────────────
    test_group("function expressions");
    
    var n = _ts_parse_p25_parse_expr("function() { return 1; }");
    assert_eq(TS_AST_KIND(ts_base, n), TS_AST_DECL_FUNCTION, "anon fn expr");
    
    n = _ts_parse_p25_parse_expr("function named(x: number) { return x; }");
    assert_eq(TS_AST_KIND(ts_base, n), TS_AST_DECL_FUNCTION, "named fn expr");
    
    # Function expr in const init
    s = _ts_parse_p25_parse_first_stmt("const f = function(x: number) { return x; };");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "const f = function...");
    assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on const fn-expr init");
    
    # ─── type aliases ────────────────────────────────────────────────
    test_group("type aliases");
    
    s = _ts_parse_p25_parse_first_stmt("type ID = string;");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "type ID = string");
    var alias_t = TS_AST_PAYLOAD(ts_base, s, 1);
    assert(alias_t > 0, "alias body stored");
    assert_eq(TS_AST_KIND(ts_base, alias_t), TS_AST_TYPE_REF, "body = TYPE_REF");
    
    # Generic alias
    s = _ts_parse_p25_parse_first_stmt("type Pair<A, B> = { first: A; second: B };");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "generic alias");
    var tp_count = TS_AST_PAYLOAD(ts_base, s, 2);
    assert_eq(tp_count, 2, "two type params");
    alias_t = TS_AST_PAYLOAD(ts_base, s, 1);
    assert_eq(TS_AST_KIND(ts_base, alias_t), TS_AST_TYPE_OBJECT, "body = TYPE_OBJECT");
    
    # Union alias
    s = _ts_parse_p25_parse_first_stmt("type Result = string | number | null;");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "union alias");
    alias_t = TS_AST_PAYLOAD(ts_base, s, 1);
    assert_eq(TS_AST_KIND(ts_base, alias_t), TS_AST_TYPE_UNION, "body = TYPE_UNION");
    
    # `type` used as variable name (NOT a type-alias) — falls through to expr
    s = _ts_parse_p25_parse_first_stmt("type;");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_EXPR, "bare `type;` -> expr stmt");
    
    # ─── interfaces ──────────────────────────────────────────────────
    test_group("interfaces");
    
    s = _ts_parse_p25_parse_first_stmt("interface Empty {}");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_INTERFACE, "empty interface");
    assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on empty interface");
    
    s = _ts_parse_p25_parse_first_stmt("interface Point { x: number; y: number; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_INTERFACE, "interface with props");
    var members = TS_AST_PAYLOAD(ts_base, s, 1);
    var first_m = TS_AST_CHILDREN_GET(ts_base, members);
    assert_eq(TS_AST_KIND(ts_base, first_m), TS_AST_DECL_PROPERTY, "first member = PROPERTY");
    
    # Interface with methods + optional + readonly
    s = _ts_parse_p25_parse_first_stmt("interface User { readonly id: string; name?: string; greet(): void; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_INTERFACE, "user interface");
    assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on user interface");
    
    # Interface with extends
    s = _ts_parse_p25_parse_first_stmt("interface Cat extends Animal, Pet { meow(): void; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_INTERFACE, "interface extends list");
    var ext = TS_AST_PAYLOAD(ts_base, s, 2);
    assert(ext > 0, "extends offset stored");
    var first_ext = TS_AST_CHILDREN_GET(ts_base, ext);
    assert_eq(TS_AST_KIND(ts_base, first_ext), TS_AST_TYPE_REF, "first extends -> TYPE_REF");
    
    # Interface with generic + extends + index sig
    s = _ts_parse_p25_parse_first_stmt("interface Map<K, V> extends Iterable<V> { [k: K]: V; size: number; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_INTERFACE, "complex interface");
    var tpc = TS_AST_PAYLOAD(ts_base, s, 3);
    assert_eq(tpc, 2, "two type params on Map");
    
    # Interface with construct sig + call sig
    s = _ts_parse_p25_parse_first_stmt("interface Factory { new (x: number): Foo; (s: string): Bar; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_INTERFACE, "interface ctor + call sigs");
    assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on sigs");
    
    # ─── classes ─────────────────────────────────────────────────────
    test_group("classes");
    
    s = _ts_parse_p25_parse_first_stmt("class Empty {}");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "empty class");
    
    s = _ts_parse_p25_parse_first_stmt("class Point { x: number = 0; y: number = 0; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class with fields");
    var class_members = TS_AST_PAYLOAD(ts_base, s, 1);
    var fm = TS_AST_CHILDREN_GET(ts_base, class_members);
    assert_eq(TS_AST_KIND(ts_base, fm), TS_AST_DECL_PROPERTY, "first field = PROPERTY");
    
    # Class with constructor
    s = _ts_parse_p25_parse_first_stmt("class P { constructor(public x: number, private y: string) {} }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "ctor with parameter properties");
    var pmembers = TS_AST_PAYLOAD(ts_base, s, 1);
    var ctor = TS_AST_CHILDREN_GET(ts_base, pmembers);
    assert_eq(TS_AST_KIND(ts_base, ctor), TS_AST_DECL_CONSTRUCTOR, "first member = CONSTRUCTOR");
    
    # Class with extends + implements
    s = _ts_parse_p25_parse_first_stmt("class Cat extends Animal implements Pet, Cuddly { meow(): void { } }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "extends + implements");
    var ext_t = TS_AST_PAYLOAD(ts_base, s, 2);
    assert(ext_t > 0, "extends type stored");
    assert_eq(TS_AST_KIND(ts_base, ext_t), TS_AST_TYPE_REF, "extends -> TYPE_REF");
    var impl_off = TS_AST_PAYLOAD(ts_base, s, 3);
    assert(impl_off > 0, "implements offset stored");
    
    # Class with get/set
    s = _ts_parse_p25_parse_first_stmt("class P { _x: number = 0; get x(): number { return this._x; } set x(v: number) { this._x = v; } }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class with accessors");
    assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on accessors");
    
    # Class with all the modifiers
    s = _ts_parse_p25_parse_first_stmt("class All { public a: number = 1; private b: string = \"\"; protected c: boolean = false; static d: number = 0; readonly e: string = \"\"; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "all modifiers");
    assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on modifiers");
    
    # Abstract class + abstract method
    s = _ts_parse_p25_parse_first_stmt("abstract class Shape { abstract area(): number; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "abstract class");
    assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on abstract");
    
    # Generic class with method
    s = _ts_parse_p25_parse_first_stmt("class Box<T> { value: T; constructor(v: T) { this.value = v; } get(): T { return this.value; } }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "generic class");
    
    # ─── multi-decl programs ─────────────────────────────────────────
    test_group("multi-decl programs");
    
    s = _ts_parse_p25_parse_first_stmt("interface I { x: number; } class C implements I { x: number = 0; } function use(c: C): number { return c.x; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_INTERFACE, "first = interface");
    assert_eq(_ts_parse_p25_top_count(), 3, "three top-level decls");
    
    # Nested function inside function body
    s = _ts_parse_p25_parse_first_stmt("function outer() { function inner() { return 1; } return inner(); }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "outer fn parses");
    assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on nested fn");
    
    # ─── error paths ─────────────────────────────────────────────────
    test_group("decl parse errors");
    
    # Unnamed function decl is invalid
    var nt = TS_LEX(ts_base, "function () { }", 15);
    assert(nt > 0, "lex unnamed fn decl OK");
    TS_PARSE_INIT(ts_base);
    TS_AST_PUSH(ts_base, TS_AST_ROOT, 0);
    TS_PARSE_CONSUME(ts_base);  # function
    var bad = TS_PARSE_DECL_FUNCTION(ts_base, 1);
    assert(bad < 0, "unnamed function decl rejected");
    
    return 0;
}

# ── ts_parse_p26 ───────────────────────────────────────────
fn ts_parse_test_ts_parse_p26() {
    
    
    
    
    
    # ─── imports ─────────────────────────────────────────────────────
    test_group("imports");
    
    # Side-effect import
    var s = _ts_parse_p26_parse_first_stmt("import \"./side-effect\";");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_IMPORT, "side-effect import -> IMPORT");
    var specs = TS_AST_PAYLOAD(ts_base, s, 1);
    assert_eq(specs, 0, "side-effect import has no specs");
    
    # Default import
    s = _ts_parse_p26_parse_first_stmt("import foo from \"./foo\";");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_IMPORT, "default import -> IMPORT");
    specs = TS_AST_PAYLOAD(ts_base, s, 1);
    assert(specs > 0, "default import has specs offset");
    var first_spec = TS_AST_CHILDREN_GET(ts_base, specs);
    assert_eq(TS_AST_KIND(ts_base, first_spec), TS_AST_IMPORT_DEFAULT, "spec[0] = IMPORT_DEFAULT");
    
    # Namespace import
    s = _ts_parse_p26_parse_first_stmt("import * as ns from \"./mod\";");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_IMPORT, "ns import");
    specs = TS_AST_PAYLOAD(ts_base, s, 1);
    first_spec = TS_AST_CHILDREN_GET(ts_base, specs);
    assert_eq(TS_AST_KIND(ts_base, first_spec), TS_AST_IMPORT_NAMESPACE, "spec[0] = IMPORT_NAMESPACE");
    
    # Named imports
    s = _ts_parse_p26_parse_first_stmt("import { a, b, c } from \"./mod\";");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_IMPORT, "named import");
    specs = TS_AST_PAYLOAD(ts_base, s, 1);
    first_spec = TS_AST_CHILDREN_GET(ts_base, specs);
    assert_eq(TS_AST_KIND(ts_base, first_spec), TS_AST_IMPORT_NAMED, "spec[0] = IMPORT_NAMED");
    
    # Named with alias
    s = _ts_parse_p26_parse_first_stmt("import { foo as bar } from \"./mod\";");
    specs = TS_AST_PAYLOAD(ts_base, s, 1);
    first_spec = TS_AST_CHILDREN_GET(ts_base, specs);
    assert_eq(TS_AST_KIND(ts_base, first_spec), TS_AST_IMPORT_NAMED, "named-with-alias");
    var alias_v = TS_AST_PAYLOAD(ts_base, first_spec, 1);
    assert(alias_v > 0, "alias name span recorded");
    
    # Default + named
    s = _ts_parse_p26_parse_first_stmt("import def, { a, b } from \"./mod\";");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_IMPORT, "default + named");
    assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on default+named");
    specs = TS_AST_PAYLOAD(ts_base, s, 1);
    first_spec = TS_AST_CHILDREN_GET(ts_base, specs);
    assert_eq(TS_AST_KIND(ts_base, first_spec), TS_AST_IMPORT_DEFAULT, "first = DEFAULT");
    var second_spec = TS_AST_CHILDREN_GET(ts_base, specs + 1);
    assert_eq(TS_AST_KIND(ts_base, second_spec), TS_AST_IMPORT_NAMED, "second = NAMED");
    
    # Default + namespace
    s = _ts_parse_p26_parse_first_stmt("import def, * as ns from \"./mod\";");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_IMPORT, "default + namespace");
    specs = TS_AST_PAYLOAD(ts_base, s, 1);
    first_spec = TS_AST_CHILDREN_GET(ts_base, specs);
    assert_eq(TS_AST_KIND(ts_base, first_spec), TS_AST_IMPORT_DEFAULT, "first = DEFAULT");
    second_spec = TS_AST_CHILDREN_GET(ts_base, specs + 1);
    assert_eq(TS_AST_KIND(ts_base, second_spec), TS_AST_IMPORT_NAMESPACE, "second = NAMESPACE");
    
    # Type-only import
    s = _ts_parse_p26_parse_first_stmt("import type { Config } from \"./types\";");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_IMPORT, "import type");
    var to = TS_AST_PAYLOAD(ts_base, s, 2);
    assert_eq(to, 1, "type-only flag set");
    
    # Mixed type-only inside named list
    s = _ts_parse_p26_parse_first_stmt("import { type T, runtime } from \"./mod\";");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_IMPORT, "mixed type-only spec");
    assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on mixed type-only");
    
    # `import type from "x"` — `type` is the default name (NOT type-only)
    s = _ts_parse_p26_parse_first_stmt("import type from \"./mod\";");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_IMPORT, "import type from -> default 'type'");
    to = TS_AST_PAYLOAD(ts_base, s, 2);
    assert_eq(to, 0, "this is NOT type-only");
    
    # ─── exports ─────────────────────────────────────────────────────
    test_group("exports");
    
    # Decl export wraps a decl
    s = _ts_parse_p26_parse_first_stmt("export const x = 1;");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_EXPORT, "export const -> EXPORT");
    var inner = TS_AST_PAYLOAD(ts_base, s, 0);
    assert_eq(TS_AST_KIND(ts_base, inner), TS_AST_STMT_VAR_DECL, "wraps VAR_DECL");
    
    s = _ts_parse_p26_parse_first_stmt("export function foo() {}");
    inner = TS_AST_PAYLOAD(ts_base, s, 0);
    assert_eq(TS_AST_KIND(ts_base, inner), TS_AST_DECL_FUNCTION, "wraps DECL_FUNCTION");
    
    s = _ts_parse_p26_parse_first_stmt("export class C {}");
    inner = TS_AST_PAYLOAD(ts_base, s, 0);
    assert_eq(TS_AST_KIND(ts_base, inner), TS_AST_DECL_CLASS, "wraps DECL_CLASS");
    
    s = _ts_parse_p26_parse_first_stmt("export interface I { x: number; }");
    inner = TS_AST_PAYLOAD(ts_base, s, 0);
    assert_eq(TS_AST_KIND(ts_base, inner), TS_AST_DECL_INTERFACE, "wraps DECL_INTERFACE");
    
    s = _ts_parse_p26_parse_first_stmt("export type Pair = [number, string];");
    inner = TS_AST_PAYLOAD(ts_base, s, 0);
    assert_eq(TS_AST_KIND(ts_base, inner), TS_AST_DECL_TYPE_ALIAS, "wraps DECL_TYPE_ALIAS");
    
    # `export abstract class`
    s = _ts_parse_p26_parse_first_stmt("export abstract class Shape { abstract area(): number; }");
    inner = TS_AST_PAYLOAD(ts_base, s, 0);
    assert_eq(TS_AST_KIND(ts_base, inner), TS_AST_DECL_CLASS, "export abstract class wraps");
    
    # Async export
    s = _ts_parse_p26_parse_first_stmt("export async function fetchIt() { return 1; }");
    inner = TS_AST_PAYLOAD(ts_base, s, 0);
    assert_eq(TS_AST_KIND(ts_base, inner), TS_AST_DECL_FUNCTION, "export async function wraps");
    
    # Named export (no decl)
    s = _ts_parse_p26_parse_first_stmt("export { a, b as c };");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_EXPORT, "export { ... } -> EXPORT");
    var kind_v = TS_AST_PAYLOAD(ts_base, s, 3);
    assert_eq(kind_v, 1, "kind = 1 (named export)");
    var src_v = TS_AST_PAYLOAD(ts_base, s, 1);
    assert_eq(src_v, 0, "no source span (not re-export)");
    
    # Re-export named
    s = _ts_parse_p26_parse_first_stmt("export { a, b as c } from \"./mod\";");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_EXPORT, "re-export -> EXPORT");
    kind_v = TS_AST_PAYLOAD(ts_base, s, 3);
    assert_eq(kind_v, 2, "kind = 2 (re-export)");
    src_v = TS_AST_PAYLOAD(ts_base, s, 1);
    assert(src_v > 0, "source span recorded");
    
    # export * from
    s = _ts_parse_p26_parse_first_stmt("export * from \"./mod\";");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_EXPORT_ALL, "export * from -> EXPORT_ALL");
    src_v = TS_AST_PAYLOAD(ts_base, s, 0);
    assert(src_v > 0, "EXPORT_ALL has source span");
    
    # export * as ns from
    s = _ts_parse_p26_parse_first_stmt("export * as utils from \"./util\";");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_EXPORT_ALL, "export * as ns -> EXPORT_ALL");
    var ns_alias = TS_AST_PAYLOAD(ts_base, s, 1);
    assert(ns_alias > 0, "namespace alias recorded");
    
    # export default ...
    s = _ts_parse_p26_parse_first_stmt("export default 42;");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_EXPORT_DEFAULT, "export default literal");
    inner = TS_AST_PAYLOAD(ts_base, s, 0);
    assert_eq(TS_AST_KIND(ts_base, inner), TS_AST_EXPR_INT, "wraps EXPR_INT");
    
    s = _ts_parse_p26_parse_first_stmt("export default function() { return 1; }");
    inner = TS_AST_PAYLOAD(ts_base, s, 0);
    assert_eq(TS_AST_KIND(ts_base, inner), TS_AST_DECL_FUNCTION, "default fn-expr");
    
    s = _ts_parse_p26_parse_first_stmt("export default class { x = 1; }");
    inner = TS_AST_PAYLOAD(ts_base, s, 0);
    assert_eq(TS_AST_KIND(ts_base, inner), TS_AST_DECL_CLASS, "default class");
    
    # Type-only export
    s = _ts_parse_p26_parse_first_stmt("export type { T, U as V };");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_EXPORT, "export type { ... }");
    var to2 = TS_AST_PAYLOAD(ts_base, s, 2);
    assert_eq(to2, 1, "type-only flag on named export");
    
    # ─── multi-stmt module program ───────────────────────────────────
    test_group("multi-stmt module");
    
    s = _ts_parse_p26_parse_first_stmt("import { x } from \"./a\"; import * as b from \"./b\"; export const c = 1; export default function main() { return c; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_IMPORT, "first = import");
    assert_eq(_ts_parse_p26_top_count(), 4, "four module-level stmts");
    assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err in module program");
    
    # ─── error paths ─────────────────────────────────────────────────
    test_group("module parse errors");
    
    # `import x;` — missing `from "..."` clause
    var src_bad = "import x;";
    var nt = TS_LEX(ts_base, src_bad, strlen(src_bad));
    assert(nt > 0, "lex `import x;` OK");
    TS_PARSE_INIT(ts_base);
    TS_AST_PUSH(ts_base, TS_AST_ROOT, 0);
    TS_PARSE_CONSUME(ts_base);   # import
    var bad = TS_PARSE_IMPORT(ts_base);
    assert(bad < 0, "import without `from` rejected");
    
    return 0;
}

# ── ts_parse_p44 ───────────────────────────────────────────
fn ts_parse_test_ts_parse_p44() {
    
    
    
    # Parse `src` as one top-level statement; return first stmt index.
    
    # Parse `src` as expression (placeholder reserves node 0).
    
    # ─── async function declarations ─────────────────────────────────
    test_group("async function decl");
    
    var s = _ts_parse_p44_parse_first_stmt("async function fetchIt() { return 1; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "async fn -> DECL_FUNCTION");
    assert_eq(TS_AST_IS_ASYNC(ts_base, s), 1, "async flag set");
    
    s = _ts_parse_p44_parse_first_stmt("function plain() { return 2; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "plain fn -> DECL_FUNCTION");
    assert_eq(TS_AST_IS_ASYNC(ts_base, s), 0, "no async flag on plain fn");
    
    # ─── async arrow expressions ─────────────────────────────────────
    test_group("async arrow expr");
    
    var n = _ts_parse_p44_parse_expr("async () => 1");
    assert_eq(TS_AST_KIND(ts_base, n), TS_AST_EXPR_ARROW, "async () => 1 parses");
    assert_eq(TS_AST_IS_ASYNC(ts_base, n), 1, "async paren-arrow flag set");
    
    n = _ts_parse_p44_parse_expr("(x) => x");
    assert_eq(TS_AST_KIND(ts_base, n), TS_AST_EXPR_ARROW, "plain arrow parses");
    assert_eq(TS_AST_IS_ASYNC(ts_base, n), 0, "no async flag on plain arrow");
    
    n = _ts_parse_p44_parse_expr("async x => x");
    assert_eq(TS_AST_KIND(ts_base, n), TS_AST_EXPR_ARROW, "async bare-ident arrow");
    assert_eq(TS_AST_IS_ASYNC(ts_base, n), 1, "async bare-arrow flag set");
    
    n = _ts_parse_p44_parse_expr("async <T>(x: T): T => x");
    assert_eq(TS_AST_KIND(ts_base, n), TS_AST_EXPR_ARROW, "async generic arrow");
    assert_eq(TS_AST_IS_ASYNC(ts_base, n), 1, "async generic-arrow flag set");
    
    # ─── async function expressions ──────────────────────────────────
    test_group("async function expr");
    
    n = _ts_parse_p44_parse_expr("async function() { return 1; }");
    assert_eq(TS_AST_KIND(ts_base, n), TS_AST_DECL_FUNCTION, "async fn-expr");
    assert_eq(TS_AST_IS_ASYNC(ts_base, n), 1, "async fn-expr flag set");
    
    n = _ts_parse_p44_parse_expr("function() { return 1; }");
    assert_eq(TS_AST_IS_ASYNC(ts_base, n), 0, "plain fn-expr no flag");
    
    # ─── async class methods ─────────────────────────────────────────
    test_group("async class methods");
    
    s = _ts_parse_p44_parse_first_stmt("class C { async run() { return 1; } plain() { return 2; } }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class parses");
    var members = TS_AST_PAYLOAD(ts_base, s, 1);
    var m0 = TS_AST_CHILDREN_GET(ts_base, members);
    var m1 = TS_AST_CHILDREN_GET(ts_base, members + 1);
    assert_eq(TS_AST_KIND(ts_base, m0), TS_AST_DECL_METHOD, "first member is method");
    assert_eq(TS_AST_IS_ASYNC(ts_base, m0), 1, "async method flag set");
    assert_eq(TS_AST_KIND(ts_base, m1), TS_AST_DECL_METHOD, "second member is method");
    assert_eq(TS_AST_IS_ASYNC(ts_base, m1), 0, "plain method no flag");
    
    # ─── async object methods (shorthand) ────────────────────────────
    test_group("async object methods");
    
    n = _ts_parse_p44_parse_expr("({ async run() { return 1; }, plain() { return 2; } })");
    # The expression is wrapped in PAREN; unwrap to OBJECT.
    var inner = TS_AST_PAYLOAD(ts_base, n, 0);
    assert_eq(TS_AST_KIND(ts_base, inner), TS_AST_EXPR_OBJECT, "object literal");
    var props = TS_AST_PAYLOAD(ts_base, inner, 0);
    var p0 = TS_AST_CHILDREN_GET(ts_base, props);
    var p1 = TS_AST_CHILDREN_GET(ts_base, props + 1);
    assert_eq(TS_AST_KIND(ts_base, p0), TS_AST_DECL_METHOD, "first prop = method");
    assert_eq(TS_AST_IS_ASYNC(ts_base, p0), 1, "async object-method flag set");
    assert_eq(TS_AST_KIND(ts_base, p1), TS_AST_DECL_METHOD, "second prop = method");
    assert_eq(TS_AST_IS_ASYNC(ts_base, p1), 0, "plain object-method no flag");
    
    return 0;
}

# ── ts_parse_p45 ───────────────────────────────────────────
fn ts_parse_test_ts_parse_p45() {
    
    
    
    # Try to parse `src` as one top-level statement; return the first stmt
    # index, or -1 on lex/parse failure. Mirrors ts_parse_p44.tcyr.
    
    # ─── definite-assignment in let/const/var declarators ───────────
    test_group("definite-assignment !: in let/const/var declarators");
    
    var s = _ts_parse_p45_parse_first_stmt("let x!: number;");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "let x!: number;");
    
    s = _ts_parse_p45_parse_first_stmt("const y!: string = 'ok';");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "const y!: string = 'ok';");
    
    s = _ts_parse_p45_parse_first_stmt("var z!: boolean;");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "var z!: boolean;");
    
    # Multiple declarators in one statement — `!` on each.
    s = _ts_parse_p45_parse_first_stmt("let a!: number, b!: string;");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "let a!: number, b!: string;");
    
    # Mixed: with and without `!` in same declarator list.
    s = _ts_parse_p45_parse_first_stmt("let a!: number, b: string = 'x';");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "let a!: number, b: string = 'x';");
    
    # ─── regression: forms without `!` still parse ──────────────────
    test_group("regression: plain declarators still parse");
    
    s = _ts_parse_p45_parse_first_stmt("let a: number = 1;");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "let a: number = 1;");
    
    s = _ts_parse_p45_parse_first_stmt("const c = 'plain';");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "const c = 'plain';");
    
    s = _ts_parse_p45_parse_first_stmt("var v;");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "var v;");
    
    # ─── pre-existing: class properties already accept !: ───────────
    test_group("class property definite-assignment (pre-existing path)");
    
    s = _ts_parse_p45_parse_first_stmt("class C { data!: string; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class C { data!: string; }");
    
    s = _ts_parse_p45_parse_first_stmt("class D { name!: string; age!: number; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class D { name!: string; age!: number; }");
    
    return 0;
}

# ── ts_parse_p47 ───────────────────────────────────────────
fn ts_parse_test_ts_parse_p47() {
    
    
    
    
    # ─── modifier kw used as param name ──────────────────────────────
    test_group("modifier kw used as param name");
    
    var s = _ts_parse_p47_parse_first_stmt("function f(override?: string) { return; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "f(override?: string)");
    
    s = _ts_parse_p47_parse_first_stmt("function g(declare: number, async: boolean) { return; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "g(declare, async)");
    
    s = _ts_parse_p47_parse_first_stmt("function h(readonly: string, public: number) { return; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "h(readonly, public)");
    
    s = _ts_parse_p47_parse_first_stmt("function i(static = 1, abstract = 2) { return; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "i(static, abstract) with defaults");
    
    # ─── modifier kw used as method/prop name ────────────────────────
    test_group("modifier kw used as method/prop name");
    
    s = _ts_parse_p47_parse_first_stmt("class C { override(): void {} }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class C { override(): void }");
    
    s = _ts_parse_p47_parse_first_stmt("class D { async = 1; readonly = 'x'; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class D { async, readonly as props }");
    
    s = _ts_parse_p47_parse_first_stmt("class E { declare(x: number): void {} }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class E { declare() method }");
    
    # ─── regression: real modifier usage still works ────────────────
    test_group("regression: real modifier usage");
    
    s = _ts_parse_p47_parse_first_stmt("class F { private readonly x: string = 'a'; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class F { private readonly x }");
    
    s = _ts_parse_p47_parse_first_stmt("class G { override foo(): void {} }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class G { override foo() }");
    
    s = _ts_parse_p47_parse_first_stmt("class H { async fetch(): Promise<void> { return; } }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class H { async fetch() }");
    
    s = _ts_parse_p47_parse_first_stmt("class I { static name = 'I'; protected count = 0; }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class I { static + protected props }");
    
    # ─── regression: constructor parameter properties ───────────────
    test_group("regression: constructor parameter properties");
    
    s = _ts_parse_p47_parse_first_stmt("class J { constructor(public x: number, private readonly y: string) {} }");
    assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class J { constructor(public x, private readonly y) }");
    
    return 0;
}

ts_parse_test_ts_parse_p25();
ts_parse_test_ts_parse_p26();
ts_parse_test_ts_parse_p44();
ts_parse_test_ts_parse_p45();
ts_parse_test_ts_parse_p47();

var exit_code = assert_summary();
syscall(60, exit_code);
