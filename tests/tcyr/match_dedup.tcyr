# match_dedup.tcyr — v5.8.25 — exhaustive-match arm-tag dedup.
#
# Pre-bite: `match s { A => ..., A => ... }` over 3-variant enum
# counted as 2-of-3 covered (false-clean — adding any third arm
# would make it 3-of-3 even though A is duplicated and B/C are
# missing).
#
# Bite: PARSE_MATCH stack-allocates `seen_vcnt[256]` per match;
# per arm scans for prior occurrence of the arm's variant vcnt.
# Duplicate emits `warning: duplicate match arm 'X'` and skips
# counting toward match_covered (so non-exhaustive math stays
# accurate). Codegen unchanged — runtime cmp/jcc-skip cascade
# still picks the FIRST matching arm.
#
# This file regression-floors the RUNTIME behavior — like
# exhaustive_match.tcyr, the warning text itself can't be
# observed from inside the compiled binary; smoke-tested via
# /tmp/probe_dedup.cyr at v5.8.25 ship.

include "lib/string.cyr"
include "lib/syscalls.cyr"
include "lib/alloc.cyr"
include "lib/assert.cyr"

enum Tri { TA; TB; TC; }
enum Quad { Q1; Q2; Q3; Q4; }

alloc_init();

# ---- Helper: duplicate first arm fires only once at runtime ----
fn _tri_dispatch(t) {
    var r = 0;
    match t {
        TA => { r = 100; }
        TA => { r = 200; }   # dead — first match wins
        TB => { r = 300; }
        TC => { r = 400; }
    }
    return r;
}

# ---- Helper: duplicate non-first arm doesn't shadow earlier ----
fn _quad_dispatch(q) {
    var r = 0;
    match q {
        Q1 => { r = 1; }
        Q2 => { r = 2; }
        Q2 => { r = 99; }    # dead — Q2 already matched
        Q3 => { r = 3; }
        Q4 => { r = 4; }
    }
    return r;
}

# ---- Helper: triple-duplicate accurate runtime ----
fn _triple_dup(t) {
    var r = 0;
    match t {
        TA => { r = 1; }
        TA => { r = 2; }
        TA => { r = 3; }
        TB => { r = 4; }
        TC => { r = 5; }
    }
    return r;
}

# ---- Tests ----

test_group("duplicate first arm — runtime correctness");
assert_eq(_tri_dispatch(TA), 100, "TA -> first arm wins (100, not 200)");
assert_eq(_tri_dispatch(TB), 300, "TB -> 300 (skip past dup TA)");
assert_eq(_tri_dispatch(TC), 400, "TC -> 400");

test_group("duplicate middle arm — runtime correctness");
assert_eq(_quad_dispatch(Q1), 1, "Q1 -> 1");
assert_eq(_quad_dispatch(Q2), 2, "Q2 -> first arm wins (2, not 99)");
assert_eq(_quad_dispatch(Q3), 3, "Q3 -> 3");
assert_eq(_quad_dispatch(Q4), 4, "Q4 -> 4");

test_group("triple duplicate — runtime correctness");
assert_eq(_triple_dup(TA), 1, "TA -> first arm wins among 3 dups");
assert_eq(_triple_dup(TB), 4, "TB -> 4");
assert_eq(_triple_dup(TC), 5, "TC -> 5");

# Note: warning emission for duplicate arms fires at COMPILE time —
# can't be observed from inside the compiled binary. This file
# proves the dedup check DOES NOT ALTER CODEGEN (runtime cmp/jcc
# cascade unchanged; first matching arm always wins).
# Compile-stderr verification at v5.8.25 ship: /tmp/probe_dedup.cyr
# emits both `warning: duplicate match arm 'A'` and
# `warning: non-exhaustive match over enum 'Maybe' — covers 1 of 3
# variants` (was 2 of 3 pre-bite — fixed false-clean math).

var r = assert_summary();
