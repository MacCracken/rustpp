# Test: `secret var buf[N];` — zeroise-on-scope-exit for local arrays
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/assert.cyr"

# Helper that writes bytes into a secret buffer and returns its address.
# After this fn returns, the `secret` machinery must have zeroed the buffer.
fn make_and_mark_16() {
    secret var key[16];
    store64(&key, 0xAABBCCDDEEFF0011);
    store64(&key + 8, 0x1122334455667788);
    return &key;
}

fn make_and_mark_32() {
    secret var key32[32];
    store64(&key32, 0x1111111111111111);
    store64(&key32 + 8, 0x2222222222222222);
    store64(&key32 + 16, 0x3333333333333333);
    store64(&key32 + 24, 0x4444444444444444);
    return &key32;
}

fn make_and_mark_64() {
    secret var key64[64];
    var i = 0;
    while (i < 64) { store8(&key64 + i, 0 - 1); i = i + 1; }
    return &key64;
}

# Control: a regular (non-secret) var should NOT be zeroed at exit.
fn make_plain_16() {
    var plain[16];
    store64(&plain, 0xDEADBEEFCAFEBABE);
    store64(&plain + 8, 0xBADCAFED00DFEED0);
    return &plain;
}

test_group("secret var 16 bytes zeroed at scope exit");
var a16 = make_and_mark_16();
assert_eq(load64(a16), 0, "key[0..8] = 0 after return");
assert_eq(load64(a16 + 8), 0, "key[8..16] = 0 after return");

test_group("secret var 32 bytes zeroed at scope exit");
var a32 = make_and_mark_32();
assert_eq(load64(a32), 0, "key32[0..8] = 0");
assert_eq(load64(a32 + 8), 0, "key32[8..16] = 0");
assert_eq(load64(a32 + 16), 0, "key32[16..24] = 0");
assert_eq(load64(a32 + 24), 0, "key32[24..32] = 0");

test_group("secret var 64 bytes zeroed at scope exit");
var a64 = make_and_mark_64();
var zi = 0;
var allzero = 1;
while (zi < 8) {
    if (load64(a64 + zi * 8) != 0) { allzero = 0; }
    zi = zi + 1;
}
assert_eq(allzero, 1, "all 8 qwords of key64 = 0");

test_group("plain var is NOT zeroed (control)");
var ap = make_plain_16();
# Plain array is untouched — the bytes written before return are still there.
assert_eq(load64(ap), 0xDEADBEEFCAFEBABE, "plain[0..8] preserved");
assert_eq(load64(ap + 8), 0xBADCAFED00DFEED0, "plain[8..16] preserved");

var r = assert_summary();
