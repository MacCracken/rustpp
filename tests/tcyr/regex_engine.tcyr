# regex_engine.tcyr — v5.7.18 acceptance gate for the full Thompson NFA
# / Pike's matcher. Covers literals, escapes, anchors, character classes
# (literal + ranges + negation + predefined), quantifiers (greedy + lazy
# + brace), alternation, groups (capturing + non-capturing), word
# boundaries, and capture-group offset extraction.
#
# Out of scope (not yet implemented; covered by future patches):
# backreferences, lookaround, Unicode property classes, multiline mode.

include "lib/syscalls.cyr"
include "lib/alloc.cyr"
include "lib/string.cyr"
include "lib/str.cyr"
include "lib/vec.cyr"
include "lib/regex.cyr"
include "lib/assert.cyr"

alloc_init();

# ── glob_match regression: existing helpers must still work ──────────
test_group("glob_match (regression)");
assert_eq(glob_match("hello", "hello"), 1, "glob exact match");
assert_eq(glob_match("hel*", "hello"), 1, "glob star suffix");
assert_eq(glob_match("*.cyr", "test.cyr"), 1, "glob ext");

# ── Literals + . any-char ────────────────────────────────────────────
test_group("literals");
var rl = regex_compile("abc");
assert_eq(regex_match(rl, "abc"), 1, "abc / abc");
assert_eq(regex_match(rl, "abcdef"), 1, "abc / abcdef (anchored start)");
assert_eq(regex_match(rl, "ab"), 0, "abc / ab");
assert_eq(regex_match(rl, "xabc"), 0, "abc / xabc (anchored)");
assert_eq(regex_search(rl, "xxabc"), 2, "search abc in xxabc");
assert_eq(regex_search(rl, "xxxxx"), 0 - 1, "search miss");

var rdot = regex_compile("a.c");
assert_eq(regex_match(rdot, "abc"), 1, "a.c / abc");
assert_eq(regex_match(rdot, "axc"), 1, "a.c / axc");
assert_eq(regex_match(rdot, "a c"), 1, "a.c / a-space-c");
assert_eq(regex_match(rdot, "ac"), 0, "a.c / ac (need 3 chars)");

# ── Anchors ──────────────────────────────────────────────────────────
test_group("anchors");
var ranc = regex_compile("^foo$");
assert_eq(regex_match(ranc, "foo"), 1, "^foo$ / foo");
assert_eq(regex_match(ranc, "foo "), 0, "^foo$ / 'foo ' fail");
assert_eq(regex_match(ranc, " foo"), 0, "^foo$ / ' foo' fail");
var rstart = regex_compile("^abc");
assert_eq(regex_search(rstart, "abc def"), 0, "^abc / abc def");
assert_eq(regex_search(rstart, "x abc"), 0 - 1, "^abc / x abc fail");
var rend = regex_compile("end$");
assert_eq(regex_search(rend, "the end"), 4, "end$ / 'the end'");

# ── Character classes (literal, ranges, negation) ────────────────────
test_group("char classes");
var rc1 = regex_compile("[abc]");
assert_eq(regex_match(rc1, "a"), 1, "[abc] / a");
assert_eq(regex_match(rc1, "b"), 1, "[abc] / b");
assert_eq(regex_match(rc1, "d"), 0, "[abc] / d");
var rc2 = regex_compile("[a-z]");
assert_eq(regex_match(rc2, "m"), 1, "[a-z] / m");
assert_eq(regex_match(rc2, "M"), 0, "[a-z] / M");
var rc3 = regex_compile("[^0-9]");
assert_eq(regex_match(rc3, "a"), 1, "[^0-9] / a");
assert_eq(regex_match(rc3, "5"), 0, "[^0-9] / 5");
var rc4 = regex_compile("[a-zA-Z0-9_]");
assert_eq(regex_match(rc4, "_"), 1, "alnum+_ / _");

# ── Predefined classes (\d \D \w \W \s \S) ────────────────────────────
test_group("predefined classes");
var rd  = regex_compile("\\d");
assert_eq(regex_match(rd, "5"), 1, "\\d / 5");
assert_eq(regex_match(rd, "x"), 0, "\\d / x");
var rD  = regex_compile("\\D");
assert_eq(regex_match(rD, "x"), 1, "\\D / x");
assert_eq(regex_match(rD, "5"), 0, "\\D / 5");
var rw  = regex_compile("\\w");
assert_eq(regex_match(rw, "_"), 1, "\\w / _");
assert_eq(regex_match(rw, "5"), 1, "\\w / 5");
assert_eq(regex_match(rw, " "), 0, "\\w / space");
var rs  = regex_compile("\\s");
assert_eq(regex_match(rs, " "), 1, "\\s / space");
assert_eq(regex_match(rs, "\t"), 1, "\\s / tab");
assert_eq(regex_match(rs, "a"), 0, "\\s / a");

# ── Quantifiers — greedy ─────────────────────────────────────────────
test_group("quantifiers — greedy");
var rstar = regex_compile("a*");
assert_eq(regex_match(rstar, ""), 1, "a* / empty");
assert_eq(regex_match(rstar, "aaa"), 1, "a* / aaa");
assert_eq(regex_match(rstar, "b"), 1, "a* / b (matches empty prefix)");
var rplus = regex_compile("a+");
assert_eq(regex_match(rplus, "a"), 1, "a+ / a");
assert_eq(regex_match(rplus, "aaaaa"), 1, "a+ / aaaaa");
assert_eq(regex_match(rplus, ""), 0, "a+ / empty");
var ropt = regex_compile("colou?r");
assert_eq(regex_match(ropt, "color"), 1, "colou?r / color");
assert_eq(regex_match(ropt, "colour"), 1, "colou?r / colour");
assert_eq(regex_match(ropt, "colouur"), 0, "colou?r / colouur");

# ── Quantifiers — lazy (greedy?) ─────────────────────────────────────
test_group("quantifiers — lazy");
var rlazy = regex_compile("a+?b");
assert_eq(regex_match(rlazy, "aaab"), 1, "a+?b / aaab");
var rlazy2 = regex_compile(".*?b");
assert_eq(regex_match(rlazy2, "ab"), 1, ".*?b / ab");

# ── Brace quantifiers ────────────────────────────────────────────────
test_group("brace quantifiers");
var rb1 = regex_compile("a{3}");
assert_eq(regex_match(rb1, "aaa"), 1, "a{3} / aaa");
assert_eq(regex_match(rb1, "aa"), 0, "a{3} / aa");
assert_eq(regex_match(rb1, "aaaa"), 1, "a{3} / aaaa (anchored start, takes 3)");
var rb2 = regex_compile("a{2,4}");
assert_eq(regex_match(rb2, "aa"), 1, "a{2,4} / aa");
assert_eq(regex_match(rb2, "aaa"), 1, "a{2,4} / aaa");
assert_eq(regex_match(rb2, "aaaaa"), 1, "a{2,4} / aaaaa (eats 4)");
assert_eq(regex_match(rb2, "a"), 0, "a{2,4} / a");
var rb3 = regex_compile("a{2,}");
assert_eq(regex_match(rb3, "aa"), 1, "a{2,} / aa");
assert_eq(regex_match(rb3, "aaaaaaa"), 1, "a{2,} / aaaaaaa");
assert_eq(regex_match(rb3, "a"), 0, "a{2,} / a");
var rb4 = regex_compile("a{0,3}");
assert_eq(regex_match(rb4, ""), 1, "a{0,3} / empty");
assert_eq(regex_match(rb4, "aaa"), 1, "a{0,3} / aaa");

# ── Alternation ──────────────────────────────────────────────────────
test_group("alternation");
var ralt = regex_compile("cat|dog|fish");
assert_eq(regex_match(ralt, "cat"), 1, "cat|dog|fish / cat");
assert_eq(regex_match(ralt, "dog"), 1, "cat|dog|fish / dog");
assert_eq(regex_match(ralt, "fish"), 1, "cat|dog|fish / fish");
assert_eq(regex_match(ralt, "bird"), 0, "cat|dog|fish / bird");

# ── Grouping ─────────────────────────────────────────────────────────
test_group("groups");
var rg1 = regex_compile("(ab)+");
assert_eq(regex_match(rg1, "ab"), 1, "(ab)+ / ab");
assert_eq(regex_match(rg1, "abab"), 1, "(ab)+ / abab");
assert_eq(regex_match(rg1, "a"), 0, "(ab)+ / a");
var rg2 = regex_compile("(?:foo)bar");
assert_eq(regex_match(rg2, "foobar"), 1, "(?:foo)bar / foobar");

# ── Captures ─────────────────────────────────────────────────────────
test_group("captures");
var rcap = regex_compile("([a-z]+)=([0-9]+)");
assert_eq(regex_match(rcap, "key=42"), 1, "captures match");
assert_eq(regex_group_start(rcap, 1), 0, "g1 start");
assert_eq(regex_group_end(rcap, 1),   3, "g1 end");
assert_eq(regex_group_start(rcap, 2), 4, "g2 start");
assert_eq(regex_group_end(rcap, 2),   6, "g2 end");
assert_eq(regex_group_start(rcap, 0), 0, "g0 start");
assert_eq(regex_group_end(rcap, 0),   6, "g0 end");

# ── Word boundaries ──────────────────────────────────────────────────
test_group("boundaries");
var rwb = regex_compile("\\bword\\b");
assert_eq(regex_search(rwb, "the word here"), 4, "\\bword\\b in 'the word here'");
assert_eq(regex_search(rwb, "swordfish"), 0 - 1, "\\bword\\b NOT in swordfish");
assert_eq(regex_search(rwb, "word"), 0, "\\bword\\b at start");

# ── Common patterns ──────────────────────────────────────────────────
test_group("common patterns");
var rint = regex_compile("^-?[0-9]+$");
assert_eq(regex_match(rint, "0"), 1, "int / 0");
assert_eq(regex_match(rint, "42"), 1, "int / 42");
assert_eq(regex_match(rint, "-7"), 1, "int / -7");
assert_eq(regex_match(rint, "1a"), 0, "int / 1a");

var rhex = regex_compile("^0x[0-9a-fA-F]+$");
assert_eq(regex_match(rhex, "0xDEADbeef"), 1, "hex / 0xDEADbeef");
assert_eq(regex_match(rhex, "0x"),         0, "hex / 0x (no digits)");
assert_eq(regex_match(rhex, "DEAD"),       0, "hex / DEAD (no prefix)");

# IPv4-shaped (not a real IPv4 validator — just structure).
var ripv4 = regex_compile("^\\d+\\.\\d+\\.\\d+\\.\\d+$");
assert_eq(regex_match(ripv4, "192.168.1.1"), 1, "ipv4-ish / 192.168.1.1");
assert_eq(regex_match(ripv4, "1.2.3"),       0, "ipv4-ish / 1.2.3");

# Scanning search returns first match position.
var rscan = regex_compile("\\d+");
assert_eq(regex_search(rscan, "abc123def456"), 3, "search \\d+ in abc123 → 3");

# Empty pattern matches at every position.
var rempty = regex_compile("");
assert_eq(regex_match(rempty, "anything"), 1, "empty / matches anything");

var r = assert_summary();
