# Test: io library
include "lib/alloc.cyr"
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/io.cyr"
include "lib/assert.cyr"

alloc_init();

test_group("file_open / file_write / file_read / file_close");
var path = "/tmp/cyrius_io_test";
var fd = file_open(path, 577, 0x1ED);
assert_eq(fd >= 0, 1, "open for write");
var n = file_write(fd, "test data", 9);
assert_eq(n, 9, "write 9");
file_close(fd);

var fd2 = file_open(path, 0, 0);
assert_eq(fd2 >= 0, 1, "open for read");
var buf = alloc(64);
var nr = file_read(fd2, buf, 63);
assert_eq(nr, 9, "read 9");
store8(buf + nr, 0);
assert_eq(streq(buf, "test data"), 1, "content");
file_close(fd2);

test_group("file_exists");
assert_eq(file_exists(path), 1, "exists");
assert_eq(file_exists("/tmp/cyrius_io_no_such"), 0, "not exists");

test_group("file_read_all / file_write_all");
var wn = file_write_all(path, "overwrite", 9);
assert_eq(wn, 9, "write_all");
var buf2 = alloc(64);
var rn = file_read_all(path, buf2, 63);
assert_eq(rn, 9, "read_all");

test_group("file_lock / file_unlock");
var lockpath = "/tmp/cyrius_lock_test";
var lfd = file_open(lockpath, O_WRONLY | O_CREAT | O_TRUNC, 0x1A4);
assert_eq(lfd >= 0, 1, "lock file open");
var lr = file_lock(lfd);
assert_eq(lr, 0, "lock acquired");
file_write(lfd, "locked", 6);
file_unlock(lfd);
file_close(lfd);
# Verify content survived lock/unlock
var lbuf = alloc(32);
var ln = file_read_all(lockpath, lbuf, 31);
store8(lbuf + ln, 0);
assert_eq(streq(lbuf, "locked"), 1, "locked content");

test_group("file_trylock");
var tfd = file_open(lockpath, O_RDONLY, 0);
var tr = file_trylock(tfd);
assert_eq(tr, 0, "trylock ok");
file_unlock(tfd);
file_close(tfd);

test_group("file_append_locked");
syscall(87, lockpath);
file_append_locked(lockpath, "line1\n", 6);
file_append_locked(lockpath, "line2\n", 6);
var abuf = alloc(64);
var an = file_read_all(lockpath, abuf, 63);
assert_eq(an, 12, "append 12 bytes");
store8(abuf + an, 0);
assert_eq(streq(abuf, "line1\nline2\n"), 1, "append content");

# Cleanup
syscall(87, path);
syscall(87, lockpath);

var r = assert_summary();
