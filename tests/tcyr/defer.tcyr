# Test: defer statement
include "lib/alloc.cyr"
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/io.cyr"
include "lib/assert.cyr"

alloc_init();

test_group("defer basic");
fn test_defer_basic() {
    var path = "/tmp/cyrius_defer_t1";
    var fd = file_open(path, 577, 0x1A4);
    defer { file_close(fd); }
    file_write(fd, "ok", 2);
    return 0;
}
test_defer_basic();
var buf = alloc(32);
var n = file_read_all("/tmp/cyrius_defer_t1", buf, 31);
assert_eq(n, 2, "defer wrote+closed");
syscall(87, "/tmp/cyrius_defer_t1");

test_group("defer LIFO");
fn test_defer_lifo() {
    var fd = file_open("/tmp/cyrius_defer_t2", 577, 0x1A4);
    defer { file_write(fd, "C", 1); file_close(fd); }
    defer { file_write(fd, "B", 1); }
    defer { file_write(fd, "A", 1); }
    file_write(fd, "0", 1);
    return 0;
}
test_defer_lifo();
var buf2 = alloc(32);
var n2 = file_read_all("/tmp/cyrius_defer_t2", buf2, 31);
store8(buf2 + n2, 0);
assert_eq(n2, 4, "lifo 4 bytes");
assert_eq(streq(buf2, "0ABC"), 1, "lifo order 0ABC");
syscall(87, "/tmp/cyrius_defer_t2");

test_group("defer with return value");
fn test_defer_retval() {
    defer { syscall(1, 2, "", 0); }
    return 42;
}
var rv = test_defer_retval();
assert_eq(rv, 42, "retval preserved");

var r = assert_summary();
