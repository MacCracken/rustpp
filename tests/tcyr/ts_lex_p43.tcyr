# v5.7.6 mode-stack JSX lex acceptance.
#
# v5.7.5 P4.3a originally shipped a self-contained `TS_LEX_JSX(...)`
# walker with hard-coded test expectations. v5.7.6 (P4.3d) restructured
# JSX lex into mode-stack helpers (modes 4=JSX_TAG, 5=JSX_TEXT,
# 8=JSX_EXPR on the existing template-stack) dispatched from the main
# `TS_LEX` loop — `TS_LEX_JSX` now only emits the opening-tag tokens,
# the rest is driven by the main loop. The mode-stack also tokenizes
# the bodies of `{...}` JSX expression containers that v5.7.5
# byte-skipped over (the v5.7.6 inner-expr feature).
#
# This test was ported to call `TS_LEX` end-to-end and assert the
# resulting v5.7.6 token sequence (with inner-expr tokens; trailing
# `0` is the EOF terminator emitted by `TS_LEX`).

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/syscalls.cyr"
include "lib/assert.cyr"

include "src/frontend/ts/lex.cyr"

alloc_init();
var ts_base = alloc(TS_HEAP_SIZE + 4096);

# Lex `src` end-to-end through TS_LEX. Returns slen on a clean lex
# (TS_LEX consumed the whole input without error), 0 on lex error.
# The test asserts on the emitted token stream — TS_GTCNT,
# TS_PEEKT(idx, ...) — exactly as the v5.7.5-shape test did, since
# the token sequence is the durable contract; the entry-point
# function name is not.
fn lex_jsx(src) {
    var slen = strlen(src);
    var rc = TS_LEX(ts_base, src, slen);
    if (rc < 0) { return 0; }
    return slen;
}

fn assert_tok(idx, expected_typ, name) {
    assert_eq(TS_PEEKT(ts_base, idx), expected_typ, name);
    return 0;
}

fn assert_count(expected, name) {
    assert_eq(TS_GTCNT(ts_base), expected, name);
    return 0;
}

# ─── simple open/close ──────────────────────────────────────────
test_group("simple open/close");
var end = lex_jsx("<Foo>txt</Foo>");
assert_eq(end, 14, "<Foo>txt</Foo> end pos");
assert_count(8, "<Foo>txt</Foo> tok count (incl EOF)");
assert_tok(0, TS_TOK_JSX_OPEN_START,  "0: <");
assert_tok(1, TS_TOK_JSX_TAG_NAME,    "1: Foo");
assert_tok(2, TS_TOK_JSX_OPEN_END,    "2: >");
assert_tok(3, TS_TOK_JSX_TEXT,        "3: txt");
assert_tok(4, TS_TOK_JSX_CLOSE_START, "4: </");
assert_tok(5, TS_TOK_JSX_TAG_NAME,    "5: Foo");
assert_tok(6, TS_TOK_JSX_CLOSE_END,   "6: >");
assert_tok(7, TS_TOK_EOF,             "7: EOF");

# ─── self-closing ───────────────────────────────────────────────
test_group("self-closing");
end = lex_jsx("<Foo />");
assert_eq(end, 7, "<Foo /> end pos");
assert_count(4, "<Foo /> tok count");
assert_tok(0, TS_TOK_JSX_OPEN_START, "0: <");
assert_tok(1, TS_TOK_JSX_TAG_NAME,   "1: Foo");
assert_tok(2, TS_TOK_JSX_SELF_CLOSE, "2: />");
assert_tok(3, TS_TOK_EOF,            "3: EOF");

# ─── fragment ───────────────────────────────────────────────────
test_group("fragment");
end = lex_jsx("<>txt</>");
assert_eq(end, 8, "<>txt</> end pos");
assert_count(4, "<>txt</> tok count");
assert_tok(0, TS_TOK_JSX_FRAGMENT_OPEN,  "0: <>");
assert_tok(1, TS_TOK_JSX_TEXT,           "1: txt");
assert_tok(2, TS_TOK_JSX_FRAGMENT_CLOSE, "2: </>");
assert_tok(3, TS_TOK_EOF,                "3: EOF");

# ─── attr string ────────────────────────────────────────────────
test_group("attr string");
end = lex_jsx("<Foo a=\"x\" />");
assert_count(6, "<Foo a=\"x\" /> tok count");
assert_tok(0, TS_TOK_JSX_OPEN_START,        "0: <");
assert_tok(1, TS_TOK_JSX_TAG_NAME,          "1: Foo");
assert_tok(2, TS_TOK_JSX_ATTR_NAME,         "2: a");
assert_tok(3, TS_TOK_JSX_ATTR_VALUE_STRING, "3: \"x\"");
assert_tok(4, TS_TOK_JSX_SELF_CLOSE,        "4: />");
assert_tok(5, TS_TOK_EOF,                   "5: EOF");

# ─── attr expr (v5.7.6 inner-expr tokenization) ─────────────────
test_group("attr expr");
end = lex_jsx("<Foo a={1} />");
assert_count(8, "<Foo a={1} /> tok count");
assert_tok(0, TS_TOK_JSX_OPEN_START,  "0: <");
assert_tok(1, TS_TOK_JSX_TAG_NAME,    "1: Foo");
assert_tok(2, TS_TOK_JSX_ATTR_NAME,   "2: a");
assert_tok(3, TS_TOK_JSX_EXPR_OPEN,   "3: {");
assert_tok(4, TS_TOK_INT,             "4: 1 (inner-expr tokenized)");
assert_tok(5, TS_TOK_JSX_EXPR_CLOSE,  "5: }");
assert_tok(6, TS_TOK_JSX_SELF_CLOSE,  "6: />");
assert_tok(7, TS_TOK_EOF,             "7: EOF");

# ─── spread attr (inner ELLIPSIS + IDENT now tokenized) ─────────
test_group("spread attr");
end = lex_jsx("<Foo {...x} />");
assert_count(8, "<Foo {...x} /> tok count");
assert_tok(0, TS_TOK_JSX_OPEN_START,  "0: <");
assert_tok(1, TS_TOK_JSX_TAG_NAME,    "1: Foo");
assert_tok(2, TS_TOK_JSX_EXPR_OPEN,   "2: {");
assert_tok(3, TS_TOK_ELLIPSIS,        "3: ...");
assert_tok(4, TS_TOK_IDENT,           "4: x");
assert_tok(5, TS_TOK_JSX_EXPR_CLOSE,  "5: }");
assert_tok(6, TS_TOK_JSX_SELF_CLOSE,  "6: />");
assert_tok(7, TS_TOK_EOF,             "7: EOF");

# ─── bare boolean attr ──────────────────────────────────────────
test_group("bare boolean attr");
end = lex_jsx("<Foo bar />");
assert_count(5, "<Foo bar /> tok count");
assert_tok(0, TS_TOK_JSX_OPEN_START,  "0: <");
assert_tok(1, TS_TOK_JSX_TAG_NAME,    "1: Foo");
assert_tok(2, TS_TOK_JSX_ATTR_NAME,   "2: bar");
assert_tok(3, TS_TOK_JSX_SELF_CLOSE,  "3: />");
assert_tok(4, TS_TOK_EOF,             "4: EOF");

# ─── expr child (inner IDENT now tokenized) ─────────────────────
test_group("expr child");
end = lex_jsx("<Foo>{x}</Foo>");
assert_count(10, "<Foo>{x}</Foo> tok count");
assert_tok(0, TS_TOK_JSX_OPEN_START,  "0: <");
assert_tok(1, TS_TOK_JSX_TAG_NAME,    "1: Foo");
assert_tok(2, TS_TOK_JSX_OPEN_END,    "2: >");
assert_tok(3, TS_TOK_JSX_EXPR_OPEN,   "3: {");
assert_tok(4, TS_TOK_IDENT,           "4: x");
assert_tok(5, TS_TOK_JSX_EXPR_CLOSE,  "5: }");
assert_tok(6, TS_TOK_JSX_CLOSE_START, "6: </");
assert_tok(7, TS_TOK_JSX_TAG_NAME,    "7: Foo");
assert_tok(8, TS_TOK_JSX_CLOSE_END,   "8: >");
assert_tok(9, TS_TOK_EOF,             "9: EOF");

# ─── nested element ─────────────────────────────────────────────
test_group("nested element");
end = lex_jsx("<Foo><Bar /></Foo>");
assert_count(10, "<Foo><Bar /></Foo> tok count");
assert_tok(0, TS_TOK_JSX_OPEN_START,  "0: <Foo");
assert_tok(1, TS_TOK_JSX_TAG_NAME,    "1: Foo");
assert_tok(2, TS_TOK_JSX_OPEN_END,    "2: >");
assert_tok(3, TS_TOK_JSX_OPEN_START,  "3: <Bar");
assert_tok(4, TS_TOK_JSX_TAG_NAME,    "4: Bar");
assert_tok(5, TS_TOK_JSX_SELF_CLOSE,  "5: />");
assert_tok(6, TS_TOK_JSX_CLOSE_START, "6: </");
assert_tok(7, TS_TOK_JSX_TAG_NAME,    "7: Foo");
assert_tok(8, TS_TOK_JSX_CLOSE_END,   "8: >");
assert_tok(9, TS_TOK_EOF,             "9: EOF");

# ─── member tag name (the dot is inside the TAG_NAME span) ──────
test_group("member tag name");
end = lex_jsx("<Foo.Bar />");
assert_count(4, "<Foo.Bar /> tok count");
assert_tok(0, TS_TOK_JSX_OPEN_START, "0: <");
assert_tok(1, TS_TOK_JSX_TAG_NAME,   "1: Foo.Bar");
assert_tok(2, TS_TOK_JSX_SELF_CLOSE, "2: />");
assert_tok(3, TS_TOK_EOF,            "3: EOF");

# ─── JSX inside expr inside JSX (v5.7.6 inner-expr tokenization) ─
# Inner `c ? <Bar /> : null` is fully tokenized: c, ?, <Bar, Bar,
# />, :, null. Tokens 4-10 are the inner expression; the outer
# wrap (open + expr-container + close) is 9 tokens.
test_group("JSX inside expr inside JSX");
end = lex_jsx("<Foo>{c?<Bar />:null}</Foo>");
assert_count(16, "JSX-in-expr-in-JSX tok count");
assert_tok(0, TS_TOK_JSX_OPEN_START,  "outer: <");
assert_tok(1, TS_TOK_JSX_TAG_NAME,    "outer: Foo");
assert_tok(2, TS_TOK_JSX_OPEN_END,    "outer: >");
assert_tok(3, TS_TOK_JSX_EXPR_OPEN,   "expr: {");
assert_tok(4, TS_TOK_IDENT,           "inner: c");
assert_tok(5, TS_TOK_QUESTION,        "inner: ?");
assert_tok(6, TS_TOK_JSX_OPEN_START,  "inner: <");
assert_tok(7, TS_TOK_JSX_TAG_NAME,    "inner: Bar");
assert_tok(8, TS_TOK_JSX_SELF_CLOSE,  "inner: />");
assert_tok(9, TS_TOK_COLON,           "inner: :");
assert_tok(10, TS_TOK_KW_NULL,        "inner: null");
assert_tok(11, TS_TOK_JSX_EXPR_CLOSE, "expr: }");
assert_tok(12, TS_TOK_JSX_CLOSE_START,"outer: </");
assert_tok(13, TS_TOK_JSX_TAG_NAME,   "outer: Foo");
assert_tok(14, TS_TOK_JSX_CLOSE_END,  "outer: >");
assert_tok(15, TS_TOK_EOF,            "EOF");

# ─── generic-arrow disambig ────────────────────────────────────
# `<T>(x) => x` is NOT JSX. v5.7.6 BYTE_SKIP correctly rejects it
# at lex time — main loop tokenizes as ordinary expression bytes.
# v5.7.5 walker bailed and emitted 0 tokens; v5.7.6 emits the
# regular tokens (LT, T, GT, LPAREN, x, RPAREN, ARROW, x).
test_group("generic-arrow disambig");
end = lex_jsx("<T>(x) => x");
assert_count(9, "<T>(x) => x lexes as plain expr (not JSX)");
assert_tok(0, TS_TOK_LT,     "0: <");
assert_tok(1, TS_TOK_IDENT,  "1: T");
assert_tok(2, TS_TOK_GT,     "2: >");
assert_tok(3, TS_TOK_LPAREN, "3: (");
assert_tok(4, TS_TOK_IDENT,  "4: x");
assert_tok(5, TS_TOK_RPAREN, "5: )");
assert_tok(6, TS_TOK_ARROW,  "6: =>");
assert_tok(7, TS_TOK_IDENT,  "7: x");
assert_tok(8, TS_TOK_EOF,    "8: EOF");

var exit_code = assert_summary();
syscall(60, exit_code);
