# v5.7.5 P4.3a — TS lexer structured JSX tokens.
#
# Exercises TS_LEX_JSX directly (it's not wired into TS_LEX yet —
# P4.3b flips the dispatch). Asserts the structured token sequence
# replaces the v5.7.3 single-TOK_INT placeholder approach.
#
# Coverage:
#   - simple open/close: <Foo>txt</Foo>
#   - self-closing: <Foo />
#   - fragment: <>txt</>
#   - attrs: name="val" + name={expr} + bare boolean attr
#   - spread attr: <Foo {...x} />
#   - expr child: <Foo>{x}</Foo>
#   - nested: <Foo><Bar /></Foo>
#   - member tag name: <Foo.Bar />
#   - JSX inside expr inside JSX: <Foo>{cond ? <Bar /> : null}</Foo>
#   - generic-arrow disambig: <T>(x) => x — bails (returns start)

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/syscalls.cyr"
include "lib/assert.cyr"

include "src/frontend/ts/lex.cyr"

alloc_init();
var ts_base = alloc(TS_HEAP_SIZE + 4096);

# Reset lex state, then call TS_LEX_JSX from offset 0. Returns the end
# position TS_LEX_JSX advanced to (or 0 if it bailed).
fn lex_jsx(src) {
    TS_SPOS(ts_base, 0);
    store64(ts_base + TS_LEX_STATE_OFF + TS_LS_LINE, 1);
    TS_STCNT(ts_base, 0);
    TS_SETERR(ts_base, 0);
    store64(ts_base + TS_LEX_STATE_OFF + TS_LS_LAST_TOK_CLASS, 0);
    store64(ts_base + TS_LEX_STATE_OFF + TS_LS_TEMPLATE_DEPTH, 0);
    return TS_LEX_JSX(ts_base, src, strlen(src), 0);
}

fn assert_tok(idx, expected_typ, name) {
    assert_eq(TS_PEEKT(ts_base, idx), expected_typ, name);
    return 0;
}

fn assert_count(expected, name) {
    assert_eq(TS_GTCNT(ts_base), expected, name);
    return 0;
}

# ─── simple open/close ──────────────────────────────────────────
test_group("simple open/close");
var end = lex_jsx("<Foo>txt</Foo>");
assert_eq(end, 14, "<Foo>txt</Foo> end pos");
assert_count(7, "<Foo>txt</Foo> tok count");
assert_tok(0, TS_TOK_JSX_OPEN_START,  "0: <");
assert_tok(1, TS_TOK_JSX_TAG_NAME,    "1: Foo");
assert_tok(2, TS_TOK_JSX_OPEN_END,    "2: >");
assert_tok(3, TS_TOK_JSX_TEXT,        "3: txt");
assert_tok(4, TS_TOK_JSX_CLOSE_START, "4: </");
assert_tok(5, TS_TOK_JSX_TAG_NAME,    "5: Foo");
assert_tok(6, TS_TOK_JSX_CLOSE_END,   "6: >");

# ─── self-closing ───────────────────────────────────────────────
test_group("self-closing");
end = lex_jsx("<Foo />");
assert_eq(end, 7, "<Foo /> end pos");
assert_count(3, "<Foo /> tok count");
assert_tok(0, TS_TOK_JSX_OPEN_START, "0: <");
assert_tok(1, TS_TOK_JSX_TAG_NAME,   "1: Foo");
assert_tok(2, TS_TOK_JSX_SELF_CLOSE, "2: />");

# ─── fragment ───────────────────────────────────────────────────
test_group("fragment");
end = lex_jsx("<>txt</>");
assert_eq(end, 8, "<>txt</> end pos");
assert_count(3, "<>txt</> tok count");
assert_tok(0, TS_TOK_JSX_FRAGMENT_OPEN,  "0: <>");
assert_tok(1, TS_TOK_JSX_TEXT,           "1: txt");
assert_tok(2, TS_TOK_JSX_FRAGMENT_CLOSE, "2: </>");

# ─── attribute string ───────────────────────────────────────────
test_group("attr string");
end = lex_jsx("<Foo a=\"x\" />");
assert_eq(end, 13, "<Foo a=\"x\" /> end pos");
assert_count(5, "<Foo a=\"x\" /> tok count");
assert_tok(0, TS_TOK_JSX_OPEN_START,        "0: <");
assert_tok(1, TS_TOK_JSX_TAG_NAME,          "1: Foo");
assert_tok(2, TS_TOK_JSX_ATTR_NAME,         "2: a");
assert_tok(3, TS_TOK_JSX_ATTR_VALUE_STRING, "3: x");
assert_tok(4, TS_TOK_JSX_SELF_CLOSE,        "4: />");

# ─── attribute expr ─────────────────────────────────────────────
test_group("attr expr");
end = lex_jsx("<Foo a={1} />");
assert_eq(end, 13, "<Foo a={1} /> end pos");
assert_count(6, "<Foo a={1} /> tok count");
assert_tok(0, TS_TOK_JSX_OPEN_START, "0: <");
assert_tok(1, TS_TOK_JSX_TAG_NAME,   "1: Foo");
assert_tok(2, TS_TOK_JSX_ATTR_NAME,  "2: a");
assert_tok(3, TS_TOK_JSX_EXPR_OPEN,  "3: {");
assert_tok(4, TS_TOK_JSX_EXPR_CLOSE, "4: }");
assert_tok(5, TS_TOK_JSX_SELF_CLOSE, "5: />");

# ─── spread attr ────────────────────────────────────────────────
test_group("spread attr");
end = lex_jsx("<Foo {...x} />");
assert_eq(end, 14, "<Foo {...x} /> end pos");
assert_count(5, "<Foo {...x} /> tok count");
assert_tok(0, TS_TOK_JSX_OPEN_START, "0: <");
assert_tok(1, TS_TOK_JSX_TAG_NAME,   "1: Foo");
assert_tok(2, TS_TOK_JSX_EXPR_OPEN,  "2: {");
assert_tok(3, TS_TOK_JSX_EXPR_CLOSE, "3: }");
assert_tok(4, TS_TOK_JSX_SELF_CLOSE, "4: />");

# ─── bare boolean attr ──────────────────────────────────────────
test_group("bare boolean attr");
end = lex_jsx("<Foo bar />");
assert_eq(end, 11, "<Foo bar /> end pos");
assert_count(4, "<Foo bar /> tok count");
assert_tok(0, TS_TOK_JSX_OPEN_START, "0: <");
assert_tok(1, TS_TOK_JSX_TAG_NAME,   "1: Foo");
assert_tok(2, TS_TOK_JSX_ATTR_NAME,  "2: bar");
assert_tok(3, TS_TOK_JSX_SELF_CLOSE, "3: />");

# ─── expr child ─────────────────────────────────────────────────
test_group("expr child");
end = lex_jsx("<Foo>{x}</Foo>");
assert_eq(end, 14, "<Foo>{x}</Foo> end pos");
assert_count(8, "<Foo>{x}</Foo> tok count");
assert_tok(0, TS_TOK_JSX_OPEN_START,  "0: <");
assert_tok(1, TS_TOK_JSX_TAG_NAME,    "1: Foo");
assert_tok(2, TS_TOK_JSX_OPEN_END,    "2: >");
assert_tok(3, TS_TOK_JSX_EXPR_OPEN,   "3: {");
assert_tok(4, TS_TOK_JSX_EXPR_CLOSE,  "4: }");
assert_tok(5, TS_TOK_JSX_CLOSE_START, "5: </");
assert_tok(6, TS_TOK_JSX_TAG_NAME,    "6: Foo");
assert_tok(7, TS_TOK_JSX_CLOSE_END,   "7: >");

# ─── nested element ─────────────────────────────────────────────
test_group("nested element");
end = lex_jsx("<Foo><Bar /></Foo>");
assert_eq(end, 18, "<Foo><Bar /></Foo> end pos");
assert_count(9, "<Foo><Bar /></Foo> tok count");
assert_tok(0, TS_TOK_JSX_OPEN_START,  "0: <Foo");
assert_tok(1, TS_TOK_JSX_TAG_NAME,    "1: Foo");
assert_tok(2, TS_TOK_JSX_OPEN_END,    "2: >");
assert_tok(3, TS_TOK_JSX_OPEN_START,  "3: <Bar");
assert_tok(4, TS_TOK_JSX_TAG_NAME,    "4: Bar");
assert_tok(5, TS_TOK_JSX_SELF_CLOSE,  "5: />");
assert_tok(6, TS_TOK_JSX_CLOSE_START, "6: </");
assert_tok(7, TS_TOK_JSX_TAG_NAME,    "7: Foo");
assert_tok(8, TS_TOK_JSX_CLOSE_END,   "8: >");

# ─── member tag name (Foo.Bar) ──────────────────────────────────
test_group("member tag name");
end = lex_jsx("<Foo.Bar />");
assert_eq(end, 11, "<Foo.Bar /> end pos");
assert_count(3, "<Foo.Bar /> tok count");
assert_tok(0, TS_TOK_JSX_OPEN_START, "0: <");
assert_tok(1, TS_TOK_JSX_TAG_NAME,   "1: Foo.Bar");
assert_tok(2, TS_TOK_JSX_SELF_CLOSE, "2: />");

# ─── JSX inside expr inside JSX ─────────────────────────────────
test_group("JSX inside expr inside JSX");
end = lex_jsx("<Foo>{c?<Bar />:null}</Foo>");
assert_eq(end, 27, "JSX-in-expr-in-JSX end pos");
# In P4.3b, BALANCE_BRACES byte-skips the {...} body (NOT recursing
# into TS_LEX_JSX for nested JSX). So inner <Bar /> emits no tokens.
# Total: 3 (outer open) + 1 (EXPR_OPEN) + 1 (EXPR_CLOSE) + 3 (outer close) = 8 toks.
# (Inner-expr tokenization deferred to v5.7.6 P4.3d.)
assert_count(8, "JSX-in-expr-in-JSX tok count");
assert_tok(0, TS_TOK_JSX_OPEN_START,  "outer open <");
assert_tok(1, TS_TOK_JSX_TAG_NAME,    "outer Foo");
assert_tok(2, TS_TOK_JSX_OPEN_END,    "outer open >");
assert_tok(3, TS_TOK_JSX_EXPR_OPEN,   "expr {");
assert_tok(4, TS_TOK_JSX_EXPR_CLOSE,  "expr }");
assert_tok(5, TS_TOK_JSX_CLOSE_START, "outer </");
assert_tok(6, TS_TOK_JSX_TAG_NAME,    "outer Foo (close)");
assert_tok(7, TS_TOK_JSX_CLOSE_END,   "outer >");

# ─── generic-arrow disambig ─────────────────────────────────────
test_group("generic-arrow disambig");
# <T>(x) => x — looks like JSX_OPEN_START + JSX_TAG_NAME + JSX_OPEN_END
# but `>` is followed by `(`, so heuristic bails.
end = lex_jsx("<T>(x) => x");
assert_eq(end, 0, "<T>(x) => bails (generic arrow)");
assert_count(0, "no tokens emitted on bail");

# ─── final pass ─────────────────────────────────────────────────
var exit_code = assert_summary();
syscall(60, exit_code);
