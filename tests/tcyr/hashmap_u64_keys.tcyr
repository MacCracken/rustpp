# Test: u64-keyed hashmap (v5.5.20) — the mabda cache hot-path variant.
# Acceptance: new/set/get/has/delete/size/clear all work; 1024-key
# stress insert-retrieve-delete-reinsert cycle retains all entries;
# zero heap allocations on the get/has/set-of-existing-key path.
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/assert.cyr"
include "lib/syscalls.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/fnptr.cyr"
include "lib/hashmap.cyr"

alloc_init();

test_group("map_u64_new / map_u64_size");
var m = map_u64_new();
assert_eq(map_u64_size(m), 0, "empty size");

test_group("map_u64_set / map_u64_get — basic");
map_u64_set(m, 100, 10);
map_u64_set(m, 200, 20);
map_u64_set(m, 300, 30);
assert_eq(map_u64_get(m, 100), 10, "get 100");
assert_eq(map_u64_get(m, 200), 20, "get 200");
assert_eq(map_u64_get(m, 300), 30, "get 300");
assert_eq(map_u64_size(m), 3, "size after 3 puts");

test_group("map_u64_set overwrite");
map_u64_set(m, 200, 99);
assert_eq(map_u64_get(m, 200), 99, "overwrite 200");
assert_eq(map_u64_size(m), 3, "size unchanged after overwrite");

test_group("map_u64_has");
assert_eq(map_u64_has(m, 100), 1, "has existing key");
assert_eq(map_u64_has(m, 99999), 0, "has missing key");

test_group("map_u64_get missing");
assert_eq(map_u64_get(m, 99999), 0, "get missing returns 0");
assert_eq(map_u64_get_or(m, 99999, 42), 42, "get_or default");
assert_eq(map_u64_get_or(m, 100, 42), 10, "get_or existing");

test_group("map_u64_delete");
var del = map_u64_delete(m, 300);
assert_eq(del, 1, "delete found");
assert_eq(map_u64_has(m, 300), 0, "deleted key gone");
assert_eq(map_u64_size(m), 2, "size after delete");
assert_eq(map_u64_delete(m, 300), 0, "delete already-deleted");
assert_eq(map_u64_delete(m, 99999), 0, "delete missing");

test_group("map_u64_delete + re-insert (tombstone reuse)");
map_u64_set(m, 300, 333);
assert_eq(map_u64_get(m, 300), 333, "re-insert after delete");
assert_eq(map_u64_size(m), 3, "size after re-insert");

test_group("map_u64_clear");
map_u64_clear(m);
assert_eq(map_u64_size(m), 0, "size after clear");
assert_eq(map_u64_has(m, 100), 0, "cleared entries gone");

test_group("large-value keys (high bits set, sentinel-adjacent)");
# 0 and u64::MAX are reserved sentinels; keys adjacent to them must work.
map_u64_set(m, 1, 111);
map_u64_set(m, 0xFFFFFFFFFFFFFFFE, 222);
map_u64_set(m, 0x8000000000000000, 333);
assert_eq(map_u64_get(m, 1), 111, "get key=1");
assert_eq(map_u64_get(m, 0xFFFFFFFFFFFFFFFE), 222, "get key=u64::MAX-1");
assert_eq(map_u64_get(m, 0x8000000000000000), 333, "get key=sign-bit");

test_group("grow — 1024 sequential keys");
map_u64_clear(m);
var i = 1;                         # skip 0 (reserved sentinel)
while (i <= 1024) {
    map_u64_set(m, i, i * 7);
    i = i + 1;
}
assert_eq(map_u64_size(m), 1024, "size after 1024 inserts");

test_group("retrieval after grow");
var j = 1;
var ok = 1;
while (j <= 1024) {
    if (map_u64_get(m, j) != j * 7) { ok = 0; }
    j = j + 1;
}
assert_eq(ok, 1, "all 1024 retrievable with correct values");

test_group("delete half, verify remainder");
var k = 1;
while (k <= 1024) {
    if (k % 2 == 0) { map_u64_delete(m, k); }
    k = k + 1;
}
assert_eq(map_u64_size(m), 512, "size after deleting even keys");
var kk = 1;
var missing_odd = 0;
var stray_even = 0;
while (kk <= 1024) {
    if (kk % 2 == 1) {
        if (map_u64_has(m, kk) == 0) { missing_odd = missing_odd + 1; }
    } else {
        if (map_u64_has(m, kk) == 1) { stray_even = stray_even + 1; }
    }
    kk = kk + 1;
}
assert_eq(missing_odd, 0, "no odd keys lost");
assert_eq(stray_even, 0, "no even keys leaked");

test_group("alloc stability — set on existing key allocates nothing");
var before = alloc_used();
map_u64_set(m, 1, 7);              # 1 was inserted above — overwrite, no grow
map_u64_get(m, 1);                 # pure read
map_u64_has(m, 1);                 # pure read
map_u64_has(m, 99999);             # pure read, missing
var after = alloc_used();
assert_eq(after, before, "no alloc on overwrite/get/has hot path");

var r = assert_summary();
