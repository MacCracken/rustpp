# Test: base64 encoding/decoding
include "lib/alloc.cyr"
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/base64.cyr"
include "lib/assert.cyr"

alloc_init();

test_group("base64_encode");
assert_eq(streq(base64_encode("", 0), ""), 1, "empty");
assert_eq(streq(base64_encode("f", 1), "Zg=="), 1, "f");
assert_eq(streq(base64_encode("fo", 2), "Zm8="), 1, "fo");
assert_eq(streq(base64_encode("foo", 3), "Zm9v"), 1, "foo");
assert_eq(streq(base64_encode("foobar", 6), "Zm9vYmFy"), 1, "foobar");
assert_eq(streq(base64_encode("hello world", 11), "aGVsbG8gd29ybGQ="), 1, "hello world");

test_group("base64_decode");
var d1 = base64_decode("Zm9v", 4);
assert_eq(load64(d1 + 8), 3, "dec len 3");
assert_eq(memeq(load64(d1), "foo", 3), 1, "dec foo");

var d2 = base64_decode("aGVsbG8gd29ybGQ=", 16);
assert_eq(load64(d2 + 8), 11, "dec len 11");
assert_eq(memeq(load64(d2), "hello world", 11), 1, "dec hello world");

test_group("roundtrip");
var msg = "The quick brown fox";
var enc = base64_encode(msg, 19);
var dec = base64_decode(enc, strlen(enc));
assert_eq(load64(dec + 8), 19, "roundtrip len");
assert_eq(memeq(load64(dec), msg, 19), 1, "roundtrip data");

test_group("base64url_encode");
# RFC 4648 §10 test vectors — URL alphabet matches standard for these
# (no bytes produce + or /). No padding.
assert_eq(streq(base64url_encode("", 0), ""), 1, "empty");
assert_eq(streq(base64url_encode("f", 1), "Zg"), 1, "f (no pad)");
assert_eq(streq(base64url_encode("fo", 2), "Zm8"), 1, "fo (no pad)");
assert_eq(streq(base64url_encode("foo", 3), "Zm9v"), 1, "foo");
assert_eq(streq(base64url_encode("foob", 4), "Zm9vYg"), 1, "foob");
assert_eq(streq(base64url_encode("fooba", 5), "Zm9vYmE"), 1, "fooba");
assert_eq(streq(base64url_encode("foobar", 6), "Zm9vYmFy"), 1, "foobar");
assert_eq(streq(base64url_encode("hello world", 11), "aGVsbG8gd29ybGQ"), 1, "hello world (no pad)");

test_group("base64url_decode");
var u1 = base64url_decode("Zm9v", 4);
assert_eq(load64(u1 + 8), 3, "dec foo len");
assert_eq(memeq(load64(u1), "foo", 3), 1, "dec foo");
# Padding tolerance
var u2 = base64url_decode("Zm9vYg", 6);
assert_eq(load64(u2 + 8), 4, "dec foob unpadded");
var u3 = base64url_decode("Zm9vYg==", 8);
assert_eq(load64(u3 + 8), 4, "dec foob padded");
# JWT header real-world example (RFC 7515 §3.5)
var jwt = base64url_decode("eyJ0eXAiOiJKV1QiLA0KICJhbGciOiJIUzI1NiJ9", 40);
assert_eq(load64(jwt + 8), 30, "JWT header decoded length");
# Invalid char rejected
assert_eq(base64url_decode("Zm9*Yg", 6), 0, "invalid char rejected");

test_group("base64url URL-safety");
# 0xFB 0xFF 0xBF — standard base64 would produce "+/+/", URL produces "-_-_"
var bin[3];
store8(&bin, 0xFB); store8(&bin + 1, 0xFF); store8(&bin + 2, 0xBF);
var enc_url = base64url_encode(&bin, 3);
assert_eq(streq(enc_url, "-_-_"), 1, "url alphabet (no + or /)");
# Standard encoder on same bytes produces the + / form
var enc_std = base64_encode(&bin, 3);
assert_eq(streq(enc_std, "+/+/"), 1, "std alphabet uses + and /");

test_group("base64url roundtrip");
var ur_msg = "The quick brown fox";
var ur_enc = base64url_encode(ur_msg, 19);
var ur_dec = base64url_decode(ur_enc, strlen(ur_enc));
assert_eq(load64(ur_dec + 8), 19, "roundtrip len");
assert_eq(memeq(load64(ur_dec), ur_msg, 19), 1, "roundtrip data");

var r = assert_summary();
