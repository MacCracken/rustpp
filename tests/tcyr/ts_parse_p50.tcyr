# v5.7.x P4.11 — element-level defaults in array binding patterns:
# `const [a, b = 1] = arr` and `const [a = 0, b = 1] = arr`. Pre-fix
# only object-pattern members handled defaults; array-pattern element
# loop didn't, so the `= expr` at element granularity tripped the
# parser at TS_TOK_EQ.
#
# Slot lifted +2 SY corpus .ts files.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/syscalls.cyr"
include "lib/assert.cyr"

include "src/frontend/ts/lex.cyr"
include "src/frontend/ts/parse.cyr"

alloc_init();
var ts_base = alloc(TS_HEAP_SIZE + 4096);

fn parse_first_stmt(src) {
    var nt = TS_LEX(ts_base, src, strlen(src));
    if (nt < 0) { return 0 - 1; }
    var nn = TS_PARSE(ts_base);
    if (nn < 0) { return 0 - 1; }
    var head = TS_AST_PAYLOAD(ts_base, 0, 0);
    return TS_AST_CHILDREN_GET(ts_base, head);
}

# ─── element-level defaults in array destructure ────────────────
test_group("element-level defaults in array destructure");

var s = parse_first_stmt("const [a, b = 1] = arr;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "[a, b = 1]");

s = parse_first_stmt("const [a = 0, b = 1] = arr;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "[a = 0, b = 1]");

s = parse_first_stmt("const [first, second = 'default', ...rest] = parts;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "[a, b = 'default', ...rest]");

# ─── nested patterns with defaults ───────────────────────────────
test_group("nested array destructure with defaults");

s = parse_first_stmt("const [{x}, [y, z = 0]] = arr;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "[{x}, [y, z = 0]]");

# ─── as a function param ─────────────────────────────────────────
test_group("array destructure as fn param");

s = parse_first_stmt("function f([a, b = 1] = []) { return; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "f([a, b = 1] = [])");

# ─── regression: holes still work ────────────────────────────────
test_group("regression: holes");

s = parse_first_stmt("const [, x] = arr;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "[, x]");

s = parse_first_stmt("const [a, , c] = arr;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "[a, , c]");

# ─── regression: object destructure defaults still work ────────
test_group("regression: object destructure");

s = parse_first_stmt("const {a, b = 1} = obj;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "{a, b = 1}");

var exit_code = assert_summary();
syscall(60, exit_code);
