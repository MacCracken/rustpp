# Test: vec module — dynamic array
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/assert.cyr"
include "lib/vec.cyr"

alloc_init();

test_group("vec_new + vec_len");
var v = vec_new();
assert_eq(vec_len(v), 0, "new vec is empty");
assert(vec_cap(v) >= 16, "initial capacity >= 16");

test_group("vec_push + vec_get");
vec_push(v, 100);
vec_push(v, 200);
vec_push(v, 300);
assert_eq(vec_len(v), 3, "len after 3 pushes");
assert_eq(vec_get(v, 0), 100, "get index 0");
assert_eq(vec_get(v, 1), 200, "get index 1");
assert_eq(vec_get(v, 2), 300, "get index 2");

test_group("vec_set");
vec_set(v, 1, 999);
assert_eq(vec_get(v, 1), 999, "set index 1 to 999");
assert_eq(vec_len(v), 3, "len unchanged after set");

test_group("vec_pop");
var popped = vec_pop(v);
assert_eq(popped, 300, "pop returns last element");
assert_eq(vec_len(v), 2, "len after pop");
var popped2 = vec_pop(v);
assert_eq(popped2, 999, "pop returns updated element");

test_group("vec_pop empty");
var ev = vec_new();
assert_eq(vec_pop(ev), 0, "pop empty returns 0");

test_group("vec_find");
var fv = vec_new();
vec_push(fv, 10);
vec_push(fv, 20);
vec_push(fv, 30);
assert_eq(vec_find(fv, 20), 1, "find existing element");
assert_eq(vec_find(fv, 99), 0 - 1, "find missing returns -1");

test_group("vec_remove");
var rv = vec_new();
vec_push(rv, 1);
vec_push(rv, 2);
vec_push(rv, 3);
vec_push(rv, 4);
vec_remove(rv, 1);
assert_eq(vec_len(rv), 3, "len after remove");
assert_eq(vec_get(rv, 0), 1, "remove shifts: idx 0");
assert_eq(vec_get(rv, 1), 3, "remove shifts: idx 1");
assert_eq(vec_get(rv, 2), 4, "remove shifts: idx 2");

test_group("vec_push grow");
var gv = vec_new();
for (var i = 0; i < 20; i = i + 1) {
    vec_push(gv, i * 10);
}
assert_eq(vec_len(gv), 20, "len after 20 pushes");
assert_eq(vec_get(gv, 0), 0, "grow: first element");
assert_eq(vec_get(gv, 19), 190, "grow: last element");

var r = assert_summary();
