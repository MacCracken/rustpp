# v5.7.x P4.10 — template literal types in type position (TS 4.1+).
# `type T = \`prefix:${string}\``, `type T = \`${A}-${B}\``,
# `type T = \`static\``. Lexed as TOK_TEMPLATE_NOSUB (no interps) or
# as TOK_TEMPLATE_HEAD + (TYPE TOK_TEMPLATE_MID)* + TYPE TOK_TEMPLATE_TAIL.
#
# Slot lifted +2 SY corpus .ts files.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/syscalls.cyr"
include "lib/assert.cyr"

include "src/frontend/ts/lex.cyr"
include "src/frontend/ts/parse.cyr"

alloc_init();
var ts_base = alloc(TS_HEAP_SIZE + 4096);

fn parse_first_stmt(src) {
    var nt = TS_LEX(ts_base, src, strlen(src));
    if (nt < 0) { return 0 - 1; }
    var nn = TS_PARSE(ts_base);
    if (nn < 0) { return 0 - 1; }
    var head = TS_AST_PAYLOAD(ts_base, 0, 0);
    return TS_AST_CHILDREN_GET(ts_base, head);
}

# ─── template literal types ──────────────────────────────────────
test_group("template literal types");

var s = parse_first_stmt("type T = `static`;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "type T = `static` (no interp)");

s = parse_first_stmt("type T = `prefix:${string}`;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "type T = `prefix:${string}`");

s = parse_first_stmt("type T = `${A}-${B}`;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "type T = `${A}-${B}` (multi-interp)");

s = parse_first_stmt("type ThemeId = 'dark' | 'light' | `custom:${string}`;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "ThemeId union with template literal type");

# ─── as a property type ──────────────────────────────────────────
test_group("template literal type as object-type property");

s = parse_first_stmt("let x: { id: `route-${string}` };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "{ id: `route-${string}` }");

# ─── regression: regular string literal types still work ────────
test_group("regression: string literal types");

s = parse_first_stmt("type T = 'foo';");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "type T = 'foo'");

s = parse_first_stmt("type T = 'a' | 'b' | 'c';");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "type T = 'a' | 'b' | 'c'");

# ─── regression: expr template literal still works ──────────────
test_group("regression: expr template literal");

s = parse_first_stmt("let s = `hello, ${name}!`;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "let s = `hello, ${name}!`");

var exit_code = assert_summary();
syscall(60, exit_code);
