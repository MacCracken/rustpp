# result_propagation.tcyr — v5.8.29 — postfix `?` propagation
# operator on `Result<T, E>` values.
#
# Locks the regression floor for:
#   (1) `var x = expr?` — when expr evaluates to `Ok(v)`, `x` binds
#       to the unwrapped payload `v` (load64(result_ptr + 8)).
#   (2) `var x = expr?` — when expr evaluates to `Err(e)`, the
#       enclosing fn returns `Err(e)` immediately (the early-return
#       short-circuit; rax holds the original Result heap pointer).
#   (3) Chained `?`: multiple `?`s in one fn body each behave as
#       above; first one to trip Err short-circuits the fn.
#   (4) `return expr?;` and `var y = a()? + b()?;` shapes.
#   (5) Fn whose body uses `?` and never trips Err returns the
#       computed Ok value via the normal return path.
#
# The `outside-fn-body` parse-time error is enforced (token 124
# `?` outside a fn body emits the
# "?: '?' propagation operator only valid inside a fn body" error
# and bails the compile). That negative case is verified via a
# standalone smoke probe (not testable from inside a compiled
# binary); v5.8.29 ship verified `/tmp/probe_q_outside.cyr`
# (a top-level `var x = Ok(1)?;`) emits the error and rc != 0.
#
# v5.8.29 enforces "outside any fn body" — the stricter "outside
# Result-returning fn is type error" requires fn return-type
# tracking that doesn't exist yet; pinned for a future slot per
# CLAUDE.md "honest scope-shrink" pattern. The desugar still
# generates correct code in non-Result-returning fns; it just
# won't error at compile time.

include "lib/syscalls.cyr"
include "lib/alloc.cyr"
include "lib/fmt.cyr"
include "lib/result.cyr"
include "lib/assert.cyr"

alloc_init();

# Helper: Ok if d != 0, Err(99) on div-by-zero
fn _safe_div(n, d) {
    if (d == 0) { return Err(99); }
    return Ok(n / d);
}

# Helper: chain two _safe_div calls via `?`. If either trips Err,
# the chain short-circuits with that Err; otherwise returns Ok(y).
fn _chain(a, b, c) {
    var x = _safe_div(a, b)?;
    var y = _safe_div(x, c)?;
    return Ok(y);
}

# Helper: `return expr?;` form — directly returns the unwrapped Ok.
# Wraps the unwrapped value back as Ok(v) so the return type stays
# Result-shaped for the caller's `?` chain.
fn _return_q(n, d) {
    return Ok(_safe_div(n, d)?);
}

# Helper: a()? + b()? — exercises ? in a binary-op context.
fn _sum_two(a, b, c, d) {
    var s = _safe_div(a, b)? + _safe_div(c, d)?;
    return Ok(s);
}

# Helper: ? at the very first statement of the fn (no prior frame
# alloc / regalloc state) — covers the edge where the early-return
# epilogue jump lands at a "first thing in fn body" code position.
fn _first_stmt_q(n, d) {
    var x = _safe_div(n, d)?;
    return Ok(x + 1);
}

# Helper: ? inside an `if` body — the early-return jump must still
# land at the fn epilogue, not at the `if` join point.
fn _q_in_if(n, d, gate) {
    if (gate == 1) {
        var x = _safe_div(n, d)?;
        return Ok(x);
    }
    return Ok(0);
}

test_group("Ok unwrap — single `?` in chain");
var r1 = _chain(100, 4, 5);     # 100/4 = 25; 25/5 = 5 → Ok(5)
assert_eq(is_ok(r1), 1, "_chain(100, 4, 5) is Ok");
assert_eq(load64(r1 + 8), 5, "_chain(100, 4, 5) payload = 5");

test_group("Err short-circuit — first `?` trips");
var r2 = _chain(100, 0, 5);     # 100/0 → Err(99); chain short-circuits
assert_eq(is_err_result(r2), 1, "_chain(100, 0, 5) is Err");
assert_eq(load64(r2 + 8), 99, "_chain(100, 0, 5) payload = 99 (from first ?)");

test_group("Err short-circuit — second `?` trips");
var r3 = _chain(100, 4, 0);     # 100/4 = 25; 25/0 → Err(99)
assert_eq(is_err_result(r3), 1, "_chain(100, 4, 0) is Err");
assert_eq(load64(r3 + 8), 99, "_chain(100, 4, 0) payload = 99 (from second ?)");

test_group("`return expr?;` shape — Ok case");
var r4 = _return_q(20, 4);
assert_eq(is_ok(r4), 1, "_return_q(20, 4) is Ok");
assert_eq(load64(r4 + 8), 5, "_return_q(20, 4) payload = 5");

test_group("`return expr?;` shape — Err case");
var r5 = _return_q(20, 0);
assert_eq(is_err_result(r5), 1, "_return_q(20, 0) is Err");
assert_eq(load64(r5 + 8), 99, "_return_q(20, 0) payload = 99");

test_group("`?` in binary-op context — both Ok");
var r6 = _sum_two(20, 4, 30, 6);   # 5 + 5 → Ok(10)
assert_eq(is_ok(r6), 1, "_sum_two(20,4,30,6) is Ok");
assert_eq(load64(r6 + 8), 10, "_sum_two(20,4,30,6) payload = 10");

test_group("`?` in binary-op context — first arg Err");
var r7 = _sum_two(20, 0, 30, 6);   # first ? trips
assert_eq(is_err_result(r7), 1, "_sum_two(20,0,30,6) is Err");
assert_eq(load64(r7 + 8), 99, "_sum_two(20,0,30,6) payload = 99");

test_group("`?` in binary-op context — second arg Err");
var r8 = _sum_two(20, 4, 30, 0);   # first ? unwraps, second ? trips
assert_eq(is_err_result(r8), 1, "_sum_two(20,4,30,0) is Err");
assert_eq(load64(r8 + 8), 99, "_sum_two(20,4,30,0) payload = 99");

test_group("`?` as first statement in fn body");
var r9 = _first_stmt_q(50, 5);   # Ok(10), +1 → Ok(11)
assert_eq(is_ok(r9), 1, "_first_stmt_q(50, 5) is Ok");
assert_eq(load64(r9 + 8), 11, "_first_stmt_q(50, 5) payload = 11");
var r10 = _first_stmt_q(50, 0);  # Err short-circuits
assert_eq(is_err_result(r10), 1, "_first_stmt_q(50, 0) is Err");
assert_eq(load64(r10 + 8), 99, "_first_stmt_q(50, 0) payload = 99");

test_group("`?` inside `if` body — Err exits whole fn, not just if-block");
var r11 = _q_in_if(20, 0, 1);   # gate=1, _safe_div(20,0)=Err → fn returns Err
assert_eq(is_err_result(r11), 1, "_q_in_if(20, 0, 1) is Err (whole fn)");
assert_eq(load64(r11 + 8), 99, "_q_in_if(20, 0, 1) payload = 99");
var r12 = _q_in_if(20, 4, 1);   # Ok path inside the if
assert_eq(is_ok(r12), 1, "_q_in_if(20, 4, 1) is Ok");
assert_eq(load64(r12 + 8), 5, "_q_in_if(20, 4, 1) payload = 5");
var r13 = _q_in_if(20, 0, 0);   # gate=0 → ? never executes → Ok(0)
assert_eq(is_ok(r13), 1, "_q_in_if(20, 0, 0) is Ok (gate skips ?)");
assert_eq(load64(r13 + 8), 0, "_q_in_if(20, 0, 0) payload = 0");

test_group("payload roundtrip through `?` — negatives + zero");
var rz = _safe_div(0, 1);
assert_eq(is_ok(rz), 1, "Ok(0/1) is Ok");
var rz_unwrapped = _first_stmt_q(0, 1);   # exercises ? on Ok(0)
assert_eq(load64(rz_unwrapped + 8), 1, "?-unwrapped 0 then +1 = 1");
var rn = _first_stmt_q(0 - 100, 5);       # ?-unwraps -20 then +1 = -19
assert_eq(load64(rn + 8), 0 - 19, "?-unwrapped -20 then +1 = -19");

var r = assert_summary();
