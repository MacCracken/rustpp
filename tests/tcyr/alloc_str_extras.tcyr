# alloc_str_extras.tcyr — Allocator `_a` variant coverage for the
# peripheral str helpers (str_sub / str_trim / str_split /
# str_builder_*) plus the u64-keyed map variant (map_u64_*). The
# map_u64 group is a small carve-out — it lives here because it landed
# in the same migration sweep as the str peripherals; it could fold
# into alloc_collections later if reorg is wanted. Originally landed at
# v5.8.43 as `alloc_stdlib_pass3.tcyr` (migration "pass 3"
# nomenclature); renamed to its topical name at v5.8.48.
#
# Closes the deferred-from-v5.8.35-and-v5.8.36 peripheral _a
# variants for str (str_sub_a, str_trim_a, str_split_a, _sb_grow_a,
# str_builder_new_a, str_builder_add_a, str_builder_add_cstr_a,
# str_builder_add_int_a, str_builder_build_a) and hashmap
# (_map_u64_grow_a, map_u64_new_a, map_u64_set_a). Unblocks the
# sandhi v1.1.0 dup-elimination work parked at sandhi-side (per
# sandhi v1.1.0 CHANGELOG: `_sandhi_client_host_header_a` /
# `_sandhi_wd_session_url_a` / `sandhi_json_build_a` use the
# global bump for builder scratch and dup the final cstr — those
# dups can drop in a follow-up sandhi release once these `_a`
# variants reach sandhi's pinned cyrius version).
#
# Coverage:
#   (1) str_sub_a / str_trim_a / str_split_a — bump_allocator path
#       (header allocs only — data is shared with parent Str).
#   (2) str_builder_*_a chain — full builder lifecycle through one
#       arena: new → add (Str + cstr + int) → build → reset.
#   (3) _sb_grow_a OOM — fail_after_n_allocs threshold tuned so
#       grow #1 trips OOM; str_builder_add_a returns -1.
#   (4) map_u64_new_a / map_u64_set_a — bump path + grow inside arena.
#   (5) map_u64_set_a OOM — fail_after_n_allocs at the grow-trigger
#       point (12th set on cap=16 with load 7/10).
#   (6) Back-compat wrappers unchanged — pre-v5.8.43 call sites
#       still work (str_sub / str_trim / str_split / str_builder_*
#       / map_u64_new / map_u64_set all delegate via default_alloc).

include "lib/syscalls.cyr"
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/str.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/assert.cyr"

alloc_init();

# ---- str_sub / str_trim / str_split _a variants ----

test_group("str_sub_a — bump_allocator");
var b = bump_allocator();
var s_full = str_from("hello world");
var s_sub = str_sub_a(b, s_full, 6, 5);
assert(s_sub != 0, "str_sub_a returned non-zero");
assert_eq(str_len(s_sub), 5, "sub len = 5");
assert_eq(load8(str_data(s_sub)), 119, "sub byte 0 = 'w' (119)");

test_group("str_trim_a — bump_allocator");
var s_pad = str_from("   hello   ");
var s_trim = str_trim_a(b, s_pad);
assert(s_trim != 0, "str_trim_a returned non-zero");
assert_eq(str_len(s_trim), 5, "trim len = 5");
assert_eq(load8(str_data(s_trim)), 104, "trim byte 0 = 'h' (104)");

test_group("str_split_a — arena_allocator (matches pre-v5.8.43 broken behavior)");
# Pre-existing bug: str_split's `sep` arg is treated as a byte
# value at the comparison site but the API takes a Str/cstr, so
# load8(sd+si) == sep never matches (sep is a pointer >255).
# Result: always 1 part = the whole input. v5.8.43 _a variant
# preserves this behavior end-to-end (a true fix is a separate
# slot — out of scope for this absorber). Verify allocator
# routing via the part vec landing in the arena.
var ar = arena_allocator(4096);
var s_csv = str_from("alpha,beta,gamma");
var parts = str_split_a(ar, s_csv, str_from(","));
assert(parts != 0, "str_split_a returned non-zero (vec allocated in arena)");
assert_eq(vec_len(parts), 1, "1 part (pre-existing str_split bug; sep ignored)");
# Verify the single part contains the whole input
assert_eq(str_len(vec_get(parts, 0)), str_len(s_csv),
    "single part = whole input");

# ---- str_builder_* chain through arena ----

test_group("str_builder_*_a — full lifecycle in arena");
var ar2 = arena_allocator(8192);
var sb = str_builder_new_a(ar2);
assert(sb != 0, "str_builder_new_a OK");
assert_eq(str_builder_add_cstr_a(ar2, sb, "Result: "), 0, "add_cstr Ok");
assert_eq(str_builder_add_int_a(ar2, sb, 42), 0, "add_int Ok");
assert_eq(str_builder_add_a(ar2, sb, str_from(" / total ")), 0, "add Str Ok");
assert_eq(str_builder_add_int_a(ar2, sb, 100), 0, "add_int again Ok");
var built = str_builder_build_a(ar2, sb);
assert(built != 0, "str_builder_build_a Ok");
assert_eq(str_len(built), 22, "built len = 22 ('Result: 42 / total 100')");
assert_eq(load8(str_data(built)), 82, "built byte 0 = 'R' (82)");

# After arena reset, all the builder + built memory is reclaimed
test_group("arena reset clears all str_builder allocations");
reset_via(ar2);
var sb2 = str_builder_new_a(ar2);
assert(sb2 != 0, "post-reset str_builder_new_a OK");

# ---- str_builder OOM via fail_after_n_allocs ----

# str_builder_new_a = 1 alloc (88 bytes). fail_after=1 lets new
# through; first add that needs grow trips OOM.
test_group("str_builder_add_a — OOM on grow returns -1");
var fa1 = fail_after_n_allocs(1);
var sb3 = str_builder_new_a(fa1);
assert(sb3 != 0, "new within budget");
# Initial cap is 64 bytes; add a 100-byte string → forces grow → OOM.
var rc = str_builder_add_cstr_a(fa1, sb3,
    "this is a hundred byte string used to force the builder to grow past its initial 64 cap.");
assert_eq(rc, 0 - 1, "add_cstr_a returns -1 on grow OOM");

# ---- map_u64 _a variants ----

test_group("map_u64_new_a / map_u64_set_a — bump_allocator");
var mu = map_u64_new_a(b);
assert(mu != 0, "map_u64_new_a OK");
assert_eq(map_u64_set_a(b, mu, 100, 200), 0, "set OK");
assert_eq(map_u64_set_a(b, mu, 300, 400), 0, "set OK");
assert_eq(map_u64_get(mu, 100), 200, "get(100) = 200");
assert_eq(map_u64_get(mu, 300), 400, "get(300) = 400");

test_group("map_u64_new_a + grow inside arena");
var ar3 = arena_allocator(16384);
var mu2 = map_u64_new_a(ar3);
# Start from key=1; key=0 is MAP_U64_EMPTY (sentinel), would
# fail to store as a real entry. Pre-existing map_u64 semantics
# — u64 keys can't be 0 or all-Fs.
var ki = 1;
while (ki <= 30) {
    map_u64_set_a(ar3, mu2, ki * 100, ki * 1000);
    ki = ki + 1;
}
assert_eq(map_u64_size(mu2), 30, "30 entries via _a path");
assert_eq(map_u64_get(mu2, 1500), 15000, "get(1500) = 15000");

# map_u64 OOM at grow trigger:
# map_u64_new_a = 2 allocs (header + 16-slot entries).
# fail_after=2 means grow #1 (12th set, when load 7/10 of cap 16
# trips) is the 3rd alloc → fails.
test_group("map_u64_set_a — OOM on grow returns -1");
var fb = fail_after_n_allocs(2);
var mu3 = map_u64_new_a(fb);
assert(mu3 != 0, "new within budget");
var rc_set = 0;
var ki2 = 0;
while (ki2 < 30) {
    rc_set = map_u64_set_a(fb, mu3, ki2, ki2 * 10);
    if (rc_set != 0) { ki2 = 30; }
    else { ki2 = ki2 + 1; }
}
assert_eq(rc_set, 0 - 1, "map_u64_set_a returns -1 once grow OOM hits");

# ---- back-compat wrappers ----

test_group("back-compat — str_sub / str_trim / str_split unchanged");
var s_back = str_from("  back-compat  ");
var s_back_trim = str_trim(s_back);
assert_eq(str_len(s_back_trim), 11, "back-compat str_trim len = 11");
var s_back_csv = str_split(str_from("a,b,c,d"), str_from(","));
# Pre-existing bug — back-compat preserves the same broken
# behavior as the _a variant. See CHANGELOG note.
assert_eq(vec_len(s_back_csv), 1, "back-compat str_split — 1 part (pre-existing bug)");

test_group("back-compat — str_builder unchanged");
var sb_back = str_builder_new();
str_builder_add_cstr(sb_back, "x");
str_builder_add_int(sb_back, 99);
var built_back = str_builder_build(sb_back);
assert_eq(str_len(built_back), 3, "back-compat builder built 'x99'");

test_group("back-compat — map_u64 unchanged");
var mu_back = map_u64_new();
map_u64_set(mu_back, 1, 10);
map_u64_set(mu_back, 2, 20);
assert_eq(map_u64_size(mu_back), 2, "back-compat map_u64 → 2 entries");

var r = assert_summary();
