# tests/tcyr/ts_parse_advanced.tcyr — TS parser advanced types + JSX.
#
# v5.7.37: groups the 9 advanced-feature tests — JSX (P4.3b),
# instantiation expressions (P4.6), generic fn types (P4.8),
# template literal types (P4.9), array destructure defaults
# (P5.0), SY corpus 100% polish bundle (P5.1), `asserts`
# predicate signatures (v5.7.24), mapped types (v5.7.25),
# decorators (v5.7.26). Includes lex.cyr + parse.cyr once;
# bodies share `ts_base`.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/syscalls.cyr"
include "lib/vec.cyr"
include "lib/fnptr.cyr"
include "lib/assert.cyr"
include "lib/test.cyr"   # v5.7.47: pulls assert.cyr + fnptr.cyr; provides test_each

include "src/frontend/ts/lex.cyr"
include "src/frontend/ts/parse.cyr"

alloc_init();
var ts_base = alloc(TS_HEAP_SIZE + 4096);

# ── helpers from ts_parse_p43 ──
fn _ts_parse_p43_parse_jsx(src) {
    var n = TS_LEX(ts_base, src, strlen(src));
    if (n < 0) { return 0 - 1; }
    return TS_PARSE(ts_base);
}
fn _ts_parse_p43_find_first_jsx(ts_base) {
    var i = 0;
    var count = load64(ts_base + TS_PARSE_STATE_OFF + TS_PS_NODE_COUNT);
    while (i < count) {
        var k = load64(ts_base + TS_AST_NODES_OFF + i * TS_AST_NODE_SIZE);
        if (k == TS_AST_JSX_ELEMENT) { return i; }
        if (k == TS_AST_JSX_FRAGMENT) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}
fn _ts_parse_p43_node_kind(ts_base, idx) {
    return load64(ts_base + TS_AST_NODES_OFF + idx * TS_AST_NODE_SIZE);
}
fn _ts_parse_p43_node_payload(ts_base, idx, slot) {
    return load64(ts_base + TS_AST_NODES_OFF + idx * TS_AST_NODE_SIZE + 16 + slot * 8);
}
fn _ts_parse_p43_count_children(ts_base, off) {
    # Convention (TS_PARSE_INIT): offset 0 means "no list" — children[0]
    # is reserved as a permanent sentinel so all real RESERVE() calls
    # return offset >= 1. Empty unset payload[X] == 0 → 0 children.
    if (off == 0) { return 0; }
    var i = 0;
    while (1 == 1) {
        var v = load64(ts_base + TS_AST_CHILDREN_OFF + (off + i) * 8);
        if (v == 0 - 1) { return i; }
        i = i + 1;
        if (i > 1000) { return 0 - 1; }
    }
    return i;
}
fn _ts_parse_p43_nth_child(ts_base, off, i) {
    return load64(ts_base + TS_AST_CHILDREN_OFF + (off + i) * 8);
}

# ── helpers from ts_parse_p46 ──
fn _ts_parse_p46_parse_first_stmt(src) {
    var nt = TS_LEX(ts_base, src, strlen(src));
    if (nt < 0) { return 0 - 1; }
    var nn = TS_PARSE(ts_base);
    if (nn < 0) { return 0 - 1; }
    var head = TS_AST_PAYLOAD(ts_base, 0, 0);
    return TS_AST_CHILDREN_GET(ts_base, head);
}

