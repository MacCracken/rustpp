# v5.7.2 P2.6 — TS parser module statements (import / export).
#
# Verifies the ES module surface that TypeScript carries:
#   import "side-effect";
#   import x from "m";
#   import * as ns from "m";
#   import { a, b as c } from "m";
#   import x, { a, b } from "m";
#   import x, * as ns from "m";
#   import type { T } from "m";
#   import { type T, runtime } from "m";
#
#   export const x = ...;
#   export function f() {} / export class C {} / etc.
#   export { a, b as c };
#   export { a } from "m";
#   export * from "m";
#   export * as ns from "m";
#   export default expr / function / class;
#   export type { T };

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/syscalls.cyr"
include "lib/assert.cyr"

include "src/frontend/ts/lex.cyr"
include "src/frontend/ts/parse.cyr"

alloc_init();
var ts_base = alloc(TS_HEAP_SIZE + 4096);

fn parse_first_stmt(src) {
    var nt = TS_LEX(ts_base, src, strlen(src));
    if (nt < 0) { return 0 - 1; }
    var nn = TS_PARSE(ts_base);
    if (nn < 0) { return 0 - 1; }
    var head = TS_AST_PAYLOAD(ts_base, 0, 0);
    return TS_AST_CHILDREN_GET(ts_base, head);
}

fn top_count() {
    return TS_AST_PAYLOAD(ts_base, 0, 1);
}

# ─── imports ─────────────────────────────────────────────────────
test_group("imports");

# Side-effect import
var s = parse_first_stmt("import \"./side-effect\";");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_IMPORT, "side-effect import -> IMPORT");
var specs = TS_AST_PAYLOAD(ts_base, s, 1);
assert_eq(specs, 0, "side-effect import has no specs");

# Default import
s = parse_first_stmt("import foo from \"./foo\";");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_IMPORT, "default import -> IMPORT");
specs = TS_AST_PAYLOAD(ts_base, s, 1);
assert(specs > 0, "default import has specs offset");
var first_spec = TS_AST_CHILDREN_GET(ts_base, specs);
assert_eq(TS_AST_KIND(ts_base, first_spec), TS_AST_IMPORT_DEFAULT, "spec[0] = IMPORT_DEFAULT");

# Namespace import
s = parse_first_stmt("import * as ns from \"./mod\";");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_IMPORT, "ns import");
specs = TS_AST_PAYLOAD(ts_base, s, 1);
first_spec = TS_AST_CHILDREN_GET(ts_base, specs);
assert_eq(TS_AST_KIND(ts_base, first_spec), TS_AST_IMPORT_NAMESPACE, "spec[0] = IMPORT_NAMESPACE");

# Named imports
s = parse_first_stmt("import { a, b, c } from \"./mod\";");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_IMPORT, "named import");
specs = TS_AST_PAYLOAD(ts_base, s, 1);
first_spec = TS_AST_CHILDREN_GET(ts_base, specs);
assert_eq(TS_AST_KIND(ts_base, first_spec), TS_AST_IMPORT_NAMED, "spec[0] = IMPORT_NAMED");

# Named with alias
s = parse_first_stmt("import { foo as bar } from \"./mod\";");
specs = TS_AST_PAYLOAD(ts_base, s, 1);
first_spec = TS_AST_CHILDREN_GET(ts_base, specs);
assert_eq(TS_AST_KIND(ts_base, first_spec), TS_AST_IMPORT_NAMED, "named-with-alias");
var alias_v = TS_AST_PAYLOAD(ts_base, first_spec, 1);
assert(alias_v > 0, "alias name span recorded");

# Default + named
s = parse_first_stmt("import def, { a, b } from \"./mod\";");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_IMPORT, "default + named");
assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on default+named");
specs = TS_AST_PAYLOAD(ts_base, s, 1);
first_spec = TS_AST_CHILDREN_GET(ts_base, specs);
assert_eq(TS_AST_KIND(ts_base, first_spec), TS_AST_IMPORT_DEFAULT, "first = DEFAULT");
var second_spec = TS_AST_CHILDREN_GET(ts_base, specs + 1);
assert_eq(TS_AST_KIND(ts_base, second_spec), TS_AST_IMPORT_NAMED, "second = NAMED");

# Default + namespace
s = parse_first_stmt("import def, * as ns from \"./mod\";");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_IMPORT, "default + namespace");
specs = TS_AST_PAYLOAD(ts_base, s, 1);
first_spec = TS_AST_CHILDREN_GET(ts_base, specs);
assert_eq(TS_AST_KIND(ts_base, first_spec), TS_AST_IMPORT_DEFAULT, "first = DEFAULT");
second_spec = TS_AST_CHILDREN_GET(ts_base, specs + 1);
assert_eq(TS_AST_KIND(ts_base, second_spec), TS_AST_IMPORT_NAMESPACE, "second = NAMESPACE");

# Type-only import
s = parse_first_stmt("import type { Config } from \"./types\";");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_IMPORT, "import type");
var to = TS_AST_PAYLOAD(ts_base, s, 2);
assert_eq(to, 1, "type-only flag set");

# Mixed type-only inside named list
s = parse_first_stmt("import { type T, runtime } from \"./mod\";");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_IMPORT, "mixed type-only spec");
assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err on mixed type-only");

# `import type from "x"` — `type` is the default name (NOT type-only)
s = parse_first_stmt("import type from \"./mod\";");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_IMPORT, "import type from -> default 'type'");
to = TS_AST_PAYLOAD(ts_base, s, 2);
assert_eq(to, 0, "this is NOT type-only");

# ─── exports ─────────────────────────────────────────────────────
test_group("exports");

# Decl export wraps a decl
s = parse_first_stmt("export const x = 1;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_EXPORT, "export const -> EXPORT");
var inner = TS_AST_PAYLOAD(ts_base, s, 0);
assert_eq(TS_AST_KIND(ts_base, inner), TS_AST_STMT_VAR_DECL, "wraps VAR_DECL");

s = parse_first_stmt("export function foo() {}");
inner = TS_AST_PAYLOAD(ts_base, s, 0);
assert_eq(TS_AST_KIND(ts_base, inner), TS_AST_DECL_FUNCTION, "wraps DECL_FUNCTION");

s = parse_first_stmt("export class C {}");
inner = TS_AST_PAYLOAD(ts_base, s, 0);
assert_eq(TS_AST_KIND(ts_base, inner), TS_AST_DECL_CLASS, "wraps DECL_CLASS");

s = parse_first_stmt("export interface I { x: number; }");
inner = TS_AST_PAYLOAD(ts_base, s, 0);
assert_eq(TS_AST_KIND(ts_base, inner), TS_AST_DECL_INTERFACE, "wraps DECL_INTERFACE");

s = parse_first_stmt("export type Pair = [number, string];");
inner = TS_AST_PAYLOAD(ts_base, s, 0);
assert_eq(TS_AST_KIND(ts_base, inner), TS_AST_DECL_TYPE_ALIAS, "wraps DECL_TYPE_ALIAS");

# `export abstract class`
s = parse_first_stmt("export abstract class Shape { abstract area(): number; }");
inner = TS_AST_PAYLOAD(ts_base, s, 0);
assert_eq(TS_AST_KIND(ts_base, inner), TS_AST_DECL_CLASS, "export abstract class wraps");

# Async export
s = parse_first_stmt("export async function fetchIt() { return 1; }");
inner = TS_AST_PAYLOAD(ts_base, s, 0);
assert_eq(TS_AST_KIND(ts_base, inner), TS_AST_DECL_FUNCTION, "export async function wraps");

# Named export (no decl)
s = parse_first_stmt("export { a, b as c };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_EXPORT, "export { ... } -> EXPORT");
var kind_v = TS_AST_PAYLOAD(ts_base, s, 3);
assert_eq(kind_v, 1, "kind = 1 (named export)");
var src_v = TS_AST_PAYLOAD(ts_base, s, 1);
assert_eq(src_v, 0, "no source span (not re-export)");

# Re-export named
s = parse_first_stmt("export { a, b as c } from \"./mod\";");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_EXPORT, "re-export -> EXPORT");
kind_v = TS_AST_PAYLOAD(ts_base, s, 3);
assert_eq(kind_v, 2, "kind = 2 (re-export)");
src_v = TS_AST_PAYLOAD(ts_base, s, 1);
assert(src_v > 0, "source span recorded");

# export * from
s = parse_first_stmt("export * from \"./mod\";");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_EXPORT_ALL, "export * from -> EXPORT_ALL");
src_v = TS_AST_PAYLOAD(ts_base, s, 0);
assert(src_v > 0, "EXPORT_ALL has source span");

# export * as ns from
s = parse_first_stmt("export * as utils from \"./util\";");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_EXPORT_ALL, "export * as ns -> EXPORT_ALL");
var ns_alias = TS_AST_PAYLOAD(ts_base, s, 1);
assert(ns_alias > 0, "namespace alias recorded");

# export default ...
s = parse_first_stmt("export default 42;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_EXPORT_DEFAULT, "export default literal");
inner = TS_AST_PAYLOAD(ts_base, s, 0);
assert_eq(TS_AST_KIND(ts_base, inner), TS_AST_EXPR_INT, "wraps EXPR_INT");

s = parse_first_stmt("export default function() { return 1; }");
inner = TS_AST_PAYLOAD(ts_base, s, 0);
assert_eq(TS_AST_KIND(ts_base, inner), TS_AST_DECL_FUNCTION, "default fn-expr");

s = parse_first_stmt("export default class { x = 1; }");
inner = TS_AST_PAYLOAD(ts_base, s, 0);
assert_eq(TS_AST_KIND(ts_base, inner), TS_AST_DECL_CLASS, "default class");

# Type-only export
s = parse_first_stmt("export type { T, U as V };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_EXPORT, "export type { ... }");
var to2 = TS_AST_PAYLOAD(ts_base, s, 2);
assert_eq(to2, 1, "type-only flag on named export");

# ─── multi-stmt module program ───────────────────────────────────
test_group("multi-stmt module");

s = parse_first_stmt("import { x } from \"./a\"; import * as b from \"./b\"; export const c = 1; export default function main() { return c; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_IMPORT, "first = import");
assert_eq(top_count(), 4, "four module-level stmts");
assert_eq(TS_PARSE_GETERR(ts_base), 0, "no err in module program");

# ─── error paths ─────────────────────────────────────────────────
test_group("module parse errors");

# `import x;` — missing `from "..."` clause
var src_bad = "import x;";
var nt = TS_LEX(ts_base, src_bad, strlen(src_bad));
assert(nt > 0, "lex `import x;` OK");
TS_PARSE_INIT(ts_base);
TS_AST_PUSH(ts_base, TS_AST_ROOT, 0);
TS_PARSE_CONSUME(ts_base);   # import
var bad = TS_PARSE_IMPORT(ts_base);
assert(bad < 0, "import without `from` rejected");

var exit_code = assert_summary();
syscall(60, exit_code);
