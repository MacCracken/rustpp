# v5.7.24 — `asserts` predicate signatures (TS 3.7+).
#
# Covers:
#   1. `asserts <ident> is <Type>`            — typed assertion predicate
#   2. `asserts <ident>`                       — bare assertion predicate
#   3. `asserts this is <Type>`                — class method `this` form
#   4. Polymorphic `this`-type in return position
#   5. `asserts` ident-eligibility (var, type-ref)
#   6. Regression: `<ident> is <Type>` still works (v5.7.x baseline)
#
# Parser-side: KW_ASSERTS contextual keyword + return-type prefix
# consumer in TS_PARSE_TYPE; KW_THIS branch in TS_PARSE_TYPE_PRIMARY
# emitting TYPE_REF.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/syscalls.cyr"
include "lib/assert.cyr"

include "src/frontend/ts/lex.cyr"
include "src/frontend/ts/parse.cyr"

alloc_init();
var ts_base = alloc(TS_HEAP_SIZE + 4096);

fn parse_first_stmt(src) {
    var nt = TS_LEX(ts_base, src, strlen(src));
    if (nt < 0) { return 0 - 1; }
    var nn = TS_PARSE(ts_base);
    if (nn < 0) { return 0 - 1; }
    var head = TS_AST_PAYLOAD(ts_base, 0, 0);
    return TS_AST_CHILDREN_GET(ts_base, head);
}

# ─── asserts <ident> is <Type> ──────────────────────────────────
test_group("asserts <ident> is <Type>");

var s = parse_first_stmt("function isString(x: any): asserts x is string {}");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "asserts x is string");

s = parse_first_stmt("function chk(x: unknown): asserts x is number | bigint {}");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "asserts x is union");

s = parse_first_stmt("function notNull<T>(x: T | null): asserts x is T {}");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "asserts x is generic param");

# ─── asserts <ident> (bare) ──────────────────────────────────────
test_group("asserts <ident> bare predicate");

s = parse_first_stmt("function ok(cond: boolean): asserts cond {}");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "asserts cond bare");

s = parse_first_stmt("function defined<T>(x: T | undefined): asserts x {}");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "asserts x bare with generic");

# ─── asserts this is <Type> ─────────────────────────────────────
test_group("asserts this method predicates");

s = parse_first_stmt("class C { check(): asserts this is C { return; } }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "method asserts this is C");

s = parse_first_stmt("class Loaded<T> { ensure(): asserts this is Loaded<T> { return; } }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "method asserts this is generic");

# ─── polymorphic this-type ──────────────────────────────────────
test_group("this-type in return position");

s = parse_first_stmt("interface Builder { build(): this; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_INTERFACE, "interface method returning this");

s = parse_first_stmt("class B { chain(): this { return this; } }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class method returning this");

s = parse_first_stmt("class P { is(): this is P { return; } }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class method `this is P` predicate");

# ─── asserts as ident name ──────────────────────────────────────
test_group("asserts ident-eligibility");

s = parse_first_stmt("var asserts = 1;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "var asserts = 1");

s = parse_first_stmt("let x: asserts;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "let x: asserts (type-ref)");

s = parse_first_stmt("type T = asserts;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "type T = asserts (type-ref)");

# ─── regressions ────────────────────────────────────────────────
test_group("regressions — pre-v5.7.24 forms still pass");

s = parse_first_stmt("function isStr(x: any): x is string {}");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "<id> is <T> predicate (existing)");

s = parse_first_stmt("function f(x: number): number { return x; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "regular return type");

var exit_code = assert_summary();
syscall(60, exit_code);
