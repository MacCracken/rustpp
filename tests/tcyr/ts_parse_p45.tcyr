# v5.7.x P4.6 — definite-assignment assertion `!:` in var/let/const
# declarators. v5.7.4 already had class-property `data!: T` and class-
# member `data!:` working (TS_PARSE_CLASS_MEMBER consumes BANG inline).
# This slot closes the var/let/const declarator gap by adding the
# optional BANG consumption in TS_PARSE_VAR_BINDING, between the
# binding pattern and the optional type annotation.
#
# Slot lifted +3 SY corpus files: 2 .ts + 1 .tsx through 99% threshold.
#
# Spec: TypeScript 2.7+ definite assignment assertions.
# https://devblogs.microsoft.com/typescript/announcing-typescript-2-7/

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/syscalls.cyr"
include "lib/assert.cyr"

include "src/frontend/ts/lex.cyr"
include "src/frontend/ts/parse.cyr"

alloc_init();
var ts_base = alloc(TS_HEAP_SIZE + 4096);

# Try to parse `src` as one top-level statement; return the first stmt
# index, or -1 on lex/parse failure. Mirrors ts_parse_p44.tcyr.
fn parse_first_stmt(src) {
    var nt = TS_LEX(ts_base, src, strlen(src));
    if (nt < 0) { return 0 - 1; }
    var nn = TS_PARSE(ts_base);
    if (nn < 0) { return 0 - 1; }
    var head = TS_AST_PAYLOAD(ts_base, 0, 0);
    return TS_AST_CHILDREN_GET(ts_base, head);
}

# ─── definite-assignment in let/const/var declarators ───────────
test_group("definite-assignment !: in let/const/var declarators");

var s = parse_first_stmt("let x!: number;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "let x!: number;");

s = parse_first_stmt("const y!: string = 'ok';");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "const y!: string = 'ok';");

s = parse_first_stmt("var z!: boolean;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "var z!: boolean;");

# Multiple declarators in one statement — `!` on each.
s = parse_first_stmt("let a!: number, b!: string;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "let a!: number, b!: string;");

# Mixed: with and without `!` in same declarator list.
s = parse_first_stmt("let a!: number, b: string = 'x';");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "let a!: number, b: string = 'x';");

# ─── regression: forms without `!` still parse ──────────────────
test_group("regression: plain declarators still parse");

s = parse_first_stmt("let a: number = 1;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "let a: number = 1;");

s = parse_first_stmt("const c = 'plain';");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "const c = 'plain';");

s = parse_first_stmt("var v;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "var v;");

# ─── pre-existing: class properties already accept !: ───────────
test_group("class property definite-assignment (pre-existing path)");

s = parse_first_stmt("class C { data!: string; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class C { data!: string; }");

s = parse_first_stmt("class D { name!: string; age!: number; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class D { name!: string; age!: number; }");

var exit_code = assert_summary();
syscall(60, exit_code);
