# v5.7.x P4.7 — `typeof X<TypeArgs>` in type position (TS 4.7+
# Instantiation Expressions). The existing TS_PARSE_TYPE_REF path
# already accepted the LT-clause for plain type refs (e.g.
# `Partial<T>`); the typeof branch in TS_PARSE_TYPE_PRIMARY did not.
# This slot extends the typeof branch to mirror the TYPE_REF logic
# after the dotted-name chain.
#
# Concrete shape from SY corpus (artifactory-client.test.ts):
#     let fetchSpy: ReturnType<typeof vi.spyOn<typeof globalThis, 'fetch'>>;
#
# Slot lifted +4 SY corpus files: 3 .ts + 1 .tsx through threshold.
#
# Spec: TypeScript 4.7 release notes — Instantiation Expressions.
# https://devblogs.microsoft.com/typescript/announcing-typescript-4-7/

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/syscalls.cyr"
include "lib/assert.cyr"

include "src/frontend/ts/lex.cyr"
include "src/frontend/ts/parse.cyr"

alloc_init();
var ts_base = alloc(TS_HEAP_SIZE + 4096);

# Try to parse `src` as one top-level statement; return first stmt idx
# or -1 on failure.
fn parse_first_stmt(src) {
    var nt = TS_LEX(ts_base, src, strlen(src));
    if (nt < 0) { return 0 - 1; }
    var nn = TS_PARSE(ts_base);
    if (nn < 0) { return 0 - 1; }
    var head = TS_AST_PAYLOAD(ts_base, 0, 0);
    return TS_AST_CHILDREN_GET(ts_base, head);
}

# ─── instantiation expressions in type position ──────────────────
test_group("typeof X<TypeArgs> in type position");

var s = parse_first_stmt("let f: typeof foo<string>;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "typeof foo<string>");

s = parse_first_stmt("let g: typeof foo<A, B>;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "typeof foo<A, B> (multi-arg)");

s = parse_first_stmt("let h: typeof y.foo<typeof z, 'lit'>;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "typeof y.foo<typeof z, 'lit'>");

# ─── nested in ReturnType (the SY repro) ─────────────────────────
test_group("nested in ReturnType");

s = parse_first_stmt("let r: ReturnType<typeof foo<A>>;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "ReturnType<typeof foo<A>>");

s = parse_first_stmt("let r: ReturnType<typeof vi.spyOn<typeof globalThis, 'fetch'>>;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "ReturnType<typeof vi.spyOn<typeof globalThis, 'fetch'>>");

# ─── regression: plain typeof type-query still works ─────────────
test_group("regression: plain typeof type-query");

s = parse_first_stmt("let a: typeof foo;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "typeof foo (no args)");

s = parse_first_stmt("let b: typeof y.foo;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "typeof y.foo (no args)");

s = parse_first_stmt("let c: typeof import('mod');");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "typeof import('mod')");

# ─── regression: plain type-ref with type args still works ───────
test_group("regression: type-ref type-args");

s = parse_first_stmt("let p: Partial<Config>;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "Partial<Config>");

s = parse_first_stmt("let q: Map<string, number>;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "Map<string, number>");

var exit_code = assert_summary();
syscall(60, exit_code);
