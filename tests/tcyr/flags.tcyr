# flags.tcyr — regression coverage for lib/flags.cyr (v5.5.33).
#
# `lib/args.cyr` pre-v5.5.33 only exposed argc/argv; every
# toolchain binary and consumer shipped ad-hoc `streq("--foo",
# argv(i))` loops (60+ hits across cyrius/ark/cyrld/cyrfmt/
# cyrlint/cyrdoc/cyrc + ecosystem repos). v5.5.33 ships
# `lib/flags.cyr` — getopt-long-shaped parser with bool/int/str
# flags, long + short forms, `--foo=val` and `--foo val` syntax,
# `--` terminator, positional capture, auto-help printer.
#
# Coverage:
#   1. bool long + short set correctly
#   2. int via `--name=value` syntax
#   3. int via `--name value` syntax (space)
#   4. str via `-x value` short form
#   5. defaults when flag absent
#   6. positional capture (accumulated in argv order)
#   7. `--` terminator routes remaining args to positional
#   8. unknown flag → error code, parse returns -1
#   9. missing value for int flag → error code, parse returns -1
#  10. bad int parse → error code (non-numeric)
#  11. bundled short rejected (`-abc` not supported)
#  12. multiple flags in one call

include "lib/assert.cyr"
include "lib/alloc.cyr"
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/syscalls.cyr"
include "lib/flags.cyr"

# Helper: construct a fresh argv of n cstrs from fixed slots.
# Each slot is a cstr the caller supplies; argv[0]..argv[n-1].
fn _argv(n, s0, s1, s2, s3, s4, s5, s6, s7) {
    var argv = alloc(n * 8);
    if (n > 0) { store64(argv + 0,  s0); }
    if (n > 1) { store64(argv + 8,  s1); }
    if (n > 2) { store64(argv + 16, s2); }
    if (n > 3) { store64(argv + 24, s3); }
    if (n > 4) { store64(argv + 32, s4); }
    if (n > 5) { store64(argv + 40, s5); }
    if (n > 6) { store64(argv + 48, s6); }
    if (n > 7) { store64(argv + 56, s7); }
    return argv;
}

fn test_bool_long_and_short() {
    test_group("bool flags — long and short forms");
    var fs = flags_new();
    var f_h = flags_add_bool(fs, 104, "help", 0, "show help");      # 'h'
    var f_v = flags_add_bool(fs, 118, "verbose", 0, "verbose");     # 'v'
    var argv = _argv(3, "prog", "--help", "-v", 0, 0, 0, 0, 0);
    assert_eq(flags_parse(fs, 3, argv), 0, "parse ok");
    assert_eq(flags_get_bool(fs, f_h), 1, "--help set");
    assert_eq(flags_get_bool(fs, f_v), 1, "-v set");
}

fn test_int_equals() {
    test_group("int flag — --name=value syntax");
    var fs = flags_new();
    var f_n = flags_add_int(fs, 110, "count", 0, "count");
    var argv = _argv(2, "prog", "--count=42", 0, 0, 0, 0, 0, 0);
    assert_eq(flags_parse(fs, 2, argv), 0, "parse ok");
    assert_eq(flags_get_int(fs, f_n), 42, "--count=42 → 42");
}

fn test_int_space() {
    test_group("int flag — --name value syntax (space)");
    var fs = flags_new();
    var f_n = flags_add_int(fs, 110, "count", 0, "count");
    var argv = _argv(3, "prog", "--count", "99", 0, 0, 0, 0, 0);
    assert_eq(flags_parse(fs, 3, argv), 0, "parse ok");
    assert_eq(flags_get_int(fs, f_n), 99, "--count 99 → 99");
}

fn test_str_short() {
    test_group("str flag — -x value short form");
    var fs = flags_new();
    var f_o = flags_add_str(fs, 111, "output", 0, "output file");   # 'o'
    var argv = _argv(3, "prog", "-o", "/tmp/out.s", 0, 0, 0, 0, 0);
    assert_eq(flags_parse(fs, 3, argv), 0, "parse ok");
    assert_eq(streq(flags_get_str(fs, f_o), "/tmp/out.s"), 1, "-o /tmp/out.s");
}

fn test_defaults() {
    test_group("defaults preserved when flag absent");
    var fs = flags_new();
    var f_b = flags_add_bool(fs, 0, "on", 0, "");
    var f_n = flags_add_int(fs, 0, "count", 7, "");
    var f_s = flags_add_str(fs, 0, "label", "tag", "");
    var argv = _argv(1, "prog", 0, 0, 0, 0, 0, 0, 0);
    assert_eq(flags_parse(fs, 1, argv), 0, "parse empty ok");
    assert_eq(flags_get_bool(fs, f_b), 0, "bool default 0");
    assert_eq(flags_get_int(fs, f_n), 7, "int default 7");
    assert_eq(streq(flags_get_str(fs, f_s), "tag"), 1, "str default 'tag'");
}

fn test_positional_and_terminator() {
    test_group("positional capture + -- terminator");
    var fs = flags_new();
    var f_v = flags_add_bool(fs, 118, "verbose", 0, "");
    # "-v file1 -- --weird file2" → -v set, positional = [file1, --weird, file2]
    var argv = _argv(6, "prog", "-v", "file1", "--", "--weird", "file2", 0, 0);
    assert_eq(flags_parse(fs, 6, argv), 0, "parse ok");
    assert_eq(flags_get_bool(fs, f_v), 1, "-v set");
    assert_eq(flags_positional_count(fs), 3, "3 positionals captured");
    assert_eq(streq(flags_positional(fs, 0), "file1"), 1, "[0] = file1");
    assert_eq(streq(flags_positional(fs, 1), "--weird"), 1, "[1] = --weird (post-term)");
    assert_eq(streq(flags_positional(fs, 2), "file2"), 1, "[2] = file2");
}

fn test_unknown_flag_errors() {
    test_group("unknown flag → FLAG_ERR_UNKNOWN");
    var fs = flags_new();
    flags_add_bool(fs, 0, "help", 0, "");
    var argv = _argv(2, "prog", "--nonexistent", 0, 0, 0, 0, 0, 0);
    assert_eq(flags_parse(fs, 2, argv), 0 - 1, "parse returns -1");
    assert_eq(flags_error(fs), FLAG_ERR_UNKNOWN, "error = UNKNOWN");
}

fn test_missing_value_errors() {
    test_group("missing value for int → FLAG_ERR_MISSING_VALUE");
    var fs = flags_new();
    flags_add_int(fs, 110, "count", 0, "");
    var argv = _argv(2, "prog", "--count", 0, 0, 0, 0, 0, 0);
    assert_eq(flags_parse(fs, 2, argv), 0 - 1, "parse returns -1");
    assert_eq(flags_error(fs), FLAG_ERR_MISSING_VALUE, "error = MISSING_VALUE");
}

fn test_bad_int_errors() {
    test_group("non-numeric int value → FLAG_ERR_BAD_INT");
    var fs = flags_new();
    flags_add_int(fs, 110, "count", 0, "");
    var argv = _argv(3, "prog", "--count", "abc", 0, 0, 0, 0, 0);
    assert_eq(flags_parse(fs, 3, argv), 0 - 1, "parse returns -1");
    assert_eq(flags_error(fs), FLAG_ERR_BAD_INT, "error = BAD_INT");
}

fn test_bundled_short_rejected() {
    test_group("-abc bundled → FLAG_ERR_BUNDLED");
    var fs = flags_new();
    flags_add_bool(fs, 97, "a", 0, "");
    flags_add_bool(fs, 98, "b", 0, "");
    flags_add_bool(fs, 99, "c", 0, "");
    var argv = _argv(2, "prog", "-abc", 0, 0, 0, 0, 0, 0);
    assert_eq(flags_parse(fs, 2, argv), 0 - 1, "parse returns -1");
    assert_eq(flags_error(fs), FLAG_ERR_BUNDLED, "error = BUNDLED");
}

fn test_mixed_combination() {
    test_group("realistic mixed flags + positionals");
    var fs = flags_new();
    var f_w = flags_add_bool(fs, 119, "write", 0, "write in place");
    var f_o = flags_add_str(fs, 111, "output", 0, "output file");
    var f_n = flags_add_int(fs, 110, "count", 1, "count");
    var argv = _argv(8, "fmt", "-w", "--output=out.s", "--count", "3",
                     "a.cyr", "b.cyr", "c.cyr");
    assert_eq(flags_parse(fs, 8, argv), 0, "parse ok");
    assert_eq(flags_get_bool(fs, f_w), 1, "-w set");
    assert_eq(streq(flags_get_str(fs, f_o), "out.s"), 1, "--output=out.s");
    assert_eq(flags_get_int(fs, f_n), 3, "--count 3");
    assert_eq(flags_positional_count(fs), 3, "3 positionals");
    assert_eq(streq(flags_positional(fs, 2), "c.cyr"), 1, "c.cyr landed");
}

fn main() {
    alloc_init();
    test_bool_long_and_short();
    test_int_equals();
    test_int_space();
    test_str_short();
    test_defaults();
    test_positional_and_terminator();
    test_unknown_flag_errors();
    test_missing_value_errors();
    test_bad_int_errors();
    test_bundled_short_rejected();
    test_mixed_combination();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
