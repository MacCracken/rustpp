# Test: fncall0..fncall8 correctness + register-order discrimination
#
# Originally landed at v5.4.13 as `fncall_repro.tcyr` — a cyrius-only
# repro that ruled out the mabda-reported `fncall6 + wgpu-native` crash
# as a cyrius bug. Extended with fncall7 / fncall8 coverage when those
# landed in `lib/fnptr.cyr` the same release (ceiling lift from 6 → 8).
#
# Each fncallN runs with distinct prime-like inputs so a mis-loaded
# register produces a uniquely identifiable wrong sum (vs a masked-by-
# symmetry wrong sum that uniform 1,2,3,… inputs would hide). A
# callee-with-local-stack variant catches red-zone / alignment bugs
# that only surface when the callee touches its own frame.

include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/fnptr.cyr"
include "lib/assert.cyr"

alloc_init();

fn nullary() { return 42; }
fn inc(x) { return x + 1; }
fn add2(a, b) { return a + b; }
fn add3(a, b, c) { return a + b + c; }
fn add4(a, b, c, d) { return a + b + c + d; }
fn add5(a, b, c, d, e) { return a + b + c + d + e; }
fn add6(a, b, c, d, e, f) { return a + b + c + d + e + f; }
fn add7(a, b, c, d, e, f, g) { return a + b + c + d + e + f + g; }
fn add8(a, b, c, d, e, f, g, h) { return a + b + c + d + e + f + g + h; }

test_group("fncall0..8 — arg-count coverage");
assert_eq(fncall0(&nullary),                                 42, "fncall0");
assert_eq(fncall1(&inc, 41),                                 42, "fncall1");
assert_eq(fncall2(&add2, 10, 20),                            30, "fncall2");
assert_eq(fncall3(&add3, 1, 2, 3),                            6, "fncall3");
assert_eq(fncall4(&add4, 1, 2, 3, 4),                        10, "fncall4");
assert_eq(fncall5(&add5, 1, 2, 3, 4, 5),                     15, "fncall5");
assert_eq(fncall6(&add6, 1, 2, 3, 4, 5, 6),                  21, "fncall6");
assert_eq(fncall7(&add7, 1, 2, 3, 4, 5, 6, 7),               28, "fncall7");
assert_eq(fncall8(&add8, 1, 2, 3, 4, 5, 6, 7, 8),            36, "fncall8");

# Distinct-value sums — a register-order bug here produces a wrong
# sum in a uniquely identifiable pattern:
#   fncall6 expected 146 = 5+13+21+29+37+41 (primes)
#   fncall7 expected 199 = 146 + 53
#   fncall8 expected 258 = 199 + 59
test_group("fncall6..8 — register-order discrimination");
assert_eq(fncall6(&add6, 5, 13, 21, 29, 37, 41),             146, "fncall6 ordered");
assert_eq(fncall7(&add7, 5, 13, 21, 29, 37, 41, 53),         199, "fncall7 ordered");
assert_eq(fncall8(&add8, 5, 13, 21, 29, 37, 41, 53, 59),     258, "fncall8 ordered");

# Callee-with-local-stack — catches red-zone / alignment regressions.
# Also exercises fncall8's x86_64 stack-arg path (two 8-byte slots at
# [rsp+0] / [rsp+8]) with a callee that does real stack work rather
# than a leaf function.
test_group("fncall7/8 — callee with stack");
fn add7_stack(a, b, c, d, e, f, g) {
    var scratch[7];
    store64(&scratch,      a); store64(&scratch + 8,  b);
    store64(&scratch + 16, c); store64(&scratch + 24, d);
    store64(&scratch + 32, e); store64(&scratch + 40, f);
    store64(&scratch + 48, g);
    var sum = load64(&scratch)      + load64(&scratch + 8)
            + load64(&scratch + 16) + load64(&scratch + 24)
            + load64(&scratch + 32) + load64(&scratch + 40)
            + load64(&scratch + 48);
    return sum;
}
fn add8_stack(a, b, c, d, e, f, g, h) {
    var scratch[8];
    store64(&scratch,      a); store64(&scratch + 8,  b);
    store64(&scratch + 16, c); store64(&scratch + 24, d);
    store64(&scratch + 32, e); store64(&scratch + 40, f);
    store64(&scratch + 48, g); store64(&scratch + 56, h);
    var sum = load64(&scratch)      + load64(&scratch + 8)
            + load64(&scratch + 16) + load64(&scratch + 24)
            + load64(&scratch + 32) + load64(&scratch + 40)
            + load64(&scratch + 48) + load64(&scratch + 56);
    return sum;
}
assert_eq(fncall7(&add7_stack, 5, 13, 21, 29, 37, 41, 53),   199, "fncall7 callee-with-stack");
assert_eq(fncall8(&add8_stack, 5, 13, 21, 29, 37, 41, 53, 59), 258, "fncall8 callee-with-stack");

var r = assert_summary();
