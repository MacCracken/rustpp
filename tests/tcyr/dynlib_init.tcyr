# Test: dynlib end-to-end libc — cpu_features + TLS + stack_end +
# IFUNC-aware symbol lookup (v5.3.11) let Cyrius static binaries
# drive libc string/memory/syscall functions through dlopen.
#
# The symbol lookup now detects STT_GNU_IFUNC entries and calls
# the resolver so `dynlib_sym("strlen")` returns a real strlen
# implementation rather than the resolver address.
#
# NSS-dispatching functions (getgrouplist, getaddrinfo) still hang
# inside nsswitch.conf parsing / NSS module dlopen — that surface
# needs locale + NSS table bootstrap tracked for a follow-up.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/assert.cyr"
include "lib/syscalls.cyr"
include "lib/mmap.cyr"
include "lib/fnptr.cyr"
include "lib/dynlib.cyr"

alloc_init();

test_group("bootstrap sequence");
var boot_rc = dynlib_bootstrap_cpu_features();
if (boot_rc != 0) {
    syscall(SYS_WRITE, 1, "  SKIP: ld-linux not available (non-glibc host)\n", 48);
    var _r = assert_summary();
    syscall(60, 0);
}
assert_eq(boot_rc, 0, "dynlib_bootstrap_cpu_features returns 0");
var tls = dynlib_bootstrap_tls();
assert(tls != 0, "dynlib_bootstrap_tls returns non-null TLS block");
var sr = dynlib_bootstrap_stack_end(0);
assert_eq(sr, 0, "dynlib_bootstrap_stack_end returns 0");

test_group("libc.so.6 load + IRELATIVE apply");
var hc = dynlib_open("libc.so.6");
if (hc == 0) {
    hc = dynlib_open("/lib/x86_64-linux-gnu/libc.so.6");
    if (hc == 0) { hc = dynlib_open("/lib64/libc.so.6"); }
    if (hc == 0) { hc = dynlib_open("/usr/lib/libc.so.6"); }
}
assert(hc != 0, "libc.so.6 opened");
var bias = load64(hc + 40);
_dynlib_apply_irelative(hc, bias, load64(hc + 88), load64(hc + 96));
_dynlib_apply_irelative(hc, bias, load64(hc + 104), load64(hc + 112));
assert(1, "IRELATIVE walked both tables without crash");

test_group("IFUNC-aware symbol lookup returns real implementations");
var fp_strlen = dynlib_sym(hc, "strlen");
assert(fp_strlen != 0, "strlen resolves");
assert_eq(fncall1(fp_strlen, "hello there"), 11, "strlen(\"hello there\") = 11");
assert_eq(fncall1(fp_strlen, ""), 0, "strlen(\"\") = 0");

var fp_strcmp = dynlib_sym(hc, "strcmp");
assert(fp_strcmp != 0, "strcmp resolves");
assert_eq(fncall2(fp_strcmp, "abc", "abc"), 0, "strcmp equal = 0");
assert(fncall2(fp_strcmp, "abc", "abd") != 0, "strcmp unequal != 0");

var fp_memcmp = dynlib_sym(hc, "memcmp");
assert(fp_memcmp != 0, "memcmp resolves");
assert_eq(fncall3(fp_memcmp, "abcdef", "abcdef", 6), 0, "memcmp equal = 0");

test_group("syscall wrapper libc calls");
var fp_getpid = dynlib_sym(hc, "getpid");
var pid = fncall0(fp_getpid);
assert(pid > 0, "getpid > 0");

var fp_getuid = dynlib_sym(hc, "getuid");
var uid = fncall0(fp_getuid);
assert(uid >= 0, "getuid >= 0");

test_group("dynlib_init safety gates");
assert_eq(dynlib_init(0), 1, "dynlib_init(null) returns 1");
# Can't exercise the full-success path against libc.so.6 — DT_INIT
# still SIGSEGVs until TLS bootstrap is complete (tracked). Return-2
# (no cpu_features bootstrap) and return-3 (oversized init_array_sz)
# paths require module state reset / a crafted handle, respectively —
# code paths are trivial but not covered here.

# v5.5.23 — dynlib_bootstrap_locale via newlocale + uselocale.
# Side-steps the setlocale(LC_ALL, non-null) SIGSEGV without
# needing glibc's global-locale rwlock bootstrap.
test_group("dynlib_bootstrap_locale");
assert_eq(dynlib_bootstrap_locale(0), 1, "dynlib_bootstrap_locale(null) returns 1");
# dynlib_init(hc) must run first so libc's DT_INIT_ARRAY has set
# up its internal __libc_rtld_global (etc.) before newlocale runs.
dynlib_init(hc);
var bl = dynlib_bootstrap_locale(hc);
assert_eq(bl, 0, "dynlib_bootstrap_locale(libc) returns 0");

# uselocale(0) returns current thread's locale_t — should be
# non-null after bootstrap (pre-v5.5.23 it was the global-locale
# sentinel; now it's the newlocale-created thread-local handle).
var fp_useloc = dynlib_sym(hc, "uselocale");
assert(fp_useloc != 0, "uselocale symbol resolves");
var tloc = fncall1(fp_useloc, 0);
assert(tloc != 0, "uselocale(0) returns non-null thread-local locale");

# NSS-dispatching fns (getpwuid, getgrouplist, pam_authenticate)
# still SIGSEGV — the NSS module-table state is not initialised by
# dynlib_bootstrap_locale. Tracked for the next patch.

var r = assert_summary();
syscall(60, 0);
