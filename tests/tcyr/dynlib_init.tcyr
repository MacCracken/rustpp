# Test: dynlib full init flow — cpu_features + TLS + stack_end bootstrap
# unlocks calling libc entry points from a Cyrius static binary.
#
# v5.3.9 landed the TLS and `__libc_stack_end` bootstrap helpers.
# Combined with `dynlib_bootstrap_cpu_features` (v5.3.8) and the
# IRELATIVE walker (v5.3.7), statically-linked Cyrius programs can
# now drive simple libc functions (`getpid`, `getuid`) through
# `dynlib_open` + `dynlib_sym` + `fncall*`.
#
# Still broken (beyond v5.3.9 scope):
#   - NSS-dispatching functions (getgrouplist, getpwent) hang inside
#     nsswitch.conf parsing / dlopen of NSS modules
#   - Full pthread state (locale, malloc arenas) isn't set up, so
#     anything that touches locale or large mallocs crashes
# These require more of `__libc_start_main`'s preamble to be
# emulated; tracked for a follow-up patch.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/assert.cyr"
include "lib/syscalls.cyr"
include "lib/mmap.cyr"
include "lib/fnptr.cyr"
include "lib/dynlib.cyr"

alloc_init();

test_group("bootstrap sequence");
var boot_rc = dynlib_bootstrap_cpu_features();
if (boot_rc != 0) {
    syscall(SYS_WRITE, 1, "  SKIP: ld-linux not available (non-glibc host)\n", 48);
    var _r = assert_summary();
    syscall(60, 0);
}
assert_eq(boot_rc, 0, "dynlib_bootstrap_cpu_features returns 0");

var tls = dynlib_bootstrap_tls();
assert(tls != 0, "dynlib_bootstrap_tls returns non-null TLS block");

var sr = dynlib_bootstrap_stack_end(0);
assert_eq(sr, 0, "dynlib_bootstrap_stack_end returns 0");

test_group("libc.so.6 load + IRELATIVE apply");
var hc = dynlib_open("libc.so.6");
if (hc == 0) {
    hc = dynlib_open("/lib/x86_64-linux-gnu/libc.so.6");
    if (hc == 0) { hc = dynlib_open("/lib64/libc.so.6"); }
    if (hc == 0) { hc = dynlib_open("/usr/lib/libc.so.6"); }
}
assert(hc != 0, "libc.so.6 opened");
var bias = load64(hc + 40);
_dynlib_apply_irelative(hc, bias, load64(hc + 88), load64(hc + 96));
_dynlib_apply_irelative(hc, bias, load64(hc + 104), load64(hc + 112));
assert(1, "IRELATIVE walked both tables without crash");

test_group("libc syscall wrapper dispatch works");
# These are simple syscall wrappers that return positive values.
# Before v5.3.9 they SIGSEGVed inside libc on uninitialised TLS/stack.
var fp_getpid = dynlib_sym(hc, "getpid");
assert(fp_getpid != 0, "getpid resolves");
var pid = fncall0(fp_getpid);
assert(pid > 0, "getpid returns positive PID");

var fp_getuid = dynlib_sym(hc, "getuid");
assert(fp_getuid != 0, "getuid resolves");
var uid = fncall0(fp_getuid);
assert(uid >= 0, "getuid returns non-negative UID");

var r = assert_summary();
syscall(60, 0);
