# Test: dynlib_init infrastructure — opt-in IRELATIVE + DT_INIT walking
# for loaded shared libraries.
#
# v5.3.7 landed the machinery but DOES NOT yet call the init path against
# libc.so.6 because IRELATIVE resolvers read `__cpu_features`, which is
# uninitialised in a static Cyrius binary and SIGSEGVs on touch. A follow-
# up patch will bootstrap that struct (SSE2 baseline on x86_64) and flip
# this test to drive `getgrouplist` end-to-end.
#
# Today's test exercises:
#   - dynlib_open still returns a usable handle (regression against
#     the extended 120-byte struct)
#   - dynlib_sym / fncall0 for libc entry points that don't need init
#     (getpid, trivial syscall wrapper)
#   - handle fields at +64..+112 are populated from the dynamic section

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/assert.cyr"
include "lib/syscalls.cyr"
include "lib/mmap.cyr"
include "lib/fnptr.cyr"
include "lib/dynlib.cyr"

alloc_init();

test_group("dynlib libc.so.6 open");
var hc = dynlib_open("libc.so.6");
if (hc == 0) {
    hc = dynlib_open("/lib/x86_64-linux-gnu/libc.so.6");
    if (hc == 0) { hc = dynlib_open("/lib64/libc.so.6"); }
    if (hc == 0) { hc = dynlib_open("/usr/lib/libc.so.6"); }
}
if (hc == 0) {
    syscall(SYS_WRITE, 1, "  SKIP: libc.so.6 not found (non-glibc host)\n", 45);
    var _r = assert_summary();
} else {
    assert(hc != 0, "libc.so.6 opened");

    test_group("handle carries init + reloc metadata");
    # Fields at offsets 64..112 must be populated from PT_DYNAMIC so
    # dynlib_init can find them without re-parsing.
    var init_array_vaddr = load64(hc + 72);
    assert(init_array_vaddr != 0, "DT_INIT_ARRAY vaddr captured");
    var init_array_sz = load64(hc + 80);
    assert(init_array_sz > 0, "DT_INIT_ARRAYSZ > 0");
    var rela_addr = load64(hc + 88);
    assert(rela_addr != 0, "rela_addr captured");
    var rela_size = load64(hc + 96);
    assert(rela_size > 0, "rela_size > 0");

    test_group("getpid via dynlib (no init required)");
    var fp_getpid = dynlib_sym(hc, "getpid");
    assert(fp_getpid != 0, "getpid resolves");
    var pid = fncall0(fp_getpid);
    assert(pid > 0, "getpid returns positive");

    test_group("getgrouplist resolves (call deferred)");
    # Resolution alone doesn't need init; calling does. Skip the call
    # until __cpu_features bootstrap lands.
    var fp_ggl = dynlib_sym(hc, "getgrouplist");
    assert(fp_ggl != 0, "getgrouplist resolves (not called yet)");

    var r = assert_summary();
}
syscall(60, 0);
