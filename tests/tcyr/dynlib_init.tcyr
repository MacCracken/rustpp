# Test: dynlib_init + dynlib_bootstrap_cpu_features — opt-in IRELATIVE
# machinery for shared libraries.
#
# v5.3.8 landed the __cpu_features bootstrap path: we load
# ld-linux-x86-64.so.2, invoke its `_dl_x86_get_cpu_features` getter,
# and zero-fill the struct so IFUNC resolvers pick the SSE2-baseline
# fallback. This unblocks Phase 3 IRELATIVE relocations but NOT the
# rest of glibc startup state (TLS, `__libc_stack_end`). Calling libc
# entry points post-bootstrap still crashes inside paths that touch
# TLS — that's the remaining piece before NSS/PAM works end-to-end.
#
# This test exercises:
#   - ld-linux loads + `_dl_x86_get_cpu_features` resolves
#   - dynlib_bootstrap_cpu_features returns 0
#   - IRELATIVE can be applied against libc.so.6 without SIGSEGV
#     (previously crashed on first resolver call)
#   - dynlib_open / dynlib_sym for libc still work
#   - handle carries init + reloc metadata

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/assert.cyr"
include "lib/syscalls.cyr"
include "lib/mmap.cyr"
include "lib/fnptr.cyr"
include "lib/dynlib.cyr"

alloc_init();

test_group("ld-linux + cpu_features bootstrap");
var boot_rc = dynlib_bootstrap_cpu_features();
if (boot_rc != 0) {
    syscall(SYS_WRITE, 1, "  SKIP: ld-linux not available (non-glibc host)\n", 48);
    var _r = assert_summary();
    syscall(60, 0);
}
assert_eq(boot_rc, 0, "dynlib_bootstrap_cpu_features returns 0");

test_group("dynlib libc.so.6 open");
var hc = dynlib_open("libc.so.6");
if (hc == 0) {
    hc = dynlib_open("/lib/x86_64-linux-gnu/libc.so.6");
    if (hc == 0) { hc = dynlib_open("/lib64/libc.so.6"); }
    if (hc == 0) { hc = dynlib_open("/usr/lib/libc.so.6"); }
}
assert(hc != 0, "libc.so.6 opened");

test_group("handle carries init + reloc metadata");
var init_array_vaddr = load64(hc + 72);
assert(init_array_vaddr != 0, "DT_INIT_ARRAY vaddr captured");
var init_array_sz = load64(hc + 80);
assert(init_array_sz > 0, "DT_INIT_ARRAYSZ > 0");
var rela_addr = load64(hc + 88);
assert(rela_addr != 0, "rela_addr captured");
var rela_size = load64(hc + 96);
assert(rela_size > 0, "rela_size > 0");

test_group("IRELATIVE applies without SIGSEGV (post-bootstrap)");
# This was the cliff in v5.3.7 — now unblocked by the cpu_features
# bootstrap. If the resolvers touch uninitialised state they'll crash
# the test process and CI reports FAIL.
var bias = load64(hc + 40);
_dynlib_apply_irelative(hc, bias, rela_addr, rela_size);
_dynlib_apply_irelative(hc, bias, load64(hc + 104), load64(hc + 112));
assert(1, "IRELATIVE walked both tables without crash");

test_group("getpid resolves (call deferred — needs TLS)");
# Even with IRELATIVE applied, calling into libc still trips on
# uninitialised TLS / __libc_stack_end. Resolution alone is safe.
var fp_getpid = dynlib_sym(hc, "getpid");
assert(fp_getpid != 0, "getpid resolves");

var r = assert_summary();
syscall(60, 0);
