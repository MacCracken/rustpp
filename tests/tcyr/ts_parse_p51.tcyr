# v5.7.x P4.12 — six remaining cyrius-ts polish features that took
# SY corpus parse acceptance to 100% (.ts 2053/2053, .tsx 435/435).
# Each was added in a separate edit but collapsed here into one
# acceptance test for compactness.
#
#   1. Labeled tuple elements: [name: T, name?: T, ...rest: T[]]
#   2. Labeled statements: outer: for (...) { break outer; }
#   3. Computed-key destructure: const { [k]: v } = obj
#   4. String-keyed destructure: const { 'lit': v } = obj
#   5. Numeric-keyed destructure: const { 0: first } = arr
#   6. Arrow-with-object-return-type: () : { x: T } => ({ x: 1 })

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/syscalls.cyr"
include "lib/assert.cyr"

include "src/frontend/ts/lex.cyr"
include "src/frontend/ts/parse.cyr"

alloc_init();
var ts_base = alloc(TS_HEAP_SIZE + 4096);

fn parse_first_stmt(src) {
    var nt = TS_LEX(ts_base, src, strlen(src));
    if (nt < 0) { return 0 - 1; }
    var nn = TS_PARSE(ts_base);
    if (nn < 0) { return 0 - 1; }
    var head = TS_AST_PAYLOAD(ts_base, 0, 0);
    return TS_AST_CHILDREN_GET(ts_base, head);
}

# ─── labeled tuple elements ──────────────────────────────────────
test_group("labeled tuple elements (TS 4.0+)");

var s = parse_first_stmt("let x: [prefix: string, resource: string] = ['a', 'b'];");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "[prefix: string, resource: string]");

s = parse_first_stmt("let x: readonly [prefix: string, resource: string][] = [];");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "readonly [a: T, b: U][]");

s = parse_first_stmt("let x: [a: string, b?: number, ...rest: boolean[]];");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "[a, b?, ...rest] labeled");

# ─── labeled statements ──────────────────────────────────────────
test_group("labeled statements");

s = parse_first_stmt("outer: for (let i = 0; i < 10; i = i + 1) { break outer; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_FOR, "outer: for(...) { break outer; }");

s = parse_first_stmt("label: while (true) { continue label; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_WHILE, "label: while { continue label; }");

# ─── computed-key destructure ────────────────────────────────────
test_group("computed-key destructure");

s = parse_first_stmt("const { [id]: target } = obj;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "{ [id]: target }");

s = parse_first_stmt("const { [id]: _, ...rest } = obj;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "{ [id]: _, ...rest }");

s = parse_first_stmt("const { x = 1, [k]: y = 2 } = obj;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "computed-key with default");

# ─── string/numeric-keyed destructure ───────────────────────────
test_group("string/numeric-keyed destructure");

s = parse_first_stmt("const { 'literal-key': val } = obj;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "{ 'literal-key': val }");

s = parse_first_stmt("const { 'a': x, 'b': y } = obj;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "two string-keys");

# ─── arrow with object return-type ──────────────────────────────
test_group("arrow with object-literal return type");

s = parse_first_stmt("const f = (): { tab: T; subTab: U } => ({ tab: 'a', subTab: 'b' });");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "(): { tab; subTab } => obj");

s = parse_first_stmt("const g = (a: number): { x: T } => ({ x: 1 });");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "(a): { x } => obj");

# ─── regression: plain forms still work ─────────────────────────
test_group("regressions");

s = parse_first_stmt("const f = () => { return 1; };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "plain arrow with body");

s = parse_first_stmt("const f = (x: number): number => x + 1;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "arrow with simple return type");

s = parse_first_stmt("let x: [string, number] = ['a', 1];");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "unlabeled tuple");

s = parse_first_stmt("const { a, b } = obj;");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_STMT_VAR_DECL, "plain destructure");

var exit_code = assert_summary();
syscall(60, exit_code);
