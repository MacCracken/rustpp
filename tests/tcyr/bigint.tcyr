# Test: bigint (256-bit unsigned arithmetic)
include "lib/alloc.cyr"
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/bigint.cyr"
include "lib/assert.cyr"

alloc_init();

test_group("u256 create");
var z = u256_zero();
assert_eq(u256_is_zero(z), 1, "zero is zero");
var one = u256_from(1);
assert_eq(u256_is_zero(one), 0, "one not zero");
assert_eq(u256_limb(one, 0), 1, "limb0 = 1");
assert_eq(u256_limb(one, 1), 0, "limb1 = 0");

test_group("u256 compare");
var a = u256_from(100);
var b = u256_from(200);
assert_eq(u256_cmp(a, b), 0 - 1, "100 < 200");
assert_eq(u256_cmp(b, a), 1, "200 > 100");
assert_eq(u256_cmp(a, a), 0, "self equal");
assert_eq(u256_eq(a, a), 1, "eq self");
assert_eq(u256_eq(a, b), 0, "neq diff");

test_group("u256 add");
var r = u256_zero();
u256_add(r, u256_from(100), u256_from(200));
assert_eq(u256_limb(r, 0), 300, "100+200=300");
# Add with high limb
var big = u256_zero();
u256_set_limb(big, 3, 1);
var big2 = u256_clone(big);
u256_add(r, big, big2);
assert_eq(u256_limb(r, 3), 2, "high limb add");

test_group("u256 sub");
u256_sub(r, u256_from(200), u256_from(100));
assert_eq(u256_limb(r, 0), 100, "200-100=100");

test_group("u256 mul");
u256_mul(r, u256_from(7), u256_from(6));
assert_eq(u256_limb(r, 0), 42, "7*6=42");
u256_mul(r, u256_from(1000000), u256_from(1000000));
assert_eq(u256_limb(r, 0), 1000000000000, "1M*1M");

test_group("u256 shift");
var v = u256_from(1);
u256_shl1(r, v);
assert_eq(u256_limb(r, 0), 2, "1<<1=2");
u256_shr1(r, u256_from(4));
assert_eq(u256_limb(r, 0), 2, "4>>1=2");

test_group("u256 mod");
u256_mod(r, u256_from(17), u256_from(5));
assert_eq(u256_limb(r, 0), 2, "17 mod 5 = 2");

test_group("u256 addmod");
u256_addmod(r, u256_from(4), u256_from(3), u256_from(5));
assert_eq(u256_limb(r, 0), 2, "(4+3) mod 5 = 2");

test_group("u256 hex");
var hex = u256_to_hex(u256_from(255));
assert_eq(streq(hex + 62, "ff"), 1, "255 = ff");
var parsed = u256_from_hex("ff");
assert_eq(u256_limb(parsed, 0), 255, "parse ff = 255");
var parsed2 = u256_from_hex("100");
assert_eq(u256_limb(parsed2, 0), 256, "parse 100 = 256");

var r2 = assert_summary();
