# tests/tcyr/ts_lex_combined.tcyr — TS lexer unit-test runner.
#
# v5.7.37: consolidates the 6 ts_lex_*.tcyr files into a single
# binary that includes `src/frontend/ts/lex.cyr` ONCE rather than
# 6 times. Each original test body is wrapped as
# `fn ts_lex_test_<name>()`; bodies run sequentially against a
# shared `ts_base` heap. `lib/assert.cyr`'s pass/fail accumulator
# provides per-assertion isolation; group-level isolation is
# preserved because each fn calls TS_LEX_INIT or
# TS_PARSE_INIT against the shared heap to reset state at entry.
#
# Why grouped instead of one megafile: a hard segfault in any
# single test still loses the rest of THIS binary, but the lex
# / parse-core / parse-decls / parse-advanced split keeps the
# blast radius per group rather than across all 24 originals.
# See `docs/development/roadmap.md §v5.7.37`.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/syscalls.cyr"
include "lib/assert.cyr"

include "src/frontend/ts/lex.cyr"

alloc_init();
var ts_base = alloc(TS_HEAP_SIZE + 4096);

# ── helpers from ts_lex_p12 ──
fn _ts_lex_p12_test_lex(src) {
    var src_len = strlen(src);
    return TS_LEX(ts_base, src, src_len);
}
fn _ts_lex_p12_assert_tok(idx, expected_typ, name) {
    var actual = TS_PEEKT(ts_base, idx);
    assert_eq(actual, expected_typ, name);
    return 0;
}

# ── helpers from ts_lex_p13 ──
fn _ts_lex_p13_test_lex(src) {
    return TS_LEX(ts_base, src, strlen(src));
}
fn _ts_lex_p13_assert_tok(idx, expected_typ, name) {
    assert_eq(TS_PEEKT(ts_base, idx), expected_typ, name);
    return 0;
}

# ── helpers from ts_lex_p14 ──
fn _ts_lex_p14_test_lex(src) {
    return TS_LEX(ts_base, src, strlen(src));
}
fn _ts_lex_p14_assert_tok(idx, expected_typ, name) {
    assert_eq(TS_PEEKT(ts_base, idx), expected_typ, name);
    return 0;
}

# ── helpers from ts_lex_p15 ──
fn _ts_lex_p15_test_lex(src) {
    return TS_LEX(ts_base, src, strlen(src));
}
fn _ts_lex_p15_assert_tok(idx, expected_typ, name) {
    assert_eq(TS_PEEKT(ts_base, idx), expected_typ, name);
    return 0;
}

# ── helpers from ts_lex_p16 ──
fn _ts_lex_p16_test_lex(src) {
    return TS_LEX(ts_base, src, strlen(src));
}
fn _ts_lex_p16_assert_tok(idx, expected_typ, name) {
    assert_eq(TS_PEEKT(ts_base, idx), expected_typ, name);
    return 0;
}

# ── helpers from ts_lex_p43 ──
fn _ts_lex_p43_lex_jsx(src) {
    var slen = strlen(src);
    var rc = TS_LEX(ts_base, src, slen);
    if (rc < 0) { return 0; }
    return slen;
}
fn _ts_lex_p43_assert_tok(idx, expected_typ, name) {
    assert_eq(TS_PEEKT(ts_base, idx), expected_typ, name);
    return 0;
}
fn _ts_lex_p43_assert_count(expected, name) {
    assert_eq(TS_GTCNT(ts_base), expected, name);
    return 0;
}

# ── ts_lex_p12 ───────────────────────────────────────────
fn ts_lex_test_ts_lex_p12() {
    
    
    
    # Allocate ts_base — TS_HEAP_SIZE bytes, plus a guard page so any
    # off-by-one access fails noisy. alloc returns zero-filled memory.
    
    
    
    # ─── identifiers + keywords ──────────────────────────────────────
    test_group("identifiers + keywords");
    
    var n = _ts_lex_p12_test_lex("var x = 42");
    assert_eq(n, 5, "var x = 42 → 4 toks + EOF");
    _ts_lex_p12_assert_tok(0, TS_TOK_KW_VAR, "tok[0] = var");
    _ts_lex_p12_assert_tok(1, TS_TOK_IDENT,  "tok[1] = ident x");
    _ts_lex_p12_assert_tok(2, TS_TOK_EQ,     "tok[2] = =");
    _ts_lex_p12_assert_tok(3, TS_TOK_INT,    "tok[3] = int 42");
    _ts_lex_p12_assert_tok(4, TS_TOK_EOF,    "tok[4] = EOF");
    
    n = _ts_lex_p12_test_lex("let y = true");
    assert_eq(n, 5, "let y = true");
    _ts_lex_p12_assert_tok(0, TS_TOK_KW_LET,  "tok[0] = let");
    _ts_lex_p12_assert_tok(2, TS_TOK_EQ,      "tok[2] = =");
    _ts_lex_p12_assert_tok(3, TS_TOK_KW_TRUE, "tok[3] = true");
    
    n = _ts_lex_p12_test_lex("class Foo extends Bar implements Baz");
    assert_eq(n, 7, "class Foo extends Bar implements Baz");
    _ts_lex_p12_assert_tok(0, TS_TOK_KW_CLASS,      "class");
    _ts_lex_p12_assert_tok(1, TS_TOK_IDENT,         "Foo");
    _ts_lex_p12_assert_tok(2, TS_TOK_KW_EXTENDS,    "extends");
    _ts_lex_p12_assert_tok(3, TS_TOK_IDENT,         "Bar");
    _ts_lex_p12_assert_tok(4, TS_TOK_KW_IMPLEMENTS, "implements");
    _ts_lex_p12_assert_tok(5, TS_TOK_IDENT,         "Baz");
    
    n = _ts_lex_p12_test_lex("interface Point readonly x");
    assert_eq(n, 5, "interface Point readonly x");
    _ts_lex_p12_assert_tok(0, TS_TOK_KW_INTERFACE, "interface");
    _ts_lex_p12_assert_tok(1, TS_TOK_IDENT,        "Point");
    _ts_lex_p12_assert_tok(2, TS_TOK_KW_READONLY,  "readonly");
    _ts_lex_p12_assert_tok(3, TS_TOK_IDENT,        "x");
    
    n = _ts_lex_p12_test_lex("public private protected static");
    assert_eq(n, 5, "public private protected static");
    _ts_lex_p12_assert_tok(0, TS_TOK_KW_PUBLIC,    "public");
    _ts_lex_p12_assert_tok(1, TS_TOK_KW_PRIVATE,   "private");
    _ts_lex_p12_assert_tok(2, TS_TOK_KW_PROTECTED, "protected");
    _ts_lex_p12_assert_tok(3, TS_TOK_KW_STATIC,    "static");
    
    n = _ts_lex_p12_test_lex("async await yield");
    assert_eq(n, 4, "async await yield");
    _ts_lex_p12_assert_tok(0, TS_TOK_KW_ASYNC, "async");
    _ts_lex_p12_assert_tok(1, TS_TOK_KW_AWAIT, "await");
    _ts_lex_p12_assert_tok(2, TS_TOK_KW_YIELD, "yield");
    
    n = _ts_lex_p12_test_lex("if else for while do return break continue");
    assert_eq(n, 9, "control-flow keywords");
    _ts_lex_p12_assert_tok(0, TS_TOK_KW_IF,       "if");
    _ts_lex_p12_assert_tok(1, TS_TOK_KW_ELSE,     "else");
    _ts_lex_p12_assert_tok(2, TS_TOK_KW_FOR,      "for");
    _ts_lex_p12_assert_tok(3, TS_TOK_KW_WHILE,    "while");
    _ts_lex_p12_assert_tok(4, TS_TOK_KW_DO,       "do");
    _ts_lex_p12_assert_tok(5, TS_TOK_KW_RETURN,   "return");
    _ts_lex_p12_assert_tok(6, TS_TOK_KW_BREAK,    "break");
    _ts_lex_p12_assert_tok(7, TS_TOK_KW_CONTINUE, "continue");
    
    # Keyword-shaped identifiers (e.g., "vardo" should be IDENT, not KW_VAR)
    n = _ts_lex_p12_test_lex("vardo classy interfacey");
    assert_eq(n, 4, "keyword-prefix idents");
    _ts_lex_p12_assert_tok(0, TS_TOK_IDENT, "vardo (not var)");
    _ts_lex_p12_assert_tok(1, TS_TOK_IDENT, "classy (not class)");
    _ts_lex_p12_assert_tok(2, TS_TOK_IDENT, "interfacey (not interface)");
    
    # Identifier with $ and _
    n = _ts_lex_p12_test_lex("$foo _bar __baz $_$");
    assert_eq(n, 5, "$/_ identifiers");
    _ts_lex_p12_assert_tok(0, TS_TOK_IDENT, "$foo");
    _ts_lex_p12_assert_tok(1, TS_TOK_IDENT, "_bar");
    _ts_lex_p12_assert_tok(2, TS_TOK_IDENT, "__baz");
    _ts_lex_p12_assert_tok(3, TS_TOK_IDENT, "$_$");
    
    # ─── integer literals ────────────────────────────────────────────
    test_group("integer literals");
    
    n = _ts_lex_p12_test_lex("0 1 42 12345");
    assert_eq(n, 5, "decimal literals");
    _ts_lex_p12_assert_tok(0, TS_TOK_INT, "0");
    _ts_lex_p12_assert_tok(1, TS_TOK_INT, "1");
    _ts_lex_p12_assert_tok(2, TS_TOK_INT, "42");
    _ts_lex_p12_assert_tok(3, TS_TOK_INT, "12345");
    
    n = _ts_lex_p12_test_lex("0x2A 0X7F 0xff 0xDEADBEEF");
    assert_eq(n, 5, "hex literals");
    _ts_lex_p12_assert_tok(0, TS_TOK_INT, "0x2A");
    _ts_lex_p12_assert_tok(1, TS_TOK_INT, "0X7F");
    _ts_lex_p12_assert_tok(2, TS_TOK_INT, "0xff");
    _ts_lex_p12_assert_tok(3, TS_TOK_INT, "0xDEADBEEF");
    
    n = _ts_lex_p12_test_lex("0b101010 0B11110000");
    assert_eq(n, 3, "binary literals");
    _ts_lex_p12_assert_tok(0, TS_TOK_INT, "0b101010");
    _ts_lex_p12_assert_tok(1, TS_TOK_INT, "0B11110000");
    
    n = _ts_lex_p12_test_lex("0o52 0O777");
    assert_eq(n, 3, "octal literals");
    _ts_lex_p12_assert_tok(0, TS_TOK_INT, "0o52");
    _ts_lex_p12_assert_tok(1, TS_TOK_INT, "0O777");
    
    n = _ts_lex_p12_test_lex("1_000_000 0xDEAD_BEEF 0b1010_1010");
    assert_eq(n, 4, "numeric separators");
    _ts_lex_p12_assert_tok(0, TS_TOK_INT, "1_000_000");
    _ts_lex_p12_assert_tok(1, TS_TOK_INT, "0xDEAD_BEEF");
    _ts_lex_p12_assert_tok(2, TS_TOK_INT, "0b1010_1010");
    
    # ─── string literals ─────────────────────────────────────────────
    test_group("string literals");
    
    n = _ts_lex_p12_test_lex("\"hello\" 'world'");
    assert_eq(n, 3, "double + single quote");
    _ts_lex_p12_assert_tok(0, TS_TOK_STRING, "\"hello\"");
    _ts_lex_p12_assert_tok(1, TS_TOK_STRING, "'world'");
    
    n = _ts_lex_p12_test_lex("\"with\\nescape\" \"with\\\\backslash\"");
    assert_eq(n, 3, "escape sequences");
    _ts_lex_p12_assert_tok(0, TS_TOK_STRING, "\"with\\nescape\"");
    _ts_lex_p12_assert_tok(1, TS_TOK_STRING, "\"with\\\\backslash\"");
    
    n = _ts_lex_p12_test_lex("\"\"");
    assert_eq(n, 2, "empty string");
    _ts_lex_p12_assert_tok(0, TS_TOK_STRING, "\"\"");
    
    # ─── single-char operators ───────────────────────────────────────
    test_group("single-char operators");
    
    n = _ts_lex_p12_test_lex("( ) { } [ ] ; , . : ?");
    assert_eq(n, 12, "structural punctuation");
    _ts_lex_p12_assert_tok(0,  TS_TOK_LPAREN,   "(");
    _ts_lex_p12_assert_tok(1,  TS_TOK_RPAREN,   ")");
    _ts_lex_p12_assert_tok(2,  TS_TOK_LBRACE,   "{");
    _ts_lex_p12_assert_tok(3,  TS_TOK_RBRACE,   "}");
    _ts_lex_p12_assert_tok(4,  TS_TOK_LBRACKET, "[");
    _ts_lex_p12_assert_tok(5,  TS_TOK_RBRACKET, "]");
    _ts_lex_p12_assert_tok(6,  TS_TOK_SEMI,     ";");
    _ts_lex_p12_assert_tok(7,  TS_TOK_COMMA,    ",");
    _ts_lex_p12_assert_tok(8,  TS_TOK_DOT,      ".");
    _ts_lex_p12_assert_tok(9,  TS_TOK_COLON,    ":");
    _ts_lex_p12_assert_tok(10, TS_TOK_QUESTION, "?");
    
    # P1.6a regex disambiguation note: `/` and `/=` are context-sensitive.
    # In expression context (start-of-input, after operators), `/` starts
    # a regex literal. So sequences of bare operators with `/` mid-stream
    # would lex differently. We test the non-/ ops in one batch and /
    # separately with an ident prefix to force primary context.
    n = _ts_lex_p12_test_lex("+ - * % = < > ! & | ^ ~");
    assert_eq(n, 13, "arithmetic + bitwise (no slash)");
    _ts_lex_p12_assert_tok(0,  TS_TOK_PLUS,    "+");
    _ts_lex_p12_assert_tok(1,  TS_TOK_MINUS,   "-");
    _ts_lex_p12_assert_tok(2,  TS_TOK_STAR,    "*");
    _ts_lex_p12_assert_tok(3,  TS_TOK_PERCENT, "%");
    _ts_lex_p12_assert_tok(4,  TS_TOK_EQ,      "=");
    _ts_lex_p12_assert_tok(5,  TS_TOK_LT,      "<");
    _ts_lex_p12_assert_tok(6,  TS_TOK_GT,      ">");
    _ts_lex_p12_assert_tok(7,  TS_TOK_BANG,    "!");
    _ts_lex_p12_assert_tok(8,  TS_TOK_AMP,     "&");
    _ts_lex_p12_assert_tok(9,  TS_TOK_PIPE,    "|");
    _ts_lex_p12_assert_tok(10, TS_TOK_CARET,   "^");
    _ts_lex_p12_assert_tok(11, TS_TOK_TILDE,   "~");
    
    # / in primary context (after ident) -> bare SLASH
    n = _ts_lex_p12_test_lex("a / b");
    assert_eq(n, 4, "a / b -> SLASH");
    _ts_lex_p12_assert_tok(1, TS_TOK_SLASH, "/ in primary context");
    
    n = _ts_lex_p12_test_lex("@ # ``");
    assert_eq(n, 4, "@/#/empty-template");
    _ts_lex_p12_assert_tok(0, TS_TOK_AT,       "@");
    _ts_lex_p12_assert_tok(1, TS_TOK_HASH,     "#");
    _ts_lex_p12_assert_tok(2, TS_TOK_TEMPLATE_NOSUB, "`` -> NOSUB (P1.4 backtick semantics)");
    
    # ─── line tracking ───────────────────────────────────────────────
    test_group("line tracking");
    
    n = _ts_lex_p12_test_lex("a\nb\nc");
    assert_eq(n, 4, "3 idents over 3 lines");
    assert_eq(TS_PEEKLINE(ts_base, 0), 1, "tok[0] line=1");
    assert_eq(TS_PEEKLINE(ts_base, 1), 2, "tok[1] line=2");
    assert_eq(TS_PEEKLINE(ts_base, 2), 3, "tok[2] line=3");
    
    # CRLF
    n = _ts_lex_p12_test_lex("a\r\nb\r\nc");
    assert_eq(n, 4, "CRLF over 3 lines");
    assert_eq(TS_PEEKLINE(ts_base, 0), 1, "CRLF tok[0] line=1");
    assert_eq(TS_PEEKLINE(ts_base, 1), 2, "CRLF tok[1] line=2");
    
    # ─── mixed real-shape input ──────────────────────────────────────
    test_group("mixed input");
    
    n = _ts_lex_p12_test_lex("function add(a, b) { return a + b; }");
    assert_eq(n, 15, "function decl (13 toks + ; + } + EOF)");
    _ts_lex_p12_assert_tok(0,  TS_TOK_KW_FUNCTION, "function");
    _ts_lex_p12_assert_tok(1,  TS_TOK_IDENT,       "add");
    _ts_lex_p12_assert_tok(2,  TS_TOK_LPAREN,      "(");
    _ts_lex_p12_assert_tok(3,  TS_TOK_IDENT,       "a");
    _ts_lex_p12_assert_tok(4,  TS_TOK_COMMA,       ",");
    _ts_lex_p12_assert_tok(5,  TS_TOK_IDENT,       "b");
    _ts_lex_p12_assert_tok(6,  TS_TOK_RPAREN,      ")");
    _ts_lex_p12_assert_tok(7,  TS_TOK_LBRACE,      "{");
    _ts_lex_p12_assert_tok(8,  TS_TOK_KW_RETURN,   "return");
    _ts_lex_p12_assert_tok(9,  TS_TOK_IDENT,       "a");
    _ts_lex_p12_assert_tok(10, TS_TOK_PLUS,        "+");
    _ts_lex_p12_assert_tok(11, TS_TOK_IDENT,       "b");
    
    # ─── error paths ─────────────────────────────────────────────────
    test_group("error paths");
    
    # Unterminated string returns -1
    n = _ts_lex_p12_test_lex("\"hello");
    assert_eq(n, 0 - 1, "unterminated string returns -1");
    assert_eq(TS_GETERR(ts_base), 5, "err code 5 = unterminated string");
    
    # Newline inside single-line string returns -1
    n = _ts_lex_p12_test_lex("\"hello\nworld\"");
    assert_eq(n, 0 - 1, "raw newline in string returns -1");
    assert_eq(TS_GETERR(ts_base), 4, "err code 4 = raw newline");
    
    return 0;
}

# ── ts_lex_p13 ───────────────────────────────────────────
fn ts_lex_test_ts_lex_p13() {
    
    
    
    
    
    # ─── 2-char equality + comparison ────────────────────────────────
    test_group("2-char equality/comparison");
    
    var n = _ts_lex_p13_test_lex("== != <= >=");
    assert_eq(n, 5, "== != <= >= (4 toks + EOF)");
    _ts_lex_p13_assert_tok(0, TS_TOK_EQ_EQ,    "==");
    _ts_lex_p13_assert_tok(1, TS_TOK_BANG_EQ,  "!=");
    _ts_lex_p13_assert_tok(2, TS_TOK_LT_EQ,    "<=");
    _ts_lex_p13_assert_tok(3, TS_TOK_GT_EQ,    ">=");
    _ts_lex_p13_assert_tok(4, TS_TOK_EOF,      "EOF");
    
    # ─── 3-char strict equality ──────────────────────────────────────
    test_group("3-char strict equality");
    
    n = _ts_lex_p13_test_lex("=== !==");
    assert_eq(n, 3, "=== !== (2 toks + EOF)");
    _ts_lex_p13_assert_tok(0, TS_TOK_EQ_EQ_EQ,   "===");
    _ts_lex_p13_assert_tok(1, TS_TOK_BANG_EQ_EQ, "!==");
    
    # Longest-match — === must not be == + =
    n = _ts_lex_p13_test_lex("===");
    assert_eq(n, 2, "=== alone is one token");
    _ts_lex_p13_assert_tok(0, TS_TOK_EQ_EQ_EQ, "=== as single tok");
    
    # Longest-match — !== must not be != + =
    n = _ts_lex_p13_test_lex("!==");
    assert_eq(n, 2, "!== alone is one token");
    _ts_lex_p13_assert_tok(0, TS_TOK_BANG_EQ_EQ, "!== as single tok");
    
    # == followed by ident (not =) should still parse correctly
    n = _ts_lex_p13_test_lex("a == b");
    assert_eq(n, 4, "a == b");
    _ts_lex_p13_assert_tok(0, TS_TOK_IDENT,  "a");
    _ts_lex_p13_assert_tok(1, TS_TOK_EQ_EQ,  "==");
    _ts_lex_p13_assert_tok(2, TS_TOK_IDENT,  "b");
    
    # = followed by something else stays single =
    n = _ts_lex_p13_test_lex("a = b");
    assert_eq(n, 4, "a = b");
    _ts_lex_p13_assert_tok(0, TS_TOK_IDENT, "a");
    _ts_lex_p13_assert_tok(1, TS_TOK_EQ,    "=");
    _ts_lex_p13_assert_tok(2, TS_TOK_IDENT, "b");
    
    # ─── shift operators ─────────────────────────────────────────────
    test_group("shift operators");
    
    n = _ts_lex_p13_test_lex("<< >>");
    assert_eq(n, 3, "<< >>");
    _ts_lex_p13_assert_tok(0, TS_TOK_LT_LT, "<<");
    _ts_lex_p13_assert_tok(1, TS_TOK_GT_GT, ">>");
    
    n = _ts_lex_p13_test_lex(">>> <<= >>=");
    assert_eq(n, 4, ">>> <<= >>=");
    _ts_lex_p13_assert_tok(0, TS_TOK_GT_GT_GT, ">>>");
    _ts_lex_p13_assert_tok(1, TS_TOK_LT_LT_EQ, "<<=");
    _ts_lex_p13_assert_tok(2, TS_TOK_GT_GT_EQ, ">>=");
    
    n = _ts_lex_p13_test_lex(">>>=");
    assert_eq(n, 2, ">>>=");
    _ts_lex_p13_assert_tok(0, TS_TOK_GT_GT_GT_EQ, ">>>= as single tok");
    
    # Longest-match: >>> must not be >> + >
    n = _ts_lex_p13_test_lex(">>>");
    assert_eq(n, 2, ">>> single tok");
    _ts_lex_p13_assert_tok(0, TS_TOK_GT_GT_GT, ">>>");
    
    # Longest-match: >>>= must not be >>> + = or >>= + =
    n = _ts_lex_p13_test_lex(">>>=");
    assert_eq(n, 2, ">>>= single tok");
    _ts_lex_p13_assert_tok(0, TS_TOK_GT_GT_GT_EQ, ">>>=");
    
    # Border case: >> followed by space then = should be >> then =
    n = _ts_lex_p13_test_lex(">> =");
    assert_eq(n, 3, ">> =");
    _ts_lex_p13_assert_tok(0, TS_TOK_GT_GT, ">>");
    _ts_lex_p13_assert_tok(1, TS_TOK_EQ,    "=");
    
    # ─── logical and nullish ─────────────────────────────────────────
    test_group("logical/nullish");
    
    n = _ts_lex_p13_test_lex("&& || ??");
    assert_eq(n, 4, "&& || ??");
    _ts_lex_p13_assert_tok(0, TS_TOK_AMP_AMP,   "&&");
    _ts_lex_p13_assert_tok(1, TS_TOK_PIPE_PIPE, "||");
    _ts_lex_p13_assert_tok(2, TS_TOK_QQ,        "??");
    
    n = _ts_lex_p13_test_lex("&&= ||= ??=");
    assert_eq(n, 4, "&&= ||= ??=");
    _ts_lex_p13_assert_tok(0, TS_TOK_AMP_AMP_EQ,   "&&=");
    _ts_lex_p13_assert_tok(1, TS_TOK_PIPE_PIPE_EQ, "||=");
    _ts_lex_p13_assert_tok(2, TS_TOK_QQ_EQ,        "??=");
    
    # Longest-match: &&= must not be && + =
    n = _ts_lex_p13_test_lex("&&=");
    _ts_lex_p13_assert_tok(0, TS_TOK_AMP_AMP_EQ, "&&= single tok");
    
    n = _ts_lex_p13_test_lex("||=");
    _ts_lex_p13_assert_tok(0, TS_TOK_PIPE_PIPE_EQ, "||= single tok");
    
    n = _ts_lex_p13_test_lex("??=");
    _ts_lex_p13_assert_tok(0, TS_TOK_QQ_EQ, "??= single tok");
    
    # ─── optional chaining ───────────────────────────────────────────
    test_group("optional chaining");
    
    n = _ts_lex_p13_test_lex("a?.b");
    assert_eq(n, 4, "a?.b");
    _ts_lex_p13_assert_tok(0, TS_TOK_IDENT, "a");
    _ts_lex_p13_assert_tok(1, TS_TOK_Q_DOT, "?.");
    _ts_lex_p13_assert_tok(2, TS_TOK_IDENT, "b");
    
    # ? alone (ternary) should stay TS_TOK_QUESTION
    n = _ts_lex_p13_test_lex("a ? b : c");
    assert_eq(n, 6, "a ? b : c");
    _ts_lex_p13_assert_tok(0, TS_TOK_IDENT,    "a");
    _ts_lex_p13_assert_tok(1, TS_TOK_QUESTION, "?");
    _ts_lex_p13_assert_tok(2, TS_TOK_IDENT,    "b");
    _ts_lex_p13_assert_tok(3, TS_TOK_COLON,    ":");
    _ts_lex_p13_assert_tok(4, TS_TOK_IDENT,    "c");
    
    # ─── arrow + spread + power ──────────────────────────────────────
    test_group("arrow/spread/power");
    
    n = _ts_lex_p13_test_lex("=> ... **");
    assert_eq(n, 4, "=> ... **");
    _ts_lex_p13_assert_tok(0, TS_TOK_ARROW,     "=>");
    _ts_lex_p13_assert_tok(1, TS_TOK_ELLIPSIS,  "...");
    _ts_lex_p13_assert_tok(2, TS_TOK_STAR_STAR, "**");
    
    n = _ts_lex_p13_test_lex("**=");
    assert_eq(n, 2, "**=");
    _ts_lex_p13_assert_tok(0, TS_TOK_STAR_STAR_EQ, "**=");
    
    # Longest-match: ** must not be * + *
    n = _ts_lex_p13_test_lex("**");
    _ts_lex_p13_assert_tok(0, TS_TOK_STAR_STAR, "** single tok");
    
    # Longest-match: =>  must not be = + >
    n = _ts_lex_p13_test_lex("=>");
    assert_eq(n, 2, "=>");
    _ts_lex_p13_assert_tok(0, TS_TOK_ARROW, "=> single tok");
    
    # ─── increment / decrement ───────────────────────────────────────
    test_group("inc/dec");
    
    n = _ts_lex_p13_test_lex("++ --");
    assert_eq(n, 3, "++ --");
    _ts_lex_p13_assert_tok(0, TS_TOK_PLUS_PLUS,   "++");
    _ts_lex_p13_assert_tok(1, TS_TOK_MINUS_MINUS, "--");
    
    # Longest-match: ++ not + +
    n = _ts_lex_p13_test_lex("++");
    _ts_lex_p13_assert_tok(0, TS_TOK_PLUS_PLUS, "++ single tok");
    
    # Border: + + (with space) IS two pluses
    n = _ts_lex_p13_test_lex("+ +");
    assert_eq(n, 3, "+ +");
    _ts_lex_p13_assert_tok(0, TS_TOK_PLUS, "+ first");
    _ts_lex_p13_assert_tok(1, TS_TOK_PLUS, "+ second");
    
    # ─── compound assignment ─────────────────────────────────────────
    test_group("compound assignment");
    
    # P1.6a regex disambiguation: `/=` is a compound-assign only in
    # primary context. After `*=` (operator) we'd be in expr context and
    # `/...` would be lexed as regex. Test the non-/ ops in one batch
    # and /= separately with an ident prefix.
    n = _ts_lex_p13_test_lex("+= -= *= %=");
    assert_eq(n, 5, "4 arithmetic compound assignments (no /=)");
    _ts_lex_p13_assert_tok(0, TS_TOK_PLUS_EQ,    "+=");
    _ts_lex_p13_assert_tok(1, TS_TOK_MINUS_EQ,   "-=");
    _ts_lex_p13_assert_tok(2, TS_TOK_STAR_EQ,    "*=");
    _ts_lex_p13_assert_tok(3, TS_TOK_PERCENT_EQ, "%=");
    
    # /= in primary context (after ident) -> SLASH_EQ
    n = _ts_lex_p13_test_lex("a /= 2");
    assert_eq(n, 4, "/= in primary context");
    _ts_lex_p13_assert_tok(1, TS_TOK_SLASH_EQ, "/= after ident");
    
    n = _ts_lex_p13_test_lex("&= |= ^=");
    assert_eq(n, 4, "3 bitwise compound assignments");
    _ts_lex_p13_assert_tok(0, TS_TOK_AMP_EQ,   "&=");
    _ts_lex_p13_assert_tok(1, TS_TOK_PIPE_EQ,  "|=");
    _ts_lex_p13_assert_tok(2, TS_TOK_CARET_EQ, "^=");
    
    # ─── ellipsis (…) — exactly three dots, two-dot is error ──────────
    test_group("ellipsis edge cases");
    
    n = _ts_lex_p13_test_lex("...");
    _ts_lex_p13_assert_tok(0, TS_TOK_ELLIPSIS, "... single tok");
    
    # .. should error (TS has no .. operator)
    n = _ts_lex_p13_test_lex("..");
    assert_eq(n, 0 - 1, ".. errors");
    assert_eq(TS_GETERR(ts_base), 6, "err code 6 = bad ..");
    
    # Single . is fine (member access)
    n = _ts_lex_p13_test_lex("a.b");
    assert_eq(n, 4, "a.b");
    _ts_lex_p13_assert_tok(0, TS_TOK_IDENT, "a");
    _ts_lex_p13_assert_tok(1, TS_TOK_DOT,   ".");
    _ts_lex_p13_assert_tok(2, TS_TOK_IDENT, "b");
    
    # ─── realistic mixed expressions ─────────────────────────────────
    test_group("realistic expressions");
    
    # foo === bar && baz >= 0
    n = _ts_lex_p13_test_lex("foo === bar && baz >= 0");
    assert_eq(n, 8, "foo === bar && baz >= 0");
    _ts_lex_p13_assert_tok(0, TS_TOK_IDENT,      "foo");
    _ts_lex_p13_assert_tok(1, TS_TOK_EQ_EQ_EQ,   "===");
    _ts_lex_p13_assert_tok(2, TS_TOK_IDENT,      "bar");
    _ts_lex_p13_assert_tok(3, TS_TOK_AMP_AMP,    "&&");
    _ts_lex_p13_assert_tok(4, TS_TOK_IDENT,      "baz");
    _ts_lex_p13_assert_tok(5, TS_TOK_GT_EQ,      ">=");
    _ts_lex_p13_assert_tok(6, TS_TOK_INT,        "0");
    
    # x?.y ?? z
    n = _ts_lex_p13_test_lex("x?.y ?? z");
    assert_eq(n, 6, "x?.y ?? z");
    _ts_lex_p13_assert_tok(0, TS_TOK_IDENT, "x");
    _ts_lex_p13_assert_tok(1, TS_TOK_Q_DOT, "?.");
    _ts_lex_p13_assert_tok(2, TS_TOK_IDENT, "y");
    _ts_lex_p13_assert_tok(3, TS_TOK_QQ,    "??");
    _ts_lex_p13_assert_tok(4, TS_TOK_IDENT, "z");
    
    # arrow function with rest param + spread
    n = _ts_lex_p13_test_lex("(...args) => fn(...args)");
    assert_eq(n, 11, "(...args) => fn(...args) (10 toks + EOF)");
    _ts_lex_p13_assert_tok(0,  TS_TOK_LPAREN,   "(");
    _ts_lex_p13_assert_tok(1,  TS_TOK_ELLIPSIS, "...");
    _ts_lex_p13_assert_tok(2,  TS_TOK_IDENT,    "args");
    _ts_lex_p13_assert_tok(3,  TS_TOK_RPAREN,   ")");
    _ts_lex_p13_assert_tok(4,  TS_TOK_ARROW,    "=>");
    _ts_lex_p13_assert_tok(5,  TS_TOK_IDENT,    "fn");
    _ts_lex_p13_assert_tok(6,  TS_TOK_LPAREN,   "(");
    _ts_lex_p13_assert_tok(7,  TS_TOK_ELLIPSIS, "...");
    _ts_lex_p13_assert_tok(8,  TS_TOK_IDENT,    "args");
    _ts_lex_p13_assert_tok(9,  TS_TOK_RPAREN,   ")");
    
    # i++ in a for loop
    n = _ts_lex_p13_test_lex("for (var i = 0; i < n; i++)");
    assert_eq(n, 15, "for (var i = 0; i < n; i++) (14 toks + EOF)");
    _ts_lex_p13_assert_tok(0,  TS_TOK_KW_FOR,    "for");
    _ts_lex_p13_assert_tok(1,  TS_TOK_LPAREN,    "(");
    _ts_lex_p13_assert_tok(2,  TS_TOK_KW_VAR,    "var");
    _ts_lex_p13_assert_tok(3,  TS_TOK_IDENT,     "i");
    _ts_lex_p13_assert_tok(4,  TS_TOK_EQ,        "=");
    _ts_lex_p13_assert_tok(5,  TS_TOK_INT,       "0");
    _ts_lex_p13_assert_tok(6,  TS_TOK_SEMI,      ";");
    _ts_lex_p13_assert_tok(7,  TS_TOK_IDENT,     "i");
    _ts_lex_p13_assert_tok(8,  TS_TOK_LT,        "<");
    _ts_lex_p13_assert_tok(9,  TS_TOK_IDENT,     "n");
    _ts_lex_p13_assert_tok(10, TS_TOK_SEMI,      ";");
    _ts_lex_p13_assert_tok(11, TS_TOK_IDENT,     "i");
    _ts_lex_p13_assert_tok(12, TS_TOK_PLUS_PLUS, "++");
    
    return 0;
}

# ── ts_lex_p14 ───────────────────────────────────────────
fn ts_lex_test_ts_lex_p14() {
    
    
    
    
    
    # ─── plain templates (no interpolation) ──────────────────────────
    test_group("plain templates");
    
    var n = _ts_lex_p14_test_lex("``");
    assert_eq(n, 2, "empty template -> 1 tok + EOF");
    _ts_lex_p14_assert_tok(0, TS_TOK_TEMPLATE_NOSUB, "`` -> NOSUB");
    
    n = _ts_lex_p14_test_lex("`hello`");
    assert_eq(n, 2, "`hello` -> NOSUB + EOF");
    _ts_lex_p14_assert_tok(0, TS_TOK_TEMPLATE_NOSUB, "`hello` -> NOSUB");
    
    n = _ts_lex_p14_test_lex("`with spaces and 123`");
    assert_eq(n, 2, "`with spaces and 123` -> NOSUB");
    _ts_lex_p14_assert_tok(0, TS_TOK_TEMPLATE_NOSUB, "spaces+digits inside backticks");
    
    # ─── single interpolation ────────────────────────────────────────
    test_group("single interpolation");
    
    n = _ts_lex_p14_test_lex("`hi ${name}`");
    # Tokens: TEMPLATE_HEAD("hi "), IDENT(name), TEMPLATE_TAIL(""), EOF
    assert_eq(n, 4, "`hi ${name}` -> HEAD, IDENT, TAIL, EOF");
    _ts_lex_p14_assert_tok(0, TS_TOK_TEMPLATE_HEAD,  "TEMPLATE_HEAD `hi ${`");
    _ts_lex_p14_assert_tok(1, TS_TOK_IDENT,          "IDENT name");
    _ts_lex_p14_assert_tok(2, TS_TOK_TEMPLATE_TAIL,  "TEMPLATE_TAIL `}`");
    
    n = _ts_lex_p14_test_lex("`${x}`");
    # Tokens: HEAD(""), IDENT(x), TAIL(""), EOF
    assert_eq(n, 4, "`${x}` -> 4 toks");
    _ts_lex_p14_assert_tok(0, TS_TOK_TEMPLATE_HEAD, "HEAD with empty content");
    _ts_lex_p14_assert_tok(1, TS_TOK_IDENT,         "x");
    _ts_lex_p14_assert_tok(2, TS_TOK_TEMPLATE_TAIL, "TAIL with empty content");
    
    # Interp expression with multiple tokens
    n = _ts_lex_p14_test_lex("`sum: ${a + b}`");
    # HEAD("sum: "), IDENT(a), PLUS, IDENT(b), TAIL(""), EOF
    assert_eq(n, 6, "interp with binary op -> 5 toks + EOF");
    _ts_lex_p14_assert_tok(0, TS_TOK_TEMPLATE_HEAD, "HEAD");
    _ts_lex_p14_assert_tok(1, TS_TOK_IDENT,         "a");
    _ts_lex_p14_assert_tok(2, TS_TOK_PLUS,          "+");
    _ts_lex_p14_assert_tok(3, TS_TOK_IDENT,         "b");
    _ts_lex_p14_assert_tok(4, TS_TOK_TEMPLATE_TAIL, "TAIL");
    
    # ─── multiple interpolations ─────────────────────────────────────
    test_group("multiple interpolations");
    
    n = _ts_lex_p14_test_lex("`${a} mid ${b}`");
    # HEAD(""), IDENT(a), MID(" mid "), IDENT(b), TAIL(""), EOF
    assert_eq(n, 6, "two interps -> HEAD, ident, MID, ident, TAIL, EOF");
    _ts_lex_p14_assert_tok(0, TS_TOK_TEMPLATE_HEAD, "HEAD ");
    _ts_lex_p14_assert_tok(1, TS_TOK_IDENT,         "a");
    _ts_lex_p14_assert_tok(2, TS_TOK_TEMPLATE_MID,  "MID");
    _ts_lex_p14_assert_tok(3, TS_TOK_IDENT,         "b");
    _ts_lex_p14_assert_tok(4, TS_TOK_TEMPLATE_TAIL, "TAIL");
    
    # Three interps
    n = _ts_lex_p14_test_lex("`${a}-${b}-${c}`");
    # HEAD, a, MID, b, MID, c, TAIL, EOF = 8
    assert_eq(n, 8, "three interps");
    _ts_lex_p14_assert_tok(0, TS_TOK_TEMPLATE_HEAD, "HEAD");
    _ts_lex_p14_assert_tok(1, TS_TOK_IDENT,         "a");
    _ts_lex_p14_assert_tok(2, TS_TOK_TEMPLATE_MID,  "MID 1");
    _ts_lex_p14_assert_tok(3, TS_TOK_IDENT,         "b");
    _ts_lex_p14_assert_tok(4, TS_TOK_TEMPLATE_MID,  "MID 2");
    _ts_lex_p14_assert_tok(5, TS_TOK_IDENT,         "c");
    _ts_lex_p14_assert_tok(6, TS_TOK_TEMPLATE_TAIL, "TAIL");
    
    # ─── nested templates ────────────────────────────────────────────
    test_group("nested templates");
    
    # `outer ${`inner`}`
    # TOKENS: HEAD("outer "), TEMPLATE_NOSUB("inner"), TAIL(""), EOF
    # (the inner `inner` is a complete template inside the interp)
    n = _ts_lex_p14_test_lex("`outer ${`inner`}`");
    assert_eq(n, 4, "nested template inside interp");
    _ts_lex_p14_assert_tok(0, TS_TOK_TEMPLATE_HEAD,  "outer HEAD");
    _ts_lex_p14_assert_tok(1, TS_TOK_TEMPLATE_NOSUB, "inner NOSUB");
    _ts_lex_p14_assert_tok(2, TS_TOK_TEMPLATE_TAIL,  "outer TAIL");
    
    # `${`${x}`}`
    # HEAD(""), HEAD(""), IDENT(x), TAIL(""), TAIL(""), EOF = 6
    n = _ts_lex_p14_test_lex("`${`${x}`}`");
    assert_eq(n, 6, "nested interp inside interp");
    _ts_lex_p14_assert_tok(0, TS_TOK_TEMPLATE_HEAD,  "outer HEAD");
    _ts_lex_p14_assert_tok(1, TS_TOK_TEMPLATE_HEAD,  "inner HEAD");
    _ts_lex_p14_assert_tok(2, TS_TOK_IDENT,          "x");
    _ts_lex_p14_assert_tok(3, TS_TOK_TEMPLATE_TAIL,  "inner TAIL");
    _ts_lex_p14_assert_tok(4, TS_TOK_TEMPLATE_TAIL,  "outer TAIL");
    
    # ─── escapes inside template ─────────────────────────────────────
    test_group("escapes");
    
    n = _ts_lex_p14_test_lex("`\\``");
    # Single template containing an escaped backtick. Becomes NOSUB.
    # Content span includes the escape but doesn't decode it (P3+ work).
    assert_eq(n, 2, "`\\`` -> NOSUB containing escaped backtick");
    _ts_lex_p14_assert_tok(0, TS_TOK_TEMPLATE_NOSUB, "escaped backtick inside template");
    
    n = _ts_lex_p14_test_lex("`escaped \\${not_interp}`");
    # Escape on the $ should suppress interpolation. Treat as plain NOSUB.
    assert_eq(n, 2, "escaped $ suppresses interp");
    _ts_lex_p14_assert_tok(0, TS_TOK_TEMPLATE_NOSUB, "\\${...} stays in template body");
    
    # ─── newlines inside template (allowed in TS, unlike strings) ────
    test_group("newlines");
    
    n = _ts_lex_p14_test_lex("`line1\nline2`");
    assert_eq(n, 2, "multi-line template -> NOSUB");
    _ts_lex_p14_assert_tok(0, TS_TOK_TEMPLATE_NOSUB, "newline in template OK");
    # Verify line counter ticked
    assert_eq(TS_PEEKLINE(ts_base, 1), 2, "EOF on line 2 after embedded \\n");
    
    n = _ts_lex_p14_test_lex("`a\nb\nc`");
    assert_eq(n, 2, "two newlines in template");
    assert_eq(TS_PEEKLINE(ts_base, 1), 3, "EOF on line 3");
    
    # ─── interp with ${} containing braces ───────────────────────────
    test_group("interp with brace expression");
    
    # `${{key: val}}` — object literal inside interp.
    # Per v5.7.4 fix: the lexer now properly balances `{` opened inside an
    # interpolation expression. The inner `{...}` is the object-literal,
    # the OUTER `}` closes the interpolation. Token stream:
    #   HEAD, {, key, :, val, }, TAIL = 7 tokens + EOF = 8 total.
    #
    # Pre-v5.7.4 (buggy): the first `}` was incorrectly popping the interp
    # and the outer `}` was absorbed into TAIL content (7 total). The new
    # behavior matches JS semantics correctly.
    
    n = _ts_lex_p14_test_lex("`${{key:val}}`");
    assert_eq(n, 8, "object literal in interp — properly balanced (v5.7.4)");
    _ts_lex_p14_assert_tok(0, TS_TOK_TEMPLATE_HEAD, "HEAD");
    _ts_lex_p14_assert_tok(1, TS_TOK_LBRACE,        "{");
    _ts_lex_p14_assert_tok(2, TS_TOK_IDENT,         "key");
    _ts_lex_p14_assert_tok(3, TS_TOK_COLON,         ":");
    _ts_lex_p14_assert_tok(4, TS_TOK_IDENT,         "val");
    _ts_lex_p14_assert_tok(5, TS_TOK_RBRACE,        "} closes object literal");
    _ts_lex_p14_assert_tok(6, TS_TOK_TEMPLATE_TAIL, "TAIL after the closing interp }");
    
    # ─── error paths ─────────────────────────────────────────────────
    test_group("error paths");
    
    # Unterminated template
    n = _ts_lex_p14_test_lex("`hello world");
    assert_eq(n, 0 - 1, "unterminated template returns -1");
    assert_eq(TS_GETERR(ts_base), 8, "err code 8 = unterminated template");
    
    # Truncated escape (backslash at end of source)
    n = _ts_lex_p14_test_lex("`oops \\");
    assert_eq(n, 0 - 1, "truncated escape returns -1");
    assert_eq(TS_GETERR(ts_base), 7, "err code 7 = truncated escape");
    
    # Unterminated after seeing ${
    n = _ts_lex_p14_test_lex("`a ${b");
    assert_eq(n, 0 - 1, "unterminated after interp");
    # Either err 8 (still inside template) or another code — just check non-zero
    assert(TS_GETERR(ts_base) != 0, "some err code on unterminated post-interp");
    
    return 0;
}

# ── ts_lex_p15 ───────────────────────────────────────────
fn ts_lex_test_ts_lex_p15() {
    
    
    
    
    
    # ─── line comments ───────────────────────────────────────────────
    test_group("// line comments");
    
    # Pure comment — nothing but EOF
    var n = _ts_lex_p15_test_lex("// just a comment");
    assert_eq(n, 1, "pure // comment -> EOF only");
    _ts_lex_p15_assert_tok(0, TS_TOK_EOF, "EOF");
    
    # Comment after code on same line
    n = _ts_lex_p15_test_lex("var x = 42; // assignment");
    # var, x, =, 42, ;, EOF = 6
    assert_eq(n, 6, "code then // comment");
    _ts_lex_p15_assert_tok(0, TS_TOK_KW_VAR, "var");
    _ts_lex_p15_assert_tok(1, TS_TOK_IDENT,  "x");
    _ts_lex_p15_assert_tok(2, TS_TOK_EQ,     "=");
    _ts_lex_p15_assert_tok(3, TS_TOK_INT,    "42");
    _ts_lex_p15_assert_tok(4, TS_TOK_SEMI,   ";");
    _ts_lex_p15_assert_tok(5, TS_TOK_EOF,    "EOF");
    
    # Comment then code on next line
    n = _ts_lex_p15_test_lex("// header\nvar x");
    # var, x, EOF = 3
    assert_eq(n, 3, "// then newline then code");
    _ts_lex_p15_assert_tok(0, TS_TOK_KW_VAR, "var");
    _ts_lex_p15_assert_tok(1, TS_TOK_IDENT,  "x (line 2)");
    # Line tracking: tok[0] should be on line 2
    assert_eq(TS_PEEKLINE(ts_base, 0), 2, "var on line 2");
    
    # Multiple line comments
    n = _ts_lex_p15_test_lex("// a\n// b\n// c\nx");
    # x, EOF
    assert_eq(n, 2, "3 // comments + x");
    _ts_lex_p15_assert_tok(0, TS_TOK_IDENT, "x");
    assert_eq(TS_PEEKLINE(ts_base, 0), 4, "x on line 4");
    
    # // at end of source (no trailing newline)
    n = _ts_lex_p15_test_lex("var x // trailing");
    # var, x, EOF
    assert_eq(n, 3, "// at EOF without trailing newline");
    _ts_lex_p15_assert_tok(0, TS_TOK_KW_VAR, "var");
    _ts_lex_p15_assert_tok(1, TS_TOK_IDENT,  "x");
    
    # ─── block comments ──────────────────────────────────────────────
    test_group("/* */ block comments");
    
    n = _ts_lex_p15_test_lex("/* simple */");
    assert_eq(n, 1, "pure /* */ -> EOF only");
    
    n = _ts_lex_p15_test_lex("var/*inline*/x");
    # var, x, EOF
    assert_eq(n, 3, "/* */ between tokens");
    _ts_lex_p15_assert_tok(0, TS_TOK_KW_VAR, "var");
    _ts_lex_p15_assert_tok(1, TS_TOK_IDENT,  "x");
    
    # Multi-line block comment (line counter must tick)
    n = _ts_lex_p15_test_lex("/* line 1\nline 2\nline 3 */ var x");
    # var, x, EOF
    assert_eq(n, 3, "multi-line /* */");
    _ts_lex_p15_assert_tok(0, TS_TOK_KW_VAR, "var");
    # var should be on line 3 (after 2 embedded LFs in the comment)
    assert_eq(TS_PEEKLINE(ts_base, 0), 3, "var on line 3 after multi-line /* */");
    
    # Block comment with * inside (not closing)
    n = _ts_lex_p15_test_lex("/* one * two ** three */ x");
    assert_eq(n, 2, "* inside block comment doesn't close");
    _ts_lex_p15_assert_tok(0, TS_TOK_IDENT, "x");
    
    # Block comment with / inside
    n = _ts_lex_p15_test_lex("/* a/b/c */ x");
    assert_eq(n, 2, "/ inside block comment OK");
    _ts_lex_p15_assert_tok(0, TS_TOK_IDENT, "x");
    
    # JSDoc-style /** ... */ — treated identically to /* */
    n = _ts_lex_p15_test_lex("/** docstring */ var x");
    assert_eq(n, 3, "JSDoc /** */ treated as block comment");
    _ts_lex_p15_assert_tok(0, TS_TOK_KW_VAR, "var");
    
    # Empty block comment /**/
    n = _ts_lex_p15_test_lex("/**/x");
    assert_eq(n, 2, "/**/ empty block");
    _ts_lex_p15_assert_tok(0, TS_TOK_IDENT, "x");
    
    # ─── mixed comments + division (regex is P1.6) ───────────────────
    test_group("comments vs division");
    
    # Bare / is still SLASH (not comment, not regex)
    n = _ts_lex_p15_test_lex("a / b");
    assert_eq(n, 4, "a / b -> SLASH");
    _ts_lex_p15_assert_tok(0, TS_TOK_IDENT, "a");
    _ts_lex_p15_assert_tok(1, TS_TOK_SLASH, "/");
    _ts_lex_p15_assert_tok(2, TS_TOK_IDENT, "b");
    
    # /= is still SLASH_EQ (not /* )
    n = _ts_lex_p15_test_lex("a /= b");
    assert_eq(n, 4, "a /= b -> SLASH_EQ");
    _ts_lex_p15_assert_tok(0, TS_TOK_IDENT,    "a");
    _ts_lex_p15_assert_tok(1, TS_TOK_SLASH_EQ, "/=");
    _ts_lex_p15_assert_tok(2, TS_TOK_IDENT,    "b");
    
    # // immediately after /= still becomes a comment? Actually no:
    # /= consumes both bytes, then // would start fresh comment
    n = _ts_lex_p15_test_lex("a /= b // tail");
    assert_eq(n, 4, "code then comment");
    _ts_lex_p15_assert_tok(0, TS_TOK_IDENT,    "a");
    _ts_lex_p15_assert_tok(1, TS_TOK_SLASH_EQ, "/=");
    _ts_lex_p15_assert_tok(2, TS_TOK_IDENT,    "b");
    
    # ─── error paths ─────────────────────────────────────────────────
    test_group("error paths");
    
    # Unterminated /* (ends mid-comment)
    n = _ts_lex_p15_test_lex("/* never closes");
    assert_eq(n, 0 - 1, "unterminated /* -> -1");
    assert_eq(TS_GETERR(ts_base), 10, "err code 10 = unterminated block comment");
    
    # /* with newline then EOF
    n = _ts_lex_p15_test_lex("/* line 1\nline 2");
    assert_eq(n, 0 - 1, "unterminated /* with newlines");
    assert_eq(TS_GETERR(ts_base), 10, "err 10");
    
    # /* immediately followed by EOF (no body)
    n = _ts_lex_p15_test_lex("/*");
    assert_eq(n, 0 - 1, "/* alone unterminated");
    
    # /*/ — / inside comment, then EOF
    n = _ts_lex_p15_test_lex("/*/");
    assert_eq(n, 0 - 1, "/*/ unterminated (the / is comment content)");
    
    # But /**/ closes correctly (already tested above)
    
    return 0;
}

# ── ts_lex_p16 ───────────────────────────────────────────
fn ts_lex_test_ts_lex_p16() {
    
    
    
    
    
    # ─── regex in expression context ─────────────────────────────────
    test_group("regex in expression context");
    
    # After = (assignment)
    var n = _ts_lex_p16_test_lex("let x = /foo/");
    # let, x, =, REGEX, EOF = 5
    assert_eq(n, 5, "let x = /foo/ -> 4 toks + EOF");
    _ts_lex_p16_assert_tok(0, TS_TOK_KW_LET,  "let");
    _ts_lex_p16_assert_tok(1, TS_TOK_IDENT,   "x");
    _ts_lex_p16_assert_tok(2, TS_TOK_EQ,      "=");
    _ts_lex_p16_assert_tok(3, TS_TOK_REGEX,   "/foo/");
    
    # After return
    n = _ts_lex_p16_test_lex("return /pattern/g");
    assert_eq(n, 3, "return /pattern/g");
    _ts_lex_p16_assert_tok(0, TS_TOK_KW_RETURN, "return");
    _ts_lex_p16_assert_tok(1, TS_TOK_REGEX,     "/pattern/g");
    
    # At start of file (expr context)
    n = _ts_lex_p16_test_lex("/^abc$/");
    assert_eq(n, 2, "/^abc$/ at start of file");
    _ts_lex_p16_assert_tok(0, TS_TOK_REGEX, "/^abc$/");
    
    # After comma (in args)
    n = _ts_lex_p16_test_lex("fn(a, /sep/)");
    assert_eq(n, 7, "fn(a, /sep/)");
    _ts_lex_p16_assert_tok(0, TS_TOK_IDENT,  "fn");
    _ts_lex_p16_assert_tok(1, TS_TOK_LPAREN, "(");
    _ts_lex_p16_assert_tok(2, TS_TOK_IDENT,  "a");
    _ts_lex_p16_assert_tok(3, TS_TOK_COMMA,  ",");
    _ts_lex_p16_assert_tok(4, TS_TOK_REGEX,  "/sep/");
    _ts_lex_p16_assert_tok(5, TS_TOK_RPAREN, ")");
    
    # After ! (logical not)
    n = _ts_lex_p16_test_lex("!/match/");
    assert_eq(n, 3, "!/match/");
    _ts_lex_p16_assert_tok(0, TS_TOK_BANG,  "!");
    _ts_lex_p16_assert_tok(1, TS_TOK_REGEX, "/match/");
    
    # ─── division in primary context ─────────────────────────────────
    test_group("division in primary context");
    
    # After ident
    n = _ts_lex_p16_test_lex("a / b");
    assert_eq(n, 4, "a / b -> SLASH, not REGEX");
    _ts_lex_p16_assert_tok(0, TS_TOK_IDENT, "a");
    _ts_lex_p16_assert_tok(1, TS_TOK_SLASH, "/");
    _ts_lex_p16_assert_tok(2, TS_TOK_IDENT, "b");
    
    # After number
    n = _ts_lex_p16_test_lex("42 / 2");
    assert_eq(n, 4, "42 / 2 -> SLASH");
    _ts_lex_p16_assert_tok(0, TS_TOK_INT,   "42");
    _ts_lex_p16_assert_tok(1, TS_TOK_SLASH, "/");
    _ts_lex_p16_assert_tok(2, TS_TOK_INT,   "2");
    
    # After ) — common pattern: (expr) / divisor
    n = _ts_lex_p16_test_lex("(a + b) / c");
    # (, a, +, b, ), /, c, EOF = 8
    assert_eq(n, 8, "(a + b) / c");
    _ts_lex_p16_assert_tok(0, TS_TOK_LPAREN, "(");
    _ts_lex_p16_assert_tok(1, TS_TOK_IDENT,  "a");
    _ts_lex_p16_assert_tok(2, TS_TOK_PLUS,   "+");
    _ts_lex_p16_assert_tok(3, TS_TOK_IDENT,  "b");
    _ts_lex_p16_assert_tok(4, TS_TOK_RPAREN, ")");
    _ts_lex_p16_assert_tok(5, TS_TOK_SLASH,  "/");
    _ts_lex_p16_assert_tok(6, TS_TOK_IDENT,  "c");
    
    # After ] — array indexing then divide
    n = _ts_lex_p16_test_lex("arr[0] / 2");
    assert_eq(n, 7, "arr[0] / 2");
    _ts_lex_p16_assert_tok(0, TS_TOK_IDENT,    "arr");
    _ts_lex_p16_assert_tok(1, TS_TOK_LBRACKET, "[");
    _ts_lex_p16_assert_tok(2, TS_TOK_INT,      "0");
    _ts_lex_p16_assert_tok(3, TS_TOK_RBRACKET, "]");
    _ts_lex_p16_assert_tok(4, TS_TOK_SLASH,    "/");
    _ts_lex_p16_assert_tok(5, TS_TOK_INT,      "2");
    
    # /= still works in primary context
    n = _ts_lex_p16_test_lex("a /= 2");
    assert_eq(n, 4, "a /= 2");
    _ts_lex_p16_assert_tok(0, TS_TOK_IDENT,    "a");
    _ts_lex_p16_assert_tok(1, TS_TOK_SLASH_EQ, "/=");
    _ts_lex_p16_assert_tok(2, TS_TOK_INT,      "2");
    
    # ─── regex flags ─────────────────────────────────────────────────
    test_group("regex flags");
    
    n = _ts_lex_p16_test_lex("/abc/g");
    assert_eq(n, 2, "/abc/g (single flag)");
    _ts_lex_p16_assert_tok(0, TS_TOK_REGEX, "/abc/g");
    
    n = _ts_lex_p16_test_lex("/abc/gi");
    assert_eq(n, 2, "/abc/gi");
    
    n = _ts_lex_p16_test_lex("/abc/gimsuyd");
    assert_eq(n, 2, "/abc/gimsuyd (all valid flags)");
    
    n = _ts_lex_p16_test_lex("/abc/");
    assert_eq(n, 2, "/abc/ (no flags)");
    
    # Flag scan stops at non-letter
    n = _ts_lex_p16_test_lex("/abc/g + 1");
    # REGEX, PLUS, INT, EOF = 4
    assert_eq(n, 4, "regex with flag then op");
    _ts_lex_p16_assert_tok(0, TS_TOK_REGEX, "/abc/g");
    _ts_lex_p16_assert_tok(1, TS_TOK_PLUS,  "+");
    _ts_lex_p16_assert_tok(2, TS_TOK_INT,   "1");
    
    # ─── regex with escapes + char classes ───────────────────────────
    test_group("regex escapes + char classes");
    
    # \/ (escaped slash) inside regex doesn't close
    n = _ts_lex_p16_test_lex("/a\\/b/");
    assert_eq(n, 2, "regex with escaped /");
    _ts_lex_p16_assert_tok(0, TS_TOK_REGEX, "/a\\/b/");
    
    # [/] (slash inside char class) doesn't close
    n = _ts_lex_p16_test_lex("/[/]/");
    assert_eq(n, 2, "regex with / inside [...] doesn't close");
    _ts_lex_p16_assert_tok(0, TS_TOK_REGEX, "/[/]/");
    
    # Char class with multiple chars
    n = _ts_lex_p16_test_lex("/[a-z0-9]+/");
    assert_eq(n, 2, "regex with char class range");
    _ts_lex_p16_assert_tok(0, TS_TOK_REGEX, "/[a-z0-9]+/");
    
    # Common email-shape regex
    n = _ts_lex_p16_test_lex("var re = /^[a-z]+@[a-z]+\\.[a-z]+$/i");
    # var, re, =, REGEX, EOF = 5
    assert_eq(n, 5, "var re = /email/i");
    _ts_lex_p16_assert_tok(0, TS_TOK_KW_VAR, "var");
    _ts_lex_p16_assert_tok(1, TS_TOK_IDENT,  "re");
    _ts_lex_p16_assert_tok(2, TS_TOK_EQ,     "=");
    _ts_lex_p16_assert_tok(3, TS_TOK_REGEX,  "email regex");
    
    # ─── after primary keywords (this/super/true/false/null/undefined) ─
    test_group("primary keywords -> division");
    
    n = _ts_lex_p16_test_lex("this / 2");
    assert_eq(n, 4, "this / 2 -> SLASH");
    _ts_lex_p16_assert_tok(0, TS_TOK_KW_THIS, "this");
    _ts_lex_p16_assert_tok(1, TS_TOK_SLASH,   "/");
    
    n = _ts_lex_p16_test_lex("true / false");
    assert_eq(n, 4, "true / false -> SLASH (silly but lex-correct)");
    _ts_lex_p16_assert_tok(1, TS_TOK_SLASH, "/");
    
    n = _ts_lex_p16_test_lex("null / x");
    assert_eq(n, 4, "null / x -> SLASH");
    _ts_lex_p16_assert_tok(1, TS_TOK_SLASH, "/");
    
    # ─── error paths ─────────────────────────────────────────────────
    test_group("error paths");
    
    # Unterminated regex
    n = _ts_lex_p16_test_lex("let x = /foo");
    assert_eq(n, 0 - 1, "unterminated regex");
    assert_eq(TS_GETERR(ts_base), 11, "err code 11 = unterminated regex");
    
    # Raw newline inside regex (outside char class)
    n = _ts_lex_p16_test_lex("let x = /foo\nbar/");
    assert_eq(n, 0 - 1, "raw newline in regex outside [...]");
    assert_eq(TS_GETERR(ts_base), 11, "err 11 (newline in regex)");
    
    # Truncated escape inside regex
    n = _ts_lex_p16_test_lex("let x = /foo\\");
    assert_eq(n, 0 - 1, "truncated escape in regex");
    assert_eq(TS_GETERR(ts_base), 11, "err 11 (truncated escape)");
    
    # But newline INSIDE [...] is technically invalid in JS spec but
    # we allow it in P1.6a (parser/regex-engine concern, not lexer).
    n = _ts_lex_p16_test_lex("/[a\nb]/");
    # Just verify it doesn't error at the lex level
    assert(n > 0, "newline inside [...] doesn't crash lex");
    
    return 0;
}

# ── ts_lex_p43 ───────────────────────────────────────────
fn ts_lex_test_ts_lex_p43() {
    
    
    
    # Lex `src` end-to-end through TS_LEX. Returns slen on a clean lex
    # (TS_LEX consumed the whole input without error), 0 on lex error.
    # The test asserts on the emitted token stream — TS_GTCNT,
    # TS_PEEKT(idx, ...) — exactly as the v5.7.5-shape test did, since
    # the token sequence is the durable contract; the entry-point
    # function name is not.
    
    
    
    # ─── simple open/close ──────────────────────────────────────────
    test_group("simple open/close");
    var end = _ts_lex_p43_lex_jsx("<Foo>txt</Foo>");
    assert_eq(end, 14, "<Foo>txt</Foo> end pos");
    _ts_lex_p43_assert_count(8, "<Foo>txt</Foo> tok count (incl EOF)");
    _ts_lex_p43_assert_tok(0, TS_TOK_JSX_OPEN_START,  "0: <");
    _ts_lex_p43_assert_tok(1, TS_TOK_JSX_TAG_NAME,    "1: Foo");
    _ts_lex_p43_assert_tok(2, TS_TOK_JSX_OPEN_END,    "2: >");
    _ts_lex_p43_assert_tok(3, TS_TOK_JSX_TEXT,        "3: txt");
    _ts_lex_p43_assert_tok(4, TS_TOK_JSX_CLOSE_START, "4: </");
    _ts_lex_p43_assert_tok(5, TS_TOK_JSX_TAG_NAME,    "5: Foo");
    _ts_lex_p43_assert_tok(6, TS_TOK_JSX_CLOSE_END,   "6: >");
    _ts_lex_p43_assert_tok(7, TS_TOK_EOF,             "7: EOF");
    
    # ─── self-closing ───────────────────────────────────────────────
    test_group("self-closing");
    end = _ts_lex_p43_lex_jsx("<Foo />");
    assert_eq(end, 7, "<Foo /> end pos");
    _ts_lex_p43_assert_count(4, "<Foo /> tok count");
    _ts_lex_p43_assert_tok(0, TS_TOK_JSX_OPEN_START, "0: <");
    _ts_lex_p43_assert_tok(1, TS_TOK_JSX_TAG_NAME,   "1: Foo");
    _ts_lex_p43_assert_tok(2, TS_TOK_JSX_SELF_CLOSE, "2: />");
    _ts_lex_p43_assert_tok(3, TS_TOK_EOF,            "3: EOF");
    
    # ─── fragment ───────────────────────────────────────────────────
    test_group("fragment");
    end = _ts_lex_p43_lex_jsx("<>txt</>");
    assert_eq(end, 8, "<>txt</> end pos");
    _ts_lex_p43_assert_count(4, "<>txt</> tok count");
    _ts_lex_p43_assert_tok(0, TS_TOK_JSX_FRAGMENT_OPEN,  "0: <>");
    _ts_lex_p43_assert_tok(1, TS_TOK_JSX_TEXT,           "1: txt");
    _ts_lex_p43_assert_tok(2, TS_TOK_JSX_FRAGMENT_CLOSE, "2: </>");
    _ts_lex_p43_assert_tok(3, TS_TOK_EOF,                "3: EOF");
    
    # ─── attr string ────────────────────────────────────────────────
    test_group("attr string");
    end = _ts_lex_p43_lex_jsx("<Foo a=\"x\" />");
    _ts_lex_p43_assert_count(6, "<Foo a=\"x\" /> tok count");
    _ts_lex_p43_assert_tok(0, TS_TOK_JSX_OPEN_START,        "0: <");
    _ts_lex_p43_assert_tok(1, TS_TOK_JSX_TAG_NAME,          "1: Foo");
    _ts_lex_p43_assert_tok(2, TS_TOK_JSX_ATTR_NAME,         "2: a");
    _ts_lex_p43_assert_tok(3, TS_TOK_JSX_ATTR_VALUE_STRING, "3: \"x\"");
    _ts_lex_p43_assert_tok(4, TS_TOK_JSX_SELF_CLOSE,        "4: />");
    _ts_lex_p43_assert_tok(5, TS_TOK_EOF,                   "5: EOF");
    
    # ─── attr expr (v5.7.6 inner-expr tokenization) ─────────────────
    test_group("attr expr");
    end = _ts_lex_p43_lex_jsx("<Foo a={1} />");
    _ts_lex_p43_assert_count(8, "<Foo a={1} /> tok count");
    _ts_lex_p43_assert_tok(0, TS_TOK_JSX_OPEN_START,  "0: <");
    _ts_lex_p43_assert_tok(1, TS_TOK_JSX_TAG_NAME,    "1: Foo");
    _ts_lex_p43_assert_tok(2, TS_TOK_JSX_ATTR_NAME,   "2: a");
    _ts_lex_p43_assert_tok(3, TS_TOK_JSX_EXPR_OPEN,   "3: {");
    _ts_lex_p43_assert_tok(4, TS_TOK_INT,             "4: 1 (inner-expr tokenized)");
    _ts_lex_p43_assert_tok(5, TS_TOK_JSX_EXPR_CLOSE,  "5: }");
    _ts_lex_p43_assert_tok(6, TS_TOK_JSX_SELF_CLOSE,  "6: />");
    _ts_lex_p43_assert_tok(7, TS_TOK_EOF,             "7: EOF");
    
    # ─── spread attr (inner ELLIPSIS + IDENT now tokenized) ─────────
    test_group("spread attr");
    end = _ts_lex_p43_lex_jsx("<Foo {...x} />");
    _ts_lex_p43_assert_count(8, "<Foo {...x} /> tok count");
    _ts_lex_p43_assert_tok(0, TS_TOK_JSX_OPEN_START,  "0: <");
    _ts_lex_p43_assert_tok(1, TS_TOK_JSX_TAG_NAME,    "1: Foo");
    _ts_lex_p43_assert_tok(2, TS_TOK_JSX_EXPR_OPEN,   "2: {");
    _ts_lex_p43_assert_tok(3, TS_TOK_ELLIPSIS,        "3: ...");
    _ts_lex_p43_assert_tok(4, TS_TOK_IDENT,           "4: x");
    _ts_lex_p43_assert_tok(5, TS_TOK_JSX_EXPR_CLOSE,  "5: }");
    _ts_lex_p43_assert_tok(6, TS_TOK_JSX_SELF_CLOSE,  "6: />");
    _ts_lex_p43_assert_tok(7, TS_TOK_EOF,             "7: EOF");
    
    # ─── bare boolean attr ──────────────────────────────────────────
    test_group("bare boolean attr");
    end = _ts_lex_p43_lex_jsx("<Foo bar />");
    _ts_lex_p43_assert_count(5, "<Foo bar /> tok count");
    _ts_lex_p43_assert_tok(0, TS_TOK_JSX_OPEN_START,  "0: <");
    _ts_lex_p43_assert_tok(1, TS_TOK_JSX_TAG_NAME,    "1: Foo");
    _ts_lex_p43_assert_tok(2, TS_TOK_JSX_ATTR_NAME,   "2: bar");
    _ts_lex_p43_assert_tok(3, TS_TOK_JSX_SELF_CLOSE,  "3: />");
    _ts_lex_p43_assert_tok(4, TS_TOK_EOF,             "4: EOF");
    
    # ─── expr child (inner IDENT now tokenized) ─────────────────────
    test_group("expr child");
    end = _ts_lex_p43_lex_jsx("<Foo>{x}</Foo>");
    _ts_lex_p43_assert_count(10, "<Foo>{x}</Foo> tok count");
    _ts_lex_p43_assert_tok(0, TS_TOK_JSX_OPEN_START,  "0: <");
    _ts_lex_p43_assert_tok(1, TS_TOK_JSX_TAG_NAME,    "1: Foo");
    _ts_lex_p43_assert_tok(2, TS_TOK_JSX_OPEN_END,    "2: >");
    _ts_lex_p43_assert_tok(3, TS_TOK_JSX_EXPR_OPEN,   "3: {");
    _ts_lex_p43_assert_tok(4, TS_TOK_IDENT,           "4: x");
    _ts_lex_p43_assert_tok(5, TS_TOK_JSX_EXPR_CLOSE,  "5: }");
    _ts_lex_p43_assert_tok(6, TS_TOK_JSX_CLOSE_START, "6: </");
    _ts_lex_p43_assert_tok(7, TS_TOK_JSX_TAG_NAME,    "7: Foo");
    _ts_lex_p43_assert_tok(8, TS_TOK_JSX_CLOSE_END,   "8: >");
    _ts_lex_p43_assert_tok(9, TS_TOK_EOF,             "9: EOF");
    
    # ─── nested element ─────────────────────────────────────────────
    test_group("nested element");
    end = _ts_lex_p43_lex_jsx("<Foo><Bar /></Foo>");
    _ts_lex_p43_assert_count(10, "<Foo><Bar /></Foo> tok count");
    _ts_lex_p43_assert_tok(0, TS_TOK_JSX_OPEN_START,  "0: <Foo");
    _ts_lex_p43_assert_tok(1, TS_TOK_JSX_TAG_NAME,    "1: Foo");
    _ts_lex_p43_assert_tok(2, TS_TOK_JSX_OPEN_END,    "2: >");
    _ts_lex_p43_assert_tok(3, TS_TOK_JSX_OPEN_START,  "3: <Bar");
    _ts_lex_p43_assert_tok(4, TS_TOK_JSX_TAG_NAME,    "4: Bar");
    _ts_lex_p43_assert_tok(5, TS_TOK_JSX_SELF_CLOSE,  "5: />");
    _ts_lex_p43_assert_tok(6, TS_TOK_JSX_CLOSE_START, "6: </");
    _ts_lex_p43_assert_tok(7, TS_TOK_JSX_TAG_NAME,    "7: Foo");
    _ts_lex_p43_assert_tok(8, TS_TOK_JSX_CLOSE_END,   "8: >");
    _ts_lex_p43_assert_tok(9, TS_TOK_EOF,             "9: EOF");
    
    # ─── member tag name (the dot is inside the TAG_NAME span) ──────
    test_group("member tag name");
    end = _ts_lex_p43_lex_jsx("<Foo.Bar />");
    _ts_lex_p43_assert_count(4, "<Foo.Bar /> tok count");
    _ts_lex_p43_assert_tok(0, TS_TOK_JSX_OPEN_START, "0: <");
    _ts_lex_p43_assert_tok(1, TS_TOK_JSX_TAG_NAME,   "1: Foo.Bar");
    _ts_lex_p43_assert_tok(2, TS_TOK_JSX_SELF_CLOSE, "2: />");
    _ts_lex_p43_assert_tok(3, TS_TOK_EOF,            "3: EOF");
    
    # ─── JSX inside expr inside JSX (v5.7.6 inner-expr tokenization) ─
    # Inner `c ? <Bar /> : null` is fully tokenized: c, ?, <Bar, Bar,
    # />, :, null. Tokens 4-10 are the inner expression; the outer
    # wrap (open + expr-container + close) is 9 tokens.
    test_group("JSX inside expr inside JSX");
    end = _ts_lex_p43_lex_jsx("<Foo>{c?<Bar />:null}</Foo>");
    _ts_lex_p43_assert_count(16, "JSX-in-expr-in-JSX tok count");
    _ts_lex_p43_assert_tok(0, TS_TOK_JSX_OPEN_START,  "outer: <");
    _ts_lex_p43_assert_tok(1, TS_TOK_JSX_TAG_NAME,    "outer: Foo");
    _ts_lex_p43_assert_tok(2, TS_TOK_JSX_OPEN_END,    "outer: >");
    _ts_lex_p43_assert_tok(3, TS_TOK_JSX_EXPR_OPEN,   "expr: {");
    _ts_lex_p43_assert_tok(4, TS_TOK_IDENT,           "inner: c");
    _ts_lex_p43_assert_tok(5, TS_TOK_QUESTION,        "inner: ?");
    _ts_lex_p43_assert_tok(6, TS_TOK_JSX_OPEN_START,  "inner: <");
    _ts_lex_p43_assert_tok(7, TS_TOK_JSX_TAG_NAME,    "inner: Bar");
    _ts_lex_p43_assert_tok(8, TS_TOK_JSX_SELF_CLOSE,  "inner: />");
    _ts_lex_p43_assert_tok(9, TS_TOK_COLON,           "inner: :");
    _ts_lex_p43_assert_tok(10, TS_TOK_KW_NULL,        "inner: null");
    _ts_lex_p43_assert_tok(11, TS_TOK_JSX_EXPR_CLOSE, "expr: }");
    _ts_lex_p43_assert_tok(12, TS_TOK_JSX_CLOSE_START,"outer: </");
    _ts_lex_p43_assert_tok(13, TS_TOK_JSX_TAG_NAME,   "outer: Foo");
    _ts_lex_p43_assert_tok(14, TS_TOK_JSX_CLOSE_END,  "outer: >");
    _ts_lex_p43_assert_tok(15, TS_TOK_EOF,            "EOF");
    
    # ─── generic-arrow disambig ────────────────────────────────────
    # `<T>(x) => x` is NOT JSX. v5.7.6 BYTE_SKIP correctly rejects it
    # at lex time — main loop tokenizes as ordinary expression bytes.
    # v5.7.5 walker bailed and emitted 0 tokens; v5.7.6 emits the
    # regular tokens (LT, T, GT, LPAREN, x, RPAREN, ARROW, x).
    test_group("generic-arrow disambig");
    end = _ts_lex_p43_lex_jsx("<T>(x) => x");
    _ts_lex_p43_assert_count(9, "<T>(x) => x lexes as plain expr (not JSX)");
    _ts_lex_p43_assert_tok(0, TS_TOK_LT,     "0: <");
    _ts_lex_p43_assert_tok(1, TS_TOK_IDENT,  "1: T");
    _ts_lex_p43_assert_tok(2, TS_TOK_GT,     "2: >");
    _ts_lex_p43_assert_tok(3, TS_TOK_LPAREN, "3: (");
    _ts_lex_p43_assert_tok(4, TS_TOK_IDENT,  "4: x");
    _ts_lex_p43_assert_tok(5, TS_TOK_RPAREN, "5: )");
    _ts_lex_p43_assert_tok(6, TS_TOK_ARROW,  "6: =>");
    _ts_lex_p43_assert_tok(7, TS_TOK_IDENT,  "7: x");
    _ts_lex_p43_assert_tok(8, TS_TOK_EOF,    "8: EOF");
    
    return 0;
}

ts_lex_test_ts_lex_p12();
ts_lex_test_ts_lex_p13();
ts_lex_test_ts_lex_p14();
ts_lex_test_ts_lex_p15();
ts_lex_test_ts_lex_p16();
ts_lex_test_ts_lex_p43();

var exit_code = assert_summary();
syscall(60, exit_code);
