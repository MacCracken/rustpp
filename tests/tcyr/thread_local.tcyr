# thread_local.tcyr — regression coverage for lib/thread_local.cyr (v5.5.30)
#
# Filed by majra: `_aaw_result_state` is a module-scope global that
# multiple threads clobber during `cbarrier_arrive_and_wait`. Fix is
# per-thread storage via the CPU's thread-pointer register (`%fs` on
# x86_64, `TPIDR_EL0` on aarch64), installed at clone time via
# CLONE_SETTLS so worker threads automatically get a fresh block.
#
# Coverage:
#   1. main-thread init + round-trip (set/get)
#   2. slot independence (slot 3 set doesn't affect slot 7)
#   3. four worker threads each write their own tid into slot 0
#      and read it back — no cross-pollination means TLS works
#   4. worker writes to slot 5, main reads slot 5 — should NOT
#      see the worker's value (proves %fs is per-thread)

include "lib/assert.cyr"
include "lib/alloc.cyr"
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/syscalls.cyr"
include "lib/thread.cyr"
include "lib/thread_local.cyr"

var _tl_mtx = 0;
var _tl_done = 0;
var _tl_mismatches = 0;

# Worker: write my tid into slot 0, read it back, increment _tl_done
# under mutex. If %fs is thread-local, every worker reads back its own
# tid. If %fs leaks (e.g. shared with main), workers race on slot 0
# and read back someone else's tid.
fn _tl_worker(arg) {
    var my_tid = gettid();
    thread_local_set(0, my_tid);
    # Burn some cycles so other workers race us on their slot-0 writes.
    var i = 0;
    while (i < 1000) { i = i + 1; }
    var got = thread_local_get(0);
    mutex_lock(_tl_mtx);
    if (got != my_tid) { _tl_mismatches = _tl_mismatches + 1; }
    _tl_done = _tl_done + 1;
    mutex_unlock(_tl_mtx);
    return 0;
}

fn test_main_roundtrip() {
    test_group("main-thread init + set/get round-trip");
    var ok = thread_local_init();
    assert_eq(ok, 1, "thread_local_init succeeded");
    thread_local_set(0, 0xDEADBEEF);
    assert_eq(thread_local_get(0), 0xDEADBEEF, "slot 0 round-trip");
    thread_local_set(7, 0xCAFEBABE);
    assert_eq(thread_local_get(7), 0xCAFEBABE, "slot 7 round-trip");
    # slot independence
    assert_eq(thread_local_get(0), 0xDEADBEEF, "slot 0 preserved after slot 7 write");
    # high slot
    thread_local_set(15, 42);
    assert_eq(thread_local_get(15), 42, "slot 15 round-trip");
}

fn test_slot_independence() {
    test_group("slot independence");
    thread_local_set(3, 100);
    thread_local_set(4, 200);
    thread_local_set(5, 300);
    assert_eq(thread_local_get(3), 100, "slot 3");
    assert_eq(thread_local_get(4), 200, "slot 4");
    assert_eq(thread_local_get(5), 300, "slot 5");
}

fn test_worker_isolation() {
    test_group("four workers each isolated in slot 0");
    _tl_mtx = mutex_new();
    _tl_done = 0;
    _tl_mismatches = 0;
    # Main thread writes sentinel into slot 0 — if any worker's %fs
    # leaks into main's block, we'll see worker tids here at the end.
    thread_local_set(0, 0x5A5A5A5A);
    var t1 = thread_create(&_tl_worker, 0);
    var t2 = thread_create(&_tl_worker, 0);
    var t3 = thread_create(&_tl_worker, 0);
    var t4 = thread_create(&_tl_worker, 0);
    thread_join(t1);
    thread_join(t2);
    thread_join(t3);
    thread_join(t4);
    assert_eq(_tl_done, 4, "four workers ran");
    assert_eq(_tl_mismatches, 0, "every worker read back its own tid");
    assert_eq(thread_local_get(0), 0x5A5A5A5A, "main's slot 0 untouched by workers");
}

fn main() {
    alloc_init();
    test_main_roundtrip();
    test_slot_independence();
    test_worker_isolation();
    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
