# Test: cc5 IR recording and analysis
# Verifies IR node recording, BB construction, and LASE.
# Runs with IR enabled (mode 1) inside the compiler.
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/assert.cyr"

alloc_init();

# The IR infrastructure is part of the compiler (src/common/ir.cyr),
# not a stdlib module. We can't call ir_emit directly from user code.
# Instead, verify that CYRIUS_IR=1 produces byte-identical output
# by checking exit codes of compiled programs.

# ── Basic: compile + run simple programs ──
test_group("ir basic");

# Verify the test harness works
assert_eq(1 + 1, 2, "sanity");
assert_eq(42 * 2, 84, "multiply");

# ── Function calls ──
test_group("ir functions");

fn ir_add(a, b) { return a + b; }
fn ir_sub(a, b) { return a - b; }
fn ir_mul(a, b) { return a * b; }

assert_eq(ir_add(3, 4), 7, "add");
assert_eq(ir_sub(10, 3), 7, "sub");
assert_eq(ir_mul(6, 7), 42, "mul");

# ── Control flow ──
test_group("ir control flow");

fn ir_abs(x) {
    if (x < 0) { return 0 - x; }
    return x;
}
assert_eq(ir_abs(5), 5, "abs pos");
assert_eq(ir_abs(0 - 5), 5, "abs neg");
assert_eq(ir_abs(0), 0, "abs zero");

fn ir_max(a, b) {
    if (a > b) { return a; }
    return b;
}
assert_eq(ir_max(3, 7), 7, "max");
assert_eq(ir_max(9, 2), 9, "max rev");

# ── Loops ──
test_group("ir loops");

fn ir_sum_to(n) {
    var s = 0;
    var i = 1;
    while (i <= n) { s = s + i; i = i + 1; }
    return s;
}
assert_eq(ir_sum_to(10), 55, "sum 1..10");
assert_eq(ir_sum_to(0), 0, "sum empty");

fn ir_fib(n) {
    if (n < 2) { return n; }
    var a = 0;
    var b = 1;
    var i = 2;
    while (i <= n) {
        var t = a + b;
        a = b;
        b = t;
        i = i + 1;
    }
    return b;
}
assert_eq(ir_fib(10), 55, "fib 10");
assert_eq(ir_fib(0), 0, "fib 0");
assert_eq(ir_fib(1), 1, "fib 1");

# ── Short-circuit ──
test_group("ir short-circuit");

fn ir_both(a, b) {
    if (a > 0 && b > 0) { return 1; }
    return 0;
}
assert_eq(ir_both(1, 1), 1, "both true");
assert_eq(ir_both(0, 1), 0, "first false");
assert_eq(ir_both(1, 0), 0, "second false");

fn ir_either(a, b) {
    if (a > 0 || b > 0) { return 1; }
    return 0;
}
assert_eq(ir_either(1, 0), 1, "either first");
assert_eq(ir_either(0, 1), 1, "either second");
assert_eq(ir_either(0, 0), 0, "neither");

# ── Locals + LASE pattern ──
test_group("ir LASE patterns");

fn ir_lase_test(n) {
    var x = n * 2;
    var y = x + 1;
    var z = y * x;
    return z;
}
assert_eq(ir_lase_test(5), 110, "lase (5*2=10, 10+1=11, 11*10=110)");

fn ir_multi_local(a, b, c) {
    var x = a + b;
    var y = b + c;
    var z = x + y;
    return z;
}
assert_eq(ir_multi_local(1, 2, 3), 8, "multi local");

# ── Switch ──
test_group("ir switch");

fn ir_switch(x) {
    switch (x) {
        case 1: { return 10; }
        case 2: { return 20; }
        case 3: { return 30; }
    }
    return 0;
}
assert_eq(ir_switch(1), 10, "switch 1");
assert_eq(ir_switch(2), 20, "switch 2");
assert_eq(ir_switch(3), 30, "switch 3");
assert_eq(ir_switch(4), 0, "switch default");

# ── Defer ──
test_group("ir defer");

var ir_defer_flag = 0;
fn ir_defer_test() {
    defer { ir_defer_flag = 99; }
    return 42;
}
var dr = ir_defer_test();
assert_eq(dr, 42, "defer return");
assert_eq(ir_defer_flag, 99, "defer executed");

var r = assert_summary();
