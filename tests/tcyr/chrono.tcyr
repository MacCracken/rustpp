# Test: chrono (time/duration utilities)
include "lib/alloc.cyr"
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/syscalls.cyr"
include "lib/chrono.cyr"
include "lib/assert.cyr"

alloc_init();

test_group("clock_now");
var t1 = clock_now_ns();
assert_eq(t1 > 0, 1, "now_ns > 0");
var t2 = clock_now_ns();
assert_eq(t2 >= t1, 1, "monotonic");
var ms = clock_now_ms();
assert_eq(ms > 0, 1, "now_ms > 0");

test_group("clock_epoch");
var epoch = clock_epoch_secs();
assert_eq(epoch > 1700000000, 1, "epoch > 2023");

test_group("duration");
var d = dur_new(1, 500000000);
assert_eq(dur_secs(d), 1, "dur secs");
assert_eq(dur_nsecs(d), 500000000, "dur nsecs");
assert_eq(dur_to_ms(d), 1500, "dur to ms");

test_group("dur_between");
var start = clock_now_ns();
var end = start + 42000000;
var elapsed = dur_between(start, end);
assert_eq(dur_to_ms(elapsed), 42, "between 42ms");

test_group("ISO-8601 format");
var ts1 = iso8601(0);
assert_eq(streq(ts1, "1970-01-01T00:00:00Z"), 1, "epoch 0");
var ts2 = iso8601(86400);
assert_eq(streq(ts2, "1970-01-02T00:00:00Z"), 1, "epoch day 2");
var ts3 = iso8601_now();
assert_eq(strlen(ts3), 20, "now len 20");
assert_eq(load8(ts3 + 4), 45, "dash at 4");
assert_eq(load8(ts3 + 10), 84, "T at 10");
assert_eq(load8(ts3 + 19), 90, "Z at 19");

test_group("ISO-8601 parse");
var e1 = iso8601_parse("1970-01-01T00:00:00Z");
assert_eq(e1, 0, "parse epoch 0");
var e2 = iso8601_parse("1970-01-02T00:00:00Z");
assert_eq(e2, 86400, "parse day 2");

test_group("ISO-8601 roundtrip");
var now_epoch = clock_epoch_secs();
var formatted = iso8601(now_epoch);
var parsed = iso8601_parse(formatted);
assert_eq(parsed, now_epoch, "roundtrip");

test_group("leap year");
assert_eq(is_leap_year(2000), 1, "2000 leap");
assert_eq(is_leap_year(2024), 1, "2024 leap");
assert_eq(is_leap_year(1900), 0, "1900 not leap");
assert_eq(is_leap_year(2023), 0, "2023 not leap");

var r = assert_summary();
