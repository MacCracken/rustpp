# Test: math library (f64 operations)
include "lib/alloc.cyr"
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/math.cyr"
include "lib/assert.cyr"

alloc_init();

test_group("f64 basic");
var a = f64_from(10);
var b = f64_from(3);
assert_eq(f64_to(f64_add(a, b)), 13, "add");
assert_eq(f64_to(f64_sub(a, b)), 7, "sub");
assert_eq(f64_to(f64_mul(a, b)), 30, "mul");
assert_eq(f64_to(f64_div(a, b)), 3, "div truncates");

test_group("f64 compare");
assert_eq(f64_eq(f64_from(5), f64_from(5)), 1, "eq yes");
assert_eq(f64_eq(f64_from(5), f64_from(6)), 0, "eq no");
assert_eq(f64_lt(f64_from(3), f64_from(5)), 1, "lt yes");
assert_eq(f64_lt(f64_from(5), f64_from(3)), 0, "lt no");

test_group("f64 convert");
assert_eq(f64_to(f64_from(0)), 0, "zero");
assert_eq(f64_to(f64_from(1)), 1, "one");
assert_eq(f64_to(f64_from(100)), 100, "hundred");

var eps = f64_div(f64_from(1), f64_from(1000000));

fn near(a, b) {
    var diff = f64_abs(f64_sub(a, b));
    return f64_lt(diff, eps);
}

test_group("f64 lerp");
assert(near(f64_lerp(f64_from(0), f64_from(10), f64_from(0)) == 1, f64_from(0)), "lerp t=0");
assert_eq(f64_to(f64_lerp(f64_from(0), f64_from(10), f64_from(1))), 10, "lerp t=1");
assert_eq(f64_to(f64_lerp(f64_from(0), f64_from(10), f64_div(f64_from(1), f64_from(2)))), 5, "lerp t=0.5");

test_group("f64 hypot");
assert_eq(f64_to(f64_hypot(f64_from(3), f64_from(4))), 5, "hypot 3-4-5");

test_group("f64 sign");
assert(near(f64_sign(f64_from(42)), f64_from(1)) == 1, "sign pos");
assert(near(f64_sign(f64_neg(f64_from(7))), f64_neg(f64_from(1))) == 1, "sign neg");
assert(near(f64_sign(f64_from(0)), f64_from(0)) == 1, "sign zero");

test_group("f64 trunc/fract");
assert_eq(f64_to(f64_trunc(f64_div(f64_from(7), f64_from(2)))), 3, "trunc 3.5");
assert_eq(f64_to(f64_trunc(f64_neg(f64_div(f64_from(7), f64_from(2))))), 0 - 3, "trunc -3.5");

test_group("gcd/lcm");
assert_eq(gcd(12, 8), 4, "gcd 12,8");
assert_eq(gcd(17, 5), 1, "gcd coprime");
assert_eq(gcd(0, 7), 7, "gcd 0,7");
assert_eq(gcd(0 - 12, 8), 4, "gcd negative");
assert_eq(lcm(4, 6), 12, "lcm 4,6");
assert_eq(lcm(0, 5), 0, "lcm 0");

test_group("fibonacci");
assert_eq(fibonacci(0), 0, "fib 0");
assert_eq(fibonacci(1), 1, "fib 1");
assert_eq(fibonacci(10), 55, "fib 10");
assert_eq(fibonacci(20), 6765, "fib 20");
assert_eq(fibonacci(93), 0 - 1, "fib overflow");

test_group("binomial");
assert_eq(binomial(5, 2), 10, "C(5,2)");
assert_eq(binomial(10, 0), 1, "C(n,0)");
assert_eq(binomial(10, 10), 1, "C(n,n)");
assert_eq(binomial(3, 5), 0, "C(3,5) invalid");
assert_eq(binomial(20, 10), 184756, "C(20,10)");

# v5.8.4: f64_log2 + _f64_log2_polyfill verification (phylax #1 unblock).
# On x86 the parser dispatches f64_log2 to native x87 (fld1 fxch fyl2x).
# On aarch64 it dispatches to _f64_log2_polyfill (this slot's contribution).
# Verify both paths agree on power-of-2 inputs (where log2 is exact).
test_group("f64 log2 (v5.8.4 phylax #1 unblock)");
assert_eq(f64_to(f64_log2(f64_from(1))), 0, "log2(1) = 0");
assert_eq(f64_to(f64_log2(f64_from(2))), 1, "log2(2) = 1");
assert_eq(f64_to(f64_log2(f64_from(8))), 3, "log2(8) = 3");
assert_eq(f64_to(f64_log2(f64_from(1024))), 10, "log2(1024) = 10");
assert_eq(f64_to(f64_log2(f64_from(65536))), 16, "log2(65536) = 16");

# Direct polyfill — exercises the v5.8.4 math regardless of arch.
# log2(8) = ln(8) * (1/ln(2)) = 2.079... * 1.4427... ≈ 3.0. Two-step
# FP (ln then mul) costs precision vs native fyl2x's x87-internal
# 80-bit path, so polyfill output is 2.9999... → f64_to truncates
# to 2. Round before truncating so the comparison reflects the
# nearest-integer log2, not the truncation artifact.
assert_eq(f64_to(f64_round(_f64_log2_polyfill(f64_from(8)))), 3, "polyfill log2(8) ~ 3");
assert_eq(f64_to(f64_round(_f64_log2_polyfill(f64_from(1024)))), 10, "polyfill log2(1024) ~ 10");
assert_eq(f64_to(f64_round(_f64_log2_polyfill(f64_from(65536)))), 16, "polyfill log2(65536) ~ 16");

# Polyfill within ulp budget of native. Compute |native_bits - polyfill_bits|
# treating the f64 representations as raw integers; for results near a
# clean integer boundary the bit-diff = ulp count. Budget: 4096 ulp
# (matches the v5.7.31 polyfill regression's exp(ln(2)) round-trip
# tolerance — generous; typical polyfill drift is <16 ulp).
var native_8  = f64_log2(f64_from(8));
var poly_8    = _f64_log2_polyfill(f64_from(8));
var diff_8    = native_8 - poly_8;
if (diff_8 < 0) { diff_8 = 0 - diff_8; }
assert(diff_8 < 4096, "polyfill log2(8) within 4096 ulp of native");

var r = assert_summary();
