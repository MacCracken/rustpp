# json_pretty.tcyr — v5.7.40 acceptance gate for json_v_build_pretty.
# Pairs with json_engine.tcyr (compact serializer coverage).
#
# Scope: indent fallback (<= 0 == compact), empty-container compactness,
# arrays / objects / nested mixes at indent 2 and 4, and a round-trip
# check (parse → pretty → parse → compact == compact-of-original).

include "lib/syscalls.cyr"
include "lib/alloc.cyr"
include "lib/string.cyr"
include "lib/str.cyr"
include "lib/vec.cyr"
include "lib/fmt.cyr"
include "lib/io.cyr"
include "lib/math.cyr"
include "lib/json.cyr"
include "lib/assert.cyr"

alloc_init();

# ── indent <= 0 fallback ─────────────────────────────────────────────
test_group("indent <= 0 falls back to compact");
var cv1 = json_v_build_pretty(json_v_parse_str("[1,2,3]", 7), 0);
assert(streq(str_data(cv1), "[1,2,3]") == 1, "indent=0 == compact");

var cv2 = json_v_build_pretty(json_v_parse_str("[1,2,3]", 7), 0 - 4);
assert(streq(str_data(cv2), "[1,2,3]") == 1, "indent<0 == compact");

# ── Scalars ──────────────────────────────────────────────────────────
test_group("scalars unchanged");
assert(streq(str_data(json_v_build_pretty(json_v_parse_str("null", 4), 2)), "null") == 1, "null");
assert(streq(str_data(json_v_build_pretty(json_v_parse_str("true", 4), 2)), "true") == 1, "true");
assert(streq(str_data(json_v_build_pretty(json_v_parse_str("42", 2), 2)), "42") == 1, "int");
assert(streq(str_data(json_v_build_pretty(json_v_parse_str("\"hi\"", 4), 2)), "\"hi\"") == 1, "str");

# ── Empty containers stay compact ────────────────────────────────────
test_group("empty containers compact");
assert(streq(str_data(json_v_build_pretty(json_v_parse_str("[]", 2), 2)), "[]") == 1, "empty arr");
assert(streq(str_data(json_v_build_pretty(json_v_parse_str("{}", 2), 2)), "{}") == 1, "empty obj");

# ── Simple array, indent=2 ──────────────────────────────────────────
test_group("array indent=2");
var a1 = json_v_build_pretty(json_v_parse_str("[1,2,3]", 7), 2);
assert(streq(str_data(a1), "[\n  1,\n  2,\n  3\n]") == 1, "[1,2,3] @ 2");

# ── Simple object, indent=2 ──────────────────────────────────────────
test_group("object indent=2");
var o1 = json_v_build_pretty(json_v_parse_str("{\"a\":1,\"b\":2}", 13), 2);
assert(streq(str_data(o1), "{\n  \"a\": 1,\n  \"b\": 2\n}") == 1, "{a:1,b:2} @ 2");

# ── Nested mix, indent=2 ─────────────────────────────────────────────
test_group("nested indent=2");
var n1 = json_v_build_pretty(json_v_parse_str("{\"x\":[1,2]}", 11), 2);
assert(streq(str_data(n1), "{\n  \"x\": [\n    1,\n    2\n  ]\n}") == 1, "{x:[1,2]} @ 2");

# ── Empty arr inside obj keeps compact tail ──────────────────────────
test_group("empty arr inside obj");
var n2 = json_v_build_pretty(json_v_parse_str("{\"e\":[]}", 8), 2);
assert(streq(str_data(n2), "{\n  \"e\": []\n}") == 1, "{e:[]} @ 2");

# ── Indent=4 step ────────────────────────────────────────────────────
test_group("indent=4 step");
var w1 = json_v_build_pretty(json_v_parse_str("[1]", 3), 4);
assert(streq(str_data(w1), "[\n    1\n]") == 1, "[1] @ 4");

# ── Round-trip: parse → pretty → parse → compact ─────────────────────
test_group("round-trip parse(pretty(parse(x))) preserves compact form");
var src1 = "{\"users\":[{\"id\":1,\"name\":\"a\"},{\"id\":2,\"name\":\"b\"}]}";
var v_src1 = json_v_parse_str(src1, 51);
var compact1 = json_v_build(v_src1);
var pretty1 = json_v_build_pretty(v_src1, 2);
var reparsed1 = json_v_parse_str(str_data(pretty1), str_len(pretty1));
assert(reparsed1 != 0, "pretty output reparses");
var compact1b = json_v_build(reparsed1);
assert(streq(str_data(compact1), str_data(compact1b)) == 1, "round-trip preserves shape");

var src2 = "{\"a\":{\"b\":{\"c\":[1,2,3]}}}";
var v_src2 = json_v_parse_str(src2, 25);
var pretty2 = json_v_build_pretty(v_src2, 2);
var reparsed2 = json_v_parse_str(str_data(pretty2), str_len(pretty2));
assert(reparsed2 != 0, "deep nest pretty reparses");
assert(streq(str_data(json_v_build(v_src2)), str_data(json_v_build(reparsed2))) == 1, "deep nest round-trip");

# ── String escapes preserved through pretty path ────────────────────
test_group("string escapes through pretty");
var obj_e = json_v_obj_new();
var msg_buf = alloc(16);
store8(msg_buf, 108);     # l
store8(msg_buf + 1, 105); # i
store8(msg_buf + 2, 110); # n
store8(msg_buf + 3, 101); # e
store8(msg_buf + 4, 49);  # 1
store8(msg_buf + 5, 10);  # \n
store8(msg_buf + 6, 108); # l
store8(msg_buf + 7, 105); # i
store8(msg_buf + 8, 110); # n
store8(msg_buf + 9, 101); # e
store8(msg_buf + 10, 50); # 2
store8(msg_buf + 11, 0);
json_v_obj_set(obj_e, str_from("msg"), json_v_str_new(str_new(msg_buf, 11)));
var pretty_e = json_v_build_pretty(obj_e, 2);
assert(streq(str_data(pretty_e), "{\n  \"msg\": \"line1\\nline2\"\n}") == 1, "embedded \\n re-escaped under pretty");

var r = assert_summary();
