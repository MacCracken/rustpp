# v5.7.25 — TS mapped types + `as`-clause + `+/-readonly`/`+/-?` modifiers.
#
# Pre-v5.7.25 the parser handled `[k: K]: V` index signatures but
# treated `[K in T]: V` mapped types as a syntax error (KW_IN
# unexpected after consuming the bracket-key IDENT and a `:` that
# wasn't there). v5.7.25 adds:
#
#   - `[K in T]: V`                  — bare mapped type (TS 2.1+)
#   - `[K in T as U]: V`             — key remapping (TS 4.5+)
#   - `readonly [K in T]: V`         — readonly modifier (already worked)
#   - `+readonly` / `-readonly`      — explicit add/remove (TS 2.8+)
#   - `[K in T]?: V`                 — optional modifier
#   - `[K in T]+?: V` / `-?: V`      — explicit add/remove ? modifier
#
# Detection: peek == LBRACKET, peek_ahead(1) is name-like, peek_ahead(2)
# == KW_IN → mapped type. Otherwise existing index-signature path.
# Modifier prefix consume extended to handle `+/-readonly` alongside
# bare `readonly`.

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/syscalls.cyr"
include "lib/assert.cyr"

include "src/frontend/ts/lex.cyr"
include "src/frontend/ts/parse.cyr"

alloc_init();
var ts_base = alloc(TS_HEAP_SIZE + 4096);

fn parse_first_stmt(src) {
    var nt = TS_LEX(ts_base, src, strlen(src));
    if (nt < 0) { return 0 - 1; }
    var nn = TS_PARSE(ts_base);
    if (nn < 0) { return 0 - 1; }
    var head = TS_AST_PAYLOAD(ts_base, 0, 0);
    return TS_AST_CHILDREN_GET(ts_base, head);
}

# ─── bare mapped type ───────────────────────────────────────────
test_group("bare mapped type [K in T]: V");

var s = parse_first_stmt("type Pick<T, K extends keyof T> = { [P in K]: T[P] };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "[P in K]: T[P]");

s = parse_first_stmt("type R<T> = { [K in keyof T]: T[K] };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "[K in keyof T]: T[K]");

s = parse_first_stmt("type U = { [K in 'a' | 'b']: number };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "[K in union literal]: V");

# ─── as-clause key remapping ───────────────────────────────────
test_group("as-clause key remapping");

s = parse_first_stmt("type R<T> = { [K in keyof T as Capitalize<string & K>]: T[K] };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "[K in keyof T as <remap>]: T[K]");

s = parse_first_stmt("type Filter<T, U> = { [K in keyof T as T[K] extends U ? K : never]: T[K] };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "as-clause with conditional");

s = parse_first_stmt("type Prefix<T> = { [K in keyof T as `_${string & K}`]: T[K] };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "as-clause with template literal");

# ─── readonly modifier (incl. explicit +/-) ────────────────────
test_group("readonly modifiers");

s = parse_first_stmt("type R<T> = { readonly [K in keyof T]: T[K] };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "readonly [K in T]: V");

s = parse_first_stmt("type AddR<T> = { +readonly [K in keyof T]: T[K] };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "+readonly [K in T]: V");

s = parse_first_stmt("type Mut<T> = { -readonly [K in keyof T]: T[K] };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "-readonly [K in T]: V");

# ─── optional modifier (incl. explicit +/-) ────────────────────
test_group("? modifiers");

s = parse_first_stmt("type P<T> = { [K in keyof T]?: T[K] };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "[K in T]?: V");

s = parse_first_stmt("type Opt<T> = { [K in keyof T]+?: T[K] };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "[K in T]+?: V");

s = parse_first_stmt("type Req<T> = { [K in keyof T]-?: T[K] };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "[K in T]-?: V");

# ─── combined modifiers + as-clause ────────────────────────────
test_group("combined forms");

s = parse_first_stmt("type X<T> = { -readonly [K in keyof T as `_${string & K}`]-?: T[K] };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "-readonly + as + -? combined");

s = parse_first_stmt("type Y<T> = { +readonly [K in keyof T as Lowercase<K & string>]+?: T[K] };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "+readonly + as + +? combined");

# ─── regressions: index signatures + plain props ───────────────
test_group("regressions — pre-v5.7.25 forms still pass");

s = parse_first_stmt("type R = { [k: string]: number };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "[k: string]: number index sig");

s = parse_first_stmt("type S = { readonly [k: number]: string };");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_TYPE_ALIAS, "readonly index sig");

s = parse_first_stmt("interface I { readonly name: string; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_INTERFACE, "readonly property");

var exit_code = assert_summary();
syscall(60, exit_code);
