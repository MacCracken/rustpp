# Test: mulh64(a, b) — high 64 bits of 64x64 unsigned multiply
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/assert.cyr"

test_group("mulh64 small values");
assert_eq(mulh64(0, 0), 0, "mulh64(0, 0) = 0");
assert_eq(mulh64(1, 1), 0, "mulh64(1, 1) = 0");
assert_eq(mulh64(42, 99), 0, "mulh64(42, 99) = 0 (fits in 64)");

test_group("mulh64 powers of 2");
# 2^32 * 2^32 = 2^64 → high = 1, low = 0
assert_eq(mulh64(0x100000000, 0x100000000), 1, "mulh64(2^32, 2^32) = 1");
# 2^63 * 2 = 2^64 → high = 1
assert_eq(mulh64(0x8000000000000000, 2), 1, "mulh64(2^63, 2) = 1");
# 2^63 * 4 = 2^65 → high = 2
assert_eq(mulh64(0x8000000000000000, 4), 2, "mulh64(2^63, 4) = 2");

test_group("mulh64 full-width UNSIGNED (not signed IMUL)");
# -1 (u64: 0xFFFFFFFFFFFFFFFF) * 2 = 0x1_FFFFFFFFFFFFFFFE; high = 1
assert_eq(mulh64(0 - 1, 2), 1, "mulh64(0xFFFF...FF, 2) = 1 (unsigned)");
# -1 * -1 = 0xFFFFFFFFFFFFFFFE_0000000000000001; high = 0xFFFFFFFFFFFFFFFE
assert_eq(mulh64(0 - 1, 0 - 1), 0 - 2, "mulh64(0xFFFF...FF, 0xFFFF...FF) = 0xFFFF...FE");

test_group("mulh64 commutative");
assert_eq(mulh64(0x123456789ABCDEF0, 0x1000), mulh64(0x1000, 0x123456789ABCDEF0), "commutative");

test_group("mulh64 matches known u128 result");
# 0xFFFFFFFFFFFFFFFF * 0xFFFFFFFF → high bits
# Full product: 0xFFFFFFFEFFFFFFFF_00000001
# high = 0xFFFFFFFE = 4294967294
assert_eq(mulh64(0 - 1, 0xFFFFFFFF), 0xFFFFFFFE, "mulh64(0xFFFF...FF, 0xFFFFFFFF) = 0xFFFFFFFE");
# 0xFFFFFFFF * 0xFFFFFFFF = 0xFFFFFFFE_00000001 — fits in 64, high = 0
assert_eq(mulh64(0xFFFFFFFF, 0xFFFFFFFF), 0, "mulh64(0xFFFFFFFF, 0xFFFFFFFF) = 0");

var r = assert_summary();
