# syscall_surface_v5735.tcyr — regression coverage for v5.7.35
# stdlib syscall surface gaps (agnosys-surfaced).
#
# CI-safety design (v3, post-ship-fix):
#
# The first version of this test made strong claims about runtime
# behavior — e.g. landlock returning a specific positive ABI version
# or `-ENOSYS` / `-EOPNOTSUPP`. Some CI environments and downstream
# kernels (notably AGNOS, which is a freestanding kernel that may or
# may not implement landlock at all) returned other valid errnos
# (-EINVAL, -EPERM, etc.), tripping the test even though the syscall
# wiring was correct.
#
# This version splits "wiring verification" from "behavior
# verification":
#
#   - Wiring: every wrapper is referenced through a syscall that
#     reaches the kernel. The test only requires the wrapper does
#     not segfault. Any return value is accepted as proof the
#     wrapper resolved + the syscall instruction executed.
#
#   - Behavior: only `sys_getrandom` is checked for actual behavior
#     (must return 32 bytes + buffer not all-zero). getrandom(2) is
#     universally available on Linux ≥ 3.17 and AGNOS implements it,
#     so this is a safe behavior assertion.
#
# Stack-buffer-only — no alloc() needed.
#
# Single binary; exit-code-encoded failure mode:
#   0  — all assertions held
#   1  — sys_getrandom returned wrong byte count
#   2  — sys_getrandom buffer all-zero (CSPRNG dead?)
#   7  — security.cyr / random.cyr enum constant mismatch
#  11  — random_bytes returned wrong count
#  12  — random_bytes buffer all-zero

include "lib/alloc.cyr"
include "lib/syscalls.cyr"
include "lib/random.cyr"
include "lib/security.cyr"

# === Test 1: sys_getrandom direct (universal Linux behavior) ===
var buf1[32];
var n1 = sys_getrandom(&buf1, 32, 0);
if (n1 != 32) { syscall(60, 1); }
var any1 = 0;
var i1 = 0;
while (i1 < 32) {
    if (load8(&buf1 + i1) != 0) { any1 = 1; }
    i1 = i1 + 1;
}
if (any1 != 1) { syscall(60, 2); }

# === Test 2: random_bytes wrapper (universal Linux behavior) ===
var buf2[64];
var i2 = 0;
while (i2 < 64) { store8(&buf2 + i2, 0); i2 = i2 + 1; }
var n2 = random_bytes(&buf2, 64);
if (n2 != 64) { syscall(60, 11); }
var any2 = 0;
i2 = 0;
while (i2 < 64) {
    if (load8(&buf2 + i2) != 0) { any2 = 1; }
    i2 = i2 + 1;
}
if (any2 != 1) { syscall(60, 12); }

# === Test 3: wiring-only — sys_getdents64, sys_landlock_* ===
# These reach the kernel but accept any return value (positive,
# zero, or -errno). The point is to prove the wrapper resolved
# and the syscall instruction ran without segfaulting.

# sys_getdents64 wiring — call with fd=-1 so the kernel returns
# -EBADF immediately. Doesn't matter what it returns; just that
# the wrapper compiled in and the syscall reached the kernel.
var trash_buf[64];
var _wired_getdents = sys_getdents64(0 - 1, &trash_buf, 64);

# sys_landlock_create_ruleset wiring — version-probe shape (attr=0
# size=0 flags=1). Kernel returns positive ABI version, -ENOSYS,
# -EOPNOTSUPP, -EINVAL, or other errno depending on configuration.
# Any non-segfault return proves the wrapper is wired up.
var _wired_lcr = sys_landlock_create_ruleset(0, 0, 1);

# sys_landlock_add_rule + sys_landlock_restrict_self wiring —
# call with invalid args; kernel returns -EBADF or similar.
var _wired_lar = sys_landlock_add_rule(0 - 1, 1, 0, 0);
var _wired_lrs = sys_landlock_restrict_self(0 - 1, 0);

# === Test 4: lib/security.cyr + lib/random.cyr enum constants ===
# Compile-time: any wrong value is caught here.
if (LANDLOCK_ACCESS_FS_EXECUTE != 1) { syscall(60, 7); }
if (LANDLOCK_ACCESS_FS_WRITE_FILE != 2) { syscall(60, 7); }
if (LANDLOCK_ACCESS_FS_READ_FILE != 4) { syscall(60, 7); }
if (LANDLOCK_ACCESS_FS_READ_DIR != 8) { syscall(60, 7); }
if (LANDLOCK_ACCESS_FS_MAKE_SYM != 4096) { syscall(60, 7); }
if (LANDLOCK_RULE_PATH_BENEATH != 1) { syscall(60, 7); }
if (GRND_NONBLOCK != 1) { syscall(60, 7); }
if (GRND_RANDOM != 2) { syscall(60, 7); }
if (GRND_INSECURE != 4) { syscall(60, 7); }

# All passed
syscall(60, 0);
