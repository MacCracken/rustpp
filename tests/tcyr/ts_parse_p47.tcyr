# v5.7.x P4.8 — modifier-vs-name disambiguation in
# TS_PARSE_SKIP_MODIFIERS. Modifier keywords (public/private/protected/
# static/readonly/abstract/async/override/declare) are contextual —
# they're modifiers ONLY when followed by a name or another modifier;
# otherwise they're the name. Pre-fix, the front-only consume loop
# always ate them, breaking `function f(override?: T)` and
# `class C { override(): void {} }`.
#
# Slot lifted +6 SY corpus .ts files (the most-impactful single fix
# in the v5.7.x cyrius-ts polish arc so far).

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/syscalls.cyr"
include "lib/assert.cyr"

include "src/frontend/ts/lex.cyr"
include "src/frontend/ts/parse.cyr"

alloc_init();
var ts_base = alloc(TS_HEAP_SIZE + 4096);

fn parse_first_stmt(src) {
    var nt = TS_LEX(ts_base, src, strlen(src));
    if (nt < 0) { return 0 - 1; }
    var nn = TS_PARSE(ts_base);
    if (nn < 0) { return 0 - 1; }
    var head = TS_AST_PAYLOAD(ts_base, 0, 0);
    return TS_AST_CHILDREN_GET(ts_base, head);
}

# ─── modifier kw used as param name ──────────────────────────────
test_group("modifier kw used as param name");

var s = parse_first_stmt("function f(override?: string) { return; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "f(override?: string)");

s = parse_first_stmt("function g(declare: number, async: boolean) { return; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "g(declare, async)");

s = parse_first_stmt("function h(readonly: string, public: number) { return; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "h(readonly, public)");

s = parse_first_stmt("function i(static = 1, abstract = 2) { return; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_FUNCTION, "i(static, abstract) with defaults");

# ─── modifier kw used as method/prop name ────────────────────────
test_group("modifier kw used as method/prop name");

s = parse_first_stmt("class C { override(): void {} }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class C { override(): void }");

s = parse_first_stmt("class D { async = 1; readonly = 'x'; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class D { async, readonly as props }");

s = parse_first_stmt("class E { declare(x: number): void {} }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class E { declare() method }");

# ─── regression: real modifier usage still works ────────────────
test_group("regression: real modifier usage");

s = parse_first_stmt("class F { private readonly x: string = 'a'; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class F { private readonly x }");

s = parse_first_stmt("class G { override foo(): void {} }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class G { override foo() }");

s = parse_first_stmt("class H { async fetch(): Promise<void> { return; } }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class H { async fetch() }");

s = parse_first_stmt("class I { static name = 'I'; protected count = 0; }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class I { static + protected props }");

# ─── regression: constructor parameter properties ───────────────
test_group("regression: constructor parameter properties");

s = parse_first_stmt("class J { constructor(public x: number, private readonly y: string) {} }");
assert_eq(TS_AST_KIND(ts_base, s), TS_AST_DECL_CLASS, "class J { constructor(public x, private readonly y) }");

var exit_code = assert_summary();
syscall(60, exit_code);
