# lib/http_server.cyr unit tests — parsing + path/query helpers.
# Covers the pure-parsing surface (no socket work — that's lib_http_server_example.cyr
# territory, exercised by the E2E smoke during development).
include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/str.cyr"
include "lib/vec.cyr"
include "lib/hashmap.cyr"
include "lib/freelist.cyr"
include "lib/fnptr.cyr"
include "lib/syscalls.cyr"
include "lib/tagged.cyr"
include "lib/net.cyr"
include "lib/assert.cyr"
include "lib/http_server.cyr"

fn mk_req(s) { return s; }   # identity; strlen does the rest

alloc_init();

test_group("status code constants");
assert_eq(HTTP_OK, 200, "200");
assert_eq(HTTP_NOT_FOUND, 404, "404");
assert_eq(HTTP_INTERNAL, 500, "500");

test_group("http_get_method");
var r1 = mk_req("GET /foo HTTP/1.1\r\nHost: x\r\n\r\n");
assert_eq(streq(http_get_method(r1, strlen(r1)), "GET"), 1, "GET");
var r2 = mk_req("POST /x HTTP/1.1\r\n\r\n");
assert_eq(streq(http_get_method(r2, strlen(r2)), "POST"), 1, "POST");

test_group("http_get_path");
assert_eq(streq(http_get_path(r1, strlen(r1)), "/foo"), 1, "/foo");
var r3 = mk_req("GET /a/b/c?x=1 HTTP/1.1\r\n\r\n");
assert_eq(streq(http_get_path(r3, strlen(r3)), "/a/b/c?x=1"), 1, "path with query");

test_group("http_body_offset");
var r4 = mk_req("POST / HTTP/1.1\r\nContent-Length: 5\r\n\r\nhello");
var bo = http_body_offset(r4, strlen(r4));
assert(bo > 0, "body offset found");
assert_eq(memeq(r4 + bo, "hello", 5), 1, "body matches");
var r5 = mk_req("POST / HTTP/1.1\r\nNo Body");
assert_eq(http_body_offset(r5, strlen(r5)), 0 - 1, "no \\r\\n\\r\\n returns -1");

test_group("http_content_length");
assert_eq(http_content_length(r4, strlen(r4)), 5, "Content-Length: 5");
var r_nocl = mk_req("GET / HTTP/1.1\r\n\r\n");
assert_eq(http_content_length(r_nocl, strlen(r_nocl)), 0, "missing header returns 0");

test_group("http_find_header (case-insensitive)");
var r6 = mk_req("GET / HTTP/1.1\r\nHost: example.com\r\nUser-Agent: bot\r\n\r\n");
var host = http_find_header(r6, strlen(r6), "Host");
assert_eq(streq(host, "example.com"), 1, "Host exact");
var ua = http_find_header(r6, strlen(r6), "user-agent");
assert_eq(streq(ua, "bot"), 1, "case-insensitive match");
var miss = http_find_header(r6, strlen(r6), "X-Missing");
assert_eq(miss, 0, "missing header returns 0");

test_group("http_path_only");
var p1 = http_path_only("/foo?bar=baz");
assert_eq(streq(p1, "/foo"), 1, "strips query");
var p2 = http_path_only("/nothingquery");
assert_eq(streq(p2, "/nothingquery"), 1, "no-query passthrough");

test_group("http_url_decode");
assert_eq(streq(http_url_decode("hello"), "hello"), 1, "no-op on alphanum");
assert_eq(streq(http_url_decode("hello%20world"), "hello world"), 1, "%20 decode");
assert_eq(streq(http_url_decode("a+b"), "a b"), 1, "+ to space");
assert_eq(streq(http_url_decode("%2F"), "/"), 1, "%2F slash");
var dec_ff = http_url_decode("%ff");
assert_eq(load8(dec_ff), 255, "lowercase hex decodes to byte 255");
assert_eq(load8(dec_ff + 1), 0, "nul-terminated");

test_group("http_get_param");
var q = http_get_param("/search?q=hello%20world&n=5", "q");
assert_eq(streq(q, "hello world"), 1, "first param decoded");
var n = http_get_param("/search?q=hello&n=5", "n");
assert_eq(streq(n, "5"), 1, "second param");
var missing = http_get_param("/search?q=hello", "missing");
assert_eq(missing, 0, "missing returns 0");
var noq = http_get_param("/noquery", "any");
assert_eq(noq, 0, "no query string returns 0");

test_group("http_path_segment");
var s0 = http_path_segment("/a/b/c", 0);
assert_eq(streq(s0, "a"), 1, "seg 0 is 'a'");
var s1 = http_path_segment("/a/b/c", 1);
assert_eq(streq(s1, "b"), 1, "seg 1 is 'b'");
var s2 = http_path_segment("/a/b/c", 2);
assert_eq(streq(s2, "c"), 1, "seg 2 is 'c'");
var soob = http_path_segment("/a/b/c", 5);
assert_eq(soob, 0, "out-of-range returns 0");

var r = assert_summary();
