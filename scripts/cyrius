#!/bin/sh
# cyrius — thin shim that finds and execs the compiled Cyrius Build Tool.
# The real tool is build/cyrius (compiled from cbt/cyrius.cyr).
# This shim exists for: PATH discovery, installed toolchain routing,
# and fallback when the compiled binary isn't available.
set -e

CYRIUS_DIR="${CYRIUS_HOME:-$HOME/.cyrius}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Find compiled cyrius binary
CYRIUS_BIN=""
for _try in "$SCRIPT_DIR/../build/cyrius" \
            "${CYRIUS_DIR}/bin/cyrius" \
            "${CYRIUS_DIR}/versions/$(cat "$CYRIUS_DIR/current" 2>/dev/null)/bin/cyrius"; do
    if [ -x "$_try" ] && file "$_try" 2>/dev/null | grep -q ELF; then
        CYRIUS_BIN="$_try"
        break
    fi
done

if [ -n "$CYRIUS_BIN" ]; then
    exec "$CYRIUS_BIN" "$@"
fi

# Fallback: no compiled binary found
echo "error: compiled cyrius tool not found." >&2
echo "  Build it: cat cbt/cyrius.cyr | build/cc5 > build/cyrius && chmod +x build/cyrius" >&2
echo "  Or install: curl -sSf https://raw.githubusercontent.com/MacCracken/cyrius/main/scripts/install.sh | sh" >&2
exit 1
