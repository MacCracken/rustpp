#!/bin/sh
# cyrb — Cyrius Build Tool
# Dispatcher that routes subcommands to individual tools.
#
# Like git dispatches to git-commit, git-push, etc.
# Each subcommand is either a Cyrius binary or a shell script.

set -e

# Read version from VERSION file (relative to script or repo root)
SCRIPT_DIR_V="$(cd "$(dirname "$0")" && pwd)"
if [ -f "$SCRIPT_DIR_V/../VERSION" ]; then
    VERSION=$(cat "$SCRIPT_DIR_V/../VERSION" | tr -d '[:space:]')
elif [ -f "VERSION" ]; then
    VERSION=$(cat VERSION | tr -d '[:space:]')
else
    VERSION="unknown"
fi
CYRB_HOME="${CYRIUS_HOME:-$HOME/.cyrius}"
# Find cc2: installed version, then local repo fallback
CC="${CYRB_HOME}/bin/cc2"
if [ ! -x "$CC" ]; then
    # Try relative to this script (dev mode)
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    if [ -x "$SCRIPT_DIR/../build/cc2" ]; then
        CC="$SCRIPT_DIR/../build/cc2"
    else
        echo "error: cc2 not found. Install Cyrius or set CYRIUS_HOME." >&2
        exit 1
    fi
fi

# Find companion tools directory
TOOLS_DIR="$(dirname "$CC")"
SCRIPTS_DIR="$(cd "$(dirname "$0")" && pwd)"

# Read a key from cyrb.toml (section-aware, handles quotes)
# Usage: toml_get <file> <key> [section]
toml_get() {
    local file="$1" key="$2" section="${3:-}"
    if [ ! -f "$file" ]; then return 1; fi
    if [ -n "$section" ]; then
        # Extract section, then find key within it
        awk -v sec="[$section]" -v k="$key" '
            $0 == sec { in_sec=1; next }
            /^\[/ { in_sec=0 }
            in_sec && $1 == k { gsub(/.*= *"?/, ""); gsub(/".*/, ""); print; exit }
        ' "$file"
    else
        # Top-level key (before any section or in [package])
        awk -v k="$key" '
            /^\[/ && !/^\[package\]/ { exit }
            $1 == k { gsub(/.*= *"?/, ""); gsub(/".*/, ""); print; exit }
        ' "$file"
    fi
}

# Read all package metadata from cyrb.toml
read_manifest() {
    if [ -f "cyrb.toml" ]; then
        PKG_NAME=$(toml_get cyrb.toml name)
        PKG_VERSION=$(toml_get cyrb.toml version)
        PKG_DESC=$(toml_get cyrb.toml description)
        PKG_ENTRY=$(toml_get cyrb.toml entry)
        PKG_OUTPUT=$(toml_get cyrb.toml output)
        PKG_LICENSE=$(toml_get cyrb.toml license)
    elif [ -f "VERSION" ]; then
        PKG_VERSION=$(cat VERSION | tr -d '[:space:]')
        PKG_NAME=$(basename "$(pwd)")
        PKG_DESC="$PKG_NAME"
        PKG_ENTRY="src/main.cyr"
        PKG_OUTPUT="$PKG_NAME"
        PKG_LICENSE="GPL-3.0-only"
    else
        echo "error: no cyrb.toml or VERSION" >&2
        return 1
    fi
}

usage() {
    cat << EOF
cyrb ${VERSION} — Cyrius Build Tool

Usage: cyrb <command> [options]

Build:
  build [--aarch64 [--native]] <src> <out>  compile a program
  run [--aarch64 [--native]] <source.cyr>  compile + run (no output file)
  test [--aarch64 [--native]] <test.cyr>   compile + run, check exit 0
  bench <bench.cyr>               compile + run benchmarks
  check <source.cyr>              syntax check (compile without output)
  self                            self-hosting check (cc2==cc3)
  pulsar                          rebuild cc2 + tools from source, install, purge old versions
  clean                           remove build/ contents

Project:
  init <name>                     scaffold a new project
  package                         create .ark distributable
  publish                         push package to Ark registry
  install <pkg>                   install package from registry
  update                          update vendored stdlib
  deps                            show resolved dependencies from cyrb.toml

Quality:
  audit                           full check: self-host, test, fmt, lint, vet, deny, bench
  fmt <file.cyr> [--check]        format code (or check formatting)
  lint <file.cyr>                 static analysis warnings
  doc [--check] <file.cyr>        generate/check documentation
  vet <source.cyr>                audit include dependencies
  deny <source.cyr>               enforce project policies

Testing:
  coverage                        report test coverage by library file
  doctest <file.cyr> [...]        run doc examples (# >>> / # ===)

Documentation:
  docs [--agent] [--port N]       serve project docs (default: HTML, --agent: markdown)

Interactive:
  repl                            interactive expression evaluator

Info:
  version                         show cyrb version
  which                           show path to cc2
  help                            show this help

EOF
}

# ── Dependency resolution ──

# Read array value from TOML: stdlib = ["a", "b", "c"] → "a b c"
toml_array() {
    local file="$1" key="$2" section="${3:-deps}"
    awk -v sec="[$section]" -v k="$key" '
        $0 == sec { in_sec=1; next }
        /^\[/ && in_sec { in_sec=0 }
        in_sec && $0 ~ k {
            gsub(/.*\[/, ""); gsub(/\].*/, "");
            gsub(/"/, ""); gsub(/,/, " "); gsub(/  +/, " ");
            gsub(/^ +| +$/, ""); print; exit
        }
    ' "$file"
}

# Read dep sections: [deps.NAME] with path= or git= and tag=
toml_dep_names() {
    local file="$1"
    grep '^\[deps\.' "$file" 2>/dev/null | sed 's/\[deps\.//; s/\]//' | sort -u
}

# Fetch git dependency to ~/.cyrius/deps/<name>/<tag>/
fetch_git_dep() {
    local name="$1" url="$2" tag="$3"
    local dest="$CYRB_HOME/deps/$name/$tag"
    if [ -d "$dest" ]; then return 0; fi
    mkdir -p "$dest"
    echo "  fetch $name@$tag..."
    git clone --depth 1 --branch "$tag" "$url" "$dest" 2>/dev/null || \
        git clone --depth 1 "$url" "$dest" 2>/dev/null
}

# Resolve all dependencies from cyrb.toml → write include list to file
# Output: one "include ..." line per dependency, in correct order
resolve_deps() {
    local manifest="${1:-cyrb.toml}"
    local outfile="$2"
    if [ ! -f "$manifest" ]; then return 1; fi

    # 1. Stdlib modules
    local stdlib=$(toml_array "$manifest" "stdlib")
    for mod in $stdlib; do
        # Check local lib/ first, then installed
        if [ -f "lib/${mod}.cyr" ]; then
            echo "include \"lib/${mod}.cyr\"" >> "$outfile"
        elif [ -f "$CYRB_HOME/versions/$(cat "$CYRB_HOME/current" 2>/dev/null)/lib/${mod}.cyr" ]; then
            local slib="$CYRB_HOME/versions/$(cat "$CYRB_HOME/current" 2>/dev/null)/lib/${mod}.cyr"
            echo "include \"$slib\"" >> "$outfile"
        fi
    done

    # 2. Path and git dependencies
    for dep in $(toml_dep_names "$manifest"); do
        local dpath=$(toml_get "$manifest" "path" "deps.$dep")
        local dgit=$(toml_get "$manifest" "git" "deps.$dep")
        local dtag=$(toml_get "$manifest" "tag" "deps.$dep")
        local resolve_dir=""

        if [ -n "$dpath" ]; then
            resolve_dir="$dpath"
        elif [ -n "$dgit" ]; then
            if [ -z "$dtag" ]; then dtag="main"; fi
            fetch_git_dep "$dep" "$dgit" "$dtag"
            resolve_dir="$CYRB_HOME/deps/$dep/$dtag"
        fi

        if [ -n "$resolve_dir" ] && [ -d "$resolve_dir" ]; then
            # Check for modules filter: modules = ["lib/syscalls.cyr", "src/error.cyr"]
            local mods=$(toml_array "$manifest" "modules" "deps.$dep")
            if [ -n "$mods" ]; then
                # Selective: only include listed modules
                for mod in $mods; do
                    local mf="$resolve_dir/$mod"
                    [ -f "$mf" ] && echo "include \"$mf\"" >> "$outfile"
                done
            else
                # All: include lib/*.cyr + src/*.cyr (excluding main.cyr)
                for f in "$resolve_dir"/lib/*.cyr; do
                    [ -f "$f" ] && echo "include \"$f\"" >> "$outfile"
                done
                for f in "$resolve_dir"/src/*.cyr; do
                    [ -f "$f" ] && [ "$(basename "$f")" != "main.cyr" ] && \
                        echo "include \"$f\"" >> "$outfile"
                done
            fi
        fi
    done
}

# Compile helper (used by build, test, bench)
# Args: src out [arch] [defines...]
compile() {
    local src="$1" out="$2" compiler="$CC"
    if [ "$3" = "aarch64" ]; then
        compiler="${TOOLS_DIR}/cc2_aarch64"
        if [ ! -x "$compiler" ]; then
            echo "error: cc2_aarch64 not found (run 'cyrb pulsar' to build)" >&2
            return 1
        fi
    elif [ "$3" = "aarch64-native" ]; then
        compiler="${TOOLS_DIR}/cc2-native-aarch64"
        if [ ! -x "$compiler" ]; then
            echo "error: cc2-native-aarch64 not found (run 'cyrb pulsar' to build)" >&2
            return 1
        fi
    fi
    # Prepend -D defines to source
    shift 3 2>/dev/null || true
    local defines=""
    while [ -n "$1" ]; do
        defines="${defines}#define $1
"
        shift
    done
    # Resolve dependencies from cyrb.toml if present
    local depfile=""
    if [ -f "cyrb.toml" ]; then
        local has_deps=$(grep -c '^\[deps' cyrb.toml 2>/dev/null || echo 0)
        if [ "$has_deps" -gt 0 ]; then
            depfile="/tmp/cyrb_deps_$$"
            resolve_deps "cyrb.toml" "$depfile"
        fi
    fi
    # Build: defines + deps + source → compiler
    {
        [ -n "$defines" ] && printf '%s\n' "$defines"
        [ -n "$depfile" ] && [ -f "$depfile" ] && cat "$depfile"
        cat "$src"
    } | "$compiler" > "$out" && chmod +x "$out"
    local rc=$?
    [ -n "$depfile" ] && rm -f "$depfile"
    return $rc
}

# Run a binary (x86 direct, aarch64 via qemu)
run_binary() {
    local bin="$1" arch="${2:-x86}"
    if [ "$arch" = "aarch64" ] || [ "$arch" = "aarch64-native" ]; then
        qemu-aarch64 "$bin" 2>/dev/null || qemu-aarch64-static "$bin" 2>/dev/null
    else
        "$bin"
    fi
}

case "${1:-help}" in
    # === Build commands ===
    build)
        shift
        arch="x86"
        if [ "$1" = "--aarch64" ]; then
            arch="aarch64"; shift
            if [ "$1" = "--native" ]; then arch="aarch64-native"; shift; fi
        fi
        # Collect -D flags: -D NAME or -DNAME
        defines=""
        while true; do
            case "$1" in
                -D) defines="$defines $2"; shift 2 ;;
                -D*) defines="$defines ${1#-D}"; shift ;;
                *) break ;;
            esac
        done
        if [ -z "$1" ] || [ -z "$2" ]; then
            echo "Usage: cyrb build [--aarch64 [--native]] [-D NAME]... <source.cyr> <output>"
            exit 1
        fi
        printf "compile %s -> %s [%s] " "$1" "$2" "$arch"
        if compile "$1" "$2" "$arch" $defines; then
            echo "OK ($(wc -c < "$2") bytes)"
        else
            echo "FAIL"
            exit 1
        fi
        ;;

    test)
        shift
        arch="x86"
        if [ "$1" = "--aarch64" ]; then
            arch="aarch64"; shift
            if [ "$1" = "--native" ]; then arch="aarch64-native"; shift; fi
        fi
        defines=""
        while true; do
            case "$1" in
                -D) defines="$defines $2"; shift 2 ;;
                -D*) defines="$defines ${1#-D}"; shift ;;
                *) break ;;
            esac
        done
        if [ -z "$1" ]; then
            echo "Usage: cyrb test [--aarch64] [-D NAME]... <test.cyr>"
            exit 1
        fi
        tmpbin="/tmp/cyrb_test_$$"
        if compile "$1" "$tmpbin" "$arch" $defines; then
            run_binary "$tmpbin" "$arch"
            exit_code=$?
            rm -f "$tmpbin"
            exit $exit_code
        else
            echo "FAIL: compile error" >&2
            rm -f "$tmpbin"
            exit 1
        fi
        ;;

    bench)
        shift
        if [ -z "$1" ]; then
            # No args: run full bench suite with history tracking
            exec "$REPO_ROOT/scripts/bench-history.sh"
        fi
        case "$1" in
            --tier1|--tier2|--tier3)
                exec "$REPO_ROOT/scripts/bench-history.sh" "$1"
                ;;
            *)
                # Single benchmark file
                tmpbin="/tmp/cyrb_bench_$$"
                if compile "$1" "$tmpbin"; then
                    "$tmpbin"
                    rm -f "$tmpbin"
                else
                    echo "FAIL: compile error" >&2
                    rm -f "$tmpbin"
                    exit 1
                fi
                ;;
        esac
        ;;

    self)
        echo "=== Self-Hosting Check ==="
        cc3="/tmp/cyrb_cc3_$$"
        cc4="/tmp/cyrb_cc4_$$"
        # Find cc2.cyr source
        CC2_SRC=""
        if [ -f "src/main.cyr" ]; then CC2_SRC="src/main.cyr"; fi
        if [ -f "../cyrius/src/main.cyr" ]; then CC2_SRC="../cyrius/src/main.cyr"; fi
        if [ -z "$CC2_SRC" ]; then
            echo "error: src/main.cyr not found" >&2
            exit 1
        fi
        cat "$CC2_SRC" | "$CC" > "$cc3" && chmod +x "$cc3"
        cat "$CC2_SRC" | "$cc3" > "$cc4"
        if cmp -s "$cc3" "$cc4"; then
            echo "  PASS: cc2==cc3 byte-identical"
            rm -f "$cc3" "$cc4"
        else
            echo "  FAIL: cc2!=cc3"
            rm -f "$cc3" "$cc4"
            exit 1
        fi
        ;;

    # === Project commands ===
    init)
        shift
        if [ -z "$1" ]; then
            echo "Usage: cyrb init <project-name>"
            exit 1
        fi
        # Find the init script
        init_script=""
        for p in "$CYRB_HOME/bin/cyrb-init" "$SCRIPTS_DIR/cyrb-init.sh" "$SCRIPTS_DIR/../scripts/cyrb-init.sh"; do
            if [ -x "$p" ]; then init_script="$p"; break; fi
        done
        if [ -z "$init_script" ]; then
            echo "error: cyrb-init not found" >&2
            exit 1
        fi
        sh "$init_script" "$@"
        ;;

    package)
        shift
        read_manifest || exit 1
        echo "=== cyrb package ==="
        echo "  name:    $PKG_NAME"
        echo "  version: $PKG_VERSION"
        echo "  entry:   $PKG_ENTRY"
        # Build
        mkdir -p build
        if [ -f "$PKG_ENTRY" ]; then
            echo "  compiling..."
            cat "$PKG_ENTRY" | "$CC" > "build/$PKG_OUTPUT" && chmod +x "build/$PKG_OUTPUT"
        fi
        # Create .ark package
        mkdir -p "build/pkg"
        cat > "build/pkg/manifest.json" << MANIFEST
{"name": "$PKG_NAME", "version": "$PKG_VERSION", "description": "$PKG_DESC", "license": "$PKG_LICENSE", "type": "binary"}
MANIFEST
        if [ -x "build/$PKG_OUTPUT" ]; then
            cp "build/$PKG_OUTPUT" "build/pkg/"
        fi
        tar -czf "build/${PKG_NAME}-${PKG_VERSION}.ark" -C "build/pkg" .
        rm -rf "build/pkg"
        SZ=$(wc -c < "build/${PKG_NAME}-${PKG_VERSION}.ark")
        echo "  -> build/${PKG_NAME}-${PKG_VERSION}.ark ($SZ bytes)"
        ;;

    publish)
        shift
        # Find the .ark package
        if [ ! -f "VERSION" ]; then
            echo "error: no VERSION file" >&2
            exit 1
        fi
        PKG_VERSION=$(cat VERSION | tr -d '[:space:]')
        PKG_NAME=$(basename "$(pwd)")
        PKG_FILE="build/${PKG_NAME}-${PKG_VERSION}.ark"
        if [ ! -f "$PKG_FILE" ]; then
            echo "error: package not found. Run 'cyrb package' first." >&2
            exit 1
        fi
        echo "=== cyrb publish ==="
        echo "  package: $PKG_FILE"
        echo "  registry: Ark marketplace"
        echo ""
        echo "Publishing not yet connected to registry."
        echo "Package is ready at: $PKG_FILE"
        echo "Upload manually or wait for Ark registry integration."
        ;;

    install)
        shift
        if [ -z "$1" ]; then
            echo "Usage: cyrb install <package>"
            exit 1
        fi
        echo "=== cyrb install ==="
        echo "  package: $1"
        echo ""
        echo "Package registry not yet available."
        echo "Install from source: git clone <repo> && cd <repo> && cyrb build"
        ;;

    # === Quality commands ===
    vet)
        shift
        cyrc="${TOOLS_DIR}/cyrc"
        if [ ! -x "$cyrc" ]; then
            # Fallback: try to find in scripts dir
            echo "error: cyrc not found" >&2
            exit 1
        fi
        "$cyrc" vet "$@"
        ;;

    deny)
        shift
        cyrc="${TOOLS_DIR}/cyrc"
        if [ ! -x "$cyrc" ]; then
            echo "error: cyrc not found" >&2
            exit 1
        fi
        "$cyrc" deny "$@"
        ;;

    # === Audit (full project check) ===
    audit)
        shift
        sh "$SCRIPTS_DIR/check.sh"
        ;;

    # === Format + Lint ===
    fmt)
        shift
        cyrfmt="${TOOLS_DIR}/cyrfmt"
        if [ ! -x "$cyrfmt" ]; then
            echo "error: cyrfmt not found" >&2; exit 1
        fi
        if [ -z "$1" ]; then echo "Usage: cyrb fmt <file.cyr> [--check]"; exit 1; fi
        if [ "$2" = "--check" ]; then
            tmpf="/tmp/cyrb_fmt_$$"
            "$cyrfmt" "$1" > "$tmpf"
            if diff -q "$1" "$tmpf" > /dev/null 2>&1; then
                echo "ok: $1"; rm -f "$tmpf"
            else
                echo "needs formatting: $1"; rm -f "$tmpf"; exit 1
            fi
        else
            "$cyrfmt" "$1"
        fi
        ;;

    lint)
        shift
        cyrlint="${TOOLS_DIR}/cyrlint"
        if [ ! -x "$cyrlint" ]; then
            echo "error: cyrlint not found" >&2; exit 1
        fi
        if [ -z "$1" ]; then echo "Usage: cyrb lint <file.cyr>"; exit 1; fi
        "$cyrlint" "$@"
        ;;

    doc)
        shift
        cyrdoc="${TOOLS_DIR}/cyrdoc"
        if [ ! -x "$cyrdoc" ]; then
            echo "error: cyrdoc not found" >&2; exit 1
        fi
        if [ -z "$1" ]; then echo "Usage: cyrb doc [--check] <file.cyr>"; exit 1; fi
        "$cyrdoc" "$@"
        ;;

    docs)
        shift
        REPO_ROOT="$(cd "$SCRIPTS_DIR/.." 2>/dev/null && pwd || cd "$(dirname "$CC")/.." && pwd)"
        PORT="${1:-8080}"
        AGENT_MODE=0
        while [ $# -gt 0 ]; do
            case "$1" in
                --agent) AGENT_MODE=1; shift ;;
                --port) shift; PORT="$1"; shift ;;
                *) PORT="$1"; shift ;;
            esac
        done
        if [ "$AGENT_MODE" = "1" ]; then
            echo "Serving docs (markdown/agent mode) on http://localhost:$PORT"
            echo "Press Ctrl+C to stop."
            cd "$REPO_ROOT"
            python3 -c "
import http.server, os, sys

class MarkdownHandler(http.server.SimpleHTTPRequestHandler):
    def do_GET(self):
        path = self.path.lstrip('/')
        if path == '' or path == '/':
            # Index: list all .md files
            self.send_response(200)
            self.send_header('Content-Type', 'text/markdown')
            self.end_headers()
            self.wfile.write(b'# Cyrius Documentation Index\n\n')
            for root, dirs, files in os.walk('.'):
                dirs[:] = [d for d in dirs if d not in ('.git', '.claude', 'build', 'node_modules')]
                for f in sorted(files):
                    if f.endswith('.md'):
                        p = os.path.join(root, f)[2:]
                        self.wfile.write(f'- [{p}](/{p})\n'.encode())
            return
        # Serve .md files as text/markdown, .cyr as text/plain
        if os.path.isfile(path):
            self.send_response(200)
            if path.endswith('.md'):
                self.send_header('Content-Type', 'text/markdown; charset=utf-8')
            elif path.endswith('.cyr') or path.endswith('.toml'):
                self.send_header('Content-Type', 'text/plain; charset=utf-8')
            else:
                self.send_header('Content-Type', 'application/octet-stream')
            self.end_headers()
            with open(path, 'rb') as f:
                self.wfile.write(f.read())
        else:
            self.send_response(404)
            self.send_header('Content-Type', 'text/plain')
            self.end_headers()
            self.wfile.write(b'Not found\n')

http.server.HTTPServer(('', $PORT), MarkdownHandler).serve_forever()
" 2>&1
        else
            echo "Serving docs (HTML) on http://localhost:$PORT"
            echo "Press Ctrl+C to stop."
            cd "$REPO_ROOT"
            python3 -m http.server "$PORT" 2>&1
        fi
        ;;

    # === Run / Clean / Update / Check ===
    header)
        shift
        exec sh "$SCRIPTS_DIR/cyrb-header.sh" "$@"
        ;;

    port)
        shift
        exec sh "$SCRIPTS_DIR/cyrb-port.sh" "$@"
        ;;

    coverage)
        shift
        exec sh "$SCRIPTS_DIR/cyrb-coverage.sh" "$@"
        ;;

    doctest)
        shift
        exec sh "$SCRIPTS_DIR/cyrb-doctest.sh" "$CC" "$@"
        ;;

    repl)
        shift
        exec sh "$SCRIPTS_DIR/cyrb-repl.sh" "$CC" "$@"
        ;;

    run)
        shift
        arch="x86"
        if [ "$1" = "--aarch64" ]; then
            arch="aarch64"; shift
            if [ "$1" = "--native" ]; then arch="aarch64-native"; shift; fi
        fi
        defines=""
        while true; do
            case "$1" in
                -D) defines="$defines $2"; shift 2 ;;
                -D*) defines="$defines ${1#-D}"; shift ;;
                *) break ;;
            esac
        done
        if [ -z "$1" ]; then echo "Usage: cyrb run [--aarch64] [-D NAME]... <source.cyr>"; exit 1; fi
        tmpbin="/tmp/cyrb_run_$$"
        if compile "$1" "$tmpbin" "$arch" $defines; then
            run_binary "$tmpbin" "$arch"
            exit_code=$?
            rm -f "$tmpbin"
            exit $exit_code
        else
            echo "error: compile failed" >&2
            rm -f "$tmpbin"
            exit 1
        fi
        ;;

    check)
        shift
        if [ -z "$1" ]; then echo "Usage: cyrb check <source.cyr>"; exit 1; fi
        if cat "$1" | "$CC" > /dev/null 2>&1; then
            echo "ok: $1"
        else
            echo "error: $1" >&2
            exit 1
        fi
        ;;

    deps)
        shift
        if [ ! -f "cyrb.toml" ]; then echo "no cyrb.toml"; exit 1; fi
        echo "=== Dependencies for $(toml_get cyrb.toml name) ==="
        _stdlib=$(toml_array "cyrb.toml" "stdlib")
        if [ -n "$_stdlib" ]; then
            echo "stdlib: $_stdlib"
        fi
        for dep in $(toml_dep_names "cyrb.toml"); do
            _dp=$(toml_get "cyrb.toml" "path" "deps.$dep")
            _dg=$(toml_get "cyrb.toml" "git" "deps.$dep")
            _dt=$(toml_get "cyrb.toml" "tag" "deps.$dep")
            if [ -n "$_dp" ]; then
                echo "$dep: path=$_dp"
            elif [ -n "$_dg" ]; then
                _cached="$CYRB_HOME/deps/$dep/${_dt:-main}"
                _status="not fetched"
                [ -d "$_cached" ] && _status="cached"
                echo "$dep: git=$_dg tag=${_dt:-main} ($_status)"
            fi
        done
        echo ""
        echo "=== Resolved includes ==="
        _tmpf="/tmp/cyrb_deps_show_$$"
        resolve_deps "cyrb.toml" "$_tmpf"
        if [ -f "$_tmpf" ]; then cat "$_tmpf"; rm -f "$_tmpf"; fi
        ;;

    clean)
        if [ -d "build" ]; then
            # Preserve bootstrap compiler (cc2, stage1f, asm)
            for f in build/*; do
                base=$(basename "$f")
                case "$base" in
                    cc2|stage1f|asm) ;; # keep
                    *) rm -f "$f" ;;
                esac
            done
            echo "cleaned build/ (preserved cc2, stage1f, asm)"
        else
            echo "nothing to clean"
        fi
        ;;

    update)
        echo "=== cyrb update ==="
        CYRIUS_LIB="${CYRB_HOME}/versions/$(cat "${CYRB_HOME}/current" 2>/dev/null)/lib"
        if [ -d "$CYRIUS_LIB" ] && [ -d "lib" ]; then
            cp "$CYRIUS_LIB"/*.cyr lib/ 2>/dev/null
            mkdir -p lib/agnosys
            cp "$CYRIUS_LIB"/agnosys/*.cyr lib/agnosys/ 2>/dev/null
            echo "updated vendored stdlib from $(cat "${CYRB_HOME}/current")"
        else
            echo "no installed stdlib found or no lib/ directory"
            echo "manual update: cp ../cyrius/lib/*.cyr lib/"
        fi
        ;;

    # === Pulsar: rebuild + reinstall from source ===
    pulsar)
        shift
        echo "pulsar: rebuilding from source..."
        # Find repo root
        REPO="$SCRIPT_DIR_V/.."
        if [ ! -f "$REPO/src/main.cyr" ]; then
            echo "error: not in a cyrius repo (no src/main.cyr)" >&2
            exit 1
        fi
        VER=$(cat "$REPO/VERSION" | tr -d '[:space:]')

        # Step 1: rebuild cc2 from source
        echo "  cc2..."
        cat "$REPO/src/main.cyr" | "$CC" > /tmp/cyrb_pulsar_cc3 2>/dev/null
        chmod +x /tmp/cyrb_pulsar_cc3
        cat "$REPO/src/main.cyr" | /tmp/cyrb_pulsar_cc3 > /tmp/cyrb_pulsar_cc4 2>/dev/null
        if ! cmp -s /tmp/cyrb_pulsar_cc3 /tmp/cyrb_pulsar_cc4; then
            # Two-step bootstrap needed
            chmod +x /tmp/cyrb_pulsar_cc4
            cat "$REPO/src/main.cyr" | /tmp/cyrb_pulsar_cc4 > /tmp/cyrb_pulsar_cc5 2>/dev/null
            if ! cmp -s /tmp/cyrb_pulsar_cc4 /tmp/cyrb_pulsar_cc5; then
                echo "  FAIL: self-hosting diverges" >&2
                rm -f /tmp/cyrb_pulsar_cc*
                exit 1
            fi
            cp /tmp/cyrb_pulsar_cc4 "$REPO/build/cc2"
        else
            cp /tmp/cyrb_pulsar_cc3 "$REPO/build/cc2"
        fi
        chmod +x "$REPO/build/cc2"
        echo "  cc2: $(wc -c < "$REPO/build/cc2") bytes (self-host OK)"

        # Step 2: rebuild aarch64 compilers
        echo "  cc2_aarch64 (cross)..."
        cat "$REPO/src/main_aarch64.cyr" | "$REPO/build/cc2" > "$REPO/build/cc2_aarch64" 2>/dev/null
        chmod +x "$REPO/build/cc2_aarch64"
        echo "  cc2_aarch64: $(wc -c < "$REPO/build/cc2_aarch64") bytes (x86→aarch64 cross-compiler)"
        echo "  cc2-native-aarch64..."
        cat "$REPO/src/main_aarch64.cyr" | "$REPO/build/cc2_aarch64" > "$REPO/build/cc2-native-aarch64" 2>/dev/null
        chmod +x "$REPO/build/cc2-native-aarch64"
        echo "  cc2-native-aarch64: $(wc -c < "$REPO/build/cc2-native-aarch64") bytes ($(file "$REPO/build/cc2-native-aarch64" | grep -o 'ARM aarch64' || echo 'WARN: not aarch64'))"

        # Step 3: rebuild tools
        echo "  tools..."
        for tool in cyrfmt cyrlint cyrdoc cyrc ark; do
            if [ -f "$REPO/programs/${tool}.cyr" ]; then
                cat "$REPO/programs/${tool}.cyr" | "$REPO/build/cc2" > "$REPO/build/${tool}" 2>/dev/null
                chmod +x "$REPO/build/${tool}"
            fi
        done

        # Step 4: install
        echo "  install $VER..."
        DEST="$CYRB_HOME/versions/$VER"
        rm -rf "$DEST"
        mkdir -p "$DEST/lib"
        cp "$REPO/build/cc2" "$DEST/cc2"
        chmod +x "$DEST/cc2"
        cp "$REPO/build/cc2_aarch64" "$DEST/cc2_aarch64" 2>/dev/null && chmod +x "$DEST/cc2_aarch64"
        cp "$REPO/build/cc2-native-aarch64" "$DEST/cc2-native-aarch64" 2>/dev/null && chmod +x "$DEST/cc2-native-aarch64"
        cp "$REPO/lib/"*.cyr "$DEST/lib/"
        # Install cyrb shell script + helpers (NOT the compiled binary)
        cp "$REPO/scripts/cyrb" "$DEST/cyrb" && chmod +x "$DEST/cyrb"
        for script in "$REPO"/scripts/cyrb-*.sh; do
            [ -f "$script" ] && cp "$script" "$DEST/" && chmod +x "$DEST/$(basename "$script")"
        done
        ln -sf "$DEST/cc2" "$CYRB_HOME/bin/cc2"
        ln -sf "$DEST/cyrb" "$CYRB_HOME/bin/cyrb"
        ln -sf "$DEST/cc2_aarch64" "$CYRB_HOME/bin/cc2_aarch64" 2>/dev/null || true
        ln -sf "$DEST/cc2-native-aarch64" "$CYRB_HOME/bin/cc2-native-aarch64" 2>/dev/null || true

        # Cleanup old versions
        for d in "$CYRB_HOME/versions/"*; do
            dname=$(basename "$d")
            if [ "$dname" != "$VER" ]; then
                rm -rf "$d"
                echo "  removed $dname"
            fi
        done
        echo "$VER" > "$CYRB_HOME/current"

        rm -f /tmp/cyrb_pulsar_cc* /tmp/cyrb_pulsar_cross
        echo 'var x=42;syscall(60,x);' | "$CYRB_HOME/bin/cc2" > /tmp/pv 2>/dev/null && chmod +x /tmp/pv
        pv_rc=0; /tmp/pv 2>/dev/null || pv_rc=$?
        rm -f /tmp/pv
        if [ "$pv_rc" = "42" ]; then
            echo "pulsar: $VER installed. verified."
        else
            echo "pulsar: $VER installed. verify FAILED (got $pv_rc, expected 42)"
        fi
        ;;

    # === Info commands ===
    version|--version|-v)
        echo "cyrb $VERSION"
        ;;

    which)
        echo "$CC"
        ;;

    help|--help|-h)
        usage
        ;;

    *)
        echo "Unknown command: $1"
        echo "Run 'cyrb help' for usage."
        exit 1
        ;;
esac
