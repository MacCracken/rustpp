# agnostik_test.cyr — integration test for agnostik Cyrius libraries
# Tests: error, types, security, agent, audit, config
# Exit 0 = all passed

include "stage1/lib/string.cyr"
include "stage1/lib/fmt.cyr"
include "stage1/lib/alloc.cyr"
include "stage1/lib/agnostik/error.cyr"
include "stage1/lib/agnostik/types.cyr"
include "stage1/lib/agnostik/security.cyr"
include "stage1/lib/agnostik/agent.cyr"
include "stage1/lib/agnostik/audit.cyr"
include "stage1/lib/agnostik/config.cyr"

var _pass = 0;
var _fail = 0;

fn ok(name) {
    _pass = _pass + 1;
    return 0;
}

fn fail(name) {
    _fail = _fail + 1;
    syscall(1, 2, "FAIL: ", 6);
    syscall(1, 2, name, strlen(name));
    syscall(1, 2, "\n", 1);
    return 0;
}

fn test_errors() {
    println("--- errors ---");
    if (ERR_NONE == 0) { ok("a"); } else { fail("ERR_NONE"); }
    if (ERR_AGENT_NOT_FOUND == 1001) { ok("a"); } else { fail("code 1001"); }
    if (ERR_IO == 1010) { ok("a"); } else { fail("code 1010"); }
    if (err_is_retriable(ERR_TIMEOUT) == 1) { ok("a"); } else { fail("timeout retriable"); }
    if (err_is_retriable(ERR_RESOURCE_EXHAUSTED) == 1) { ok("a"); } else { fail("resource retriable"); }
    if (err_is_retriable(ERR_PERMISSION_DENIED) == 0) { ok("a"); } else { fail("perm not retriable"); }
    if (err_is_retriable(ERR_INTERNAL) == 0) { ok("a"); } else { fail("internal not retriable"); }
    return 0;
}

fn test_types() {
    println("--- types ---");
    if (AGENT_SYSTEM == 0) { ok("a"); } else { fail("agent_system"); }
    if (AGENT_SERVICE == 2) { ok("a"); } else { fail("agent_service"); }
    if (STATUS_RUNNING == 2) { ok("a"); } else { fail("status_running"); }
    if (STATUS_FAILED == 8) { ok("a"); } else { fail("status_failed"); }
    if (status_is_terminal(STATUS_STOPPED) == 1) { ok("a"); } else { fail("stopped terminal"); }
    if (status_is_terminal(STATUS_TERMINATED) == 1) { ok("a"); } else { fail("terminated terminal"); }
    if (status_is_terminal(STATUS_FAILED) == 1) { ok("a"); } else { fail("failed terminal"); }
    if (status_is_terminal(STATUS_RUNNING) == 0) { ok("a"); } else { fail("running not terminal"); }
    if (status_is_active(STATUS_RUNNING) == 1) { ok("a"); } else { fail("running active"); }
    if (status_is_active(STATUS_PAUSED) == 0) { ok("a"); } else { fail("paused not active"); }
    if (MSG_HEARTBEAT == 3) { ok("a"); } else { fail("msg_heartbeat"); }
    if (SYS_CRITICAL == 2) { ok("a"); } else { fail("sys_critical"); }
    if (CB_HALF_OPEN == 2) { ok("a"); } else { fail("cb_half_open"); }
    if (ENV_PRODUCTION == 4) { ok("a"); } else { fail("env_production"); }
    return 0;
}

fn test_security() {
    println("--- security ---");
    var ctx = sec_ctx_new(1);
    if (sec_has_perm(ctx, PERM_FILE_READ) == 0) { ok("a"); } else { fail("no perms default"); }
    sec_grant_perm(ctx, PERM_FILE_READ);
    sec_grant_perm(ctx, PERM_NETWORK);
    if (sec_has_perm(ctx, PERM_FILE_READ) == 1) { ok("a"); } else { fail("file_read granted"); }
    if (sec_has_perm(ctx, PERM_NETWORK) == 1) { ok("a"); } else { fail("network granted"); }
    if (sec_has_perm(ctx, PERM_PROCESS_SPAWN) == 0) { ok("a"); } else { fail("spawn not granted"); }
    sec_revoke_perm(ctx, PERM_FILE_READ);
    if (sec_has_perm(ctx, PERM_FILE_READ) == 0) { ok("a"); } else { fail("file_read revoked"); }
    if (sec_has_perm(ctx, PERM_NETWORK) == 1) { ok("a"); } else { fail("network still"); }
    if (sec_get_role(ctx) == ROLE_VIEWER) { ok("a"); } else { fail("default viewer"); }
    sec_set_role(ctx, ROLE_ADMIN);
    if (role_is_admin(sec_get_role(ctx)) == 1) { ok("a"); } else { fail("admin check"); }
    return 0;
}

fn test_agent() {
    println("--- agent ---");
    var cfg = agent_config_new("test");
    if (agent_config_type(cfg) == AGENT_USER) { ok("a"); } else { fail("type=user"); }
    if (agent_config_restart(cfg) == RESTART_NEVER) { ok("a"); } else { fail("restart=never"); }
    agent_config_set_type(cfg, AGENT_SERVICE);
    if (agent_config_type(cfg) == AGENT_SERVICE) { ok("a"); } else { fail("set service"); }

    var info = agent_info_new(1, "svc1", AGENT_SERVICE);
    if (agent_info_id(info) == 1) { ok("a"); } else { fail("info id"); }
    if (agent_info_status(info) == STATUS_PENDING) { ok("a"); } else { fail("initial pending"); }
    agent_info_set_status(info, STATUS_RUNNING);
    if (agent_info_status(info) == STATUS_RUNNING) { ok("a"); } else { fail("set running"); }

    var st = agent_stats_new();
    agent_stats_inc_req(st);
    agent_stats_inc_req(st);
    agent_stats_inc_req(st);
    agent_stats_add_tokens(st, 2000);
    if (agent_stats_requests(st) == 3) { ok("a"); } else { fail("3 requests"); }
    if (agent_stats_tokens(st) == 2000) { ok("a"); } else { fail("2000 tokens"); }

    var ru = resource_usage_new();
    if (resource_exceeds(ru, cfg) == 0) { ok("a"); } else { fail("within limits"); }
    return 0;
}

fn test_audit() {
    println("--- audit ---");
    if (AUDIT_DEBUG == 0) { ok("a"); } else { fail("debug=0"); }
    if (AUDIT_CRITICAL == 4) { ok("a"); } else { fail("critical=4"); }
    if (severity_gte(AUDIT_ERROR, AUDIT_WARNING) == 1) { ok("a"); } else { fail("error>=warning"); }
    if (severity_gte(AUDIT_DEBUG, AUDIT_INFO) == 0) { ok("a"); } else { fail("debug<info"); }

    var e = audit_entry_new(1, 42, "test.action", AUDIT_INFO);
    if (audit_id(e) == 1) { ok("a"); } else { fail("audit id"); }
    if (audit_agent_id(e) == 42) { ok("a"); } else { fail("agent 42"); }
    if (audit_severity(e) == AUDIT_INFO) { ok("a"); } else { fail("severity info"); }
    if (audit_result(e) == AUDIT_SUCCESS) { ok("a"); } else { fail("default success"); }
    audit_set_result(e, AUDIT_DENIED);
    if (audit_result(e) == AUDIT_DENIED) { ok("a"); } else { fail("set denied"); }
    return 0;
}

fn test_config() {
    println("--- config ---");
    var cfg = agnos_config_new(ENV_DEVELOPMENT);
    if (config_profile(cfg) == ENV_DEVELOPMENT) { ok("a"); } else { fail("profile dev"); }
    if (config_is_production(cfg) == 0) { ok("a"); } else { fail("dev not prod"); }
    if (config_generation(cfg) == 1) { ok("a"); } else { fail("gen=1"); }
    config_inc_generation(cfg);
    if (config_generation(cfg) == 2) { ok("a"); } else { fail("gen=2"); }

    config_apply_edge(cfg);
    if (config_profile(cfg) == ENV_EDGE) { ok("a"); } else { fail("edge profile"); }
    if (config_is_production(cfg) == 1) { ok("a"); } else { fail("edge is prod"); }
    if (config_max_agents(cfg) == 16) { ok("a"); } else { fail("edge agents=16"); }
    return 0;
}

fn main() {
    alloc_init();
    test_errors();
    test_types();
    test_security();
    test_agent();
    test_audit();
    test_config();

    syscall(1, 1, "\n", 1);
    fmt_int(_pass);
    syscall(1, 1, " passed, ", 9);
    fmt_int(_fail);
    syscall(1, 1, " failed\n", 8);

    return _fail;
}
var exit_code = main();
syscall(60, exit_code);
