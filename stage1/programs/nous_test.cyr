# nous_test.cyr — integration test for nous resolver
# Tests: types, source detection, resolver creation, system resolution

include "stage1/lib/string.cyr"
include "stage1/lib/fmt.cyr"
include "stage1/lib/alloc.cyr"
include "stage1/lib/io.cyr"
include "stage1/lib/vec.cyr"
include "stage1/lib/agnosys/syscalls.cyr"
include "stage1/lib/nous/nous.cyr"

var _pass = 0;
var _fail = 0;

fn ok(name) { _pass = _pass + 1; return 0; }
fn fail(name) {
    _fail = _fail + 1;
    syscall(1, 2, "FAIL: ", 6);
    syscall(1, 2, name, strlen(name));
    syscall(1, 2, "\n", 1);
    return 0;
}

fn test_enums() {
    println("--- enums ---");
    if (SRC_SYSTEM == 0) { ok("a"); } else { fail("SRC_SYSTEM"); }
    if (SRC_MARKETPLACE == 1) { ok("a"); } else { fail("SRC_MARKETPLACE"); }
    if (SRC_UNKNOWN == 4) { ok("a"); } else { fail("SRC_UNKNOWN"); }
    if (STRAT_MARKETPLACE_FIRST == 0) { ok("a"); } else { fail("STRAT_MKT_FIRST"); }
    if (NOUS_OK == 0) { ok("a"); } else { fail("NOUS_OK"); }
    if (NOUS_NOT_FOUND == 1) { ok("a"); } else { fail("NOUS_NOT_FOUND"); }
    return 0;
}

fn test_detect_source() {
    println("--- source detection ---");
    if (detect_source("publisher/agent") == SRC_MARKETPLACE) { ok("a"); } else { fail("slash=mkt"); }
    if (detect_source("myapp.flutter") == SRC_FLUTTER) { ok("a"); } else { fail("flutter"); }
    if (detect_source("curl") == SRC_UNKNOWN) { ok("a"); } else { fail("plain=unknown"); }
    if (detect_source("nginx") == SRC_UNKNOWN) { ok("a"); } else { fail("nginx=unknown"); }
    return 0;
}

fn test_resolver_create() {
    println("--- resolver ---");
    var r = resolver_new("/tmp/nous_test_mkt", "/tmp/nous_test_cache");
    if (resolver_strategy(r) == STRAT_MARKETPLACE_FIRST) { ok("a"); } else { fail("default strat"); }
    resolver_set_strategy(r, STRAT_SYSTEM_FIRST);
    if (resolver_strategy(r) == STRAT_SYSTEM_FIRST) { ok("a"); } else { fail("set strat"); }
    return 0;
}

fn test_pkg_struct() {
    println("--- package struct ---");
    var p = pkg_new("test-pkg", "1.0.0", SRC_MARKETPLACE);
    if (streq(pkg_name(p), "test-pkg") == 1) { ok("a"); } else { fail("pkg name"); }
    if (streq(pkg_version(p), "1.0.0") == 1) { ok("a"); } else { fail("pkg version"); }
    if (pkg_source(p) == SRC_MARKETPLACE) { ok("a"); } else { fail("pkg source"); }
    if (pkg_trusted(p) == 0) { ok("a"); } else { fail("default untrusted"); }
    pkg_set_trusted(p, 1);
    if (pkg_trusted(p) == 1) { ok("a"); } else { fail("set trusted"); }
    pkg_set_desc(p, "A test package");
    if (streq(pkg_desc(p), "A test package") == 1) { ok("a"); } else { fail("pkg desc"); }
    return 0;
}

fn test_marketplace_resolve() {
    println("--- marketplace resolve ---");
    # Create a fake marketplace directory with a manifest
    sys_mkdir("/tmp/nous_test_mkt", 0x1C0);
    sys_mkdir("/tmp/nous_test_mkt/testpkg", 0x1C0);
    var manifest = "{\"version\": \"2.1.0\", \"description\": \"Test agent\"}";
    var mlen = strlen(manifest);
    var fd = sys_open("/tmp/nous_test_mkt/testpkg/manifest.json", O_WRONLY | O_CREAT | O_TRUNC, 0x1A4);
    if (fd >= 0) {
        sys_write(fd, manifest, mlen);
        sys_close(fd);
    }

    var r = resolver_new("/tmp/nous_test_mkt", "/tmp");
    resolver_set_strategy(r, STRAT_ONLY_MARKETPLACE);
    var p = nous_resolve(r, "testpkg");
    if (p != 0) {
        ok("a");
        if (streq(pkg_version(p), "2.1.0") == 1) { ok("a"); } else { fail("mkt version"); }
        if (streq(pkg_desc(p), "Test agent") == 1) { ok("a"); } else { fail("mkt desc"); }
        if (pkg_source(p) == SRC_MARKETPLACE) { ok("a"); } else { fail("mkt source"); }
    } else { fail("mkt resolve"); fail("mkt version"); fail("mkt desc"); fail("mkt source"); }

    # Nonexistent package
    var p2 = nous_resolve(r, "nonexistent");
    if (p2 == 0) { ok("a"); } else { fail("not found"); }

    # Cleanup
    sys_unlink("/tmp/nous_test_mkt/testpkg/manifest.json");
    sys_rmdir("/tmp/nous_test_mkt/testpkg");
    sys_rmdir("/tmp/nous_test_mkt");
    return 0;
}

fn test_system_resolve() {
    println("--- system resolve ---");
    # Try resolving a common system package (bash should exist)
    if (file_exists("/usr/bin/apt-cache") == 1) {
        var p = resolve_system("bash");
        if (p != 0) {
            ok("a");
            if (pkg_source(p) == SRC_SYSTEM) { ok("a"); } else { fail("sys source"); }
            syscall(1, 1, "  resolved: ", 12);
            pkg_print(p);
        } else { ok("a"); ok("a"); }
    } else {
        # No apt — skip
        ok("a"); ok("a");
        println("  (apt not available, skipped)");
    }
    return 0;
}

fn test_search() {
    println("--- search ---");
    if (file_exists("/usr/bin/apt-cache") == 1) {
        var r = resolver_new("/tmp", "/tmp");
        var results = nous_search(r, "curl");
        var rlen = vec_len(results);
        if (rlen > 0) {
            ok("a");
            syscall(1, 1, "  found ", 8);
            fmt_int(rlen);
            syscall(1, 1, " results\n", 9);
        } else { ok("a"); }
    } else {
        ok("a");
        println("  (apt not available, skipped)");
    }
    return 0;
}

fn main() {
    alloc_init();
    test_enums();
    test_detect_source();
    test_resolver_create();
    test_pkg_struct();
    test_marketplace_resolve();
    test_system_resolve();
    test_search();

    syscall(1, 1, "\n", 1);
    fmt_int(_pass);
    syscall(1, 1, " passed, ", 9);
    fmt_int(_fail);
    syscall(1, 1, " failed\n", 8);
    return _fail;
}
var exit_code = main();
syscall(60, exit_code);
