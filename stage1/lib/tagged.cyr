# tagged.cyr — tagged unions (enums with data)
# Usage: include "stage1/lib/tagged.cyr"
# Requires: alloc.cyr
#
# A tagged union is a heap-allocated pair: { tag: i64, value: i64 }
# The tag identifies which variant, the value carries the payload.
# This is the foundation for Option, Result, and error handling.
#
# Layout: tag at offset 0, value at offset 8. Total: 16 bytes.

# ================================================================
# Core tagged union operations
# ================================================================

# Create a tagged value (heap-allocated)
fn tagged_new(tag, value) {
    var t = alloc(16);
    store64(t, tag);
    store64(t + 8, value);
    return t;
}

# Get the discriminant tag
fn tag(t) {
    return load64(t);
}

# Get the payload value
fn payload(t) {
    return load64(t + 8);
}

# Check if tag matches
fn is_tag(t, expected) {
    if (load64(t) == expected) { return 1; }
    return 0;
}

# ================================================================
# Option type: None | Some(value)
# ================================================================

enum OptionTag { NONE = 0; SOME = 1; }

fn None() {
    return tagged_new(NONE, 0);
}

fn Some(value) {
    return tagged_new(SOME, value);
}

fn is_none(opt) {
    return is_tag(opt, NONE);
}

fn is_some(opt) {
    return is_tag(opt, SOME);
}

# Unwrap: return value or abort if None
fn unwrap(opt) {
    if (is_none(opt) == 1) {
        syscall(1, 2, "unwrap called on None\n", 22);
        syscall(60, 1);
    }
    return payload(opt);
}

# Unwrap with default: return value if Some, default if None
fn unwrap_or(opt, fallback) {
    if (is_none(opt) == 1) { return fallback; }
    return payload(opt);
}

# Map: apply fn to value if Some, return None if None
# (requires function pointer + fncall1 from fnptr.cyr)
# fn option_map(opt, fp) {
#     if (is_none(opt) == 1) { return opt; }
#     return Some(fncall1(fp, payload(opt)));
# }

# ================================================================
# Result type: Ok(value) | Err(code)
# ================================================================

enum ResultTag { OK = 0; ERR = 1; }

fn Ok(value) {
    return tagged_new(OK, value);
}

fn Err(code) {
    return tagged_new(ERR, code);
}

fn is_ok(res) {
    return is_tag(res, OK);
}

fn is_err_result(res) {
    return is_tag(res, ERR);
}

# Unwrap Result: return value or abort with error
fn result_unwrap(res) {
    if (is_err_result(res) == 1) {
        syscall(1, 2, "result_unwrap on Err(", 21);
        var ebuf[24];
        var elen = fmt_int_buf(payload(res), &ebuf);
        syscall(1, 2, &ebuf, elen);
        syscall(1, 2, ")\n", 2);
        syscall(60, 1);
    }
    return payload(res);
}

# Unwrap or default
fn result_unwrap_or(res, fallback) {
    if (is_err_result(res) == 1) { return fallback; }
    return payload(res);
}

# Get error code (0 if Ok)
fn err_code_of(res) {
    if (is_ok(res) == 1) { return 0; }
    return payload(res);
}

# ================================================================
# Either type: Left(a) | Right(b)
# ================================================================

enum EitherTag { LEFT = 0; RIGHT = 1; }

fn Left(value) {
    return tagged_new(LEFT, value);
}

fn Right(value) {
    return tagged_new(RIGHT, value);
}

fn is_left(e) {
    return is_tag(e, LEFT);
}

fn is_right(e) {
    return is_tag(e, RIGHT);
}

# ================================================================
# Print helpers
# ================================================================

fn option_print(opt) {
    if (is_none(opt) == 1) {
        syscall(1, 1, "None", 4);
    } else {
        syscall(1, 1, "Some(", 5);
        fmt_int(payload(opt));
        syscall(1, 1, ")", 1);
    }
    return 0;
}

fn result_print(res) {
    if (is_ok(res) == 1) {
        syscall(1, 1, "Ok(", 3);
        fmt_int(payload(res));
        syscall(1, 1, ")", 1);
    } else {
        syscall(1, 1, "Err(", 4);
        fmt_int(payload(res));
        syscall(1, 1, ")", 1);
    }
    return 0;
}
